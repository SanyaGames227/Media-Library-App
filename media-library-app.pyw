    def _save_date_filter(self, category_id):
        """Сохраняет текущий фильтр по дате для категории (с учётом tier-режима)."""
        if not category_id or not self.per_category_sort:
            return
        _is_tier = getattr(self, '_tier_mode', False)
        _ck = str(category_id) + ('_tier' if _is_tier else '')
        _lbl = self._date_filter_btn.text()
        _all_lbl = self.translations.get('all_time', 'All time')
        s = QSettings('MediaLibrary', 'DateFilter')
        s.setValue(f'date_from_{_ck}', self._date_from or '')
        s.setValue(f'date_to_{_ck}',   self._date_to   or '')
        s.setValue(f'label_{_ck}', '' if _lbl == _all_lbl else _lbl)

    def _restore_date_filter(self, category_id):
        """Восстанавливает сохранённый фильтр по дате для категории."""
        _all_time_lbl = self.translations.get('all_time', 'All time')
        if not self.per_category_sort:
            # Галочка выключена — сбрасываем фильтр в "All time"
            self._date_from = None
            self._date_to   = None
            if self.tier_list_widget:
                self.tier_list_widget._date_from = None
                self.tier_list_widget._date_to   = None
            self._date_filter_btn.setText(_all_time_lbl)
            return
        s = QSettings('MediaLibrary', 'DateFilter')
        _is_tier = getattr(self, '_tier_mode', False)
        cat_key = (str(category_id) if category_id else 'global') + ('_tier' if _is_tier else '')
        d_from = s.value(f'date_from_{cat_key}', '') or None
        d_to   = s.value(f'date_to_{cat_key}',   '') or None
        label  = s.value(f'label_{cat_key}',      '') or ''
        self._date_from = d_from
        self._date_to   = d_to
        if self.tier_list_widget:
            self.tier_list_widget._date_from = d_from
            self.tier_list_widget._date_to   = d_to
        self._date_filter_btn.setText(label if d_from else _all_time_lbl)

    def changeEvent(self, event):
        """Форсируем перерисовку списка категорий при деактивации окна,
        чтобы кастомный делегат отрисовал выделение через selectionModel().isSelected()."""
        super().changeEvent(event)
        if event.type() == QEvent.ActivationChange:
            if hasattr(self, 'categories_list'):
                try:
                    self.categories_list.viewport().update()
                except RuntimeError:
                    pass

    def _save_window_geometry(self):
        """Сохраняем позицию/размер/состояние окна — одним батч-коммитом."""
        try:
            screen = self.screen() if callable(getattr(self, 'screen', None)) else QApplication.primaryScreen()
            if screen is None:
                return
            ag = screen.availableGeometry()
            monitor_key = f'{ag.width()}x{ag.height()}@{ag.left()},{ag.top()}'
            is_max = self.isMaximized()
            if is_max:
                ng = self.normalGeometry()
                geom_str = f'{ng.x()},{ng.y()},{ng.width()},{ng.height()}'
            else:
                g = self.geometry()
                p = self.pos()
                geom_str = f'{p.x()},{p.y()},{g.width()},{g.height()}'
            # Все три настройки — один commit вместо трёх
            cur = self.db.conn.cursor()
            cur.executemany(
                'INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)',
                [
                    ('window_monitor_key', monitor_key),
                    ('window_geometry',    geom_str),
                    ('window_maximized',   'true' if is_max else 'false'),
                ]
            )
            self.db.conn.commit()
        except Exception:
            pass

    def closeEvent(self, event):
        """Закрытие — сохраняем геометрию и мгновенно выходим через OS."""
        self._save_window_geometry()

        # Сигналим отменить активный импорт/экспорт (не ждём)
        active = getattr(self, '_active_worker', None)
        if active and active.isRunning() and hasattr(active, 'cancel'):
            active.cancel()

        event.accept()
        # os._exit(0) — убивает процесс немедленно, OS закроет все fd сама
        os._exit(0)

    def _update_cat_bg(self, category_id):
        """Обновить фоновое изображение списка фильмов для текущей категории."""
        if not hasattr(self, 'items_list'):
            return
        # В глобальном режиме фона нет
        if getattr(self, 'all_categories_mode', False):
            self.items_list.clear_category_bg()
            if hasattr(self, '_items_delegate'):
                self._items_delegate.has_bg = False
            return
        if not category_id:
            self.items_list.clear_category_bg()
            if hasattr(self, '_items_delegate'):
                self._items_delegate.has_bg = False
                self.items_list.viewport().update()
            return
        try:
            cur = self.db.conn.cursor()
            cur.execute('SELECT bg_path, bg_overlay FROM categories WHERE id = ?', (category_id,))
            row = cur.fetchone()
            if row and row['bg_path']:
                abs_path = to_absolute_path(row['bg_path'])
                overlay  = row['bg_overlay'] if row['bg_overlay'] is not None else 0.65
                self.items_list.set_category_bg(abs_path, overlay)
                if hasattr(self, '_items_delegate'):
                    self._items_delegate.has_bg = True
            else:
                self.items_list.clear_category_bg()
                if hasattr(self, '_items_delegate'):
                    self._items_delegate.has_bg = False
            self.items_list.viewport().update()
        except Exception:
            self.items_list.clear_category_bg()
            if hasattr(self, '_items_delegate'):
                self._items_delegate.has_bg = False


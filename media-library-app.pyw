        btn_layout = QHBoxLayout()
        btn_layout.setSpacing(6)

        add_user_btn = AddSplitButton()
        add_user_btn.clicked.connect(add_user)
        _u_io_menu = QMenu(add_user_btn)
        _u_io_menu.addAction(self.translations.get('export', 'Export'), lambda: self.export_users_csv(dialog))
        _u_io_menu.addAction(self.translations.get('import', 'Import'), lambda: self.import_users_csv(dialog, load_users))
        add_user_btn.setMenu(_u_io_menu)
        btn_layout.addWidget(add_user_btn)

        btn_layout.addStretch()

        close_btn = QPushButton(self.translations.get('cancel', 'Cancel'))
        close_btn.clicked.connect(dialog.reject)

        btn_layout.addWidget(close_btn)
        layout.addLayout(btn_layout)

        dialog.setLayout(layout)
        load_users()
        dialog.exec_()


    def import_categories_new(self, paths=None, import_images_override=None):
        """Импорт одной или нескольких категорий из CSV/ZIP как новых категорий."""
        # ── 1. Выбор файлов ───────────────────────────────────────────
        if paths is None:
            paths, _ = QFileDialog.getOpenFileNames(self, '', '', 'CSV / ZIP Files (*.csv *.zip)')
            if not paths:
                return

        # ── 2. Сканируем и парсим все файлы в фоновом потоке ────────────
        class _ScanWorker(QThread):
            progress   = pyqtSignal(int, str)
            finished   = pyqtSignal(object, object, object)  # parsed_entries, diff, parse_errors
            error      = pyqtSignal(str)

            def __init__(self2, paths, db, translations):
                super().__init__()
                self2.setTerminationEnabled(False)
                self2._paths        = paths
                self2._db_path      = str(DB_PATH)  # только путь — соединение создаём внутри потока
                self2._translations = translations
                self2._cancel_event = threading.Event()

            def cancel(self2):
                self2._cancel_event.set()

            def run(self2):
                tr = self2._translations.get
                _db = Database()  # новое соединение внутри потока
                entries      = []
                parse_errors = []
                total_steps  = [0]  # будет обновлён после сканирования

                # ── Шаг 1: сбор entries из ZIP/CSV ──────────────────────
                self2.progress.emit(2, tr('progress_scanning_files', 'Scanning files...'))
                for path in self2._paths:
                    if self2._cancel_event.is_set():
                        self2.finished.emit([], {}, parse_errors); return
                    if path.lower().endswith('.zip'):
                        try:
                            with zipfile.ZipFile(path, 'r') as zf:
                                all_members     = zf.namelist()
                                csv_members    = [m for m in all_members
                                                  if m.lower().endswith('.csv') and not m.endswith('/')]
                                # Detect inner ZIPs (created by multi-folder export)
                                inner_zip_members = [m for m in all_members
                                                     if m.lower().endswith('.zip') and not m.endswith('/')]
                                zip_members_set = set(all_members)

                            # ── Inner ZIPs: extract and recurse ──────────────
                            if inner_zip_members:
                                _inner_tmp = tempfile.mkdtemp()
                                try:
                                    with zipfile.ZipFile(path, 'r') as zf:
                                        for _izm in inner_zip_members:
                                            zf.extract(_izm, _inner_tmp)
                                    for _izm in inner_zip_members:
                                        _inner_path = os.path.join(_inner_tmp, _izm)
                                        if not zipfile.is_zipfile(_inner_path):
                                            continue
                                        try:
                                            with zipfile.ZipFile(_inner_path, 'r') as _izf:
                                                _inner_members = _izf.namelist()
                                                _inner_csv = [m for m in _inner_members
                                                              if m.lower().endswith('.csv')
                                                              and not m.endswith('/')
                                                              and os.path.basename(m).lower() != '_folder.csv']
                                                _inner_set  = set(_inner_members)
                                            for _icsv in _inner_csv:
                                                _ibase        = os.path.splitext(os.path.basename(_icsv))[0]
                                                _idir         = os.path.dirname(_icsv)
                                                _iprefix      = (_idir + '/') if _idir else ''
                                                _icovers_pfx  = (_iprefix + _ibase + '_covers/').lower()
                                                _iicons_pfx   = _iprefix + _ibase + '_icons/'
                                                _ihas_icons   = any(m.startswith(_iicons_pfx) and not m.endswith('/')
                                                                     for m in _inner_set)
                                                entries.append({
                                                    'csv_member':    _icsv,
                                                    'zip_src':       _inner_path,
                                                    'icons_dir':     None,
                                                    'icons_prefix':  _iicons_pfx if _ihas_icons else None,
                                                    'images_dir':    None,
                                                    'covers_prefix': _icovers_pfx,
                                                })
                                        except Exception as _ie:
                                            parse_errors.append(f'{os.path.basename(_izm)}: {_ie}')
                                except Exception as _ite:
                                    parse_errors.append(f'{os.path.basename(path)}: {_ite}')
                                # Also process any top-level CSVs in the outer ZIP
                                # (loose categories not belonging to any folder)
                                if csv_members:
                                    for csv_member in csv_members:
                                        base         = os.path.splitext(os.path.basename(csv_member))[0]
                                        _csv_dir     = os.path.dirname(csv_member)
                                        _dir_prefix  = (_csv_dir + '/') if _csv_dir else ''
                                        covers_prefix = (_dir_prefix + base + '_covers/').lower()
                                        icons_prefix  = _dir_prefix + base + '_icons/'
                                        has_icons = any(m.startswith(icons_prefix) and not m.endswith('/')
                                                        for m in zip_members_set)
                                        entries.append({
                                            'csv_member':    csv_member,
                                            'zip_src':       path,
                                            'icons_dir':     None,
                                            'icons_prefix':  icons_prefix if has_icons else None,
                                            'images_dir':    None,
                                            'covers_prefix': covers_prefix,
                                        })
                                continue  # skip normal CSV-only processing below

                            if not csv_members:
                                parse_errors.append(
                                    tr('import_zip_no_csv', 'No CSV file found in ZIP archive.') +
                                    f': {os.path.basename(path)}')
                                continue
                            for csv_member in csv_members:
                                base         = os.path.splitext(os.path.basename(csv_member))[0]
                                _csv_dir     = os.path.dirname(csv_member)
                                _dir_prefix  = (_csv_dir + '/') if _csv_dir else ''
                                covers_prefix = (_dir_prefix + base + '_covers/').lower()
                                icons_prefix  = _dir_prefix + base + '_icons/'
                                has_icons = any(m.startswith(icons_prefix) and not m.endswith('/')
                                                for m in zip_members_set)
                                entries.append({
                                    'csv_member':    csv_member,
                                    'zip_src':       path,
                                    'icons_dir':     None,
                                    'icons_prefix':  icons_prefix if has_icons else None,
                                    'images_dir':    None,
                                    'covers_prefix': covers_prefix,
                                })
                        except zipfile.BadZipFile:
                            parse_errors.append(
                                tr('import_zip_bad', 'Invalid or corrupted ZIP file.') +
                                f': {os.path.basename(path)}')
                        except Exception as ex:
                            parse_errors.append(f'{os.path.basename(path)}: {ex}')
                    else:
                        base       = os.path.splitext(os.path.basename(path))[0]
                        d          = os.path.dirname(path)
                        icons_dir  = os.path.join(d, base + '_icons')
                        images_dir = os.path.join(d, base + '_covers')
                        entries.append({
                            'csv_path':   path,
                            'zip_src':    None,
                            'icons_dir':  icons_dir if os.path.isdir(icons_dir) else None,
                            'images_dir': images_dir if os.path.isdir(images_dir) else None,
                        })

                if not entries:
                    self2.finished.emit([], {}, parse_errors)
                    return

                # ── Шаг 2: читаем _folder.csv ───────────────────────────
                self2.progress.emit(5, tr('progress_scanning_folders', 'Scanning folders...'))
                folder_meta_by_zip = {}
                processed_zips = set()
                for e in entries:
                    if self2._cancel_event.is_set():
                        self2.finished.emit([], {}, parse_errors); return
                    zip_src = e.get('zip_src')
                    if not zip_src or zip_src in processed_zips:
                        continue
                    processed_zips.add(zip_src)
                    try:
                        with zipfile.ZipFile(zip_src, 'r') as zf:
                            folder_members = [m for m in zf.namelist()
                                              if os.path.basename(m).lower() == '_folder.csv']
                            if folder_members:
                                raw = zf.read(folder_members[0])
                                try: text = raw.decode('utf-8-sig')
                                except UnicodeDecodeError: text = raw.decode('cp1251')
                                _rows = list(csv.reader(io.StringIO(text)))
                                if len(_rows) >= 3 and _rows[0] and _rows[0][0] == '#FOLDER':
                                    _val = _rows[2]
                                    _nm  = _val[0].strip() if len(_val) > 0 else ''
                                    _ic  = _val[1].strip() if len(_val) > 1 else '📁'
                                    if _nm:
                                        folder_meta_by_zip[zip_src] = {'name': _nm, 'icon': _ic or '📁'}
                    except Exception:
                        pass

                # ── Шаг 3: парсим каждый CSV ────────────────────────────
                real_entries = [e for e in entries
                                if os.path.basename(e.get('csv_member') or e.get('csv_path', '')).lower() != '_folder.csv']
                total = max(len(real_entries), 1)
                parsed_entries = []

                for i, e in enumerate(real_entries):
                    if self2._cancel_event.is_set():
                        self2.finished.emit([], {}, parse_errors); return
                    csv_member = e.get('csv_member') or e.get('csv_path', '')
                    pct = 5 + int(i / total * 80)
                    self2.progress.emit(pct,
                        tr('progress_parsing', 'Parsing ({}/{})...').format(i + 1, total))
                    try:
                        zip_src = e.get('zip_src')
                        if zip_src:
                            raw = zipfile.ZipFile(zip_src).read(csv_member)
                            try: file_text = raw.decode('utf-8-sig')
                            except UnicodeDecodeError: file_text = raw.decode('cp1251')
                            parsed = _db.import_csv_parse(csv_member, file_text=file_text)
                        else:
                            parsed = _db.import_csv_parse(csv_member)
                        cat_info     = parsed.get('category', [{}])
                        cat_row      = cat_info[0] if cat_info else {}
                        base         = os.path.splitext(os.path.basename(csv_member))[0]
                        cat_name     = cat_row.get('name', '').strip() or base
                        cat_icon_raw = cat_row.get('icon', '').strip()
                        cat_icon     = _db.import_csv_resolve_icon(
                            cat_icon_raw, e.get('icons_dir'),
                            zip_src=zip_src, icons_prefix=e.get('icons_prefix'))
                        item_count   = len(parsed.get('items', []))
                        parsed_entries.append({**e, 'parsed': parsed, 'cat_name': cat_name,
                                               'cat_icon': cat_icon, 'item_count': item_count,
                                               '_folder_meta': folder_meta_by_zip.get(zip_src)})
                    except Exception as ex:
                        parse_errors.append(
                            tr('import_error', 'Import failed: {}').format(
                                f'{os.path.basename(csv_member)}: {ex}'))

                if not parsed_entries:
                    self2.finished.emit([], {}, parse_errors)
                    return

                # ── Шаг 4: резолвинг имён ───────────────────────────────
                self2.progress.emit(88, tr('progress_resolving', 'Resolving names...'))
                # Имена категорий не обязаны быть уникальными — уникален id
                def _resolve_name(name):
                    return name, False

                for e in parsed_entries:
                    resolved, renamed = _resolve_name(e['cat_name'])
                    e['resolved_name'] = resolved
                    e['renamed']       = renamed

                # ── Шаг 5: мерж кастомных полей + diff ──────────────────
                self2.progress.emit(93, tr('progress_merging', 'Merging fields...'))
                merged_fields        = {}
                merged_field_options = {}
                merged_users         = {}
                for e in parsed_entries:
                    p = e['parsed']
                    for f in p.get('custom_fields', []):
                        var = f.get('variable', '').strip()
                        if var and var not in merged_fields:
                            merged_fields[var] = f
                    for opt in p.get('custom_field_options', []):
                        var = opt.get('variable', '').strip()
                        if var:
                            merged_field_options.setdefault(var, [])
                            existing_labels = {o['label'] for o in merged_field_options[var]}
                            if opt.get('label', '') not in existing_labels:
                                merged_field_options[var].append(opt)
                    for u in p.get('users', []):
                        nm = u.get('name', '').strip()
                        if nm and nm not in merged_users:
                            merged_users[nm] = u

                merged_parsed = {
                    'custom_fields':        list(merged_fields.values()),
                    'custom_field_options': [o for opts in merged_field_options.values() for o in opts],
                    'users':                list(merged_users.values()),
                    'items':                [],
                }
                try:
                    diff = _db.import_csv_diff(merged_parsed)
                except Exception as ex:
                    self2.error.emit(str(ex))
                    return

                self2.progress.emit(100, tr('progress_done', 'Done'))
                self2.finished.emit(parsed_entries, diff, parse_errors)

        # Запускаем воркер и ждём с прогрессом
        _scan_result    = [None]
        _scan_diff      = [None]
        _scan_errors    = [None]
        _scan_worker    = _ScanWorker(paths, self.db, self.translations)
        self._active_worker = _scan_worker

        def _on_scan_finished(pe, diff, errs):
            _scan_result[0] = pe
            _scan_diff[0]   = diff
            _scan_errors[0] = errs
        _scan_worker.finished.connect(_on_scan_finished)

        def _on_scan_error(msg):
            self._show_dialog_error(self, self.translations.get('import_error', 'Import failed: {}').format(msg))
        _scan_worker.error.connect(_on_scan_error)

        self._run_with_progress(
            self,
            self.translations.get('import_scanning', 'Reading files...'),
            _scan_worker
        )

        parsed_entries = _scan_result[0] or []
        diff           = _scan_diff[0]
        parse_errors   = _scan_errors[0] or []

        if parse_errors:
            self._show_dialog_warning(self, '\n'.join(parse_errors))

        if not parsed_entries or diff is None:
            return

        # ── 5. Диалог предпросмотра ───────────────────────────────────
        prev_dlg = QDialog(self)
        prev_dlg.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        prev_dlg.setWindowTitle(self.translations.get('import_categories_preview', 'Import Categories'))
        prev_dlg.setMinimumWidth(380)
        prev_layout = QVBoxLayout(prev_dlg)
        prev_layout.setSpacing(8)

        # Группируем записи по папкам: zip_src → [entries]
        # None-ключ = без папки
        _groups = {}   # folder_resolved_name -> [entry]  (None = без папки)
        _folder_display = {}  # folder_resolved_name -> {'icon', 'name'}

        # Собираем резолвленные имена папок — с учётом дубликатов
        _existing_folder_names = {
            dict(r)['name'].lower()
            for r in self.db.get_categories()
            if dict(r).get('is_folder')
        }
        _used_folder_names_prev = set()
        _td_to_resolved_folder = {}
        for e in parsed_entries:
            td = e.get('zip_src')
            fm = e.get('_folder_meta')
            if td and fm:
                if td not in _td_to_resolved_folder:
                    fn = fm['name']; base_fn = fn; n = 1
                    while fn.lower() in _existing_folder_names or fn.lower() in _used_folder_names_prev:
                        fn = f'{base_fn} ({n})'; n += 1
                    _used_folder_names_prev.add(fn.lower())
                    _td_to_resolved_folder[td] = fn
                    _raw_folder_icon = fm.get('icon', '📁') or '📁'
                    if _raw_folder_icon.startswith('file:'):
                        _resolved_fi = self.db.import_csv_resolve_icon(
                            _raw_folder_icon, zip_src=td, icons_prefix='')
                        _raw_folder_icon = _resolved_fi or '📁'
                    _folder_display[fn] = {'icon': _raw_folder_icon, 'name': fn,
                                           'orig': fm['name']}

        for e in parsed_entries:
            td = e.get('zip_src')
            key = _td_to_resolved_folder.get(td) if td else None
            _groups.setdefault(key, []).append(e)

        # Список с галочками — сгруппированный
        check_list = QListWidget()
        check_list.setSelectionMode(QListWidget.NoSelection)
        check_list.setStyleSheet(
            'QListWidget { background: #2b2b2b; border: 1px solid #3c3c3c; border-radius: 4px; }'
            'QListWidget::item:hover { background: #3c3c3c; }'
        )

        # entry_index[i] = индекс в parsed_entries для i-го checkable item
        entry_index = []

        def _add_folder_header(fname, fmeta):
            _icon_str = fmeta.get('icon', '📁') or '📁'
            if _icon_str.startswith('file:'):
                _ipath = to_absolute_path(_icon_str[5:])
                _pix_loaded = False
                if os.path.exists(_ipath):
                    _pix = QPixmap(_ipath)
                    if not _pix.isNull():
                        sc = _get_dpr()
                        _spix = _pix.scaled(round(16*sc), round(16*sc), Qt.KeepAspectRatio, Qt.SmoothTransformation)
                        _spix.setDevicePixelRatio(sc)
                        _fi = QListWidgetItem(fname)
                        _fi.setData(Qt.UserRole + 11, _spix)
                        _pix_loaded = True
                if not _pix_loaded:
                    _fi = QListWidgetItem(f'  📁  {fname}')
            else:
                _fi = QListWidgetItem(f'{_icon_str}  {fname}')
            _fi.setFlags(Qt.ItemIsEnabled)
            _fi.setForeground(QColor('#ffffff'))
            f = _fi.font(); f.setBold(True); _fi.setFont(f)
            check_list.addItem(_fi)
            _fi.setFlags(Qt.ItemIsEnabled)
            _fi.setForeground(QColor('#ffffff'))
            f = _fi.font(); f.setBold(True); _fi.setFont(f)
            check_list.addItem(_fi)

        class _IndentDelegate(QStyledItemDelegate):
            CB_W  = 14   # ширина нашего чекбокса
            CB_M  = 5    # отступ слева

            def paint(self, painter, option, index):
                painter.save()
                is_indented  = bool(index.data(Qt.UserRole + 10))
                is_checkable = bool(index.flags() & Qt.ItemIsUserCheckable)
                r = option.rect

                # 1. Фон строки
                bg = QColor('#212121') if is_indented else QColor('#2b2b2b')
                painter.fillRect(r, bg)
                if option.state & QStyle.State_MouseOver:
                    painter.fillRect(r, QColor('#3c3c3c'))

                x = r.left()

                # 2. Indent
                if is_indented:
                    x += 20

                # 3. Чекбокс
                if is_checkable:
                    cb_x = x + self.CB_M
                    cb_y = r.top() + (r.height() - self.CB_W) // 2
                    cb_r = QRect(cb_x, cb_y, self.CB_W, self.CB_W)
                    # Фон + рамка
                    painter.fillRect(cb_r, QColor('#282828'))
                    painter.setPen(QPen(QColor('#181818'), 1))
                    painter.drawRect(cb_r)
                    # Галочка
                    if index.data(Qt.CheckStateRole) == Qt.Checked:
                        painter.save()
                        painter.setRenderHint(QPainter.Antialiasing, True)
                        pen = QPen(QColor('#d4d4d4'), 1.5)
                        pen.setCapStyle(Qt.RoundCap)
                        pen.setJoinStyle(Qt.RoundJoin)
                        painter.setPen(pen)
                        s = self.CB_W
                        # Отступ 0.25s от краёв чтобы галочка не впритык к рамке
                        m = s * 0.25
                        painter.drawLine(
                            QPointF(cb_x + m,         cb_y + s*0.52),
                            QPointF(cb_x + s*0.42,    cb_y + s - m))
                        painter.drawLine(
                            QPointF(cb_x + s*0.42,    cb_y + s - m),
                            QPointF(cb_x + s - m,     cb_y + m))
                        painter.restore()
                    x = cb_r.right() + 6
                else:
                    # Папка — нет чекбокса, отступ 8px для всех типов
                    x = r.left() + 8

                # 4. Иконка файловая
                pix = index.data(Qt.UserRole + 11)
                if pix and not pix.isNull():
                    isz = 16
                    iy  = r.top() + (r.height() - isz) // 2
                    painter.drawPixmap(x, iy, pix)
                    x += isz + 4

                # 5. Текст
                text = index.data(Qt.DisplayRole) or ''
                fg = index.data(Qt.ForegroundRole)
                painter.setPen(fg.color() if fg else QColor('#ffffff'))
                fnt = index.data(Qt.FontRole)
                if fnt:
                    painter.setFont(fnt)
                else:
                    painter.setFont(option.font)
                text_r = QRect(x, r.top(), r.right() - x - 4, r.height())
                fm = painter.fontMetrics()
                painter.drawText(text_r, Qt.AlignVCenter | Qt.AlignLeft,
                                 fm.elidedText(text, Qt.ElideRight, text_r.width()))
                # Разделитель снизу
                painter.setPen(QPen(QColor('#3c3c3c'), 1))
                painter.drawLine(r.left(), r.bottom(), r.right(), r.bottom())
                painter.restore()

            def editorEvent(self, event, model, option, index):
                if not (index.flags() & Qt.ItemIsUserCheckable):
                    return False
                if event.type() == event.MouseButtonRelease:
                    # Вычисляем rect чекбокса так же как в paint()
                    r = option.rect
                    is_indented = bool(index.data(Qt.UserRole + 10))
                    x = r.left()
                    if is_indented:
                        x += 20
                    cb_x = x + self.CB_M
                    cb_y = r.top() + (r.height() - self.CB_W) // 2
                    cb_r = QRect(cb_x, cb_y, self.CB_W, self.CB_W)
                    if cb_r.contains(event.pos()):
                        cur = index.data(Qt.CheckStateRole)
                        new_state = Qt.Unchecked if cur == Qt.Checked else Qt.Checked
                        model.setData(index, new_state, Qt.CheckStateRole)
                        return True
                return False

        _delegate = _IndentDelegate(check_list)
        check_list.setItemDelegate(_delegate)

        def _add_entry_item(e, indented=False):
            _icon_str = e.get('cat_icon', '') or ''
            _icon_prefix = ''
            if _icon_str and not _icon_str.startswith('file:'):
                _icon_prefix = _icon_str + '  '
            elif _icon_str.startswith('file:'):
                _icon_prefix = ''  # иконка рисуется делегатом, пробелы не нужны
            label = _icon_prefix + e['resolved_name']
            suffix = f" [{e['item_count']} {self.translations.get('stats_items', 'items')}]"
            if e['renamed']:
                suffix += f" 📝 {self.translations.get('renamed_from', 'renamed from')} '{e['cat_name']}'"
            it = QListWidgetItem(label + suffix)
            if _icon_str.startswith('file:'):
                _ipath = to_absolute_path(_icon_str[5:])
                if os.path.exists(_ipath):
                    _pix = QPixmap(_ipath)
                    if not _pix.isNull():
                        sc    = _get_dpr()
                        _spix = _pix.scaled(round(16*sc), round(16*sc), Qt.KeepAspectRatio, Qt.SmoothTransformation)
                        _spix.setDevicePixelRatio(sc)
                        it.setData(Qt.UserRole + 11, _spix)
            it.setFlags(it.flags() | Qt.ItemIsUserCheckable)
            it.setCheckState(Qt.Checked)
            if indented:
                it.setData(Qt.UserRole + 10, True)
                it.setBackground(QColor('#1a1a1a'))
            check_list.addItem(it)
            entry_index.append(parsed_entries.index(e))

        # Сначала папки
        for fname, entries_in_folder in _groups.items():
            if fname is None:
                continue
            _add_folder_header(fname, _folder_display[fname])
            for e in entries_in_folder:
                _add_entry_item(e, indented=True)

        # Потом без папки
        for e in _groups.get(None, []):
            _add_entry_item(e, indented=False)

        check_list.setHorizontalScrollBarPolicy(Qt.ScrollBarAsNeeded)
        check_list.setVerticalScrollBarPolicy(Qt.ScrollBarAsNeeded)
        _row_h = 32
        _total_rows = check_list.count()
        _visible = min(_total_rows, 12)
        # Добавляем половину строки чтобы горизонтальный скролл не обрезал контент
        _list_h = int((_visible + 0.5) * _row_h) + 8
        check_list.setFixedHeight(_list_h)

        # ── Строка Select all / None ──────────────────────────────────
        sel_row = QHBoxLayout()
        sel_row.setContentsMargins(0, 0, 0, 2)
        _sel_lbl = QLabel()
        _sel_lbl.setStyleSheet('color: #888; font-size: 11px;')
        toggle_btn = QPushButton()
        toggle_btn.setFixedHeight(22)
        toggle_btn.setStyleSheet('font-size: 11px; padding: 0 6px;')

        def _checkable_items():
            return [check_list.item(j) for j in range(check_list.count())
                    if check_list.item(j).flags() & Qt.ItemIsUserCheckable]

        def _update_sel_ui():
            items = _checkable_items()
            n     = sum(1 for it in items if it.checkState() == Qt.Checked)
            total = len(items)
            _sel_lbl.setText(f'{n} / {total}')
            all_checked = n == total
            toggle_btn.setText(
                self.translations.get('deselect_all', 'Deselect all') if all_checked
                else self.translations.get('select_all', 'Select all'))

        def _toggle_all():
            items = _checkable_items()
            all_checked = all(it.checkState() == Qt.Checked for it in items)
            state = Qt.Unchecked if all_checked else Qt.Checked
            check_list.blockSignals(True)
            for it in items:
                it.setCheckState(state)
            check_list.blockSignals(False)
            _update_sel_ui()

        check_list.itemChanged.connect(lambda _: _update_sel_ui())
        toggle_btn.clicked.connect(_toggle_all)

        sel_row.addWidget(_sel_lbl)
        sel_row.addStretch()
        sel_row.addWidget(toggle_btn)
        prev_layout.addLayout(sel_row)

        prev_layout.addWidget(check_list)
        _update_sel_ui()  # инициализируем



        # Изображения чекбокс
        imp_img_cb = type('_CB', (), {'isChecked': lambda s: True})()  # всегда импортируем картинки

        # Кнопки
        btn_row = QHBoxLayout()
        btn_row.addStretch()
        imp_btn = QPushButton(self.translations.get('import', 'Import'))
        imp_btn.setDefault(True)
        cancel_btn = QPushButton(self.translations.get('cancel', 'Cancel'))
        imp_btn.clicked.connect(prev_dlg.accept)
        cancel_btn.clicked.connect(prev_dlg.reject)
        btn_row.addWidget(imp_btn)
        btn_row.addWidget(cancel_btn)
        prev_layout.addLayout(btn_row)

        if prev_dlg.exec_() != QDialog.Accepted:
            return

        import_images = imp_img_cb.isChecked() if import_images_override is None else import_images_override

        # Фильтруем только отмеченные галочками
        # entry_index[j] = индекс в parsed_entries для j-го checkable item в списке
        selected_entries = []
        ci = 0  # индекс по checkable items
        for j in range(check_list.count()):
            it = check_list.item(j)
            if it.flags() & Qt.ItemIsUserCheckable:
                if it.checkState() == Qt.Checked:
                    selected_entries.append(parsed_entries[entry_index[ci]])
                ci += 1
        if not selected_entries:
            return

        # ── 6. Diff dialog для полей ──────────────────────────────────
        _diff_zip_entry = next((e for e in selected_entries if e.get('zip_src') and e.get('icons_prefix')), None)
        accepted, diff_dlg = ImportDiffDialog.run(
            diff, translations=self.translations, parent=self,
            icons_dir=selected_entries[0].get('icons_dir') if selected_entries else None,
            zip_src=_diff_zip_entry.get('zip_src') if _diff_zip_entry else None,
            icons_prefix=_diff_zip_entry.get('icons_prefix') if _diff_zip_entry else None,
        )
        if not accepted:
            return

        if diff_dlg is not None:
            apply_nf = diff_dlg.selected_new_fields
            apply_cf = diff_dlg.apply_changed_fields
            apply_no = diff_dlg.selected_new_options
            apply_co = diff_dlg.apply_changed_options
            apply_nu = diff_dlg.selected_new_users
        else:
            apply_nf = diff.get('new_fields', [])
            apply_cf = set()
            apply_no = diff.get('new_options', [])
            apply_co = set()
            apply_nu = diff.get('new_users', [])

        # ── 7. Создаём папки (если есть _folder.csv) ────────────────
        # folder_id_map: zip_src -> folder_id в БД
        folder_id_map = {}
        _existing_folder_names = {
            dict(r)['name'].lower()
            for r in self.db.get_categories()
            if dict(r).get('is_folder')
        }
        _used_folder_names = set()
        for e in selected_entries:
            td = e.get('zip_src')
            fm = e.get('_folder_meta')
            if td and fm and td not in folder_id_map:
                fn = fm['name']
                # Разрешаем конфликт имён папки
                base_fn = fn; n = 1
                while fn.lower() in _existing_folder_names or fn.lower() in _used_folder_names:
                    fn = f'{base_fn} ({n})'; n += 1
                _used_folder_names.add(fn.lower())
                # icon уже резолвлен в _folder_display
                _resolved_icon_for_db = _folder_display.get(fn, {}).get('icon') or fm.get('icon') or '📁'
                fid = self.db.add_folder(fn, _resolved_icon_for_db)
                folder_id_map[td] = fid

        # ── 8. Импортируем через _run_with_progress (правильный event loop) ──
        total_imported = [0]
        total_entries  = len(selected_entries)
        _import_error  = [None]
        _idx_ref       = [0]
        _first         = [True]

        # Строим список воркеров заранее
        workers = []
        _created_cat_ids = []  # для отката при ошибке
        for e in selected_entries:
            _cat_folder_id = folder_id_map.get(e.get('zip_src'))
            new_cat_id = self.db.add_category(e['resolved_name'], e['cat_icon'] or '🏷',
                                               folder_id=_cat_folder_id)
            _created_cat_ids.append(new_cat_id)
            try:
                _entry_diff = self.db.import_csv_diff(e['parsed'])
            except Exception as ex:
                _import_error[0] = str(ex)
                break
            workers.append((e, new_cat_id, _entry_diff))

        if _import_error[0]:
            # Откатываем уже созданные пустые категории
            for _cid in _created_cat_ids:
                try: self.db.delete_category(_cid)
                except Exception: pass
            self.db.invalidate_custom_fields_cache()
            self._reload_after_cat_change()
            self._show_dialog_error(self, self.translations.get('import_error', 'Import failed: {}').format(_import_error[0]))
            return

        if not workers:
            return

        # Прогресс-диалог через exec_() как в _run_with_progress
        _prog_dlg = QDialog(self)
        _prog_dlg.setWindowTitle(self.translations.get('importing', 'Importing...'))
        _prog_dlg.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        _prog_dlg.setWindowFlag(Qt.WindowCloseButtonHint, False)
        _prog_dlg.setFixedWidth(320)
        _prog_layout = QVBoxLayout(_prog_dlg)
        _prog_layout.setContentsMargins(12, 12, 12, 12)
        _prog_layout.setSpacing(8)
        _prog_label = QLabel(self.translations.get('starting', 'Starting...'))
        _prog_label.setFixedWidth(296)
        _prog_label.setWordWrap(False)
        _prog_bar   = QProgressBar()
        _prog_bar.setFixedWidth(296)
        _prog_bar.setRange(0, 100)
        _prog_layout.addWidget(_prog_label)
        _prog_layout.addWidget(_prog_bar)
        _prog_dlg.adjustSize()
        _prog_dlg.setFixedSize(_prog_dlg.sizeHint())

        _worker_ref = [None]
        _all_workers = []  # Держим ссылки на ВСЕ воркеры — GC не убьёт пока работают

        def _run_next():
            idx = _idx_ref[0]
            print(f"[DBG RUN_NEXT] idx={idx} total={len(workers)}")
            if idx >= len(workers):
                _prog_bar.setValue(100)
                _prog_dlg.accept()
                return
            e, cat_id, entry_diff = workers[idx]
            n = len(workers)
            fm = _prog_label.fontMetrics()
            _prog_label.setText(fm.elidedText(
                f"({idx+1}/{n}) {e['resolved_name']}", Qt.ElideRight, _prog_label.width()))
            _prog_bar.setValue(int(idx / n * 100))

            w = ImportWorker(
                db=self.db,
                file_path=e.get('csv_member') or e.get('csv_path', ''),
                category_id=cat_id,
                translations=self.translations,
                import_images=import_images,
                jpg_quality=self.jpg_quality,
                parsed=e['parsed'],
                diff=entry_diff,
                apply_new_fields=apply_nf if _first[0] else [],
                apply_changed_fields=apply_cf if _first[0] else set(),
                apply_new_options=apply_no if _first[0] else [],
                apply_changed_options=apply_co if _first[0] else set(),
                apply_new_users=apply_nu if _first[0] else [],
                images_dir=e.get('images_dir'),
                icons_dir=e.get('icons_dir'),
                zip_src_path=e.get('zip_src'),
                covers_prefix=e.get('covers_prefix'),
                icons_prefix=e.get('icons_prefix'),
                apply_bg=True,
            )
            _first[0] = False
            _worker_ref[0] = w
            _all_workers.append(w)  # сохраняем ссылку — GC не тронет

            def _on_progress(pct, msg):
                n2 = len(workers)
                i2 = _idx_ref[0]
                overall = int((i2 / n2 + pct / 100 / n2) * 100)
                _prog_bar.setValue(overall)
                fm2 = _prog_label.fontMetrics()
                _prog_label.setText(fm2.elidedText(
                    f"({i2+1}/{n2}) {msg}", Qt.ElideRight, _prog_label.width()))

            def _on_done(count):
                print(f"[DBG DONE] idx={_idx_ref[0]} count={count} total_workers={len(workers)}")
                total_imported[0] += count
                _idx_ref[0] += 1
                _run_next()

            def _on_error(msg):
                print(f"[DBG ERROR] idx={_idx_ref[0]} msg={msg}")
                _import_error[0] = msg
                _prog_dlg.reject()

            w.progress.connect(_on_progress)
            w.finished.connect(_on_done)
            w.error.connect(_on_error)
            w.start()

        _run_next()
        _prog_dlg.exec_()
        # Ждём завершения текущего воркера с processEvents чтобы сигналы доходили
        if _worker_ref[0] and _worker_ref[0].isRunning():
            while _worker_ref[0].isRunning():
                _worker_ref[0].wait(200)
                QApplication.processEvents()

        # Чистим временные папки

        self.db.invalidate_custom_fields_cache()
        self._reload_after_cat_change()
        _msg_parts = []
        if len(selected_entries) == 1:
            _msg_parts.append(self.translations.get('category_created', 'Category created: {}').format(
                selected_entries[0]['resolved_name']))
        else:
            _msg_parts.append(f"{len(selected_entries)} " +
                self.translations.get('categories_created', 'categories created'))
        if total_imported[0]:
            _msg_parts.append(self.translations.get('import_success', 'Imported {} items').format(total_imported[0]))
        self._show_dialog_info(self, '\n'.join(_msg_parts))

    def manage_custom_fields(self):
        """Управление кастомными полями"""
        dialog = QDialog(self)
        dialog.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        dialog.setWindowTitle(self.translations.get('custom_fields', 'Custom Fields'))
        dialog.setMinimumSize(300, 340)
        layout = QVBoxLayout()

        fields_list = SortableListWidget(translations=self.translations)
        fields_list.setDropIndicatorShown(True)
        fields_list.setContextMenuPolicy(Qt.CustomContextMenu)

        # ── delegate: renders icon+label correctly at any DPI ─────────
        class _FieldsDelegate(QStyledItemDelegate):
            ICON_SIZE   = 16
            ICON_FONT   = 11
            PAD_LEFT    = 6
            PAD_MID     = 6
            _cache: dict = {}

            def _emoji_pix(self, emoji, size):
                sc  = _get_dpr()
                key = (emoji, size, sc)
                if key in self._cache:
                    return self._cache[key]
                phys = round(size * sc)
                pix  = QPixmap(phys, phys)
                pix.fill(Qt.transparent)
                pix.setDevicePixelRatio(sc)
                p = QPainter(pix)
                f = QFont(); f.setPointSizeF(self.ICON_FONT)
                p.setFont(f)
                p.setPen(QColor(255, 255, 255))
                p.drawText(QRect(0, 0, size, size), Qt.AlignCenter, emoji)
                p.end()
                self._cache[key] = pix
                return pix

            def paint(self, painter, option, index):
                painter.save()
                painter.setClipRect(option.rect)
                # background
                is_sel   = bool(option.state & QStyle.State_Selected)
                is_hover = bool(option.state & QStyle.State_MouseOver)
                if is_sel:
                    painter.fillRect(option.rect, option.palette.color(option.palette.Highlight))
                elif is_hover:
                    painter.fillRect(option.rect, QColor(255, 255, 255, 18))
                rect = option.rect
                h    = rect.height()
                sz   = self.ICON_SIZE
                ix   = rect.left() + self.PAD_LEFT
                iy   = rect.top() + (h - sz) // 2
                icon_str = index.data(Qt.UserRole + 1) or ''
                label    = index.data(Qt.DisplayRole) or ''
                if icon_str.startswith('file:'):
                    src = _smooth_scale_pixmap(to_absolute_path(icon_str[5:]), sz)
                    if not src.isNull():
                        painter.drawPixmap(QRect(ix, iy, sz, sz), src)
                elif icon_str:
                    painter.drawPixmap(QRect(ix, iy, sz, sz),
                                       self._emoji_pix(icon_str, sz))
                lx = ix + sz + self.PAD_MID
                lw = rect.right() - lx - 4
                painter.setPen(option.palette.color(
                    option.palette.HighlightedText if is_sel else option.palette.Text))
                painter.drawText(QRect(lx, rect.top(), lw, h),
                                 Qt.AlignVCenter | Qt.AlignLeft | Qt.TextSingleLine,
                                 label)
                # separator
                _draw_separator(painter, rect, index.row())
                painter.restore()

            def sizeHint(self, option, index):
                sh = super().sizeHint(option, index)
                return QSize(sh.width(), max(sh.height(), self.ICON_SIZE + 6))

        _fields_delegate = _FieldsDelegate(fields_list)
        fields_list.setItemDelegate(_fields_delegate)

        def load_fields():
            fields_list.clear()
            for f in self.db.get_custom_fields():
                icon_str = f['icon'] or ''
                name     = f['name']
                # display text is just the name — delegate draws the icon
                item = QListWidgetItem(name)
                item.setData(Qt.UserRole,     f['id'])
                item.setData(Qt.UserRole + 1, icon_str if icon_str else '🧩')
                fields_list.addItem(item)

        def show_field_menu(pos):
            item = fields_list.itemAt(pos)
            if not item:
                return
            if item not in fields_list.selectedItems():
                fields_list.clearSelection()
                item.setSelected(True)
            selected = fields_list.selectedItems()
            menu = QMenu()
            if len(selected) == 1:
                edit_act = QAction(self.translations.get('edit', 'Edit'), dialog)
                edit_act.triggered.connect(lambda: edit_field(item))
                menu.addAction(edit_act)
                menu.addSeparator()
            del_act = QAction(self.translations.get('delete', 'Delete'), dialog)
            del_act.triggered.connect(lambda: delete_field())
            menu.addAction(del_act)
            menu.exec_(fields_list.mapToGlobal(pos))

        def edit_field(list_item):
            field_id = list_item.data(Qt.UserRole)
            dlg = CustomFieldDialog(dialog, self.db, self.translations, field_id=field_id)
            if dlg.exec_() == QDialog.Accepted:
                data = dlg.get_data()
                # Удаляем промежуточные временные файлы иконок + оригинал если заменён
                for _p in dlg._pending_icon_delete:
                    _safe_delete_file(_p, self.db.conn)
                if dlg._original_icon_file[0] and dlg._file_icon[0] != dlg._original_icon_file[0]:
                    _safe_delete_file(dlg._original_icon_file[0], self.db.conn)
                self.db.update_custom_field(
                    field_id, data['name'], data['icon'], data['type_options'],
                    data['show_in_list'], data['show_in_list_compact'],
                    data['show_in_detail'], data['show_in_context_menu'],
                    data['context_menu_label'], data.get('show_name_in_list', 0),
                    data.get('name_color', '#ffffff'), data.get('search_filter')
                )
                # Синхронизируем опции (select/marks) — применяем изменения из виджета в БД
                pending = getattr(dlg, '_pending_options', None)
                if pending is not None:
                    ftype = data.get('field_type') or dlg._edit_field_type
                    # Текущие опции в БД
                    existing = {opt['id']: opt['label'] for opt in self.db.get_field_options(field_id)}
                    existing_ids = set(existing.keys())
                    pending_ids = {opt_id for opt_id, _ in pending if opt_id is not None}
                    cursor = self.db.conn.cursor()
                    # Удаляем опции которых нет в pending
                    for opt_id in existing_ids - pending_ids:
                        self.db.delete_field_option(opt_id, field_id, ftype)
                    # Добавляем новые / переименовываем существующие / обновляем порядок
                    for pos, (opt_id, label) in enumerate(pending):
                        if opt_id is None:
                            cursor.execute(
                                'INSERT INTO custom_field_options (field_id, label, position) VALUES (?,?,?)',
                                (field_id, label, pos)
                            )
                        else:
                            cursor.execute(
                                'UPDATE custom_field_options SET label=?, position=? WHERE id=?',
                                (label, pos, opt_id)
                            )
                    self.db.conn.commit()
                    self.db.invalidate_options_cache(field_id)
                load_fields()
                self.load_items()

        def delete_field(list_item=None):
            items = fields_list.selectedItems()
            if not items:
                if list_item:
                    items = [list_item]
                else:
                    return
            msg = (self.translations.get('delete_custom_field_confirm',
                       'Delete this custom field? All stored values will be lost.')
                   if len(items) == 1
                   else self.translations.get('delete_confirm_multi', 'Delete {} items?').format(len(items)))
            if self._show_dialog_confirm(dialog, msg):
                field_ids = [it.data(Qt.UserRole) for it in items]
                self._do_backup('delete_field')
                self.db.delete_custom_fields_batch(field_ids)
                load_fields()
                self.load_items()

        def add_field():
            dlg = CustomFieldDialog(dialog, self.db, self.translations)
            if dlg.exec_() == QDialog.Accepted:
                data = dlg.get_data()
                # Удаляем промежуточные временные файлы иконок
                for _p in dlg._pending_icon_delete:
                    _safe_delete_file(_p, self.db.conn)
                try:
                    field_id = self.db.add_custom_field(
                        data['name'], data['variable'], data['icon'], data['field_type'],
                        data['type_options'], data['show_in_list'], data['show_in_list_compact'],
                        data['show_in_detail'], data['show_in_context_menu'],
                        data['context_menu_label'], data.get('show_name_in_list', 0),
                        data.get('name_color', '#ffffff'), data.get('search_filter')
                    )
                    pending = getattr(dlg, '_pending_options', None)
                    if pending:
                        cursor = self.db.conn.cursor()
                        for pos, (_, label) in enumerate(pending):
                            cursor.execute(
                                'INSERT INTO custom_field_options (field_id, label, position) VALUES (?,?,?)',
                                (field_id, label, pos)
                            )
                        self.db.commit()
                    load_fields()
                except Exception as e:
                    self._show_dialog_warning(dialog, str(e))

        def on_fields_dropped():
            dragged_ids = set(getattr(fields_list, '_dragged_multi_ids', []) or [])
            pairs = []
            for i in range(fields_list.count()):
                it = fields_list.item(i)
                if it:
                    pairs.append((it.data(Qt.UserRole), float(i + 1)))
            self.db.update_custom_field_positions_batch(pairs)
            if dragged_ids:
                for i in range(fields_list.count()):
                    it = fields_list.item(i)
                    if it and it.data(Qt.UserRole) in dragged_ids:
                        it.setSelected(True)

        fields_list.setSelectionMode(QListWidget.ExtendedSelection)
        fields_list.dropped.connect(on_fields_dropped)
        fields_list.customContextMenuRequested.connect(show_field_menu)
        fields_list.itemDoubleClicked.connect(edit_field)

        def _fields_key_press(event):
            if event.key() in (Qt.Key_Return, Qt.Key_Enter):
                sel = fields_list.selectedItems()
                if len(sel) == 1:
                    edit_field(sel[0])
            elif event.key() == Qt.Key_Delete:
                delete_field()
            else:
                QListWidget.keyPressEvent(fields_list, event)
        fields_list.keyPressEvent = _fields_key_press
        fields_list.set_label_func(lambda it: it.text() if it else '')
        fields_list._is_folder_func = lambda it: False
        fields_list._dragged_is_folder_func = lambda: False
        fields_list._current_cat_func = lambda: None
        fields_list._item_in_folder_func = lambda it: False

        layout.addWidget(fields_list)

        btn_row = QHBoxLayout()
        btn_row.setSpacing(6)

        add_btn = AddSplitButton()
        add_btn.clicked.connect(add_field)
        _cf_io_menu = QMenu(add_btn)
        _cf_io_menu.addAction(self.translations.get('export', 'Export'), lambda: self.export_custom_fields_csv(dialog))
        _cf_io_menu.addAction(self.translations.get('import', 'Import'), lambda: self.import_custom_fields_csv(
            dialog, reload_cb=lambda: (load_fields(), self.load_items())
        ))
        add_btn.setMenu(_cf_io_menu)
        btn_row.addWidget(add_btn)

        btn_row.addStretch()

        btn_row.addStretch()
        close_btn = QPushButton(self.translations.get('cancel', 'Cancel'))
        close_btn.clicked.connect(dialog.reject)
        btn_row.addWidget(close_btn)
        layout.addLayout(btn_row)

        dialog.setLayout(layout)
        load_fields()
        dialog.exec_()

    def _scroll_to_item_id(self, item_id):
        """Прокрутить список к элементу с заданным ID — только если он не виден."""
        proxy_row = self._proxy_row_for_id(item_id)
        if proxy_row >= 0:
            idx = self._item_proxy.index(proxy_row, 0)
            self.items_list.setCurrentIndex(idx)
            vp_h = self.items_list.viewport().height()
            item_rect = self.items_list.visualRect(idx)
            if item_rect.top() < 0 or item_rect.bottom() > vp_h:
                self.items_list.scrollTo(idx, QListView.PositionAtCenter)

    def add_item(self):
        """Добавление нового элемента"""
        if not self.current_category_id:
            self._show_dialog_warning(self, self.translations.get('select_category_first', 'Select a category first'))
            return

        dialog = ItemDialog(self, self.current_category_id, None, self.translations, jpg_quality=self.jpg_quality)
        if dialog.exec_() == QDialog.Accepted:
            data = dialog.get_data()
            if data['title']:
                item_id = self.db.add_item(
                    self.current_category_id,
                    data['title'],
                    data.get('year'),
                    data.get('cover_path'),
                    data.get('watch_date'),
                    data.get('notes'),
                    data.get('rating'),
                    data.get('user_ids'),
                    data.get('is_favorite', False),
                    data.get('time_spent', 0),
                    data.get('view_count', 1)
                )
                self.db.set_custom_field_values_batch(item_id, data.get('custom_field_values') or {})
                # Удаляем промежуточные обложки после записи в БД
                for path in dialog._pending_delete_covers:
                    if path and path != dialog.cover_path:
                        _safe_delete_file(to_absolute_path(path), self.db.conn)
                if getattr(self, '_tier_mode', False):
                    # В режиме тир-листа — добавляем в пул с учётом текущей сортировки/фильтра
                    self.tier_list_widget.add_item_to_pool(item_id, **self._tier_load_params())
                    self.update_stats()
                # при автосортировке — полностью перезагружаем список и прокручиваем к элементу
                elif self._current_sort_by() == 'manual':
                    self._preserved_selection = set()
                    self._selection_ids = set()
                    self.load_item(item_id)
                    self.update_stats()
                    QTimer.singleShot(0, lambda: self._scroll_to_item_id(item_id))
                else:
                    self._preserved_selection = set()
                    self._selection_ids = set()
                    self.load_items()
                    self.update_stats()
                    QTimer.singleShot(0, lambda: self._scroll_to_item_id(item_id))

    def _items_list_start_drag(self, supported_actions):
        """Кастомный drag для QListView — рисует label вместо копии элемента."""
        selected_ids = self._selected_item_ids()
        if not selected_ids:
            return

        self._dragged_multi_ids = selected_ids
        self.items_list._dragged_multi_ids = selected_ids  # для _on_item_dropped_to_category

        if len(selected_ids) > 1:
            label_text = f"{len(selected_ids)} {self.translations.get('items', 'items')}"
        else:
            # Берём название из store
            src_row = self._source_row_for_id(selected_ids[0])
            entry = self._items_store[src_row] if 0 <= src_row < len(self._items_store) else None
            item_data = entry[0] if entry else {}
            raw = str(item_data.get('title', '')) if item_data else ''
            label_text = _display_title(raw)

        # Рисуем пиксмап как в SortableListWidget._make_pixmap
        font = self.items_list.font()
        font.setPointSize(10)
        font.setBold(True)
        fm = QFontMetrics(font)
        px, py = 14, 6
        rect = fm.boundingRect(label_text)
        w, h = rect.width() + px * 2, rect.height() + py * 2
        pix = QPixmap(w, h)
        pix.fill(Qt.transparent)
        painter = QPainter(pix)
        painter.setRenderHint(QPainter.Antialiasing)
        path = QPainterPath()
        path.addRoundedRect(QRectF(0, 0, w, h), 8, 8)
        painter.fillPath(path, QColor(70, 70, 70))
        painter.setFont(font)
        painter.setPen(QColor(255, 255, 255))
        painter.drawText(pix.rect().adjusted(px, 0, -px, 0),
                         Qt.AlignVCenter | Qt.AlignLeft, label_text)
        painter.end()

        mime = self._item_proxy.mimeData(self.items_list.selectionModel().selectedIndexes())
        drag = QDrag(self.items_list)
        drag.setMimeData(mime)
        drag.setPixmap(pix)
        drag.setHotSpot(QPoint(-10, -10))
        drag.exec_(Qt.MoveAction)
        # Сбрасываем курсор в любом случае — даже если drop был отклонён
        self.items_list.viewport().unsetCursor()

    def _on_item_double_clicked(self, proxy_index):
        """Обработчик doubleClicked для QListView."""
        src_row = self._item_proxy.map_to_source_row(proxy_index.row())
        item_id = self._item_model.item_id(src_row)
        if item_id is not None:
            self.edit_item()

    def edit_item(self, proxy_index_or_item=None):
        """Редактирование элемента."""
        item_id = None
        if proxy_index_or_item is None:
            item_id = self._current_item_id()
        elif hasattr(proxy_index_or_item, 'row'):
            # QModelIndex из doubleClicked
            src_row = self._item_proxy.map_to_source_row(proxy_index_or_item.row())
            item_id = self._item_model.item_id(src_row)
        else:
            try: item_id = proxy_index_or_item.data(Qt.UserRole)
            except Exception: item_id = None

        if not item_id:
            return

        item_data = self.db.get_item_by_id(item_id)
        dialog = ItemDialog(self, self.current_category_id, dict(item_data), self.translations, jpg_quality=self.jpg_quality)
        if dialog.exec_() == QDialog.Accepted:
            data = dialog.get_data()
            if data['title']:
                cf_values = data.pop('custom_field_values', {})
                self.db.update_item_with_cf(item_id, data, cf_values)
                # Удаляем старые обложки ПОСЛЕ обновления БД — _safe_delete_file
                # теперь не найдёт ссылок на них и сможет удалить файлы
                for path in dialog._pending_delete_covers:
                    if path and path != dialog.cover_path:
                        _safe_delete_file(to_absolute_path(path), self.db.conn)
                loaded = self.load_item(item_id)
                if self._current_item_id() == item_id:
                    if loaded:
                        item_data_l, users_data_l, cf_vals_l = loaded
                        cf_fields_l = self.db.get_custom_fields_cached()
                        cf_list_l = [(f, cf_vals_l[f['id']]) for f in cf_fields_l if f['id'] in cf_vals_l]
                        self.detail_panel.show_item(item_data_l, users_data_l, cf_list_l if cf_list_l else None)
                    else:
                        self.on_item_selected_by_id(item_id)
    
    def delete_item(self):
        """Удаление одного элемента (текущего) без полной перезагрузки."""
        item_id = self._current_item_id()
        if not item_id:
            return

        if self._show_dialog_confirm(self, self.translations.get('delete_item_confirm', 'Delete this item?')):
            item_data = dict(self.db.get_item_by_id(item_id) or {})
            cover_path = to_absolute_path(item_data.get('cover_path'))
            self._do_backup('delete_item')
            self.db.delete_item(item_id)
            _safe_delete_file(cover_path, self.db.conn)

            scroll_val = self.items_list.verticalScrollBar().value()
            self._item_model.remove_row_by_id(item_id)
            # _items_store — это та же ссылка что _model._store; remove_row_by_id
            # уже удалил элемент из _store, поэтому второй pop не нужен.
            self._full_items_store = [
                e for e in self._full_items_store
                if e[0].get('id') != item_id
            ]
            if hasattr(self, '_items_delegate'):
                self._items_delegate.item_store = self._items_store
            self.items_list.verticalScrollBar().setValue(scroll_val)
            self.detail_panel.clear_item()
            self.update_stats()

    def delete_selected_items(self):
        """Удаление всех выделенных элементов с подтверждением (батч)."""
        item_ids = self._selected_item_ids()
        if not item_ids:
            return

        count = len(item_ids)
        confirm_text = (
            self.translations.get('delete_item_confirm', 'Delete this item?')
            if count == 1
            else self.translations.get('delete_items_confirm', 'Delete {} items?').format(count)
        )
        if not self._show_dialog_confirm(self, confirm_text):
            return

        cover_paths_to_delete = []
        src_rows_to_remove = []
        for iid in item_ids:
            item_data = dict(self.db.get_item_by_id(iid) or {})
            cp = to_absolute_path(item_data.get('cover_path'))
            if cp:
                cover_paths_to_delete.append(cp)
            row = self._source_row_for_id(iid)
            if row >= 0:
                src_rows_to_remove.append(row)

        self._do_backup('delete_item')
        self.db.delete_items_batch(item_ids)
        for cp in cover_paths_to_delete:
            _safe_delete_file(cp, self.db.conn)

        scroll_val = self.items_list.verticalScrollBar().value()
        deleted_ids = set(item_ids)
        # Удаляем из модели и store снизу вверх
        for row in sorted(src_rows_to_remove, reverse=True):
            self._item_model.beginRemoveRows(QModelIndex(), row, row)
            self._item_model._ids.pop(row)
            # _items_store — та же ссылка что _model._store при активном поиске,
            # поэтому pop одного достаточно.
            if row < len(self._item_model._store):
                self._item_model._store.pop(row)
            self._item_model.endRemoveRows()
        # Обновляем _all_ids и _all_store — иначе следующий поиск будет
        # работать с удалёнными элементами.
        self._item_model._all_ids = [
            iid for iid in self._item_model._all_ids if iid not in deleted_ids
        ]
        self._item_model._all_store = [
            e for e in self._item_model._all_store if e[0].get('id') not in deleted_ids
        ]
        self._full_items_store = [
            e for e in self._full_items_store
            if e[0].get('id') not in deleted_ids
        ]
        if hasattr(self, '_items_delegate'):
            self._items_delegate.item_store = self._items_store
        self.items_list.verticalScrollBar().setValue(scroll_val)
        self.detail_panel.clear_item()
        self.update_stats()

    def duplicate_selected_items(self):
        """Дублирование всех выделенных элементов в конец списка (батч, без перезагрузки)"""
        selected = self._selected_item_ids()
        if not selected:
            return

        if len(selected) == 1:
            self._do_duplicate_item(selected[0])
            return

        count = len(selected)
        dup_dialog = QDialog(self)
        dup_dialog.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        dup_dialog.setWindowTitle(self.translations.get('duplicate', 'Duplicate'))
        dup_dialog.setMinimumWidth(320)
        dup_layout = QVBoxLayout()
        dup_layout.addWidget(QLabel(
            self.translations.get('duplicate_items_confirm', 'Duplicate {} items?').format(count)
        ))
        copy_suffix_cb = QCheckBox(self.translations.get('add_copy_suffix', 'Add "-copy" to title'))
        copy_suffix_cb.setChecked(True)
        dup_layout.addWidget(copy_suffix_cb)
        dup_layout.addLayout(self._make_ok_cancel(dup_dialog, dup_dialog.accept, dup_dialog.reject))
        dup_dialog.setLayout(dup_layout)

        if dup_dialog.exec_() != QDialog.Accepted:
            return

        add_suffix = copy_suffix_cb.isChecked()

        cursor = self.db.conn.cursor()
        cursor.execute('SELECT MAX(custom_position) FROM items WHERE category_id = ?', (self.current_category_id,))
        max_pos = cursor.fetchone()[0] or 0

        rows = []       # (category_id, title, year, cover, watch_date, notes, rating, fav, time, views, pos)
        user_rows = []  # (idx_in_rows, user_id)
        cf_rows = []    # (idx_in_rows, field_id, value)

        for idx, item_id in enumerate(selected):
            item_data = dict(self.db.get_item_by_id(item_id) or {})
            users = self.db.get_item_users(item_id)

            new_title = item_data.get('title', '')
            if add_suffix:
                _copy_sfx = self.translations.get('copy_suffix', '-copy')
                if '|' in new_title:
                    parts = new_title.split('|')
                    parts[0] = parts[0].strip() + ' ' + _copy_sfx
                    new_title = '|'.join(parts)
                else:
                    new_title = new_title + ' ' + _copy_sfx

            new_cover_path = None
            old_cover = to_absolute_path(item_data.get('cover_path'))
            if old_cover and os.path.exists(old_cover):
                _dup_fn = f"cover_{uuid.uuid4().hex}.jpg"
                _dup_abs = str(COVERS_DIR / _dup_fn)
                try:
                    dup_img = Image.open(old_cover)
                    if dup_img.mode != 'RGB':
                        dup_img = dup_img.convert('RGB')
                    dup_img.save(_dup_abs, 'JPEG', quality=self.jpg_quality)
                    new_cover_path = to_relative_path(_dup_abs)
                except Exception:
                    new_cover_path = None

            rows.append((
                item_data['category_id'],
                new_title,
                item_data.get('year'),
                new_cover_path,
                item_data.get('watch_date'),
                item_data.get('notes'),
                item_data.get('rating'),
                1 if item_data.get('is_favorite') else 0,
                item_data.get('time_spent', 0),
                item_data.get('view_count', 1),
                max_pos + idx + 1,
            ))

            for u in users:
                user_rows.append((idx, u['id']))

            cursor.execute('SELECT field_id, value FROM custom_field_values WHERE item_id = ?', (item_id,))
            for cf_row in cursor.fetchall():
                cf_rows.append((idx, cf_row['field_id'], cf_row['value']))

        del cursor  # закрываем cursor перед add_items_batch чтобы не мешал подсчёту id_before
        new_ids = self.db.add_items_batch(rows, cf_rows=cf_rows, user_rows=user_rows)

        self.items_list.selectionModel().blockSignals(True)
        self.items_list.clearSelection()
        self.items_list.selectionModel().blockSignals(False)
        self._preserved_selection = set()
        self._selection_ids = set()

        row_h = (MediaItemDelegate.COMPACT_HEIGHT if self.compact_view
                 else MediaItemDelegate.NORMAL_HEIGHT)
        cf_fields = self.db.get_custom_fields()
        users_map = self.db.get_users_for_items(new_ids)
        cf_map    = self.db.get_custom_fields_for_items_batch(new_ids)
        items_map = self.db.get_items_by_ids(new_ids)

        # Батчевое добавление — без лишних сигналов на каждый элемент
        new_entries = []
        new_valid_ids = []
        for new_id in new_ids:
            _raw = items_map.get(new_id)
            if not _raw:
                continue
            item_data = dict(_raw)
            users   = [dict(u) if not isinstance(u, dict) else u for u in users_map.get(new_id, [])]
            cf_vals = cf_map.get(new_id, {})
            cf_data = [(f, cf_vals[f['id']]) for f in cf_fields if f['id'] in cf_vals]
            entry = [item_data, users, cf_data, None, None, None]
            new_entries.append(entry)
            new_valid_ids.append(new_id)

        self.load_items()
        self.update_stats()

    def duplicate_item_by_id(self, item_id):
        """Дублирование элемента по ID."""
        self._do_duplicate_item(item_id)

    def duplicate_item(self, list_item_or_id=None):
        """Дублирование элемента (обратная совместимость)."""
        if isinstance(list_item_or_id, int):
            item_id = list_item_or_id
        elif list_item_or_id is not None:
            try: item_id = list_item_or_id.data(Qt.UserRole)
            except Exception: item_id = None
        else:
            item_id = self._current_item_id()
        if not item_id:
            return
        self._do_duplicate_item(item_id)

    def _do_duplicate_item(self, item_id):
        """Реальная логика дублирования."""
        item_data = dict(self.db.get_item_by_id(item_id) or {})
        users = self.db.get_item_users(item_id)
        user_ids = [u['id'] for u in users]

        dup_dialog = QDialog(self)
        dup_dialog.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        dup_dialog.setWindowTitle(self.translations.get('duplicate', 'Duplicate'))
        dup_dialog.setMinimumWidth(320)
        dup_layout = QVBoxLayout()
        raw_title = item_data.get('title', '')
        display_title = _display_title(raw_title)
        dup_layout.addWidget(QLabel(self.translations.get('duplicate_item', 'Duplicate item:') + f" {display_title}"))
        copy_suffix_cb = QCheckBox(self.translations.get('add_copy_suffix', 'Add "-copy" to title'))
        copy_suffix_cb.setChecked(True)
        dup_layout.addWidget(copy_suffix_cb)
        dup_layout.addLayout(self._make_ok_cancel(dup_dialog, dup_dialog.accept, dup_dialog.reject))
        dup_dialog.setLayout(dup_layout)

        if dup_dialog.exec_() != QDialog.Accepted:
            return

        new_title = item_data.get('title', '')
        if copy_suffix_cb.isChecked():
            _copy_sfx = self.translations.get('copy_suffix', '-copy')
            if '|' in new_title:
                parts = new_title.split('|')
                parts[0] = parts[0].strip() + ' ' + _copy_sfx
                new_title = '|'.join(parts)
            else:
                new_title = new_title + ' ' + _copy_sfx

        new_cover_path = None
        old_cover = to_absolute_path(item_data.get('cover_path'))
        if old_cover and os.path.exists(old_cover):
            _dup_fn = f"cover_{uuid.uuid4().hex}.jpg"
            _dup_abs = str(COVERS_DIR / _dup_fn)
            dup_img = Image.open(old_cover)
            if dup_img.mode != 'RGB':
                dup_img = dup_img.convert('RGB')
            dup_img.save(_dup_abs, 'JPEG', quality=self.jpg_quality)
            new_cover_path = to_relative_path(_dup_abs)

        new_id = self.db.add_item(
            item_data['category_id'],
            new_title,
            year=item_data.get('year'),
            cover_path=new_cover_path,
            watch_date=item_data.get('watch_date'),
            notes=item_data.get('notes'),
            rating=item_data.get('rating'),
            user_ids=user_ids,
            is_favorite=item_data.get('is_favorite', False),
            time_spent=item_data.get('time_spent', 0),
            view_count=item_data.get('view_count', 1),
        )
        orig_pos = item_data.get('custom_position') or 0.0
        cursor = self.db.conn.cursor()
        cursor.execute('SELECT field_id, value FROM custom_field_values WHERE item_id = ?', (item_id,))
        for cf_row in cursor.fetchall():
            cursor.execute(
                'INSERT INTO custom_field_values (item_id, field_id, value) VALUES (?, ?, ?)',
                (new_id, cf_row['field_id'], cf_row['value'])
            )
        cursor.execute(
            'SELECT id, custom_position FROM items WHERE category_id = ? AND custom_position > ? AND id != ? ORDER BY custom_position ASC LIMIT 1',
            (item_data['category_id'], orig_pos, new_id)
        )
        next_row = cursor.fetchone()
        if next_row:
            new_pos = (orig_pos + next_row[1]) / 2.0
        else:
            new_pos = orig_pos + 1.0
        cursor.execute('UPDATE items SET custom_position = ? WHERE id = ?', (new_pos, new_id))
        self.db.conn.commit()
        self.items_list.clearSelection()
        self._preserved_selection = set()
        self.load_items()
        self.update_stats()

    def _ctx_toggle_mark(self, item_id, fid, opt_id):
        """Переключить отметку кастомного поля типа 'marks' для элемента."""
        cur = self.db.get_custom_field_value(item_id, fid)
        try:
            lst = json.loads(cur) if cur else []
            if not isinstance(lst, list): lst = []
        except Exception:
            lst = []
        sid = str(opt_id)
        if sid in lst:
            lst.remove(sid)
        else:
            lst.append(sid)
        self.db.set_custom_field_value(item_id, fid, json.dumps(lst) if lst else None)
        self.load_item(item_id)
        if self._current_item_id() == item_id:
            self.on_item_selected_by_id(item_id)

    def show_item_context_menu(self, position):

        """Показ контекстного меню для элемента(ов)"""
        proxy_idx = self.items_list.indexAt(position)
        if not proxy_idx.isValid():
            return
        src_row = self._item_proxy.map_to_source_row(proxy_idx.row())
        _ctx_item_id = self._item_model.item_id(src_row)

        selected_item_ids = self._selected_item_ids()
        # Если контекстное меню вызвано на невыделенном элементе — выделяем его
        if _ctx_item_id not in selected_item_ids:
            self._select_item_by_id(_ctx_item_id)
            selected_item_ids = [_ctx_item_id]

        if len(selected_item_ids) > 1:
            # Фиксируем список выделенных items на момент открытия меню
            _bulk_ids = list(selected_item_ids)
            menu = QMenu()
            n = len(_bulk_ids)

            # ── Helper: обновить UI для всех изменённых items ─────────────────
            # Запоминаем какой фильм показан в detail panel ДО открытия меню
            _dp = self.detail_panel
            _detail_item_id_before = (
                (_dp._last_item_data or {}).get('id')
                if hasattr(_dp, '_last_item_data') else None
            )
            def _bulk_refresh(iids):
                for iid in iids:
                    self.load_item(iid)
                # Восстанавливаем detail panel на тот фильм что был открыт до меню
                if _detail_item_id_before is not None:
                    self.on_item_selected_by_id(_detail_item_id_before)

            # ── "С кем посмотрено" ─────────────────────────────────────────────
            users = self.db.get_users()
            if users:
                watch_with_menu = menu.addMenu(self.translations.get('mark_watched_with', 'Mark Watched With'))
                # Загружаем user_ids для всех items разом
                item_users_map = {iid: [u['id'] for u in self.db.get_item_users(iid)] for iid in _bulk_ids}
                user_counts = {}
                for uid_list in item_users_map.values():
                    for uid in uid_list:
                        user_counts[uid] = user_counts.get(uid, 0) + 1

                for user in users:
                    uid = user['id']
                    cnt = user_counts.get(uid, 0)
                    all_have = (cnt == n)
                    u_act = QAction(user['name'], self)
                    u_act.setCheckable(True)
                    u_act.setChecked(all_have)

                    def _on_bulk_user(checked, _uid=uid, _all_have=all_have, _iump=item_users_map):
                        updates = {}
                        for iid in _bulk_ids:
                            cur_users = list(_iump[iid])
                            if _all_have:
                                # Все имеют → снимаем у всех
                                if _uid in cur_users:
                                    cur_users.remove(_uid)
                                    updates[iid] = cur_users
                            else:
                                # Не все имеют → добавляем только тем, у кого нет
                                if _uid not in cur_users:
                                    cur_users.append(_uid)
                                    updates[iid] = cur_users
                        if updates:
                            self.db.bulk_update_user(updates)
                            _bulk_refresh(list(updates.keys()))

                    u_act.triggered.connect(_on_bulk_user)
                    watch_with_menu.addAction(u_act)

            # ── Избранное ──────────────────────────────────────────────────────
            # Читаем is_favorite для всех items один раз
            fav_map = {iid: bool(dict(self.db.get_item_by_id(iid) or {}).get('is_favorite')) for iid in _bulk_ids}
            fav_counts = sum(1 for v in fav_map.values() if v)
            all_fav = (fav_counts == n)
            if all_fav:
                fav_text = self.translations.get('remove_from_favorites', 'Remove from Favorites')
            else:
                fav_text = self.translations.get('add_to_favorites', 'Add to Favorites')

            fav_action = QAction(fav_text, self)

            def _on_bulk_fav(checked=False, _all_fav=all_fav, _fav_map=fav_map):
                if _all_fav:
                    # Все в избранном → снимаем у всех
                    self.db.bulk_set_favorite(_bulk_ids, False)
                    _bulk_refresh(_bulk_ids)
                else:
                    # Не все → добавляем только тем, у кого нет
                    to_add = [iid for iid in _bulk_ids if not _fav_map[iid]]
                    if to_add:
                        self.db.bulk_set_favorite(to_add, True)
                        _bulk_refresh(to_add)

            fav_action.triggered.connect(_on_bulk_fav)
            menu.addAction(fav_action)

            # ── Кастомные поля с show_in_context_menu ─────────────────────────
            cf_fields = [dict(f) for f in self.db.get_custom_fields() if dict(f).get('show_in_context_menu')]
            if cf_fields:
                menu.addSeparator()

            def _bulk_cf_save_all(iids, fid, new_val):
                """Применить new_val всем items одним коммитом."""
                self.db.bulk_set_cf_value([(iid, fid, new_val) for iid in iids])
                _bulk_refresh(iids)

            for fd in cf_fields:
                fid = fd['id']
                label = fd.get('context_menu_label') or fd['name']
                ftype = fd.get('field_type', 'string')
                type_opts_raw = fd.get('type_options') or ''

                if ftype == 'select':
                    db_opts = self.db.get_field_options(fid)
                    if not db_opts:
                        continue
                    sub = menu.addMenu(label)
                    # Читаем текущие значения разом
                    sel_val_map = {iid: self.db.get_custom_field_value(iid, fid) for iid in _bulk_ids}
                    val_counts = {}
                    for v in sel_val_map.values():
                        val_counts[v] = val_counts.get(v, 0) + 1
                    has_any = any(v is not None for v in sel_val_map.values())
                    if has_any:
                        clear_act = QAction('–', self)
                        clear_act.triggered.connect(lambda checked=False, _fid=fid: _bulk_cf_save_all(_bulk_ids, _fid, None))
                        sub.addAction(clear_act)
                        sub.addSeparator()
                    for opt in db_opts:
                        cnt_opt = val_counts.get(str(opt['id']), 0)
                        all_opt = (cnt_opt == n)
                        act = QAction(opt['label'], self)
                        act.setCheckable(True)
                        act.setChecked(all_opt)

                        def _on_bulk_select(checked=False, _fid=fid, _oid=opt['id'], _all_opt=all_opt, _vmap=sel_val_map):
                            if _all_opt:
                                # Все уже имеют эту опцию → снимаем у всех
                                self.db.bulk_set_cf_value([(_iid, _fid, None) for _iid in _bulk_ids])
                                _bulk_refresh(_bulk_ids)
                            else:
                                # Не все → ставим только тем, у кого пусто
                                to_set = [iid for iid in _bulk_ids if _vmap[iid] is None]
                                if to_set:
                                    self.db.bulk_set_cf_value([(iid, _fid, str(_oid)) for iid in to_set])
                                    _bulk_refresh(to_set)

                        act.triggered.connect(_on_bulk_select)
                        sub.addAction(act)

                elif ftype == 'marks':
                    db_opts = self.db.get_field_options(fid)
                    if not db_opts:
                        continue
                    sub = menu.addMenu(label)
                    # Читаем и парсим текущие marks-списки для всех items разом
                    marks_map = {}
                    for iid in _bulk_ids:
                        cur = self.db.get_custom_field_value(iid, fid)
                        try:
                            lst = json.loads(cur) if cur else []
                            if not isinstance(lst, list): lst = []
                        except Exception:
                            lst = []
                        marks_map[iid] = [str(x) for x in lst]
                    opt_counts = {}
                    for lst in marks_map.values():
                        for sid in lst:
                            opt_counts[sid] = opt_counts.get(sid, 0) + 1

                    for opt in db_opts:
                        sid = str(opt['id'])
                        cnt_o = opt_counts.get(sid, 0)
                        all_o = (cnt_o == n)
                        m_act = QAction(opt['label'], self)
                        m_act.setCheckable(True)
                        m_act.setChecked(all_o)

                        def _on_bulk_mark(checked, _fid=fid, _sid=sid, _all_o=all_o, _mmap=marks_map):
                            cf_rows = []
                            for iid in _bulk_ids:
                                lst = list(_mmap[iid])
                                if _all_o:
                                    # Все имеют → снимаем у всех
                                    if _sid in lst:
                                        lst.remove(_sid)
                                    cf_rows.append((iid, _fid, json.dumps(lst) if lst else None))
                                else:
                                    # Не все → добавляем только тем, у кого нет
                                    if _sid not in lst:
                                        lst.append(_sid)
                                        cf_rows.append((iid, _fid, json.dumps(lst)))
                            if cf_rows:
                                self.db.bulk_set_cf_value(cf_rows)
                                _bulk_refresh([r[0] for r in cf_rows])

                        m_act.triggered.connect(_on_bulk_mark)
                        sub.addAction(m_act)

                elif ftype == 'boolean':
                    bool_map = {iid: self.db.get_custom_field_value(iid, fid) == '1' for iid in _bulk_ids}
                    all_bool = all(bool_map.values())
                    act = QAction(label, self)
                    act.setCheckable(True)
                    act.setChecked(all_bool)

                    def _on_bulk_bool(checked, _fid=fid, _all_bool=all_bool, _bmap=bool_map):
                        if _all_bool:
                            # Все включены → снимаем у всех
                            self.db.bulk_set_cf_value([(_iid, _fid, None) for _iid in _bulk_ids])
                            _bulk_refresh(_bulk_ids)
                        else:
                            # Не все → включаем только тем, у кого нет
                            to_set = [iid for iid in _bulk_ids if not _bmap[iid]]
                            if to_set:
                                self.db.bulk_set_cf_value([(iid, _fid, '1') for iid in to_set])
                                _bulk_refresh(to_set)

                    act.triggered.connect(_on_bulk_bool)
                    menu.addAction(act)

                else:
                    # string / integer / slider / date — диалог, применяем всем
                    act = QAction(label, self)

                    def _on_bulk_cf_action(checked=False, fid=fid, ftype=ftype, lbl=label, type_opts_raw=type_opts_raw):
                        new_val = None
                        ok = False

                        def _make_cf_dialog(title):
                            d = QDialog(self)
                            d.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
                            d.setWindowTitle(title)
                            d.setWindowFlags(d.windowFlags() & ~Qt.WindowMaximizeButtonHint & ~Qt.WindowContextHelpButtonHint)
                            d.setFixedWidth(260)
                            lay = QVBoxLayout()
                            d.setLayout(lay)
                            grp = QGroupBox(title)
                            grp_lay = QVBoxLayout(grp)
                            grp_lay.setContentsMargins(8, 6, 8, 6)

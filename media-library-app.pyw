    def _run_with_progress(self, parent, title, worker):
        """Show a modal progress dialog while worker QThread runs."""
        # Храним ссылку на self чтобы GC не собрал поток пока он работает
        self._active_worker = worker

        dlg = QDialog(parent)
        dlg.setWindowTitle(title)
        dlg.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        dlg.setWindowFlag(Qt.WindowCloseButtonHint, False)
        dlg.setFixedWidth(300)
        lay = QVBoxLayout(dlg)
        lay.setContentsMargins(12, 12, 12, 12)
        lay.setSpacing(8)
        lay.setSizeConstraint(QVBoxLayout.SetFixedSize)
        msg_lbl = QLabel(self.translations.get('starting', 'Starting...'))
        msg_lbl.setFixedWidth(276)
        msg_lbl.setWordWrap(False)
        msg_lbl.setTextFormat(Qt.PlainText)
        lay.addWidget(msg_lbl)
        bar = QProgressBar()
        bar.setFixedWidth(276)
        bar.setRange(0, 100)
        bar.setValue(0)
        lay.addWidget(bar)

        btn_row = QHBoxLayout()
        btn_row.addStretch()
        cancel_btn = QPushButton(self.translations.get('cancel', 'Cancel'))
        cancel_btn.setFixedWidth(90)
        btn_row.addWidget(cancel_btn)
        lay.addLayout(btn_row)

        _cancelling = [False]

        def on_cancel():
            if _cancelling[0]:
                return
            _cancelling[0] = True
            cancel_btn.setEnabled(False)
            cancel_btn.setText(self.translations.get('cancelling', 'Cancelling...'))
            if hasattr(worker, 'cancel'):
                worker.cancel()

        def on_progress(pct, msg):
            bar.setValue(pct)
            fm = msg_lbl.fontMetrics()
            msg_lbl.setText(fm.elidedText(msg, Qt.ElideRight, msg_lbl.width()))

        def on_done(*args):
            bar.setValue(100)
            dlg.accept()

        def on_cancelled():
            dlg.reject()

        def on_error(msg):
            dlg.reject()
            self._show_dialog_error(parent, msg)

        cancel_btn.clicked.connect(on_cancel)
        worker.progress.connect(on_progress)
        worker.finished.connect(on_done)
        if hasattr(worker, 'cancelled'):
            worker.cancelled.connect(on_cancelled)
        worker.error.connect(on_error)
        worker.start()
        dlg.adjustSize()
        dlg.setFixedSize(dlg.sizeHint())
        dlg.exec_()
        # Ждём завершения потока — критично для больших импортов
        # processEvents во время ожидания чтобы UI не замерзал
        while worker.isRunning():
            worker.wait(200)
            QApplication.processEvents()
        self._active_worker = None
        return worker

    def export_category(self, _open_import_tab=False, export_only=False, category_ids=None):
        """Экспорт/Импорт категории — tabbed dialog.
        export_only=True: только вкладка Export (без Import).
        category_ids: список id для мульти-экспорта (None = текущая категория).
        """
        # Определяем список категорий для экспорта
        # folder_export=True: экспорт папки — мульти по факту, но показываем все форматы
        _folder_export = getattr(self, '_export_is_folder', False)
        self._export_is_folder = False  # сбрасываем
        _folder_name = _folder_export if isinstance(_folder_export, str) else ''

        # Глобальный режим: Import недоступен, только Export
        if self.all_categories_mode and not export_only:
            export_only = True

        # Глобальный режим без явного списка — экспортируем все категории
        if category_ids is None and self.all_categories_mode and not _open_import_tab:
            _all_rows = [dict(r) for r in self.db.get_categories() if not r['is_folder']]
            category_ids = [r['id'] for r in _all_rows]

        # _multi вычисляем ПОСЛЕ того как category_ids мог быть заполнен выше

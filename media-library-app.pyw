            def minimumSizeHint(self): return QSize(0, 0)
            def sizeHint(self):
                fm = self.fontMetrics()
                w = self.width() if self.width() > 0 else 300
                rect = fm.boundingRect(0, 0, w, 10000,
                    Qt.TextWordWrap | Qt.AlignLeft, self.text())
                return QSize(rect.width(), rect.height())
            def resizeEvent(self, event):
                super().resizeEvent(event)
                self.updateGeometry()

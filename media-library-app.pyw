# Паттерн для выделения grapheme clusters (эмодзи + ZWJ + модификаторы + обычные)
_GRAPHEME_RE = re.compile(
    r'[🇠-🇿]{2}'
    r'|[#*0-9]️?⃣'
    r'|[𐀀-􏿿](?:️)?(?:‍[𐀀-􏿿](?:️)?)*'
    r'|[☀-➿]️?'
    r'|\S',
    re.UNICODE
)
def _count_graphemes(text):
    return len(_GRAPHEME_RE.findall(text))

def _first_grapheme(text):
    m = _GRAPHEME_RE.findall(text)
    return m[0] if m else text[0] if text else ''

@lru_cache(maxsize=512)
def _split_mixed_cached(text):
    """Разбивает строку на куски [(chunk, is_emoji), ...] с кэшем по строке.
    Логика идентична локальной _split_mixed в _paint_compact — только мемоизирована.
    Строки в compact-режиме стабильны между фреймами, кэш практически всегда попадает."""
    if not text:
        return ()
    clusters = _GRAPHEME_RE.findall(text)
    has_emoji = any(_is_colored_emoji(c) for c in clusters)
    has_text  = any(not _is_colored_emoji(c) and ord(c[0]) > 0x20 for c in clusters)
    if not (has_emoji and has_text):
        return ((text, has_emoji),)
    parts = []
    cur_chunks = []
    cur_is_emoji = _is_colored_emoji(clusters[0])
    for c in clusters:
        c_is_emoji = _is_colored_emoji(c)
        if c_is_emoji == cur_is_emoji:
            cur_chunks.append(c)
        else:
            parts.append((''.join(cur_chunks), cur_is_emoji))
            cur_chunks = [c]
            cur_is_emoji = c_is_emoji
    parts.append((''.join(cur_chunks), cur_is_emoji))
    return tuple(parts)


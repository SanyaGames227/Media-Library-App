    def items_list_key_press(self, event):  # подключён через keyPressEvent

        key  = event.key()
        mods = event.modifiers()
        text = event.text()

        # Typeahead: печатаемые символы без Ctrl/Alt
        is_printable = (
            len(text) == 1
            and text.isprintable()
            and not (mods & Qt.ControlModifier)
            and not (mods & Qt.AltModifier)
        )
        is_backspace = (
            key == Qt.Key_Backspace
            and not (mods & Qt.ControlModifier)
            and not (mods & Qt.AltModifier)
        )

        if is_printable or is_backspace:
            if not hasattr(self, '_typeahead_buf'):
                self._typeahead_buf = ''
                self._typeahead_timer = QTimer(self)
                self._typeahead_timer.setSingleShot(True)
                self._typeahead_timer.timeout.connect(self._typeahead_reset)
            if is_backspace:
                self._typeahead_buf = self._typeahead_buf[:-1]
            else:
                self._typeahead_buf += text
            self._typeahead_timer.start(700)
            if self._typeahead_buf:
                self._typeahead_jump(self._typeahead_buf)
            return

        QListView.keyPressEvent(self.items_list, event)
        if key in (Qt.Key_Up, Qt.Key_Down):
            if len(self._selected_item_ids()) <= 1:
                item = self._current_item_id()
                if item:
                    self.on_item_selected(item)
        elif key in (Qt.Key_Return, Qt.Key_Enter):
            selected = self._selected_item_ids()
            if len(selected) == 1:
                self.edit_item()
        elif key == Qt.Key_Escape:
            if len(self._selected_item_ids()) == 1:
                self.items_list.clearSelection()
                self._selection_ids = set()
                self._preserved_selection = set()
                self.detail_panel.clear_item()

    def _typeahead_reset(self):
        self._typeahead_buf = ''

    def _typeahead_jump(self, buf):
        store = getattr(self, '_items_store', [])
        if not store:
            return
        buf_l = buf.lower()
        found_id = None
        for entry in store:
            title = (entry[0].get('title') or '') if entry[0] else ''
            if title.lower().startswith(buf_l):
                found_id = entry[0].get('id')
                break
        if found_id is None:
            # Ничего не нашли — сброс до последнего символа и повтор
            if len(buf) > 1:
                self._typeahead_buf = buf[-1]
                self._typeahead_jump(self._typeahead_buf)
            return
        proxy_row = self._proxy_row_for_id(found_id)
        if proxy_row < 0:
            return
        idx = self._item_proxy.index(proxy_row, 0)
        sel_model = self.items_list.selectionModel()
        sel_model.clearSelection()
        sel_model.select(idx, sel_model.Select | sel_model.Current)
        self._selection_ids = {found_id}
        self._preserved_selection = {found_id}
        self.items_list.scrollTo(idx, QListView.PositionAtCenter)
        self.on_item_selected(found_id)


        def _make_preview_txt(tpl):
            sample = {
                'title': 'Inception', 'year': '2010', 'year_watch': '2023',
                'rate': '8', 'users': 'Alice', 'view_count': '3',
                'is_favorite': '🩷', 'notes': 'Great film\nSecond line',
            }
            try:
                ri_list = self.db.get_items(_exp_category_ids[0], limit=1)
                if ri_list:
                    ri = dict(ri_list[0])
                    sample['title'] = ri.get('title') or sample['title']
                    sample['year'] = str(ri.get('year') or '')
                    r = str(ri.get('rating') or '')
                    sample['rate'] = '' if r == '0' else r
                    sample['notes'] = ri.get('notes') or sample['notes']
                    sample['view_count'] = str(ri.get('view_count') or '')
                    sample['year_watch'] = str(ri.get('watch_date') or '')
                    ul = self.db.get_users_for_items([ri['id']]).get(ri['id'], [])
                    sample['users'] = ', '.join(u['name'] for u in ul)
                    sample['is_favorite'] = '🩷' if ri.get('is_favorite') else ''
            except Exception:
                pass
            if sample.get('view_count') in ('', '0', '1'):
                sample['view_count'] = ''
            for fd in cf_fields_all:
                sample.setdefault(fd['variable'], '')

            # Handle {notes:inline} — replace newlines with literal \n in preview show as ↵
            notes_val = sample.get('notes', '')
            notes_inline_preview = re.sub(r'\n+', ' ↵ ', notes_val.replace('\r', '')).strip()

            result = tpl
            # Replace {notes:inline} first (for preview show ↵)
            result = result.replace('{notes:inline}', notes_inline_preview)
            # Replace bracketed empties
            result = re.sub(
                r'[\[\(][^\[\]\(\)]*?\{(\w+)\}[^\[\]\(\)]*?[\]\)]',
                lambda m: '' if not sample.get(m.group(1), '') else m.group(0),
                result
            )
            for var, val in sample.items():
                result = result.replace('{' + var + '}', val)
            result = re.sub(r'\{[^}]+\}', '', result)
            result = re.sub(r'  +', ' ', result)
            result = re.sub(r'(^\s*)[\-\|]+(\s+)', '', result)
            result = re.sub(r'(\s+)[\-\|]+(\s*$)', '', result)
            result = re.sub(r'  +', ' ', result).strip()
            # In preview: show newlines as ↵
            result = result.replace('\n', ' ↵ ').replace('\r', '')
            return result or '—'

        def _update_preview_txt():
            preview_edit.setText(_make_preview_txt(txt_tpl_edit.toPlainText()))

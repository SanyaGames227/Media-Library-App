    def keyPressEvent(self, event):
        if event.key() in (Qt.Key_Return, Qt.Key_Enter):
            # Не перехватываем Enter в QTextEdit / QPlainTextEdit (многострочные поля)
            # и в _StringFieldWidget (однострочный режим — Shift+Enter должен работать)
            fw = self.focusWidget()
            # Проверяем что фокус не внутри _StringFieldWidget
            _in_string_field = False
            _p = fw
            while _p is not None:
                if isinstance(_p, _StringFieldWidget):
                    _in_string_field = True
                    break
                _p = _p.parent() if hasattr(_p, 'parent') and callable(_p.parent) else None
            if not isinstance(fw, (QTextEdit, _QPlainTextEdit)) and not _in_string_field:
                fn = getattr(self, '_item_accept_fn', None)
                if fn:
                    fn()
                return
        super().keyPressEvent(event)
    
    def load_data(self):
        """Загрузка данных элемента для редактирования"""
        self.title_edit.setText(self.item_data['title'])
        if self.item_data.get('year'):
            self.year_spin.setValue(self.item_data['year'])
        if self.item_data.get('watch_date'):
            wd = self.item_data['watch_date']
            parts = wd.split('-')
            if len(parts) == 1 and parts[0]:
                self.date_mode_combo.setCurrentIndex(1)
                try:
                    self.date_year_spin.setValue(int(parts[0]))
                    self._date_mem_year = int(parts[0])
                except ValueError:
                    pass
            elif len(parts) == 2:
                self.date_mode_combo.setCurrentIndex(2)
                try:
                    self.date_year_spin.setValue(int(parts[0]))
                    self.date_month_combo.setCurrentIndex(int(parts[1]) - 1)
                    self._date_mem_year  = int(parts[0])
                    self._date_mem_month = int(parts[1])
                except (ValueError, IndexError):
                    pass
            elif len(parts) == 3:
                self.date_mode_combo.setCurrentIndex(3)
                _d = QDate.fromString(wd, 'yyyy-MM-dd')
                self.date_edit.setDate(_d)
                self._date_mem_full  = _d
                self._date_mem_year  = _d.year()
                self._date_mem_month = _d.month()
        if self.item_data.get('notes'):
            self.notes_edit.setText(self.item_data['notes'])
        if self.item_data.get('rating'):
            self.rating_slider.setValue(self.item_data['rating'])
        if self.item_data.get('is_favorite'):
            self.favorite_checkbox.setChecked(True)
        if self.item_data.get('time_spent'):
            self.time_spin.setValue(self.item_data['time_spent'])
        if self.item_data.get('view_count'):
            self.view_count_spin.setValue(self.item_data['view_count'])
        
        if self.cover_path and os.path.exists(to_absolute_path(self.cover_path)):
            self.cover_label.setPixmap(QPixmap(to_absolute_path(self.cover_path)))
        
        item_users = self.db.get_item_users(self.item_data['id'])
        user_ids = [u['id'] for u in item_users]
        for checkbox in self.user_checkboxes:
            if checkbox.property('user_id') in user_ids:
                checkbox.setChecked(True)

        if hasattr(self, '_cf_widgets'):
            cf_values = self.db.get_all_custom_field_values_for_item(self.item_data['id'])
            for fid, w in self._cf_widgets.items():
                val = cf_values.get(fid)
                field = self.db.get_custom_field_by_id(fid)
                if not field:
                    continue
                ftype = dict(field).get('field_type', 'string')
                if val is None:
                    continue
                if ftype == 'boolean':
                    w.setChecked(val == '1' or val.lower() == 'true')
                elif ftype == 'integer':
                    try: w.setValue(int(val))
                    except: pass
                elif ftype == 'slider':
                    try: w._slider.setValue(int(val))
                    except: pass
                elif ftype == 'select':
                    for i in range(w.count()):
                        if str(w.itemData(i)) == str(val):
                            w.setCurrentIndex(i)
                            break
                elif ftype == 'marks':
                    try:
                        checked_ids = [str(x) for x in json.loads(val)] if val else []
                    except Exception:
                        checked_ids = []
                    for cb in w._checkboxes:
                        cb.setChecked(str(cb.property('option_id')) in checked_ids)
                elif ftype == 'date':
                    parts = val.split('-')
                    if len(parts) == 1 and parts[0]:
                        w._d_mode.setCurrentIndex(1)
                        try: w._d_year.setValue(int(parts[0]))
                        except: pass
                    elif len(parts) == 2:
                        w._d_mode.setCurrentIndex(2)
                        try:
                            w._d_year.setValue(int(parts[0]))
                            w._d_month.setCurrentIndex(int(parts[1]) - 1)
                        except: pass
                    elif len(parts) == 3:
                        w._d_mode.setCurrentIndex(3)
                        w._d_date.setDate(QDate.fromString(val, 'yyyy-MM-dd'))
                else:  # string
                    w.setText(str(val))
    
    def load_cover_from_file(self):
        """Загрузка обложки из файла"""
        file_path, _ = QFileDialog.getOpenFileName(self, "", "", "Images (*.png *.jpg *.jpeg *.bmp *.webp *.gif)")
        if file_path:
            self.process_cover(file_path)

    def _load_cover_from_paste(self):
        """Загрузка обложки из буфера обмена: если там картинка — берём её,
        если текст с URL — скачиваем по нему."""
        cb = QApplication.clipboard()

        # 1. Проверяем картинку в буфере
        img = cb.image()
        if img and not img.isNull():
            temp_path = str(COVERS_DIR / f"temp_{uuid.uuid4().hex}.png")
            img.save(temp_path, 'PNG')
            self.process_cover(temp_path)
            try:
                os.remove(temp_path)
            except Exception:
                pass
            return

        # 2. Проверяем URL в тексте буфера
        text = cb.text().strip() if cb.text() else ''
        if text and re.match(r'https?://', text, re.IGNORECASE):
            url = text

            class _UrlDownloader(QThread):
                done  = pyqtSignal(bytes)
                error = pyqtSignal(str)
                def __init__(self2, u):
                    super().__init__()
                    self2._url = u
                def run(self2):
                    self2.setTerminationEnabled(False)
                    try:
                        req = urllib.request.Request(self2._url, headers={'User-Agent': 'Mozilla/5.0'})
                        try:
                            with urllib.request.urlopen(req, timeout=10) as resp:
                                self2.done.emit(resp.read())
                        except Exception:
                            ctx = ssl.create_default_context()
                            ctx.check_hostname = False
                            ctx.verify_mode    = ssl.CERT_NONE
                            with urllib.request.urlopen(req, timeout=10, context=ctx) as resp:
                                self2.done.emit(resp.read())
                    except Exception as e:
                        self2.error.emit(str(e))

            def _on_url_done(data):
                try:
                    temp_path = str(COVERS_DIR / f'temp_{uuid.uuid4().hex}.jpg')
                    with open(temp_path, 'wb') as f:
                        f.write(data)
                    self.process_cover(temp_path)
                    try:
                        os.remove(temp_path)
                    except Exception:
                        pass
                except Exception as e:
                    _show_dialog_error(self, self.translations.get('url_download_error',
                        'Failed to download image: {}').format(e), self.translations)

            def _on_url_error(err):
                _show_dialog_error(self, self.translations.get('url_download_error',
                    'Failed to download image: {}').format(err), self.translations)

            _dl = _UrlDownloader(url)
            _dl.done.connect(_on_url_done)
            _dl.error.connect(_on_url_error)
            self._url_dl_ref = _dl  # держим ссылку
            _dl.start()
            return

        # 3. Ни картинки, ни URL — сообщаем пользователю
        _show_dialog_warning(self, self.translations.get('paste_no_image_or_url', 'No image or URL found in clipboard'), self.translations)

    def _remove_cover(self):
        """Удаление обложки"""

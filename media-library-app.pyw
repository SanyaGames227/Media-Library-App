        )
        self.commit()

    def get_tier_items(self, category_id):
        """Return {tier_key: [item_id, ...]} for category."""
        cursor = self.conn.cursor()
        cursor.execute(
            'SELECT item_id, tier_key FROM tier_items WHERE category_id=? ORDER BY tier_key, position ASC',
            (category_id,)
        )

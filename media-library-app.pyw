        def on_select_file():
            path, _ = QFileDialog.getOpenFileName(dlg, '', '', 'CSV / ZIP Files (*.csv *.zip)')
            if not path:
                return
            imp_zip_src_path[0] = None
            if path.lower().endswith('.zip'):
                try:
                    with zipfile.ZipFile(path, 'r') as zf:
                        members = zf.namelist()
                        # Flat CSVs in outer ZIP
                        flat_csvs = [m for m in members
                                     if m.lower().endswith('.csv')
                                     and not m.endswith('/')
                                     and not m.startswith('_folder')]
                        # Inner ZIPs (folder groups from multi-export)
                        inner_zips = [m for m in members if m.lower().endswith('.zip')]
                        # Build list of choices: (display_label, zip_member_or_none, csv_member)
                        choices = []
                        for csv_m in flat_csvs:
                            choices.append((os.path.basename(csv_m), None, csv_m))
                        for inner_zip_m in inner_zips:
                            inner_data = zf.read(inner_zip_m)
                            import io
                            with zipfile.ZipFile(io.BytesIO(inner_data), 'r') as izf:
                                inner_csvs = [m for m in izf.namelist()
                                              if m.lower().endswith('.csv')
                                              and not m.endswith('/')
                                              and not m.startswith('_folder')]
                                for ic in inner_csvs:
                                    label = f'{os.path.basename(inner_zip_m)} → {os.path.basename(ic)}'
                                    choices.append((label, inner_zip_m, ic))
                    if not choices:
                        self._show_dialog_error(dlg, self.translations.get(
                            'import_zip_no_csv', 'No CSV file found in ZIP archive.'))
                        return
                    elif len(choices) == 1:
                        chosen = choices[0]
                    else:
                        _ci_dlg = QDialog(dlg)
                        _ci_dlg.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
                        _ci_dlg.setWindowTitle(self.translations.get('import_zip_choose_csv', 'Choose CSV'))
                        _ci_dlg.setWindowFlags(_ci_dlg.windowFlags() & ~Qt.WindowMaximizeButtonHint & ~Qt.WindowContextHelpButtonHint)
                        _ci_layout = QVBoxLayout()
                        _ci_layout.setSizeConstraint(QVBoxLayout.SetFixedSize)
                        _ci_dlg.setLayout(_ci_layout)
                        _ci_layout.addWidget(QLabel(self.translations.get('import_zip_multiple_csv', 'Multiple CSV files found:')))
                        _ci_combo = QComboBox()
                        for label, _, _ in choices:
                            _ci_combo.addItem(label)
                        _ci_layout.addWidget(_ci_combo)
                        _ci_btn_row = QHBoxLayout(); _ci_btn_row.addStretch()
                        _ci_ok = QPushButton(self.translations.get('ok', 'OK'))
                        _ci_cancel = QPushButton(self.translations.get('cancel', 'Cancel'))
                        _ci_ok.setDefault(True)
                        _ci_ok.clicked.connect(_ci_dlg.accept)
                        _ci_cancel.clicked.connect(_ci_dlg.reject)
                        _ci_btn_row.addWidget(_ci_ok); _ci_btn_row.addWidget(_ci_cancel)
                        _ci_layout.addLayout(_ci_btn_row)
                        if _ci_dlg.exec_() != QDialog.Accepted:
                            return
                        chosen = choices[_ci_combo.currentIndex()]
                    _label, _inner_zip_m, _csv_m = chosen
                    imp_zip_src_path[0] = path
                    if _inner_zip_m:
                        # Need to extract inner ZIP first, then use its CSV
                        import io, tempfile
                        with zipfile.ZipFile(path, 'r') as _ozf:
                            _inner_data = _ozf.read(_inner_zip_m)
                        _tmp_inner = tempfile.mktemp(suffix='.zip')
                        with open(_tmp_inner, 'wb') as _tf:
                            _tf.write(_inner_data)
                        imp_zip_src_path[0] = _tmp_inner
                        imp_selected_path[0] = _csv_m
                    else:
                        imp_selected_path[0] = _csv_m
                    file_label.setText(f'{os.path.basename(path)} → {_label}')
                    file_label.setStyleSheet('color: #fff;')
                except zipfile.BadZipFile:
                    self._show_dialog_error(dlg, self.translations.get(
                        'import_zip_bad', 'Invalid or corrupted ZIP file.'))
                except Exception as e:
                    self._show_dialog_error(dlg, str(e))
            else:
                imp_selected_path[0] = path
                file_label.setText(os.path.basename(path))
                file_label.setStyleSheet('color: #fff;')

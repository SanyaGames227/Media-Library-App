        class _SearchWorker(QThread):
            results_ready = pyqtSignal(list)   # [(murl, turl, '')]
            error         = pyqtSignal(str)

            def __init__(self2, query, page):
                super().__init__()
                self2._query   = query
                self2._page    = page
                self2._stopped = False

            def stop(self2):
                self2._stopped = True

            def run(self2):
                self2.setTerminationEnabled(False)  # не убивать поток принудительно
                try:
                    offset = (self2._page - 1) * 20
                    url = (f'https://www.bing.com/images/search'
                           f'?q={urllib.parse.quote(self2._query)}&form=HDRSC2&first={offset + 1}')
                    req = urllib.request.Request(url, headers={
                        'User-Agent':     'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/120.0',
                        'Accept-Language':'en-US,en;q=0.9',
                        'Accept':         'text/html,application/xhtml+xml',
                        'Referer':        'https://www.bing.com/'})
                    with urllib.request.urlopen(req, timeout=12) as resp:
                        html = resp.read().decode('utf-8', errors='ignore')
                    if self2._stopped:
                        return
                    matches = re.findall(r'm="({[^"]+})"', html)
                    items = []
                    for m in matches:
                        try:
                            obj = json.loads(m.replace('&quot;', '"'))
                            murl = obj.get('murl', '')
                            turl = obj.get('turl', '')
                            if murl and turl:
                                items.append((murl, turl, ''))
                        except Exception:
                            continue
                    if not self2._stopped:
                        self2.results_ready.emit(items[:20])
                except Exception as e:
                    if not self2._stopped:
                        self2.error.emit(str(e))

        _search_worker = [None]

        def _stop_search():
            if _search_worker[0] and _search_worker[0].isRunning():
                _search_worker[0].stop()
                _search_worker[0].wait(300)

        def _do_search(page=1):
            _stop_loader()
            _stop_search()
            model.clear()
            ok_btn.setEnabled(False)
            query = query_edit.text().strip()
            if not query:
                return
            _current_page[0] = page
            page_lbl.setText(str(page))
            prev_btn.setEnabled(page > 1)
            next_btn.setEnabled(False)
            search_btn.setEnabled(False)
            status_lbl.setText(self.translations.get('searching', 'Searching...'))

            def _on_results(items):
                search_btn.setEnabled(True)
                if not items:
                    status_lbl.setText(self.translations.get('no_results', 'No results found.'))
                    return
                model.add_items(items)
                next_btn.setEnabled(len(items) >= 20)
                status_lbl.setText(
                    self.translations.get('cover_search_page', 'Page {}').format(page))
                loader = _ThumbLoader(items)
                loader.loaded.connect(_on_thumb_loaded)
                _loader[0] = loader
                loader.start()

            def _on_error(err):
                search_btn.setEnabled(True)
                status_lbl.setText(
                    self.translations.get('search_error', 'Error: {}').format(err))

            worker = _SearchWorker(query, page)
            worker.results_ready.connect(_on_results)
            worker.error.connect(_on_error)
            _search_worker[0] = worker
            worker.start()

        _prefetch_cache = {}   # url -> bytes (предзагруженные данные)
        _prefetch_thread = [None]

        class _Prefetcher(QThread):
            done = pyqtSignal(str, bytes)
            def __init__(self2, url):
                super().__init__()
                self2._url     = url
                self2._stopped = False
            def stop(self2):
                self2._stopped = True
            def run(self2):
                self2.setTerminationEnabled(False)  # не убивать поток принудительно
                try:
                    req = urllib.request.Request(self2._url, headers={
                        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'})
                    try:
                        with urllib.request.urlopen(req, timeout=15) as resp:
                            data = resp.read()
                    except Exception:
                        ctx = ssl.create_default_context()
                        ctx.check_hostname = False
                        ctx.verify_mode    = ssl.CERT_NONE
                        with urllib.request.urlopen(req, timeout=15, context=ctx) as resp:
                            data = resp.read()
                    if not self2._stopped:
                        self2.done.emit(self2._url, data)
                except Exception:
                    pass

        def _on_prefetched(url, data):
            _prefetch_cache[url] = data

        def _on_selection_changed(sel, desel):
            ok_btn.setEnabled(bool(view.selectionModel().selectedIndexes()))
            idxs = view.selectionModel().selectedIndexes()
            if not idxs:
                return
            url = model.data(idxs[0], _ImageModel.ROLE_URL)
            if not url or url in _prefetch_cache:
                return
            # Останавливаем предыдущий prefetch если был
            if _prefetch_thread[0] and _prefetch_thread[0].isRunning():
                _prefetch_thread[0].stop()
            pf = _Prefetcher(url)
            pf.done.connect(_on_prefetched)
            _prefetch_thread[0] = pf
            pf.start()

        def _download_selected():
            idxs = view.selectionModel().selectedIndexes()
            if not idxs:
                return
            url       = model.data(idxs[0], _ImageModel.ROLE_URL)
            thumb_url = model.data(idxs[0], _ImageModel.ROLE_THUMB_URL)
            if not url:
                return
            _stop_loader()
            if _prefetch_thread[0] and _prefetch_thread[0].isRunning():
                _prefetch_thread[0].stop()

            # Если уже есть кеш — используем сразу
            data = _prefetch_cache.get(url)
            if data:
                search_dlg.accept()
                _apply_downloaded(url, data)
                return

            # Иначе — качаем в фоновом потоке, показываем индикатор
            ok_btn.setEnabled(False)
            ok_btn.setText('...')
            status_lbl.setText(self.translations.get('downloading', 'Downloading...'))

            class _Downloader(QThread):
                done  = pyqtSignal(str, bytes)
                error = pyqtSignal(str)
                def __init__(self2, u, fallback_u):
                    super().__init__()
                    self2._url      = u
                    self2._fallback = fallback_u
                def _fetch(self2, u):
                    req = urllib.request.Request(u, headers={
                        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
                        'Referer':    'https://www.bing.com/'})
                    try:
                        with urllib.request.urlopen(req, timeout=15) as resp:
                            if resp.status == 403:
                                raise Exception('403')
                            return resp.read()
                    except Exception:
                        ctx = ssl.create_default_context()
                        ctx.check_hostname = False
                        ctx.verify_mode    = ssl.CERT_NONE
                        with urllib.request.urlopen(req, timeout=15, context=ctx) as resp:
                            if resp.getcode() == 403:
                                raise Exception('403')
                            return resp.read()
                def run(self2):
                    self2.setTerminationEnabled(False)
                    try:
                        try:
                            data = self2._fetch(self2._url)
                        except Exception:
                            # 403 или любая ошибка — fallback на превью
                            if self2._fallback:
                                data = self2._fetch(self2._fallback)
                            else:
                                raise
                        self2.done.emit(self2._url, data)
                    except Exception as e:
                        self2.error.emit(str(e))

            def _on_done(u, data):
                _prefetch_cache[u] = data
                search_dlg.accept()
                _apply_downloaded(u, data)

            def _on_dl_error(err):
                ok_btn.setEnabled(True)
                ok_btn.setText('OK')
                status_lbl.setText('')
                _show_dialog_error(self, self.translations.get('url_download_error',
                        'Failed to download image: {}').format(err), self.translations)

            dl = _Downloader(url, thumb_url)
            dl.done.connect(_on_done)
            dl.error.connect(_on_dl_error)
            # Держим ссылку чтобы GC не собрал
            search_dlg._active_dl = dl
            dl.start()

        def _apply_downloaded(url, data):
            try:
                temp_path = str(COVERS_DIR / f'search_{uuid.uuid4().hex}.jpg')
                with open(temp_path, 'wb') as f:
                    f.write(data)
                self.process_cover(temp_path)
                try:
                    os.remove(temp_path)
                except Exception:
                    pass
            except Exception as e:
                _show_dialog_error(self, self.translations.get('url_download_error',
                        'Failed to download image: {}').format(e), self.translations)

        view.selectionModel().selectionChanged.connect(_on_selection_changed)
        view.activated.connect(lambda idx: _download_selected())
        search_btn.clicked.connect(lambda: _do_search(1))
        prev_btn.clicked.connect(lambda: _do_search(_current_page[0] - 1))
        next_btn.clicked.connect(lambda: _do_search(_current_page[0] + 1))
        ok_btn.clicked.connect(_download_selected)
        cancel_btn.clicked.connect(search_dlg.reject)
        query_edit.returnPressed.connect(lambda: _do_search(1))
        search_dlg.finished.connect(lambda _: (_stop_loader(), _stop_search()))

        if _base_title:
            QTimer.singleShot(100, lambda: _do_search(1))

        search_dlg.exec_()


class WrapLabel(QLabel):
    """
    Замена QLabel, которая корректно сообщает высоту при wordWrap=True.

    Баг Qt (QTBUG-7103): QLabel.sizeHint() / minimumSizeHint() возвращают
    неверную высоту для переносов строк до первого resizeEvent, потому что
    heightForWidth() можно вызвать только когда известна реальная ширина.
    Решение: в resizeEvent пересчитываем минимальную высоту через
    heightForWidth(currentWidth) и вызываем updateGeometry() — это заставляет
    родительский layout пересмотреть размеры.

    Используется как глобальный алиас QLabel (см. строку после класса),
    поэтому fix работает для всех label'ов в проге автоматически,
    но только когда wordWrap=True — однострочные label'ы не затрагиваются.
    """
    def resizeEvent(self, event):
        super().resizeEvent(event)
        if self.wordWrap():
            self._fix_height()

    def _fix_height(self):
        w = self.width()
        if w > 0:
            h = self.heightForWidth(w)
            if h > 0:
                self.setMinimumHeight(h)
                self.updateGeometry()

# Глобальный патч: весь код ниже, который пишет QLabel(...), автоматически
# получает исправленное поведение без ручных замен.
QLabel = WrapLabel


class SmartTabWidget(QTabWidget):
    """QTabWidget that resizes to fit the current tab's content."""
    def sizeHint(self):
        w = self.currentWidget()
        if w is None:
            return super().sizeHint()
        s = w.sizeHint()
        s.setHeight(s.height() + self.tabBar().sizeHint().height() + 4)
        s.setWidth(max(s.width(), super().sizeHint().width()))
        return s

    def minimumSizeHint(self):
        w = self.currentWidget()
        if w is None:
            return super().minimumSizeHint()
        s = w.minimumSizeHint()
        s.setHeight(s.height() + self.tabBar().sizeHint().height() + 4)
        s.setWidth(max(s.width(), super().minimumSizeHint().width()))
        return s


class AutoSaveDict(dict):
    def __init__(self, data, file_path):
        super().__init__(data)
        self._file_path = file_path

    def get(self, key, default=None):
        if key not in self:
            value = default if default is not None else key
            self[key] = value
            try:
                with open(self._file_path, 'r', encoding='utf-8') as f:
                    raw = json.load(f)
                raw[key] = value
                with open(self._file_path, 'w', encoding='utf-8') as f:
                    json.dump(raw, f, ensure_ascii=False, indent=2)
            except Exception:
                pass
        return self[key]
        
def load_languages(main_window=None):
    if not os.path.exists(LANG_DIR):
        os.makedirs(LANG_DIR)

    # Встроенные языки — создаём файл если его ещё нет в папке
    _BUILTIN_LANGS = {
        'ru': _BUILTIN_LANG_RU_B64,
        'ua': _BUILTIN_LANG_UA_B64,
    }
    for _lang_key, _lang_b64 in _BUILTIN_LANGS.items():
        _lang_path = LANG_DIR / f'{_lang_key}.json'
        if not _lang_path.exists():
            try:
                _json_bytes = zlib.decompress(base64.b64decode(
                    re.sub(r'[\s\"\']', '', _lang_b64)
                ))
                _json_data = json.loads(_json_bytes.decode('utf-8'))
                with open(_lang_path, 'w', encoding='utf-8') as _f:
                    json.dump(_json_data, _f, ensure_ascii=False, indent=4, sort_keys=True)
            except Exception as _e:
                print(f'Failed to seed builtin language {_lang_key}: {_e}')

    langs = {}

    # EN — всегда встроенный, не читаем и не создаём en.json
    # Имя зарезервировано: даже если en.json существует — игнорируем его
    langs['en'] = {}  # обычный dict, translations.get() вернёт default/key

    for fname in os.listdir(LANG_DIR):
        if not fname.endswith('.json'):
            continue
        key = fname.split('.')[0].lower()
        if key == 'en':
            continue  # en зарезервирован под встроенный
        path = os.path.join(LANG_DIR, fname)
        try:
            with open(path, 'r', encoding='utf-8') as f:
                data = json.load(f)
            langs[key] = AutoSaveDict(data, path)
        except Exception as e:
            if main_window:
                QMessageBox.critical(main_window, "Error", f"Failed to load language {fname}:\n{e}")
            else:
                print(f"Failed to load language {fname}: {e}")

    return langs, 'en'

# ── DEBUG TIMER ─────────────────────────────────────────────────────────────
_DBG_ENABLED = True   # Переключить в False чтобы отключить все замеры

class _Timer:
    """Контекстный менеджер замера времени."""
    _indent = 0

    def __init__(self, label):
        self.label = label

    def __enter__(self):
        self._t = time.perf_counter()
        prefix = "  " * _Timer._indent
        print(f"[DBG] {prefix}▶ {self.label}")
        _Timer._indent += 1
        return self

    def __exit__(self, *_):
        _Timer._indent = max(0, _Timer._indent - 1)
        ms = (time.perf_counter() - self._t) * 1000
        prefix = "  " * _Timer._indent
        print(f"[DBG] {prefix}◀ {self.label}: {ms:.1f} ms")

def _t(label):
    if _DBG_ENABLED:
        return _Timer(label)
    class _Noop:
        def __enter__(self): return self
        def __exit__(self, *_): pass
    return _Noop()


        # ── фабрика inline-делегата + drag-and-drop + контекстное меню ──
        def _make_opts_list(lw, ftype, editing_state):
            """Настраивает SortableListWidget для редактирования опций поля.
            Все изменения накапливаются в виджете и применяются в БД только при OK.
            opt_id в Qt.UserRole: int = существующая запись, None = новая (ещё не в БД).
            """

            def _make_icon(draw_fn):
                pix = _make_hires_pixmap(14)
                p = QPainter(pix)
                p.setRenderHint(QPainter.Antialiasing)
                pen = QPen(QColor(255, 255, 255))
                pen.setWidthF(1.5)
                pen.setCapStyle(Qt.RoundCap)
                p.setPen(pen)
                draw_fn(p)
                p.end()
                return QIcon(pix)

            def _draw_check(p):
                p.drawLine(QPointF(2, 7), QPointF(5.5, 11))
                p.drawLine(QPointF(5.5, 11), QPointF(12, 3))

            _check_icon = _make_icon(_draw_check)

            class _InlineDelegate(QStyledItemDelegate):
                def createEditor(self_, parent, option, index):
                    container = QWidget(parent)
                    container.setAutoFillBackground(True)
                    h = QHBoxLayout(container)
                    h.setContentsMargins(2, 1, 2, 1)
                    h.setSpacing(2)
                    le = QLineEdit()
                    le.setFrame(True)
                    h.addWidget(le)
                    btn_ok = QPushButton()
                    btn_ok.setFixedSize(24, 22)
                    btn_ok.setFocusPolicy(Qt.NoFocus)
                    btn_ok.setIcon(_check_icon)
                    btn_ok.setIconSize(QSize(14, 14))
                    h.addWidget(btn_ok)
                    container._le = le

                    def _confirm():
                        text = le.text().strip()
                        it = editing_state.get('item')
                        if text and it is not None:
                            # только обновляем текст в виджете — БД не трогаем
                            it.setText(text)
                        elif not text:
                            it = editing_state.get('item')
                            _is_new = (it is not None and
                                       isinstance(it.data(Qt.UserRole), str) and
                                       str(it.data(Qt.UserRole)).startswith('_new_'))
                            if it is not None and editing_state.get('original', '') == '' and _is_new:
                                # Новый элемент оставлен пустым — удаляем без сохранения
                                self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)
                                row = lw.row(it)
                                if row >= 0:
                                    lw.takeItem(row)
                                editing_state['item'] = None
                                return
                            # Существующий элемент очищен — откатываем к оригиналу
                            le.setText(editing_state.get('original', ''))
                        self_.commitData.emit(container)
                        self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)

                    container.setFocusProxy(le)
                    container._confirm_fn = _confirm
                    btn_ok.clicked.connect(_confirm)
                    return container

                def setEditorData(self_, editor, index):
                    editor._le.setText(index.data(Qt.DisplayRole) or '')
                    editor._le.selectAll()

                def setModelData(self_, editor, model, index):
                    text = editor._le.text().strip()
                    if text:
                        model.setData(index, text, Qt.DisplayRole)
                    elif editing_state.get('original'):
                        model.setData(index, editing_state['original'], Qt.DisplayRole)
                    else:
                        it = editing_state.get('item')
                        _is_new = (it is not None and
                                   isinstance(it.data(Qt.UserRole), str) and
                                   str(it.data(Qt.UserRole)).startswith('_new_'))
                        if it is not None and _is_new:
                            QTimer.singleShot(0, lambda: (
                                lw.takeItem(lw.row(it)) if lw.row(it) >= 0 else None
                            ))

                def updateEditorGeometry(self_, editor, option, index):
                    editor.setGeometry(option.rect)

            _editing_active = [False]

            class _TrackedDelegate(_InlineDelegate):
                def createEditor(self_, parent, option, index):
                    editor = super().createEditor(parent, option, index)
                    return editor

                def eventFilter(self_, obj, event):
                    if event.type() == QEvent.KeyPress and event.key() in (Qt.Key_Return, Qt.Key_Enter):
                        editor = self_._current_editor if hasattr(self_, '_current_editor') else None
                        if editor and hasattr(editor, '_confirm_fn'):
                            editor._confirm_fn()
                            return True
                    return super().eventFilter(obj, event)

                def setEditorData(self_, editor, index):
                    self_._current_editor = editor
                    super().setEditorData(editor, index)

                def destroyEditor(self_, editor, index):
                    _editing_active[0] = False
                    super().destroyEditor(editor, index)

            _editing_active = [False]

            class _TrackedDelegate(_InlineDelegate):
                def destroyEditor(self_, editor, index):
                    _editing_active[0] = False
                    super().destroyEditor(editor, index)

            lw.setItemDelegate(_TrackedDelegate(lw))
            lw.viewport().installEventFilter(lw.itemDelegate())

            # патч editItem для отслеживания состояния
            _orig = lw.editItem
            def _patched_edit(it):
                editing_state['item'] = it
                editing_state['original'] = it.text()
                _editing_active[0] = True
                _orig(it)
            lw.editItem = _patched_edit

            lw.itemDoubleClicked.connect(lambda it: lw.editItem(it))

            # контекстное меню
            def _show_menu(pos):
                item = lw.itemAt(pos)
                if not item:
                    return
                lw.setCurrentItem(item)
                menu = QMenu()
                edit_act = QAction(self.translations.get('edit', 'Edit'), lw)
                edit_act.triggered.connect(lambda: lw.editItem(item))
                menu.addAction(edit_act)
                menu.addSeparator()
                del_act = QAction(self.translations.get('delete', 'Delete'), lw)
                del_act.triggered.connect(lambda: _delete_item(item))
                menu.addAction(del_act)
                menu.exec_(lw.mapToGlobal(pos))
            lw.customContextMenuRequested.connect(_show_menu)

            def _delete_item(it):
                lw.takeItem(lw.row(it))

            def _key_press(event):
                if event.key() in (Qt.Key_Return, Qt.Key_Enter):
                    if _editing_active[0]:
                        # редактор активен — передаём Enter ему (QLineEdit.returnPressed)
                        QListWidget.keyPressEvent(lw, event)
                        return
                    sel = lw.selectedItems()
                    if len(sel) == 1:
                        lw.editItem(sel[0])
                elif event.key() == Qt.Key_Delete:
                    for it in lw.selectedItems():
                        _delete_item(it)
                else:
                    QListWidget.keyPressEvent(lw, event)
            lw.keyPressEvent = _key_press


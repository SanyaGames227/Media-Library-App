    def update_item_with_cf(self, item_id, data: dict, cf_values: dict):
        """Обновить item и все custom fields за ОДИН коммит."""
        cursor = self.conn.cursor()
        fields = []
        values = []
        for field in ['title', 'year', 'cover_path', 'watch_date', 'notes', 'rating', 'is_favorite', 'time_spent', 'view_count']:
            if field in data:
                fields.append(f'{field} = ?')
                values.append(data[field])
        if fields:
            values.append(item_id)
            cursor.execute(f'UPDATE items SET {", ".join(fields)} WHERE id = ?', values)
        if 'user_ids' in data:
            cursor.execute('DELETE FROM item_users WHERE item_id = ?', (item_id,))
            for user_id in data['user_ids']:
                cursor.execute('INSERT INTO item_users (item_id, user_id) VALUES (?, ?)', (item_id, user_id))
        for field_id, value in (cf_values or {}).items():
            if value is None or str(value).strip() == '':
                cursor.execute('DELETE FROM custom_field_values WHERE item_id=? AND field_id=?',
                               (item_id, field_id))
            else:
                cursor.execute('''
                    INSERT OR REPLACE INTO custom_field_values (item_id, field_id, value)
                    VALUES (?, ?, ?)
                ''', (item_id, field_id, str(value)))
        self.commit()  # один коммит на всё


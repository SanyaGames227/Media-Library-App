        dlg.setWindowTitle(self.translations.get('custom_range', 'Custom range'))
        dlg.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        lay = QVBoxLayout(dlg)
        lay.setContentsMargins(12, 12, 12, 12)
        lay.setSpacing(8)
        lay.setSizeConstraint(QVBoxLayout.SetFixedSize)
        grid = QGridLayout(); grid.setSpacing(6)
        lbl_from = QLabel(self.translations.get('date_from', 'From'))

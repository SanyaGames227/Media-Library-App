        def _on_icon_pick():
            path, _ = QFileDialog.getOpenFileName(self, '', '', 'Images (*.ico *.png)')
            if not path:
                return
            dest = str(ICONS_DIR / f"icon_{uuid.uuid4().hex}.png")
            try:
                src_img = Image.open(path)
                if src_img.mode not in ('RGBA', 'RGB'):
                    src_img = src_img.convert('RGBA')
                w, h = src_img.size
                if h > 64:
                    target_h = 64
                    target_w = max(1, int(w * target_h / h))
                    while h > target_h * 2:
                        h //= 2; w //= 2
                        src_img = src_img.resize((w, h), Image.LANCZOS)
                    src_img = src_img.resize((target_w, target_h), Image.LANCZOS)
                src_img.save(dest, 'PNG')
                # Откладываем удаление старого временного файла
                old = self._file_icon[0]
                if old and str(ICONS_DIR) in old and old != self._original_icon_file[0]:
                    self._pending_icon_delete.append(old)
                self._file_icon[0] = dest
                self.icon_edit.blockSignals(True)
                self.icon_edit.clear()
                self.icon_edit.blockSignals(False)
                self.icon_edit.setEnabled(False)
                self.icon_edit.setPlaceholderText(self.translations.get('file_selected', 'File selected'))
                self.icon_remove_btn.setFixedSize(26, self._icon_btn_h)
                _refresh_icon_preview()
            except Exception as e:
                _show_dialog_warning(self, str(e), self.translations)


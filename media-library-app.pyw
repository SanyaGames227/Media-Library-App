    def export_users_csv(self, parent_dialog=None):
        """Export all users to a universal CSV (only #USERS section)."""
        parent = parent_dialog or self
        # Empty guard
        cursor = self.db.conn.cursor()
        cursor.execute('SELECT COUNT(*) FROM users')
        if cursor.fetchone()[0] == 0:
            self._show_dialog_warning(parent, self.translations.get('export_users_empty', 'Nothing to export: no users found.'))
            return
        file_path, _ = QFileDialog.getSaveFileName(parent, '', 'users.csv', 'CSV Files (*.csv)')
        if not file_path:
            return
        try:
            lines, _ = self.db.export_csv_build(
                category_id=None,
                include_items=False,
                include_custom_fields=False,
                include_users=True,
            )
            self.db.export_csv_write(file_path, lines)
            self._show_dialog_info(parent, self.translations.get('export_success', 'Exported successfully'))
        except Exception as e:
            self._show_dialog_error(parent, self.translations.get('export_error', 'Export failed: {}').format(e))

    def import_users_csv(self, parent_dialog=None, reload_cb=None):
        """Import users from a universal CSV; shows diff dialog on conflicts."""
        parent = parent_dialog or self
        file_path, _ = QFileDialog.getOpenFileName(parent, '', '', 'CSV Files (*.csv)')
        if not file_path:
            return

        try:
            parsed = self.db.import_csv_parse(file_path)
        except ValueError as e:
            self._show_dialog_error(parent, self.translations.get('import_error', 'Import failed: {}').format(e))
            return

        # Only care about users in this flow
        users_only_diff = {
            'new_fields':     [],
            'changed_fields': [],
            'new_options':    [],
            'changed_options':[],
            'new_users':      self.db.import_csv_diff(parsed).get('new_users', []),
        }

        accepted, diff_dlg = ImportDiffDialog.run(
            users_only_diff, translations=self.translations, parent=parent)
        if not accepted:
            return

        apply_new_users = diff_dlg.selected_new_users if diff_dlg else users_only_diff['new_users']

        try:
            self.db.import_csv_apply(
                parsed=parsed,
                diff=users_only_diff,
                category_id=None,
                apply_new_fields=[],
                apply_changed_fields=set(),
                apply_new_options=[],
                apply_changed_options=set(),
                apply_new_users=apply_new_users,
            )
        except Exception as e:
            self._show_dialog_error(parent, self.translations.get('import_error', 'Import failed: {}').format(e))
            return

        if reload_cb:
            reload_cb()
        self._show_dialog_info(parent, self.translations.get('import_success_users',
                'Imported {} users').format(len(apply_new_users)))

    # ------------------------------------------------------------------
    # Export / Import  — Custom fields
    # ------------------------------------------------------------------

    def export_custom_fields_csv(self, parent_dialog=None):
        """Export all custom fields (+ options + icons) to a ZIP."""
        parent = parent_dialog or self

        _cf_all = list(self.db.get_custom_fields())
        if not _cf_all:
            self._show_dialog_warning(parent, self.translations.get('export_fields_empty', 'Nothing to export: no custom fields found.'))
            return

        _has_file_icons = any(
            (dict(f).get('icon') or '').startswith('file:')
            for f in _cf_all
        )
        icon_mode = 'folder' if _has_file_icons else 'base64'

        file_path, _ = QFileDialog.getSaveFileName(parent, '', 'custom_fields.zip', 'ZIP Files (*.zip)')
        if not file_path:
            return

        try:
            base_name = os.path.splitext(os.path.basename(file_path))[0]
            tmp_dir = tempfile.mkdtemp()
            try:
                csv_path  = os.path.join(tmp_dir, base_name + '.csv')
                icons_dir = os.path.join(tmp_dir, base_name + '_icons') if _has_file_icons else None
                if icons_dir:
                    os.makedirs(icons_dir, exist_ok=True)

                lines, warnings = self.db.export_csv_build(
                    category_id=None,
                    include_items=False,
                    include_custom_fields=True,
                    include_users=False,
                    icon_mode=icon_mode,
                    icons_dir=icons_dir,
                )
                self.db.export_csv_write(csv_path, lines)

                all_files = [csv_path]
                if icons_dir and os.path.isdir(icons_dir):
                    for f in os.listdir(icons_dir):
                        all_files.append(os.path.join(icons_dir, f))

                with zipfile.ZipFile(file_path, 'w', zipfile.ZIP_STORED) as zf:
                    for fpath in all_files:
                        zf.write(fpath, os.path.relpath(fpath, tmp_dir))
            finally:
                shutil.rmtree(tmp_dir, ignore_errors=True)

            if warnings:
                self._show_dialog_warning(parent, self.translations.get('export_warnings',
                        'Export finished with warnings:\n{}').format('\n'.join(warnings[:5])))
            else:
                self._show_dialog_info(parent, self.translations.get('export_success', 'Exported successfully'))
        except Exception as e:
            self._show_dialog_error(parent, self.translations.get('export_error', 'Export failed: {}').format(e))

    def import_custom_fields_csv(self, parent_dialog=None, reload_cb=None):
        """Import custom fields from a ZIP or CSV; shows diff dialog."""
        parent = parent_dialog or self
        file_path, _ = QFileDialog.getOpenFileName(parent, '', '', 'ZIP / CSV Files (*.zip *.csv)')
        if not file_path:
            return

        zip_src   = None
        csv_member = None
        file_text  = None
        icons_dir  = None
        icons_prefix = None

        if file_path.lower().endswith('.zip'):
            try:
                with zipfile.ZipFile(file_path, 'r') as zf:
                    csv_members = [m for m in zf.namelist()
                                   if m.lower().endswith('.csv') and not m.endswith('/')]
                if not csv_members:
                    self._show_dialog_error(parent, self.translations.get(
                        'import_zip_no_csv', 'No CSV file found in ZIP archive.'))
                    return
                if len(csv_members) == 1:
                    csv_member = csv_members[0]
                else:
                    _ci2_dlg = QDialog(parent)
                    _ci2_dlg.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
                    _ci2_dlg.setWindowTitle(self.translations.get('import_zip_choose_csv', 'Choose CSV'))
                    _ci2_dlg.setWindowFlags(_ci2_dlg.windowFlags() & ~Qt.WindowMaximizeButtonHint & ~Qt.WindowContextHelpButtonHint)
                    _ci2_layout = QVBoxLayout()
                    _ci2_layout.setSizeConstraint(QVBoxLayout.SetFixedSize)
                    _ci2_dlg.setLayout(_ci2_layout)
                    _ci2_layout.addWidget(QLabel(self.translations.get('import_zip_multiple_csv', 'Multiple CSV files found:')))
                    _ci2_combo = QComboBox()
                    for _n in csv_members: _ci2_combo.addItem(_n)
                    _ci2_layout.addWidget(_ci2_combo)
                    _ci2_btn_row = QHBoxLayout(); _ci2_btn_row.addStretch()
                    _ci2_ok = QPushButton(self.translations.get('ok', 'OK'))
                    _ci2_cancel = QPushButton(self.translations.get('cancel', 'Cancel'))
                    _ci2_ok.setDefault(True)
                    _ci2_ok.clicked.connect(_ci2_dlg.accept)
                    _ci2_cancel.clicked.connect(_ci2_dlg.reject)
                    _ci2_btn_row.addWidget(_ci2_ok); _ci2_btn_row.addWidget(_ci2_cancel)
                    _ci2_layout.addLayout(_ci2_btn_row)
                    ok = _ci2_dlg.exec_() == QDialog.Accepted
                    if not ok:
                        return
                    csv_member = _ci2_combo.currentText()
                zip_src = file_path
                base_name = os.path.splitext(os.path.basename(csv_member))[0]
                icons_prefix = base_name + '_icons/'
                with zipfile.ZipFile(zip_src, 'r') as zf:
                    raw = zf.read(csv_member)
                    has_icons = any(m.startswith(icons_prefix) for m in zf.namelist())
                try: file_text = raw.decode('utf-8-sig')
                except UnicodeDecodeError: file_text = raw.decode('cp1251')
                if not has_icons:
                    icons_prefix = None
            except zipfile.BadZipFile:
                self._show_dialog_error(parent, self.translations.get(
                    'import_zip_bad', 'Invalid or corrupted ZIP file.'))
                return
            except Exception as e:
                self._show_dialog_error(parent, str(e))
                return
        else:
            base_name = os.path.splitext(os.path.basename(file_path))[0]
            file_dir  = os.path.dirname(file_path)
            _icons_candidate = os.path.join(file_dir, base_name + '_icons')
            icons_dir = _icons_candidate if os.path.isdir(_icons_candidate) else None

        try:
            parsed = self.db.import_csv_parse(file_path, file_text=file_text)
        except ValueError as e:
            self._show_dialog_error(parent, self.translations.get('import_error', 'Import failed: {}').format(e))
            return

        try:
            diff = self.db.import_csv_diff(parsed)
        except Exception as e:
            self._show_dialog_error(parent, self.translations.get('import_error', 'Import failed: {}').format(e))
            return

        # Strip users/items from diff for this flow
        cf_only_diff = {
            'new_fields':     diff.get('new_fields', []),
            'changed_fields': diff.get('changed_fields', []),
            'new_options':    diff.get('new_options', []),
            'changed_options':diff.get('changed_options', []),
            'new_users':      [],
            '_db_fields':     diff.get('_db_fields', []),  # для имён полей в changed_options
        }

        accepted, diff_dlg = ImportDiffDialog.run(
            cf_only_diff, translations=self.translations, parent=parent,
            icons_dir=icons_dir, zip_src=zip_src, icons_prefix=icons_prefix)
        if not accepted:
            return

        if diff_dlg is not None:
            apply_new_fields     = diff_dlg.selected_new_fields
            apply_changed_fields = diff_dlg.apply_changed_fields
            apply_new_options    = diff_dlg.selected_new_options
            apply_changed_options= diff_dlg.apply_changed_options
        else:
            apply_new_fields     = cf_only_diff['new_fields']
            apply_changed_fields = set()
            apply_new_options    = cf_only_diff['new_options']
            apply_changed_options= set()

        try:
            self.db.import_csv_apply(
                parsed=parsed,
                diff=cf_only_diff,
                category_id=None,
                apply_new_fields=apply_new_fields,
                apply_changed_fields=apply_changed_fields,
                apply_new_options=apply_new_options,
                apply_changed_options=apply_changed_options,
                apply_new_users=[],
                icons_dir=icons_dir,
                zip_src=zip_src,
                icons_prefix=icons_prefix,
            )
        except Exception as e:
            self._show_dialog_error(parent, self.translations.get('import_error', 'Import failed: {}').format(e))
            return

        self.db.invalidate_custom_fields_cache()
        if reload_cb:
            reload_cb()
        _fa = len(apply_new_fields)
        _fu = len(apply_changed_fields)
        _fo = len(apply_new_options) if hasattr(apply_new_options, '__len__') else 0
        parts = []
        if _fa:  parts.append(self.translations.get('diff_new_fields_short', 'Added {} fields').format(_fa))
        if _fu:  parts.append(self.translations.get('diff_changed_fields_short', 'Updated {} fields').format(_fu))
        if _fo:  parts.append(self.translations.get('diff_new_options_short', 'Added {} options').format(_fo))
        msg = '\n'.join(parts) if parts else self.translations.get('diff_nothing', 'Nothing to import.')
        self._show_dialog_info(parent, msg)


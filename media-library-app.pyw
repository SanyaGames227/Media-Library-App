                        d_row = QHBoxLayout()
                        d_row.addWidget(d_mode); d_row.addWidget(d_year); d_row.addWidget(d_month); d_row.addWidget(d_date); d_row.addStretch()
                        def _upd_d(idx, dy=d_year, dm=d_month, dd=d_date, dlg_=dlg):

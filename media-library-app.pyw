                 'Jul','Aug','Sep','Oct','Nov','Dec']


class _SLineChart(QWidget):
    """Линейный график с заливкой — для активности по годам."""
    PAD_L = 40; PAD_R = 12; PAD_B = 28; PAD_T = 22

    def __init__(self, parent=None):
        super().__init__(parent)
        self.bars   = []   # (axis_label, value, tip_title, tip_sub)
        self._hover = -1
        self.setMouseTracking(True)
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)

    def set_bars(self, bars):
        self.bars   = bars
        self._hover = -1
        self.update()

    def _chart_rect(self):
        W, H = self.width(), self.height()
        return W, H, max(W - self.PAD_L - self.PAD_R, 1), max(H - self.PAD_T - self.PAD_B, 1)

    def _pt(self, i, value, max_v, cw, ch):
        """Координата точки i на графике."""
        n = len(self.bars)
        if n == 1:
            x = self.PAD_L + cw // 2
        else:
            x = self.PAD_L + int(i * cw / (n - 1))
        y = self.PAD_T + ch - int(ch * value / max_v) if max_v else self.PAD_T + ch
        return x, y

    def _idx_at(self, mx):
        if not self.bars: return -1
        W, H, cw, ch = self._chart_rect()
        n = len(self.bars)
        if n == 1:
            return 0 if abs(mx - (self.PAD_L + cw // 2)) < 20 else -1
        sl = cw / (n - 1) if n > 1 else cw
        idx = round((mx - self.PAD_L) / sl)
        return max(0, min(idx, n - 1))

    def mouseMoveEvent(self, e):
        idx = self._idx_at(e.pos().x())
        if idx != self._hover:
            self._hover = idx
            self.update()

    def leaveEvent(self, e):
        self._hover = -1
        self.update()

    def paintEvent(self, _):
        W, H, cw, ch = self._chart_rect()
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)

        max_v = max((b[1] for b in self.bars), default=0) or 1

        # Горизонтальные сетки
        for s in range(5):
            y   = self.PAD_T + ch - int(ch * s / 4)
            val = int(max_v * s / 4)
            p.setPen(QPen(QColor(255, 255, 255, 15), 1, Qt.DashLine))
            p.drawLine(self.PAD_L, y, W - self.PAD_R, y)
            p.setPen(_S_MUTED)
            p.setFont(QFont('Segoe UI', 8))
            p.drawText(QRect(0, y - 9, self.PAD_L - 4, 18),
                       Qt.AlignRight | Qt.AlignVCenter, str(val))

        if not self.bars:
            p.end()
            return

        n = len(self.bars)

        # Заливка под кривой
        pts = [self._pt(i, b[1], max_v, cw, ch) for i, b in enumerate(self.bars)]
        base_y = self.PAD_T + ch
        fill = QPainterPath()
        fill.moveTo(pts[0][0], base_y)
        for x, y in pts:
            fill.lineTo(x, y)
        fill.lineTo(pts[-1][0], base_y)
        fill.closeSubpath()
        grad = QLinearGradient(0, self.PAD_T, 0, base_y)
        grad.setColorAt(0,   QColor(160, 160, 160, 60))
        grad.setColorAt(1,   QColor(160, 160, 160,  5))
        p.setBrush(QBrush(grad))
        p.setPen(Qt.NoPen)
        p.drawPath(fill)

        # Линия
        line_path = QPainterPath()
        line_path.moveTo(*pts[0])
        for x, y in pts[1:]:
            line_path.lineTo(x, y)
        p.setBrush(Qt.NoBrush)
        p.setPen(QPen(QColor(180, 180, 180), 1.5))
        p.drawPath(line_path)

        # Подписи по X — адаптивное прореживание
        n = len(self.bars)
        sl = cw / (n - 1) if n > 1 else cw
        label_step = 1
        for step in (1, 2, 5, 10, 20, 50):
            if sl * step >= 30:
                label_step = step
                break

        for i, (bar, (x, y)) in enumerate(zip(self.bars, pts)):
            label = bar[0]
            is_hov = (i == self._hover)

            # Точка
            dot_r = 4 if is_hov else 2
            p.setBrush(QBrush(QColor(220, 220, 220) if is_hov else QColor(160, 160, 160)))
            p.setPen(Qt.NoPen)
            p.drawEllipse(QPointF(x, y), dot_r, dot_r)

            # Подпись оси X
            if i % label_step == 0:
                p.setPen(_S_TEXT if is_hov else _S_MUTED)
                p.setFont(QFont('Segoe UI', 8))
                p.drawText(QRect(x - 20, H - self.PAD_B + 4, 40, 16),
                           Qt.AlignCenter, label)

        # Тултип при ховере
        if self._hover >= 0 and self._hover < len(self.bars):
            bar = self.bars[self._hover]
            tip_title = bar[2] if len(bar) > 2 else bar[0]
            tip_sub   = bar[3] if len(bar) > 3 else ''
            x, y = pts[self._hover]
            tw, th = 170, 52
            tx = max(0, min(x - tw // 2, W - tw - 2))
            # Сверху — если влезает; иначе снизу от точки
            ty = y - th - 10 if y - th - 10 >= 0 else y + 14
            p.setBrush(QBrush(_S_BG2))
            p.setPen(QPen(_S_BORDER, 1))
            p.drawRoundedRect(QRectF(tx, ty, tw, th), 5, 5)
            p.setPen(_S_TEXT)
            p.setFont(QFont('Segoe UI', 9, QFont.Bold))
            p.drawText(QRect(tx + 10, ty + 8, tw - 20, 17), Qt.AlignLeft, tip_title)
            p.setPen(_S_MUTED)
            p.setFont(QFont('Segoe UI', 8))
            p.drawText(QRect(tx + 10, ty + 27, tw - 20, 15), Qt.AlignLeft, tip_sub)
        p.end()


class _SBarChart(QWidget):
    PAD_L = 40; PAD_R = 12; PAD_B = 28; PAD_T = 22

    def __init__(self, parent=None):
        super().__init__(parent)
        self.bars   = []   # list of (axis_label, value, tip_title, tip_sub)
        self._hover = -1
        self.setMouseTracking(True)
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)

    def set_bars(self, bars):
        self.bars   = bars
        self._hover = -1
        self.update()

    def _chart_rect(self):
        W, H = self.width(), self.height()
        return W, H, max(W - self.PAD_L - self.PAD_R, 1), max(H - self.PAD_T - self.PAD_B, 1)

    def _bar_rect(self, i, value, max_v, cw, ch):
        n  = len(self.bars)
        sl = cw / n
        bx = int(self.PAD_L + i * sl + sl * 0.18)
        bw = max(4, int(sl * 0.64))
        bh = int(ch * value / max_v) if max_v else 0
        return bx, self.PAD_T + ch - bh, bw, bh

    def _idx_at(self, x):
        if not self.bars: return -1
        W, H, cw, ch = self._chart_rect()
        sl = cw / len(self.bars)
        for i in range(len(self.bars)):
            bx = self.PAD_L + i * sl + sl * 0.18
            if bx <= x <= bx + max(4, sl * 0.64):
                return i
        return -1

    def mouseMoveEvent(self, e):
        idx = self._idx_at(e.pos().x())
        if idx != self._hover:
            self._hover = idx
            self.update()

    def leaveEvent(self, e):
        self._hover = -1
        self.update()

    def paintEvent(self, _):
        if not self.bars:
            p = QPainter(self)
            p.setRenderHint(QPainter.Antialiasing)
            W, H = self.width(), self.height()
            cw = W - self.PAD_L - self.PAD_R
            ch = max(H - self.PAD_T - self.PAD_B, 1)
            for s in range(5):
                y = self.PAD_T + ch - int(ch * s / 4)
                p.setPen(QPen(QColor(255, 255, 255, 15), 1, Qt.DashLine))
                p.drawLine(self.PAD_L, y, W - self.PAD_R, y)
                p.setPen(_S_MUTED)
                p.setFont(QFont('Segoe UI', 8))
                p.drawText(QRect(0, y - 9, self.PAD_L - 4, 18),
                           Qt.AlignRight | Qt.AlignVCenter, '0')
            p.end()
            return
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        W, H, cw, ch = self._chart_rect()
        max_v = max(b[1] for b in self.bars) or 1

        for s in range(5):
            y   = self.PAD_T + ch - int(ch * s / 4)
            val = int(max_v * s / 4)
            p.setPen(QPen(QColor(255, 255, 255, 15), 1, Qt.DashLine))
            p.drawLine(self.PAD_L, y, W - self.PAD_R, y)
            p.setPen(_S_MUTED)
            p.setFont(QFont('Segoe UI', 8))
            p.drawText(QRect(0, y - 9, self.PAD_L - 4, 18),
                       Qt.AlignRight | Qt.AlignVCenter, str(val))

        for i, bar in enumerate(self.bars):
            label, value = bar[0], bar[1]
            bx, by, bw, bh = self._bar_rect(i, value, max_v, cw, ch)
            is_hover = (i == self._hover)
            is_max   = (value == max_v)
            if is_hover:      color = QColor(200, 200, 200)
            elif is_max:      color = QColor(160, 160, 160, 200)
            else:             color = _S_BG3
            p.setBrush(QBrush(color))
            p.setPen(Qt.NoPen if is_hover else QPen(_S_BORDER, 1))
            r    = min(3, bw // 3)
            bar_path = QPainterPath()
            bar_path.addRoundedRect(QRectF(bx, by, bw, bh), r, r)
            bar_path.addRect(QRectF(bx, by + bh - r, bw, r))
            p.drawPath(bar_path)
            p.setPen(_S_TEXT if is_hover else _S_MUTED)
            p.setFont(QFont('Segoe UI', 8))
            p.drawText(QRect(bx - 4, H - self.PAD_B + 4, bw + 8, 16),
                       Qt.AlignCenter, label)

        if self._hover >= 0:
            bar = self.bars[self._hover]
            label, val = bar[0], bar[1]
            tip_title = bar[2] if len(bar) > 2 else label
            tip_sub   = bar[3] if len(bar) > 3 else (bar[2] if len(bar) > 2 else '')
            bx, by, bw, bh = self._bar_rect(self._hover, val, max_v, cw, ch)
            tw, th = 170, 52
            tx = max(0, min(bx + bw // 2 - tw // 2, W - tw - 2))
            ty = by - th - 6 if by - th - 6 >= 0 else by + bh + 6
            p.setBrush(QBrush(_S_BG2))
            p.setPen(QPen(_S_BORDER, 1))
            p.drawRoundedRect(QRectF(tx, ty, tw, th), 5, 5)
            p.setPen(_S_TEXT)
            p.setFont(QFont('Segoe UI', 9, QFont.Bold))
            p.drawText(QRect(tx + 10, ty + 8, tw - 20, 17), Qt.AlignLeft, tip_title)
            p.setPen(_S_MUTED)
            p.setFont(QFont('Segoe UI', 8))
            p.drawText(QRect(tx + 10, ty + 27, tw - 20, 15), Qt.AlignLeft, tip_sub)
        p.end()


class _SStatCard(QWidget):
    def __init__(self, label, parent=None):
        super().__init__(parent)
        self._label = label
        self._value = '-'
        self._sub   = ''
        self.setMinimumHeight(112)
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)

    def set_data(self, value, sub=''):
        self._value = str(value)
        self._sub   = sub
        self.update()

    def paintEvent(self, _):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        PAD  = 12
        p.setBrush(QBrush(_S_BG2))
        p.setPen(QPen(_S_BORDER, 1))
        p.drawRoundedRect(QRectF(0.5, 0.5, W - 1, H - 1), 6, 6)
        p.setFont(QFont('Segoe UI', 8))
        p.setPen(_S_MUTED)
        p.drawText(QRect(PAD, 10, W - PAD * 2, 16), Qt.AlignLeft, self._label)
        avail_w = W - PAD * 2
        font_sz = 20
        while font_sz >= 11:
            fm = QFontMetrics(QFont('Segoe UI', font_sz, QFont.Bold))
            if fm.horizontalAdvance(self._value) <= avail_w:
                break
            font_sz -= 1
        p.setFont(QFont('Segoe UI', font_sz, QFont.Bold))
        p.setPen(_S_TEXT)
        p.drawText(QRect(PAD, 26, avail_w, 30), Qt.AlignLeft | Qt.AlignVCenter, self._value)
        if self._sub:
            p.setFont(QFont('Segoe UI', 8))
            p.setPen(_S_MUTED)
            p.drawText(QRect(PAD, H - 22, avail_w, 14), Qt.AlignLeft, self._sub)
        p.end()


class _SUsersWidget(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self._people = []   # list of (name, count, pct)
        self.setMinimumHeight(112)
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)

    def set_people(self, people):
        """people: list of (name, count) sorted desc, top-4"""
        total = sum(v for _, v in people)
        self._people = [
            (name, val, round(val / total * 100) if total else 0)
            for name, val in people[:4]
        ]
        self.update()

    def paintEvent(self, _):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        p.setBrush(QBrush(_S_BG2))
        p.setPen(QPen(_S_BORDER, 1))
        p.drawRoundedRect(QRectF(0.5, 0.5, W - 1, H - 1), 6, 6)
        if not self._people:
            p.setPen(_S_MUTED)
            p.setFont(QFont('Segoe UI', 14))
            p.drawText(QRect(0, 0, W, H), Qt.AlignCenter, '-')
            p.end()
            return
        n     = len(self._people)
        PAD   = 12
        AV_S  = 18
        ROW_H = 23
        PAD_V = 10
        y0    = PAD_V
        for i, (name, val, pct) in enumerate(self._people):
            cy = y0 + i * ROW_H + ROW_H // 2
            p.setBrush(QBrush(_S_BG3))
            p.setPen(Qt.NoPen)
            p.drawRoundedRect(QRectF(PAD, cy - AV_S // 2, AV_S, AV_S), 4, 4)
            p.setPen(_S_TEXT)
            p.setFont(QFont('Segoe UI', 7, QFont.Bold))
            p.drawText(QRect(PAD, cy - AV_S // 2, AV_S, AV_S),
                       Qt.AlignCenter, name[0].upper() if name else '?')
            tx = PAD + AV_S + 8
            p.setPen(_S_TEXT)
            p.setFont(QFont('Segoe UI', 8, QFont.Bold))
            p.drawText(QRect(tx, cy - 8, W - tx - 60, 16),
                       Qt.AlignLeft | Qt.AlignVCenter, name)
            pct_str   = f'{pct}%'
            count_str = f'({val})'
            p.setFont(QFont('Segoe UI', 8, QFont.Bold))
            fm      = QFontMetrics(p.font())
            pct_w   = fm.horizontalAdvance(pct_str)
            p.setFont(QFont('Segoe UI', 8))
            fm2     = QFontMetrics(p.font())
            count_w = fm2.horizontalAdvance(count_str)
            total_w = pct_w + 5 + count_w
            p.setFont(QFont('Segoe UI', 8, QFont.Bold))
            p.setPen(_S_TEXT)
            p.drawText(QRect(W - PAD - total_w, cy - 8, pct_w, 16),
                       Qt.AlignLeft | Qt.AlignVCenter, pct_str)
            p.setFont(QFont('Segoe UI', 8))
            p.setPen(_S_MUTED)
            p.drawText(QRect(W - PAD - count_w, cy - 8, count_w, 16),
                       Qt.AlignLeft | Qt.AlignVCenter, count_str)
        p.end()


def _build_date_filter_menu(menu, years, on_select, translations):
    """Общая функция построения меню фильтра по дате.
    on_select(date_from, date_to, label) — коллбэк при выборе.
    """
    menu.clear()

    all_action = QAction(translations.get('all_time', 'All time'), menu)
    all_action.triggered.connect(lambda: on_select(None, None, None))
    menu.addAction(all_action)
    menu.addSeparator()

    if len(years) > 20:
        decades = defaultdict(list)
        for yr in years:
            decades[(int(yr) // 10) * 10].append(yr)
        for decade in sorted(decades.keys(), reverse=True):
            submenu = QMenu(f'{decade}...', menu)
            for yr in decades[decade]:
                a = QAction(str(yr), submenu)
                a.triggered.connect(
                    (lambda y: lambda: on_select(f'{y}-01-01', f'{y}-12-31', str(y)))(yr)
                )
                submenu.addAction(a)
            menu.addMenu(submenu)
    else:
        for yr in years:
            a = QAction(str(yr), menu)
            a.triggered.connect(
                (lambda y: lambda: on_select(f'{y}-01-01', f'{y}-12-31', str(y)))(yr)
            )
            menu.addAction(a)

    if years:
        menu.addSeparator()

    # Произвольный диапазон
    def _show_custom(parent_widget):
        dlg = QDialog(parent_widget)
        dlg.setWindowTitle(translations.get('custom_range', 'Custom range'))
        dlg.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        lay = QVBoxLayout(dlg)
        lay.setContentsMargins(12, 12, 12, 12)
        lay.setSpacing(8)
        lay.setSizeConstraint(QVBoxLayout.SetFixedSize)
        grid = QGridLayout(); grid.setSpacing(6)
        lbl_from = QLabel(translations.get('date_from', 'From'))
        de_from  = QDateEdit(); de_from.setCalendarPopup(True)
        de_from.setDisplayFormat('yyyy-MM-dd')
        de_from.setDate(QDate.currentDate().addYears(-1))
        lbl_to = QLabel(translations.get('date_to', 'To'))
        de_to  = QDateEdit(); de_to.setCalendarPopup(True)
        de_to.setDisplayFormat('yyyy-MM-dd')
        de_to.setDate(QDate.currentDate())
        grid.addWidget(lbl_from, 0, 0); grid.addWidget(de_from, 0, 1)
        grid.addWidget(lbl_to,   1, 0); grid.addWidget(de_to,   1, 1)
        lay.addLayout(grid)
        btn_row = QHBoxLayout(); btn_row.addStretch()
        ok_btn = QPushButton(translations.get('ok', 'OK'))
        ok_btn.setDefault(True); ok_btn.clicked.connect(dlg.accept)
        cancel_btn = QPushButton(translations.get('cancel', 'Cancel'))
        cancel_btn.clicked.connect(dlg.reject)
        btn_row.addWidget(ok_btn); btn_row.addWidget(cancel_btn)
        lay.addLayout(btn_row)
        if dlg.exec_() == QDialog.Accepted:
            d_from = de_from.date().toString('yyyy-MM-dd')
            d_to   = de_to.date().toString('yyyy-MM-dd')
            label  = (f'{de_from.date().toString("dd.MM.yyyy")} – '
                      f'{de_to.date().toString("dd.MM.yyyy")}')
            on_select(d_from, d_to, label)

    custom_action = QAction(translations.get('custom_range', 'Custom range'), menu)
    custom_action.triggered.connect(lambda: _show_custom(menu.parentWidget()))
    menu.addAction(custom_action)


def _extract_button_row(layout):
    """Извлекает последний элемент layout если это QHBoxLayout с кнопками (OK/Cancel и т.д.).
    Возвращает (item, is_layout) или (None, False) если кнопок нет."""
    count = layout.count()
    if count == 0:
        return None, False
    last = layout.itemAt(count - 1)
    if last is None:
        return None, False
    if last.layout() is not None:
        sub = last.layout()
        btns = [sub.itemAt(i).widget() for i in range(sub.count())
                if sub.itemAt(i) and sub.itemAt(i).widget()
                and isinstance(sub.itemAt(i).widget(), QPushButton)]
        if btns:
            layout.takeAt(count - 1)
            return sub, True
    if last.widget() is not None:
        w = last.widget()
        from PyQt5.QtWidgets import QDialogButtonBox
        if isinstance(w, (QDialogButtonBox, QPushButton)):
            layout.takeAt(count - 1)
            return w, False
    return None, False


class _AdaptiveHeightMixin:
    """
    Универсальный миксин для QDialog: если высота окна не помещается на экране,
    оборачивает содержимое в QScrollArea — без изменения визуала на больших экранах.

    Применяется автоматически при show() / exec_() через _apply_scroll_if_needed().
    Безопасен для повторных вызовов (идемпотентен).
    """

    # Отступ от края экрана (в логических пикселях), оставляемый сверху+снизу
    _SCREEN_MARGIN = 60

    def _apply_scroll_if_needed(self):
        """Оборачивает layout диалога в QScrollArea если не влезает по высоте."""
        # Уже обёрнут — ничего не делаем
        if getattr(self, '_scroll_applied', False):
            return

        screen = (
            self.screen() if hasattr(self, 'screen') and callable(self.screen)
            else QApplication.primaryScreen()
        )
        if screen is None:
            return
        avail_h = screen.availableGeometry().height()
        max_h   = avail_h - self._SCREEN_MARGIN

        # Получаем реальную высоту содержимого.
        # _content_hint_h сохраняется в _lock_size до того как setWindowFlags мог сбросить размеры.
        # После setFixedSize() sizeHint() может вернуть зафиксированную высоту,
        # поэтому берём максимум из sizeHint и текущей геометрии.
        hint_h = getattr(self, '_content_hint_h', None)
        if hint_h is None:
            hint_h = max(self.sizeHint().height(), self.height())

        # Дополнительно: если есть layout, спрашиваем его minimumSize
        old_layout = self.layout()
        if old_layout is not None:
            layout_hint = old_layout.minimumSize().height()
            hint_h = max(hint_h, layout_hint)

        if hint_h <= max_h:
            return  # влезает — скролл не нужен

        if old_layout is None:
            return

        # Сохраняем текущую ширину до снятия ограничений
        cur_w = self.width()

        # Снимаем ограничения setFixedSize/setFixedHeight (они блокируют resize)
        self.setMinimumHeight(0)
        self.setMaximumHeight(16777215)

        # Снимаем SetFixedSize constraint на layout если есть
        from PyQt5.QtWidgets import QLayout
        old_layout.setSizeConstraint(QLayout.SetDefaultConstraint)

        # Извлекаем строку кнопок (OK/Cancel и т.д.) — она должна быть всегда видна
        btn_item, btn_is_layout = _extract_button_row(old_layout)

        # Переносим все виджеты/элементы в контейнер
        container = QWidget()
        container.setLayout(old_layout)

        scroll = QScrollArea()
        scroll.setWidget(container)
        scroll.setWidgetResizable(True)
        scroll.setFrameShape(QFrame.NoFrame)
        scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        scroll.setVerticalScrollBarPolicy(Qt.ScrollBarAsNeeded)

        # Минимальная ширина скролл-области = ширина контейнера + полоса прокрутки
        sb_w = scroll.verticalScrollBar().sizeHint().width() + 4
        cont_w = max(container.sizeHint().width(), cur_w)
        scroll.setMinimumWidth(cont_w)

        new_layout = QVBoxLayout(self)
        new_layout.setContentsMargins(0, 0, 0, 0)
        new_layout.setSpacing(0)
        new_layout.addWidget(scroll)
        if btn_item is not None:
            new_layout.addSpacing(6)
            if btn_is_layout:
                new_layout.addLayout(btn_item)
            else:
                new_layout.addWidget(btn_item)
            new_layout.addSpacing(6)

        # Ограничиваем высоту окна доступным пространством экрана
        self.setMaximumHeight(max_h)
        self.setMinimumHeight(0)
        new_w = max(cur_w, cont_w + sb_w)
        self.resize(new_w, min(hint_h, max_h))

        self._scroll_applied = True


class StatsWindow(_AdaptiveHeightMixin, QDialog):
    """Окно статистики для одной категории."""

    def __init__(self, db, category_id, translations=None, parent=None):
        super().__init__(parent)
        self._db          = db
        self._category_id = category_id
        self._tr          = translations or {}
        self._period      = 'all'   # 'all' | int(year)

        # Название категории для заголовка
        cur = db.conn.cursor()
        row = cur.execute('SELECT name FROM categories WHERE id=?', (category_id,)).fetchone()
        cat_name = row['name'] if row else ''

        self.setWindowTitle(self._tr.get('stats_window_title', 'Statistics') +
                            (f' — {cat_name}' if cat_name else ''))
        self.resize(900, 500)
        self.setMinimumWidth(900)
        self.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)

        pal = self.palette()
        pal.setColor(QPalette.Window, _S_BG)
        self.setPalette(pal)
        self.setAutoFillBackground(True)
        self.setStyleSheet('QDialog { border: 1px solid #666666; }')

        self._build_ui()
        self._refresh()

    def showEvent(self, event):
        super().showEvent(event)
        self._apply_scroll_if_needed()

    # ── UI ────────────────────────────────────────────────────────────────────
    def _build_ui(self):
        root = QVBoxLayout(self)
        root.setContentsMargins(16, 14, 16, 14)
        root.setSpacing(10)

        # Кнопка фильтра по дате справа — такая же как в основном окне
        period_row = QHBoxLayout()
        self._filter_btn = QToolButton()
        self._filter_btn.setText(self._tr.get('all_time', 'All time'))
        self._filter_btn.setPopupMode(QToolButton.InstantPopup)
        self._filter_btn.setToolButtonStyle(Qt.ToolButtonTextOnly)
        self._filter_btn.setStyleSheet("QToolButton { min-height: 16px; } QToolButton::menu-indicator { width: 0; height: 0; }")
        self._filter_menu = QMenu(self._filter_btn)
        self._filter_btn.setMenu(self._filter_menu)
        self._filter_menu.aboutToShow.connect(self._populate_filter_menu)
        self._date_from = None
        self._date_to   = None
        period_row.addStretch()
        period_row.addWidget(self._filter_btn)
        root.addLayout(period_row)

        # Карточки + пользователи
        cards_row = QHBoxLayout()
        cards_row.setSpacing(8)
        self._card_total   = _SStatCard(self._tr.get('stats_total',   'Total'))
        self._card_rating  = _SStatCard(self._tr.get('stats_rating',  'Avg. rating'))
        self._card_rewatch = _SStatCard(self._tr.get('stats_rewatch', 'Rewatched'))
        self._users_widget = _SUsersWidget()
        for w in (self._card_total, self._card_rating,
                  self._card_rewatch, self._users_widget):
            cards_row.addWidget(w)
        root.addLayout(cards_row)

        # Графики
        charts_row = QHBoxLayout()
        charts_row.setSpacing(14)

        lc = QVBoxLayout(); lc.setSpacing(5)
        lbl_d = QLabel(self._tr.get('stats_release_years', 'Release years'))
        lbl_d.setStyleSheet('color:rgba(160,160,160,0.65);font-size:10px;letter-spacing:1px;')
        lc.addWidget(lbl_d)
        self._chart_years = _SLineChart()
        lc.addWidget(self._chart_years)

        rc = QVBoxLayout(); rc.setSpacing(5)
        self._lbl_activity = QLabel(self._tr.get('stats_activity', 'Activity by month'))
        self._lbl_activity.setStyleSheet('color:rgba(160,160,160,0.65);font-size:10px;letter-spacing:1px;')
        rc.addWidget(self._lbl_activity)
        self._chart_months    = _SLineChart()
        self._chart_activity_years = _SLineChart()
        rc.addWidget(self._chart_months)
        rc.addWidget(self._chart_activity_years)
        self._chart_activity_years.hide()

        charts_row.addLayout(lc, 3)
        charts_row.addLayout(rc, 2)
        root.addLayout(charts_row, 1)

    # ── данные ────────────────────────────────────────────────────────────────
    def _populate_filter_menu(self):
        years = self._db.get_watch_years(self._category_id)
        _build_date_filter_menu(
            self._filter_menu, years,
            on_select=self._on_filter,
            translations=self._tr
        )

    def _on_filter(self, date_from, date_to, label):
        self._date_from = date_from
        self._date_to   = date_to
        lbl = label if date_from else self._tr.get('all_time', 'All time')
        self._filter_btn.setText(lbl)
        self._refresh()

    def _refresh(self):
        data = self._load_stats()

        sub = ''
        if self._date_from and self._date_to:
            sub = self._filter_btn.text()
        elif self._date_from:
            sub = self._date_from[:4]

        self._card_total.set_data(data['total'], sub)
        avg = f"{data['avg_rating']:.1f}" if data['avg_rating'] else '-'
        self._card_rating.set_data(avg, sub)
        self._card_rewatch.set_data(data['rewatch'], sub)
        self._users_widget.set_people(data['users'])

        # График годов выпуска — линейный
        self._chart_years.set_bars([
            (str(yr), cnt, str(yr),
             f"{cnt} {self._tr.get('stats_items', 'items')}  ·  ★ {rat:.1f}" if rat else
             f"{cnt} {self._tr.get('stats_items', 'items')}")
            for yr, cnt, rat in data['release_years']
        ])

        # График месяцев или годов активности
        # Режим: если нет фильтра или диапазон > 1 года — по годам, иначе по месяцам
        use_years_activity = self._activity_mode_is_years()
        if use_years_activity:
            self._lbl_activity.setText(self._tr.get('stats_activity_years', 'Activity by year'))
            self._chart_months.hide()
            self._chart_activity_years.show()
            self._chart_activity_years.set_bars([
                (str(yr), cnt, str(yr),
                 f"{cnt} {self._tr.get('stats_items', 'items')}")
                for yr, cnt in data['activity_years']
            ])
        else:
            self._lbl_activity.setText(self._tr.get('stats_activity', 'Activity by month'))
            self._chart_activity_years.hide()
            self._chart_months.show()
            months_full  = [self._tr.get(f'month_{i+1}', _MONTHS_FULL[i])  for i in range(12)]
            months_short = [self._tr.get(f'month_short_{i+1}', _MONTHS_SHORT[i]) for i in range(12)]
            self._chart_months.set_bars([
                (months_short[i], data['months'][i],
                 months_full[i],
                 f"{data['months'][i]} {self._tr.get('stats_items', 'items')}")
                for i in range(12)
            ])

    def _activity_mode_is_years(self):
        """True → показывать активность по годам; False → по месяцам."""
        d_from = self._date_from
        d_to   = self._date_to
        # Нет фильтра — «За все время» → по годам
        if not d_from and not d_to:
            return True
        # Есть явный диапазон — сравниваем годы
        if d_from and d_to:
            yr_from = int(d_from[:4]) if len(d_from) >= 4 else None
            yr_to   = int(d_to[:4])   if len(d_to)   >= 4 else None
            if yr_from is not None and yr_to is not None and yr_to > yr_from:
                return True  # больше одного года → по годам
            return False     # один и тот же год (или часть года) → по месяцам
        # Только from или только to (одиночный год) → по месяцам
        return False

    def _load_stats(self):
        """Один батч-запрос к БД, возвращает всё нужное."""
        cur = self._db.conn.cursor()
        cid = self._category_id

        # Условие фильтра по дате просмотра
        if self._date_from and self._date_to:
            year_cond  = "AND substr(watch_date,1,length(?)) >= substr(?,1,length(watch_date)) AND substr(watch_date,1,length(?)) <= substr(?,1,length(watch_date))"
            year_param = [self._date_from, self._date_from, self._date_to, self._date_to]
        elif self._date_from:
            year_cond  = "AND substr(watch_date,1,length(?)) >= substr(?,1,length(watch_date))"
            year_param = [self._date_from, self._date_from]
        elif self._date_to:
            year_cond  = "AND substr(watch_date,1,length(?)) <= substr(?,1,length(watch_date))"
            year_param = [self._date_to, self._date_to]
        else:
            year_cond  = ''
            year_param = []

        base_cond = f"category_id = ? {year_cond}"
        params    = [cid] + year_param

        # ── 1. Общие агрегаты одним запросом ─────────────────────────────────
        row = cur.execute(f"""
            SELECT
                COUNT(*)                                        AS total,
                AVG(CASE WHEN rating > 0 THEN rating END)       AS avg_rating,
                SUM(CASE WHEN view_count > 1
                         THEN view_count - 1 ELSE 0 END)        AS rewatch
            FROM items
            WHERE {base_cond}
        """, params).fetchone()

        total      = row['total']      or 0
        avg_rating = row['avg_rating'] or 0.0
        rewatch    = row['rewatch']    or 0

        # ── 2. Активность по месяцам ──────────────────────────────────────────
        months_rows = cur.execute(f"""
            SELECT CAST(substr(watch_date,6,2) AS INTEGER) AS mo, COUNT(*) AS cnt
            FROM items
            WHERE {base_cond}
              AND watch_date IS NOT NULL AND length(watch_date) >= 7
            GROUP BY mo
        """, params).fetchall()
        months = [0] * 12
        for r in months_rows:
            if r['mo'] and 1 <= r['mo'] <= 12:
                months[r['mo'] - 1] = r['cnt']

        # ── 2б. Активность по годам (для режима «За все время» / мульти-год) ─
        activity_years_rows = cur.execute(f"""
            SELECT CAST(substr(watch_date,1,4) AS INTEGER) AS yr, COUNT(*) AS cnt
            FROM items
            WHERE {base_cond}
              AND watch_date IS NOT NULL AND length(watch_date) >= 4
            GROUP BY yr
            ORDER BY yr ASC
        """, params).fetchall()
        activity_years = [(r['yr'], r['cnt']) for r in activity_years_rows if r['yr']]

        # ── 3. Годы/десятилетия выпуска (всегда по всей категории) ──────────
        # Если уникальных годов > 20 — группируем по десятилетиям, иначе по годам.
        # Оба запроса учитывают активный фильтр по дате просмотра.
        release_rows = cur.execute(f"""
            SELECT year AS period, COUNT(*) AS cnt,
                   AVG(CASE WHEN rating > 0 THEN rating END) AS avg_r
            FROM items
            WHERE category_id = ? {year_cond}
              AND year IS NOT NULL AND year != '' AND year != 0
            GROUP BY period
            ORDER BY period ASC
        """, [cid] + year_param).fetchall()

        release_years = [(r['period'], r['cnt'], r['avg_r'] or 0.0)
                         for r in release_rows]


        # ── 4. Топ пользователей + "себя" (айтемы без item_users) ───────────
        users_rows = cur.execute(f"""
            SELECT u.name, COUNT(DISTINCT iu.item_id) AS cnt
            FROM item_users iu
            JOIN users u ON u.id = iu.user_id
            JOIN items i ON i.id = iu.item_id
            WHERE i.category_id = ? {year_cond}
            GROUP BY u.id
            ORDER BY cnt DESC
            LIMIT 4
        """, [cid] + year_param).fetchall()
        users = [(r['name'], r['cnt']) for r in users_rows]

        # Айтемы без пользователей — "сам" / solo
        solo_row = cur.execute(f"""
            SELECT COUNT(*) AS cnt
            FROM items i
            WHERE i.category_id = ? {year_cond}
              AND NOT EXISTS (
                  SELECT 1 FROM item_users iu WHERE iu.item_id = i.id
              )
        """, [cid] + year_param).fetchone()
        solo_cnt = solo_row['cnt'] if solo_row else 0
        if solo_cnt > 0:
            solo_label = self._tr.get('stats_solo', 'Solo')
            users = [(solo_label, solo_cnt)] + users
            # Обрезаем до 4 после добавления себя
            users = users[:4]

        return {
            'total':          total,
            'avg_rating':     avg_rating,
            'rewatch':        rewatch,
            'months':         months,
            'activity_years': activity_years,
            'release_years':  release_years,
            'users':          users,
        }


# ─────────────────────────────────────────────────────────────────────────────
#  TierButton
# ─────────────────────────────────────────────────────────────────────────────
class TierButton(QPushButton):
    """Кнопка переключения в режим TierList — рисует иконку через QPainter."""
    def __init__(self, active=False, parent=None):
        super().__init__(parent)
        self._active = active
        self.setFixedSize(28, 28)
        self.setCheckable(True)
        self.setChecked(active)

    def setActive(self, active):
        self._active = active
        self.setChecked(active)
        self.update()

    def paintEvent(self, event):
        super().paintEvent(event)
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        w, h = self.width(), self.height()
        color = QColor('#ffffff') if (self.underMouse() or self._active) else QColor(220, 220, 220)
        p.setPen(Qt.NoPen)
        p.setBrush(color)
        # Draw 3 horizontal tier bars
        bar_w, bar_h, gap = 14, 3, 2
        total_h = 3 * bar_h + 2 * gap
        x0 = (w - bar_w) // 2
        y0 = (h - total_h) // 2
        label_w = 3
        for i in range(3):
            y = y0 + i * (bar_h + gap)
            # label block
            tier_colors = [QColor('#FF7F7F'), QColor('#FFDF7F'), QColor('#BFFF7F')]
            p.setBrush(tier_colors[i])
            p.drawRect(x0, y, label_w, bar_h)
            # content block
            p.setBrush(color)
            p.drawRect(x0 + label_w + 1, y, bar_w - label_w - 1, bar_h)
        p.end()



# ─────────────────────────────────────────────────────────────────────────────
#  TierListSetsDialog
# ─────────────────────────────────────────────────────────────────────────────
class TierListSetsDialog(_AdaptiveHeightMixin, QDialog):
    """Диалог управления именованными списками тирлиста (кастомные сеты)."""

    # UserRole mapping:
    #   Qt.UserRole      → int set_id  (None для «Основного» и несохранённых новых)
    #   Qt.UserRole + 1  → bool is_main  (True только для «Основного»)
    #   Qt.UserRole + 2  → bool is_new   (True для только что добавленного, до сохранения)

    def __init__(self, db, category_id, translations=None, parent=None,
                 on_change=None, main_window=None):
        super().__init__(parent)
        self.db            = db
        self._category_id  = category_id
        self.translations  = translations or {}
        self._on_change    = on_change
        self._main_window  = main_window
        self._editing      = {'item': None, 'original': '', '_discarding': False}
        self.setWindowTitle(self.translations.get('tier_sets_title', 'Tier Lists'))
        self.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        self.setFixedWidth(340)
        self._init_ui()

    # ── helpers ──────────────────────────────────────────────────────────────

    def _make_icon(self, draw_fn):
        pix = _make_hires_pixmap(14)
        p = QPainter(pix)
        p.setRenderHint(QPainter.Antialiasing)
        pen = QPen(QColor(255, 255, 255))
        pen.setWidthF(1.5)
        pen.setCapStyle(Qt.RoundCap)
        p.setPen(pen)
        draw_fn(p)
        p.end()
        return QIcon(pix)

    def _is_main(self, it):
        return bool(it.data(Qt.UserRole + 1))

    def _is_new(self, it):
        return bool(it.data(Qt.UserRole + 2))

    # ── UI ───────────────────────────────────────────────────────────────────

    def _init_ui(self):
        lay = QVBoxLayout(self)
        lay.setContentsMargins(12, 12, 12, 12)
        lay.setSpacing(8)

        self._list = QListWidget()
        self._list.setDragDropMode(QListWidget.InternalMove)
        self._list.setFixedHeight(200)
        self._list.setMouseTracking(True)
        self._list.viewport().setMouseTracking(True)
        self._list.setContextMenuPolicy(Qt.CustomContextMenu)
        self._list.customContextMenuRequested.connect(self._show_context_menu)
        self._list.itemDoubleClicked.connect(self._on_double_click)
        self._list.setSelectionMode(QListWidget.ExtendedSelection)

        # ── Блокируем перетаскивание «Основного» и сброс перед row 0 ─────────
        _orig_drop = self._list.dropEvent
        def _guarded_drop(event):
            # Запрещаем перетаскивать «Основной» (на случай если когда-то вернётся)
            for it in self._list.selectedItems():
                if self._is_main(it):
                    event.ignore()
                    return
            # Блокируем drop-на-себя: если перетащили ровно на тот же элемент
            # без реального смещения — Qt при InternalMove визуально дублирует его.
            target_index = self._list.indexAt(event.pos())
            drop_row = target_index.row()
            sel_rows = {self._list.row(it) for it in self._list.selectedItems()}
            if target_index.isValid() and drop_row >= 0:
                rect = self._list.visualRect(target_index)
                in_bottom_half = event.pos().y() > rect.top() + rect.height() // 2
                insert_row = drop_row + (1 if in_bottom_half else 0)
                sel_sorted = sorted(sel_rows)
                if sel_sorted:
                    would_be_noop = (
                        insert_row in sel_rows
                        and (insert_row - 1) in sel_rows
                    )
                    if would_be_noop:
                        event.ignore()
                        return
            elif not target_index.isValid():
                # Drop ниже последнего элемента — нет смысла если последний уже выделен
                last_row = self._list.count() - 1
                if sel_rows and max(sel_rows) == last_row and len(sel_rows) == 1:
                    event.ignore()
                    return
            _orig_drop(event)
            QTimer.singleShot(0, self._on_reorder)
        self._list.dropEvent = _guarded_drop

        # ── custom drag pixmap ────────────────────────────────────────────────
        def _set_start_drag(supported_actions):
            items = self._list.selectedItems()
            if not items or any(self._is_main(it) for it in items):
                return
            label = items[0].text() if len(items) == 1 else \
                f"{len(items)} {self.translations.get('items', 'items')}"
            font = self._list.font()
            font.setPointSize(10); font.setBold(True)
            fm   = QFontMetrics(font)
            px, py = 14, 6
            rect = fm.boundingRect(label)
            w, h = max(rect.width() + px * 2, 60), rect.height() + py * 2
            pix  = QPixmap(w, h); pix.fill(Qt.transparent)
            painter = QPainter(pix)
            painter.setRenderHint(QPainter.Antialiasing)
            path = QPainterPath()
            path.addRoundedRect(QRectF(0, 0, w, h), 8, 8)
            painter.fillPath(path, QColor(70, 70, 70))
            painter.setFont(font); painter.setPen(QColor(255, 255, 255))
            painter.drawText(pix.rect().adjusted(px, 0, -px, 0),
                             Qt.AlignVCenter | Qt.AlignLeft, label)
            painter.end()
            mime = self._list.model().mimeData(self._list.selectedIndexes())
            drag = QDrag(self._list)
            drag.setMimeData(mime); drag.setPixmap(pix)
            drag.setHotSpot(QPoint(-10, -10))
            drag.exec_(Qt.MoveAction)
        self._list.startDrag = _set_start_drag

        # ── keyPressEvent ────────────────────────────────────────────────────
        def _set_key_press(event):
            key  = event.key()
            mods = event.modifiers()
            if key in (Qt.Key_Return, Qt.Key_Enter):
                sel = self._list.selectedItems()
                if len(sel) == 1 and not self._is_main(sel[0]):
                    self._list.editItem(sel[0])
                    return
            if key == Qt.Key_Delete:
                self._del_set()
                return
            if key == Qt.Key_A and (mods & Qt.ControlModifier):
                # Выделяем все кроме «Основного»
                for i in range(self._list.count()):
                    it = self._list.item(i)
                    if not self._is_main(it):
                        it.setSelected(True)
                return
            QListWidget.keyPressEvent(self._list, event)
        self._list.keyPressEvent = _set_key_press

        # ── inline-edit delegate (без color-кнопки) ───────────────────────
        _editing  = self._editing
        _dlg_self = self

        class _SetEditDelegate(SimpleListDelegate):
            def createEditor(self_, parent, option, index):
                it = _dlg_self._list.item(index.row())
                if it and _dlg_self._is_main(it):
                    return None   # «Основной» не редактируем

                container = QWidget(parent)
                container.setAutoFillBackground(True)
                h = QHBoxLayout(container)
                h.setContentsMargins(2, 1, 2, 1); h.setSpacing(2)
                le = QLineEdit(); le.setFrame(True)
                h.addWidget(le)

                confirm_btn = QPushButton()
                confirm_btn.setFixedSize(24, 22)
                confirm_btn.setFocusPolicy(Qt.NoFocus)
                confirm_btn.setIcon(_dlg_self._make_icon(
                    lambda p: (p.drawLine(QPointF(2, 7), QPointF(5.5, 11)),
                               p.drawLine(QPointF(5.5, 11), QPointF(12, 3)))))
                confirm_btn.setIconSize(QSize(14, 14))
                h.addWidget(confirm_btn)

                container.setFocusProxy(le)
                container._le      = le
                container._confirm = confirm_btn

                def _confirm():
                    text   = le.text().strip()
                    it     = _editing.get('item')
                    is_new = _dlg_self._is_new(it) if it else False
                    if not text and is_new:
                        self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)
                        row = _dlg_self._list.row(it)
                        if row >= 0:
                            _dlg_self._list.takeItem(row)
                        _editing['item'] = None
                        return
                    self_.commitData.emit(container)
                    self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)
                    QTimer.singleShot(0, _dlg_self._notify_change)

                confirm_btn.clicked.connect(_confirm)
                container._confirm_fn = _confirm
                return container

            def eventFilter(self_, obj, event):
                if event.type() == QEvent.KeyPress:
                    key = event.key()
                    if key in (Qt.Key_Return, Qt.Key_Enter):
                        editor = getattr(self_, '_current_editor', None)
                        if editor and hasattr(editor, '_confirm_fn'):
                            editor._confirm_fn()
                            return True
                    if key == Qt.Key_Escape:
                        it     = _editing.get('item')
                        is_new = _dlg_self._is_new(it) if it else False
                        if is_new:
                            editor = getattr(self_, '_current_editor', None)
                            if editor:
                                self_.closeEditor.emit(editor, QStyledItemDelegate.NoHint)
                            row = _dlg_self._list.row(it)
                            if row >= 0:
                                _dlg_self._list.takeItem(row)
                            _editing['item'] = None
                            return True
                return super().eventFilter(obj, event)

            def setEditorData(self_, editor, index):
                self_._current_editor = editor
                editor._le.setText(index.data(Qt.DisplayRole) or '')
                editor._le.selectAll()

            def setModelData(self_, editor, model, index):
                if _editing.get('_discarding'):
                    return
                text   = editor._le.text().strip()
                it     = _editing.get('item')
                is_new = _dlg_self._is_new(it) if it else False

                if text:
                    model.setData(index, text, Qt.DisplayRole)
                    if is_new:
                        # Создаём в БД, записываем реальный id
                        it.setData(Qt.UserRole + 2, False)
                        new_id = _dlg_self.db.add_tier_list_set(_dlg_self._category_id, text)
                        it.setData(Qt.UserRole, new_id)
                    else:
                        # Переименование существующего
                        set_id = it.data(Qt.UserRole) if it else None
                        if set_id is not None:
                            _dlg_self.db.rename_tier_list_set(set_id, text)
                    QTimer.singleShot(0, _dlg_self._notify_change)
                elif _editing.get('original') and not is_new:
                    model.setData(index, _editing['original'], Qt.DisplayRole)
                elif is_new:
                    QTimer.singleShot(0, lambda: (
                        _dlg_self._list.takeItem(_dlg_self._list.row(it))
                        if _dlg_self._list.row(it) >= 0 else None
                    ))

            def updateEditorGeometry(self_, editor, option, index):
                editor.setGeometry(option.rect)

        self._delegate = _SetEditDelegate(self._list)
        self._list.setItemDelegate(self._delegate)
        self._list.viewport().installEventFilter(self._delegate)

        # ── patched editItem — сохраняем оригинал перед открытием ────────────
        _orig_edit = self._list.editItem
        def _patched_edit(it):
            if self._is_main(it):
                return
            self._editing['item']     = it
            self._editing['original'] = it.text()
            _orig_edit(it)
        self._list.editItem = _patched_edit

        lay.addWidget(self._list)
        self._populate()

        # ── кнопки ───────────────────────────────────────────────────────────
        btn_row = QHBoxLayout()

        add_btn = QToolButton()
        add_btn.setFixedHeight(28)
        add_btn.setObjectName('primaryButton')
        add_btn.setToolButtonStyle(Qt.ToolButtonIconOnly)
        add_btn.setIconSize(QSize(16, 16))
        add_btn.setIcon(_make_plus_icon())
        add_btn.clicked.connect(self._add_set)

        cancel_btn = QPushButton(self.translations.get('cancel', 'Cancel'))
        cancel_btn.clicked.connect(self.accept)

        btn_row.addWidget(add_btn)
        btn_row.addStretch()
        btn_row.addWidget(cancel_btn)
        lay.addLayout(btn_row)

    # ── closeEvent ───────────────────────────────────────────────────────────

    def closeEvent(self, event):
        it = self._editing.get('item')
        if it is not None and self._is_new(it):
            self._editing['_discarding'] = True
            row = self._list.row(it)
            if row >= 0:
                self._list.takeItem(row)
            self._editing['item']        = None
            self._editing['_discarding'] = False
        super().closeEvent(event)

    def showEvent(self, event):
        super().showEvent(event)
        self._apply_scroll_if_needed()

    # ── context menu ─────────────────────────────────────────────────────────

    def _show_context_menu(self, pos):
        it = self._list.itemAt(pos)
        if not it or self._is_main(it):
            return
        self._list.setCurrentItem(it)
        menu = QMenu(self)
        del_action = QAction(self.translations.get('delete', 'Delete'), self)
        del_action.triggered.connect(self._del_set)
        menu.addAction(del_action)
        menu.exec_(self._list.mapToGlobal(pos))

    def _on_double_click(self, it):
        if self._is_main(it):
            return
        self._list.editItem(it)

    # ── populate ─────────────────────────────────────────────────────────────

    def _populate(self):
        self._list.clear()

        for s in self.db.get_tier_list_sets(self._category_id):
            it = QListWidgetItem(s['name'])
            it.setData(Qt.UserRole,     s['id'])
            it.setData(Qt.UserRole + 1, False)
            it.setData(Qt.UserRole + 2, False)
            it.setFlags(it.flags() | Qt.ItemIsEditable | Qt.ItemIsDragEnabled)
            self._list.addItem(it)

    # ── notifications ────────────────────────────────────────────────────────

    def _notify_change(self):
        if self._on_change:
            self._on_change()

    def _on_reorder(self):
        """Сохраняем новый порядок кастомных сетов (Main пропускаем)."""
        ordered_ids = []
        for i in range(self._list.count()):
            it     = self._list.item(i)
            set_id = it.data(Qt.UserRole)
            if set_id is not None:
                ordered_ids.append(set_id)
        self.db.reorder_tier_list_sets(self._category_id, ordered_ids)
        self._notify_change()

    # ── add / delete ─────────────────────────────────────────────────────────

    def _add_set(self):
        self._list.clearSelection()
        it = QListWidgetItem('')
        it.setData(Qt.UserRole,     None)   # id присвоится после подтверждения
        it.setData(Qt.UserRole + 1, False)  # не is_main
        it.setData(Qt.UserRole + 2, True)   # is_new = True
        it.setFlags(it.flags() | Qt.ItemIsEditable | Qt.ItemIsDragEnabled)
        self._list.addItem(it)
        self._list.setCurrentItem(it)
        self._list.scrollToItem(it)
        # Начинаем inline-редактирование немедленно
        self._editing['item']     = it
        self._editing['original'] = ''
        QTimer.singleShot(0, lambda: self._list.editItem(it))

    def _del_set(self):
        # Берём выделенные, исключая «Основной» и несохранённые новые
        items = [it for it in self._list.selectedItems()
                 if not self._is_main(it) and it.data(Qt.UserRole) is not None]
        if not items:
            row = self._list.currentRow()
            if row >= 0:
                it = self._list.item(row)
                if it and not self._is_main(it) and it.data(Qt.UserRole) is not None:
                    items = [it]
        if not items:
            return
        if len(items) == 1:
            msg = self.translations.get(
                'delete_tier_set_confirm', 'Delete list "{}"?').format(items[0].text())
        else:
            msg = self.translations.get(
                'delete_confirm_multi', 'Delete {} items?').format(len(items))
        if _show_dialog_confirm(None, msg, self.translations):
            for it in items:
                set_id = it.data(Qt.UserRole)
                if set_id is not None:
                    self.db.delete_tier_list_set(set_id)
                self._list.takeItem(self._list.row(it))
            self._notify_change()


# ─────────────────────────────────────────────────────────────────────────────
#  TierConfigDialog
# ─────────────────────────────────────────────────────────────────────────────
class TierConfigDialog(_AdaptiveHeightMixin, QDialog):
    """Диалог настройки тиров: добавление, удаление, переименование, цвет, сброс."""
    def __init__(self, tiers, translations=None, parent=None, on_change=None, main_window=None):
        super().__init__(parent)
        self.translations = translations or {}
        self.setWindowTitle(self.translations.get('tiers', 'Tiers'))
        self.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        self.setFixedWidth(340)
        self._tiers = [dict(t) for t in tiers]
        self._editing = {'item': None, 'original': '', 'original_color': '#aaaaaa', '_discarding': False}
        self._on_change = on_change
        self._main_window = main_window
        self._init_ui()

    def _make_icon(self, draw_fn):
        pix = _make_hires_pixmap(14)
        p = QPainter(pix)
        p.setRenderHint(QPainter.Antialiasing)
        pen = QPen(QColor(255, 255, 255))
        pen.setWidthF(1.5)
        pen.setCapStyle(Qt.RoundCap)
        p.setPen(pen)
        draw_fn(p)
        p.end()
        return QIcon(pix)

    def _init_ui(self):
        lay = QVBoxLayout(self)
        lay.setContentsMargins(12, 12, 12, 12)
        lay.setSpacing(8)

        self._list = QListWidget()
        self._list.setDragDropMode(QListWidget.InternalMove)
        self._list.model().rowsMoved.connect(lambda *_: QTimer.singleShot(0, self._notify_change))
        self._list.setFixedHeight(180)
        self._list.setMouseTracking(True)
        self._list.viewport().setMouseTracking(True)
        self._list.setContextMenuPolicy(Qt.CustomContextMenu)
        self._list.customContextMenuRequested.connect(self._show_context_menu)
        self._list.itemDoubleClicked.connect(lambda it: self._list.editItem(it))

        # Защита от drop-на-себя: Qt при InternalMove визуально дублирует элемент
        # если его перетащить под него же (без реального перемещения).
        _tier_orig_drop = self._list.dropEvent
        def _tier_guarded_drop(event):
            target_index = self._list.indexAt(event.pos())
            sel_rows = {self._list.row(it) for it in self._list.selectedItems()}
            if target_index.isValid() and sel_rows:
                drop_row = target_index.row()
                rect = self._list.visualRect(target_index)
                in_bottom_half = event.pos().y() > rect.top() + rect.height() // 2
                insert_row = drop_row + (1 if in_bottom_half else 0)
                would_be_noop = (
                    insert_row in sel_rows
                    and (insert_row - 1) in sel_rows
                )
                if would_be_noop:
                    event.ignore()
                    return
            elif not target_index.isValid() and sel_rows:
                # Drop ниже последнего элемента — нет смысла если последний уже выделен
                last_row = self._list.count() - 1
                if max(sel_rows) == last_row and len(sel_rows) == 1:
                    event.ignore()
                    return
            _tier_orig_drop(event)
        self._list.dropEvent = _tier_guarded_drop

        # inline-edit delegate with ✓ + color button
        _editing = self._editing

        class _TierEditDelegate(SimpleListDelegate):
            def createEditor(self_, parent, option, index):
                container = QWidget(parent)
                container.setAutoFillBackground(True)
                h = QHBoxLayout(container)
                h.setContentsMargins(2, 1, 2, 1)
                h.setSpacing(2)
                le = QLineEdit()
                le.setFrame(True)
                h.addWidget(le)

                # color swatch button
                color_btn = QPushButton()
                color_btn.setFixedSize(22, 22)
                color_btn.setFocusPolicy(Qt.NoFocus)
                h.addWidget(color_btn)

                # confirm button
                confirm_btn = QPushButton()
                confirm_btn.setFixedSize(24, 22)
                confirm_btn.setFocusPolicy(Qt.NoFocus)
                confirm_btn.setIcon(self._make_icon(
                    lambda p: (p.drawLine(QPointF(2, 7), QPointF(5.5, 11)),
                               p.drawLine(QPointF(5.5, 11), QPointF(12, 3)))))
                confirm_btn.setIconSize(QSize(14, 14))
                h.addWidget(confirm_btn)

                # KEY FIX: make container redirect focus to le automatically.
                # Qt's view framework focuses the editor container — with a
                # focus proxy that focus is transparently forwarded to le,
                # so keyboard input (including Enter/Return) goes straight there.
                container.setFocusProxy(le)

                container._le         = le
                container._color_btn  = color_btn
                container._confirm    = confirm_btn

                def _refresh_swatch():
                    it = _editing.get('item')
                    c = it.data(Qt.UserRole + 1) if it else '#aaaaaa'
                    color_btn.setStyleSheet(
                        f'QPushButton {{ background:{c}; border:1px solid #666; border-radius:2px; }}')

                def _pick():
                    it = _editing.get('item')
                    if not it:
                        return
                    cur = it.data(Qt.UserRole + 1) or '#aaaaaa'
                    c = QColorDialog.getColor(QColor(cur), container)
                    if c.isValid():
                        it.setData(Qt.UserRole + 1, c.name())
                        it.setForeground(QBrush(c))
                        _refresh_swatch()
                    # НЕ вызываем _notify_change — обновим тирлист только при подтверждении

                def _confirm():
                    text = le.text().strip()
                    it = _editing.get('item')
                    is_new = it is not None and it.data(Qt.UserRole + 2)
                    if not text and is_new:
                        # Пустое имя у нового тира — удаляем без сохранения
                        self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)
                        row = self._list.row(it)
                        if row >= 0:
                            self._list.takeItem(row)
                        _editing['item'] = None
                        return
                    self_.commitData.emit(container)
                    self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)
                    if is_new and text:
                        it.setData(Qt.UserRole + 2, False)
                    QTimer.singleShot(0, self._notify_change)

                color_btn.clicked.connect(_pick)
                confirm_btn.clicked.connect(_confirm)
                # returnPressed alone isn't enough — Qt's view intercepts Enter at
                # the viewport level before QLineEdit sees it. We store _confirm on
                # the container so eventFilter can call it directly.
                container._confirm_fn = _confirm

                QTimer.singleShot(0, _refresh_swatch)
                return container

            def eventFilter(self_, obj, event):
                """Перехватываем Enter и ESC до того как QAbstractItemView их обработает."""
                if event.type() == QEvent.KeyPress:
                    key = event.key()
                    if key in (Qt.Key_Return, Qt.Key_Enter):
                        editor = self_._current_editor if hasattr(self_, '_current_editor') else None
                        if editor and hasattr(editor, '_confirm_fn'):
                            editor._confirm_fn()
                            return True  # событие поглощено
                if event.type() == QEvent.KeyPress and event.key() == Qt.Key_Escape:
                    it = _editing.get('item')
                    is_new = it is not None and it.data(Qt.UserRole + 2)
                    if it is not None:
                        # Восстанавливаем оригинальный цвет если был изменён
                        orig_color = _editing.get('original_color', '#aaaaaa')
                        it.setData(Qt.UserRole + 1, orig_color)
                        it.setForeground(QBrush(QColor(orig_color)))
                    if is_new:
                        # Закрываем редактор и удаляем несохранённый элемент
                        editor = self_._current_editor if hasattr(self_, '_current_editor') else None
                        if editor:
                            self_.closeEditor.emit(editor, QStyledItemDelegate.NoHint)
                        row = self._list.row(it)
                        if row >= 0:
                            self._list.takeItem(row)
                        _editing['item'] = None
                        return True  # событие поглощено
                return super().eventFilter(obj, event)

            def setEditorData(self_, editor, index):
                self_._current_editor = editor
                editor._le.setText(index.data(Qt.DisplayRole) or '')
                editor._le.selectAll()

            def setModelData(self_, editor, model, index):
                if _editing.get('_discarding'):
                    return  # отмена — ничего не сохраняем
                text = editor._le.text().strip()
                it = _editing.get('item')
                is_new = it is not None and it.data(Qt.UserRole + 2)
                if text:
                    if is_new:
                        it.setData(Qt.UserRole + 2, False)
                    model.setData(index, text, Qt.DisplayRole)
                    QTimer.singleShot(0, self._notify_change)
                elif _editing.get('original') and not is_new:
                    model.setData(index, _editing['original'], Qt.DisplayRole)
                    QTimer.singleShot(0, self._notify_change)
                elif is_new:
                    # Имя пустое у нового тира — удаляем
                    QTimer.singleShot(0, lambda: (
                        self._list.takeItem(self._list.row(it))
                        if self._list.row(it) >= 0 else None
                    ))

            def updateEditorGeometry(self_, editor, option, index):
                editor.setGeometry(option.rect)

        self._delegate = _TierEditDelegate(self._list)
        self._list.setItemDelegate(self._delegate)
        self._list.viewport().installEventFilter(self._delegate)

        def _tier_start_drag(supported_actions):
            items = self._list.selectedItems()
            if not items:
                return
            if len(items) > 1:
                label = f"{len(items)} {self.translations.get('items', 'items')}"
            else:
                label = items[0].text() or items[0].data(Qt.UserRole) or '?'
            font = self._list.font()
            font.setPointSize(10)
            font.setBold(True)
            fm = QFontMetrics(font)
            px, py = 14, 6
            rect = fm.boundingRect(label)
            w, h = max(rect.width() + px * 2, 60), rect.height() + py * 2
            pix = QPixmap(w, h)
            pix.fill(Qt.transparent)
            painter = QPainter(pix)
            painter.setRenderHint(QPainter.Antialiasing)
            path = QPainterPath()
            path.addRoundedRect(QRectF(0, 0, w, h), 8, 8)
            painter.fillPath(path, QColor(70, 70, 70))
            painter.setFont(font)
            painter.setPen(QColor(255, 255, 255))
            painter.drawText(pix.rect().adjusted(px, 0, -px, 0),
                             Qt.AlignVCenter | Qt.AlignLeft, label)
            painter.end()
            mime = self._list.model().mimeData(self._list.selectedIndexes())
            drag = QDrag(self._list)
            drag.setMimeData(mime)
            drag.setPixmap(pix)
            drag.setHotSpot(QPoint(-10, -10))
            drag.exec_(Qt.MoveAction)
        self._list.startDrag = _tier_start_drag

        self._list.setSelectionMode(QListWidget.ExtendedSelection)

        def _tier_key_press(event):
            key = event.key()
            mods = event.modifiers()
            if key in (Qt.Key_Return, Qt.Key_Enter):
                sel = self._list.selectedItems()
                if len(sel) == 1:
                    self._list.editItem(sel[0])
            elif key == Qt.Key_Delete:
                self._del_tier()
            elif key == Qt.Key_A and mods & Qt.ControlModifier:
                self._list.selectAll()
            else:
                QListWidget.keyPressEvent(self._list, event)
        self._list.keyPressEvent = _tier_key_press

        _orig_edit = self._list.editItem
        def _patched_edit(it):
            self._editing['item'] = it
            self._editing['original'] = it.text()
            self._editing['original_color'] = it.data(Qt.UserRole + 1) or '#aaaaaa'
            _orig_edit(it)
        self._list.editItem = _patched_edit

        lay.addWidget(self._list)
        self._populate()

        btn_row = QHBoxLayout()

        add_btn = QToolButton()
        add_btn.setFixedHeight(28)
        add_btn.setObjectName('primaryButton')
        add_btn.setToolButtonStyle(Qt.ToolButtonIconOnly)
        add_btn.setIconSize(QSize(16, 16))
        add_btn.setIcon(_make_plus_icon())
        add_btn.clicked.connect(self._add_tier)

        reset_btn = QToolButton()
        reset_btn.setFixedSize(28, 28)
        reset_btn.setIcon(_make_reset_icon())
        reset_btn.setIconSize(QSize(16, 16))

        cancel_btn = QPushButton(self.translations.get('cancel', 'Cancel'))
        cancel_btn.clicked.connect(self.accept)

        btn_row.addWidget(add_btn)
        btn_row.addWidget(reset_btn)
        btn_row.addStretch()
        btn_row.addWidget(cancel_btn)
        lay.addLayout(btn_row)

        reset_btn.clicked.connect(self._reset)

    def closeEvent(self, event):
        """Перехватываем закрытие окна — убираем несохранённый элемент ДО того как
        Qt закроет редактор и вызовет setModelData."""
        it = self._editing.get('item')
        if it is not None:
            # Восстанавливаем оригинальный цвет если был изменён до подтверждения
            orig_color = self._editing.get('original_color', '#aaaaaa')
            it.setData(Qt.UserRole + 1, orig_color)
            it.setForeground(QBrush(QColor(orig_color)))
            if it.data(Qt.UserRole + 2):
                # Новый несохранённый элемент — удаляем
                self._editing['_discarding'] = True
                row = self._list.row(it)
                if row >= 0:
                    self._list.takeItem(row)
                self._editing['item'] = None
                self._editing['_discarding'] = False
        super().closeEvent(event)

    def showEvent(self, event):
        super().showEvent(event)
        self._apply_scroll_if_needed()

    def _show_context_menu(self, pos):
        it = self._list.itemAt(pos)
        if not it:
            return
        self._list.setCurrentItem(it)
        menu = QMenu(self)
        del_action = QAction(self.translations.get('delete', 'Delete'), self)
        del_action.triggered.connect(self._del_tier)
        menu.addAction(del_action)
        menu.exec_(self._list.mapToGlobal(pos))

    def _populate(self):
        self._list.clear()
        for t in self._tiers:
            it = QListWidgetItem(t['label'])
            it.setData(Qt.UserRole, t['key'])
            it.setData(Qt.UserRole + 1, t['color'])
            it.setForeground(QBrush(QColor(t['color'])))
            it.setFlags(it.flags() | Qt.ItemIsEditable)
            self._list.addItem(it)

    def _notify_change(self):
        if self._on_change:
            self._on_change(self.get_tiers())

    def _add_tier(self):
        self._list.clearSelection()
        key = f'T{self._list.count() + 1}'
        it = QListWidgetItem(key)
        it.setData(Qt.UserRole, key)
        it.setData(Qt.UserRole + 1, '#aaaaaa')
        it.setData(Qt.UserRole + 2, True)   # флаг: новый, ещё не сохранён
        it.setForeground(QBrush(QColor('#aaaaaa')))
        it.setFlags(it.flags() | Qt.ItemIsEditable)
        self._list.addItem(it)
        self._list.setCurrentItem(it)
        self._list.editItem(it)
        # _notify_change НЕ вызываем — сохраним только после подтверждения

    def _del_tier(self):
        items = self._list.selectedItems()
        if not items:
            row = self._list.currentRow()
            if row < 0:
                return
            items = [self._list.item(row)]
        if len(items) == 1:
            label = items[0].text()
            msg = self.translations.get('delete_tier_confirm', 'Delete tier "{}"?').format(label)
        else:
            msg = self.translations.get('delete_confirm_multi', 'Delete {} items?').format(len(items))
        if _show_dialog_confirm(None, msg, self.translations):
            mw = getattr(self, '_main_window', None)
            if mw and hasattr(mw, '_do_backup'):
                mw._do_backup('delete_tier')
            for it in items:
                self._list.takeItem(self._list.row(it))
            self._notify_change()

    def _reset(self):
        msg = self.translations.get('reset_tier_confirm', 'Reset tiers to default?')
        if _show_dialog_confirm(None, msg, self.translations):
            self._tiers = [dict(t) for t in Database.DEFAULT_TIERS]
            self._populate()
            self._notify_change()

    def get_tiers(self):
        result = []
        for i in range(self._list.count()):
            it = self._list.item(i)
            label = it.text().strip() or it.data(Qt.UserRole)
            result.append({
                'key':   it.data(Qt.UserRole),
                'label': label,
                'color': it.data(Qt.UserRole + 1) or '#aaaaaa',
            })
        return result


# ─────────────────────────────────────────────────────────────────────────────
#  TierCoverWidget — individual cover card
# ─────────────────────────────────────────────────────────────────────────────
TIER_COVER_W = 64
TIER_COVER_H = 96
TIER_ROW_GAP = 2   # вертикальный зазор между рядами (только когда рядов 2+)

class TierCoverDelegate(QStyledItemDelegate):
    """Делегат для рядов тира и пула — фиксированный размер обложек."""

    def __init__(self, tier_widget, store_getter, parent=None, pool=False):
        super().__init__(parent)
        self._tw           = tier_widget
        self._store_getter = store_getter
        self._pool         = pool

    def sizeHint(self, option, index):
        return QSize(TIER_COVER_W + 2, TIER_COVER_H)

    def paint(self, painter, option, index):
        painter.save()
        row      = index.row()
        store    = self._store_getter()
        dragging = index.data(Qt.UserRole + 3)

        # Placeholder item вставлен во время drag — рисуем полупрозрачную обложку
        is_placeholder = bool(index.data(Qt.UserRole + 5))
        if is_placeholder:
            if self._pool:
                r = QRect(option.rect.left() + 1, option.rect.top(),
                          TIER_COVER_W, TIER_COVER_H)
            else:
                r = QRect(option.rect.left() + 1, option.rect.top(),
                          TIER_COVER_W, TIER_COVER_H)
            tw  = self._tw
            pix = getattr(tw, '_drag_cover_pix', None)
            ttl = getattr(tw, '_drag_title', '')
            painter.setOpacity(0.55)
            if pix and not pix.isNull():
                sc = _get_dpr()
                phys_w = round(r.width()  * sc)
                phys_h = round(r.height() * sc)
                scaled = pix.scaled(phys_w, phys_h,
                                    Qt.KeepAspectRatioByExpanding,
                                    Qt.SmoothTransformation)
                sx = (scaled.width()  - phys_w) // 2
                sy = (scaled.height() - phys_h) // 2
                src = scaled.copy(sx, sy, phys_w, phys_h)
                src.setDevicePixelRatio(sc)
                painter.drawPixmap(r, src)
            else:
                painter.fillRect(r, QColor('#4a6a7a'))
                if ttl:
                    painter.setPen(QColor('#ddeeff'))
                    painter.setFont(QFont('Segoe UI', 7))
                    painter.drawText(r.adjusted(2, 2, -2, -2),
                                     Qt.AlignCenter | Qt.TextWordWrap, ttl)
            painter.restore()
            return

        # Обычный item — store_row с учётом возможного placeholder перед ним
        lw = option.widget
        ph_row = getattr(self._tw, '_preview_row', -1)
        ph_lw  = getattr(self._tw, '_preview_lw', None)
        if lw is not None and ph_lw is lw and ph_row >= 0 and row > ph_row:
            store_row = row - 1
        else:
            store_row = row

        if self._pool:
            r = QRect(option.rect.left() + 1, option.rect.top(),
                      TIER_COVER_W, TIER_COVER_H)
        else:
            r = QRect(option.rect.left() + 1, option.rect.top(),
                      TIER_COVER_W, TIER_COVER_H)

        pix     = None
        cropped = None
        title   = ''
        if store is not None and 0 <= store_row < len(store):
            entry   = store[store_row]
            pix     = entry[1]
            cropped = entry[2]
            _raw_title = entry[0].get('title', '') if entry[0] else ''
            title = _display_title(_raw_title)
            if cropped and not cropped.isNull():
                # Кроп должен совпадать с физическими размерами pix
                if pix and (cropped.width() != pix.width() or cropped.height() != pix.height()):
                    cropped = None
                    entry[2] = None
                    if len(entry) > 6: entry[6] = None  # invalidate parts cache

        opacity = 0.35 if dragging else 1.0
        painter.setOpacity(opacity)

        if pix and not pix.isNull():
            if not cropped or cropped.isNull():
                pw = pix.width()
                ph = pix.height()
                tw = r.width()
                th = r.height()
                # Масштабируем до физических размеров ячейки
                sc = _get_dpr()
                phys_w = round(tw * sc)
                phys_h = round(th * sc)
                scaled = pix.scaled(phys_w, phys_h,
                                    Qt.KeepAspectRatioByExpanding,
                                    Qt.SmoothTransformation)
                sx = (scaled.width()  - phys_w) // 2
                sy = (scaled.height() - phys_h) // 2
                cropped = scaled.copy(sx, sy, phys_w, phys_h)
                cropped.setDevicePixelRatio(sc)
                if store is not None and 0 <= store_row < len(store):
                    store[store_row][2] = cropped
            painter.drawPixmap(r, cropped)
        else:
            painter.fillRect(r, QColor('#5C5C5C'))
            if title:
                painter.setPen(QColor('#cccccc'))
                f = QFont('Segoe UI', 7)
                f.setWeight(QFont.Medium)
                painter.setFont(f)
                painter.drawText(r.adjusted(3, 3, -3, -3),
                                 Qt.AlignCenter | Qt.TextWordWrap, title)

        painter.setOpacity(1.0)
        if not dragging and (option.state & QStyle.State_MouseOver):
            painter.fillRect(r, QColor(255, 255, 255, 20))

        painter.restore()


# ─────────────────────────────────────────────────────────────────────────────
#  TierRowWidget — one tier row (label + horizontal list)
# ─────────────────────────────────────────────────────────────────────────────
class TierRowWidget(QWidget):
    """Один горизонтальный ряд тира: цветной лейбл + QListWidget с обложками."""
    item_dropped = pyqtSignal(object, str, int)   # (source_list, tier_key, insert_pos)
    item_removed  = pyqtSignal(int, str)           # (item_id, from_tier_key)

    LABEL_W = 52

    def __init__(self, tier_key, label, color, parent=None):
        super().__init__(parent)
        self.tier_key = tier_key
        self._color   = color
        self.setAcceptDrops(True)
        self.setStyleSheet('TierRowWidget { background: #1e1e1e; border-radius: 0px; }')
        self.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Preferred)

        row_layout = QHBoxLayout(self)
        row_layout.setContentsMargins(0, 0, 0, 0)
        row_layout.setSpacing(0)

        # Colored label
        self._label_btn = QPushButton(label)
        self._label_btn.setMinimumWidth(TIER_COVER_W + 2)
        self._label_btn.setMaximumWidth((TIER_COVER_W + 2) * 2)
        self._label_btn.setStyleSheet(
            f'background-color:{color}; color:#1a1a1a; font-weight:bold;'
            f'font-size:16px; border:none; border-radius:0px; margin:0px; padding:0px;'
        )
        row_layout.addWidget(self._label_btn)

        # Separator
        sep = QFrame(); sep.setFrameShape(QFrame.VLine)
        sep.setFixedWidth(1)
        sep.setStyleSheet('background:#444; border:none;')
        row_layout.addWidget(sep)

        # List widget — wrapping grid, растёт вертикально
        self.list_widget = QListWidget()
        self.list_widget.setFlow(QListView.LeftToRight)
        self.list_widget.setWrapping(True)
        self.list_widget.setResizeMode(QListView.Adjust)
        self.list_widget.setUniformItemSizes(True)
        self.list_widget.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        self.list_widget.setVerticalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        self.list_widget.setSpacing(0)
        self.list_widget.setGridSize(QSize(TIER_COVER_W + 2, TIER_COVER_H))  # будет обновлён в update_height
        self.list_widget.setDragDropMode(QListWidget.NoDragDrop)
        self.list_widget.setSelectionMode(QListWidget.NoSelection)
        self.list_widget.setFocusPolicy(Qt.NoFocus)
        self.list_widget.setFrameShape(QFrame.NoFrame)
        self.list_widget.setStyleSheet(
            'QListWidget { background:#1e1e1e; border:none; outline:none; margin:0; padding:0; }'
            'QListWidget::item { padding:0; margin:0; }'
        )
        self.list_widget.setContentsMargins(0, 0, 0, 0)
        self.list_widget.viewport().setContentsMargins(0, 0, 0, 0)
        self.list_widget.setMouseTracking(True)
        row_layout.addWidget(self.list_widget)
        # _lw_extra: разница между шириной QListWidget и его viewport (рамки и т.д.)
        # Измеряем после того как виджет добавлен в layout; изначально 0
        self._lw_extra = 0

    def update_height(self, cols, label_w, lw_w):
        """Задать точные размеры: cols колонок, ширина label_w, ширина lw_w."""
        lw = self.list_widget
        n  = lw.count()
        cell_w = TIER_COVER_W + 2
        cell_h = TIER_COVER_H

        # Задаём ширину
        lw.setFixedWidth(lw_w)
        self._label_btn.setFixedWidth(label_w)

        # cols is passed from _update_tier_layout which already computed it correctly
        qt_cols   = max(1, cols)
        grid_rows = max(1, (n + qt_cols - 1) // qt_cols)

        # Gap между строками — только когда строк 2+, иначе 0
        gap = TIER_ROW_GAP if grid_rows >= 2 else 0
        lw.setSpacing(0)
        lw.setGridSize(QSize(cell_w, cell_h + gap))

        # Высота: строки * (cell + gap), но последняя строка без gap снизу
        total_h = cell_h * grid_rows + gap * (grid_rows - 1)

        lw.setFixedHeight(total_h)
        self._label_btn.setFixedHeight(total_h)
        self.setFixedHeight(total_h)
        self.setFixedWidth(label_w + 1 + lw_w)
        self.updateGeometry()

    def set_content_width(self, cols):
        """Зафиксировать ширину list_widget под cols колонок."""
        item_w = TIER_COVER_W + 3
        w = item_w * cols
        self.list_widget.setFixedWidth(w)

    def set_delegate(self, delegate):
        self.list_widget.setItemDelegate(delegate)

    def item_ids(self):
        return [self.list_widget.item(i).data(Qt.UserRole)
                for i in range(self.list_widget.count())]


# ─────────────────────────────────────────────────────────────────────────────
#  TierPreviewOverlay — прозрачный виджет для рисования drop-preview
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
class TierListWidget(QWidget):
    """Полный виджет TierList: ряды тиров + пул внизу."""

    def __init__(self, db, translations=None, parent=None):
        super().__init__(parent)
        self.db           = db
        self.translations = translations or {}
        self._category_id = None
        self._tiers       = []
        self._all_items   = []
        self._tier_rows   = {}   # tier_key → TierRowWidget
        self._tier_store  = {}   # tier_key → [[item, pix, cropped], ...]
        self._pool_store  = []   # [[item, pix, cropped], ...] — видимые (после поиска)
        self._full_pool_store = []  # все элементы пула (без текстового поиска)
        self._pool_meta   = {}   # item_id → (users, cf_data) для predicate поиска
        # Текущие параметры пула
        self._pool_sort_by   = 'watch_date'
        self._pool_ascending = False
        self._pool_favorites = False
        self._pool_search    = ''
        self._date_from      = None   # 'YYYY-MM-DD' or None
        self._date_to        = None
        self._active_set_id  = None   # None = Main/Основной, int = custom set

        self._main_layout = QVBoxLayout(self)
        self._main_layout.setContentsMargins(8, 8, 8, 8)
        self._main_layout.setSpacing(4)

        # Scroll area для тир-рядов — горизонтальный скролл на всю область
        self._tiers_scroll = QScrollArea()
        self._tiers_scroll.setWidgetResizable(True)
        self._tiers_scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        self._tiers_scroll.setVerticalScrollBarPolicy(Qt.ScrollBarAsNeeded)
        self._tiers_scroll.setFrameShape(QFrame.NoFrame)
        self._tiers_scroll.setStyleSheet('QScrollArea { background: transparent; border: none; }')

        self._tiers_container = QWidget()
        self._tiers_container.setStyleSheet('background: transparent;')
        self._tiers_layout = QVBoxLayout(self._tiers_container)
        self._tiers_layout.setContentsMargins(0, 0, 0, 0)
        self._tiers_layout.setSpacing(1)
        self._tiers_scroll.setWidget(self._tiers_container)
        self._main_layout.addWidget(self._tiers_scroll, stretch=3)
        # Пересчитываем layout когда скроллбар появляется/исчезает (меняет доступную ширину)
        # Дебаунс 50ms чтобы не создавать петлю rangeChanged → adjustSize → rangeChanged
        self._layout_debounce = QTimer(self)
        self._layout_debounce.setSingleShot(True)
        self._layout_debounce.setInterval(0)
        self._layout_debounce.timeout.connect(self._update_tier_layout)
        self._tiers_scroll.verticalScrollBar().rangeChanged.connect(
            lambda *_: self._layout_debounce.start()
        )
        self._tiers_scroll.verticalScrollBar().valueChanged.connect(
            lambda *_: QTimer.singleShot(50, self._request_visible_covers)
        )

        # Pool — wrapping grid, максимум 2 ряда высота, вертикальный скролл
        self._pool = QListWidget()
        self._pool.setFlow(QListView.LeftToRight)
        self._pool.setWrapping(True)
        self._pool.setResizeMode(QListView.Adjust)
        self._pool.setUniformItemSizes(True)
        self._pool.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        self._pool.setVerticalScrollBarPolicy(Qt.ScrollBarAsNeeded)
        self._pool.setVerticalScrollMode(QListWidget.ScrollPerPixel)
        self._pool.setSpacing(0)
        self._pool.setViewportMargins(0, 0, 0, 0)
        self._pool.setGridSize(QSize(TIER_COVER_W + 2, TIER_COVER_H))
        self._pool.setDragDropMode(QListWidget.NoDragDrop)
        self._pool.setSelectionMode(QListWidget.NoSelection)
        self._pool.setFocusPolicy(Qt.NoFocus)
        # initial height — will be recalculated in _update_pool_height
        self._pool.setFixedHeight(TIER_COVER_H)
        self._pool.setStyleSheet(
            'QListWidget { background:#1e1e1e; border:1px solid #3c3c3c; border-top:none; border-top-left-radius:0; border-top-right-radius:0; border-bottom-left-radius:4px; border-bottom-right-radius:4px; outline:none; }'
            'QListWidget::item { padding:0; }'
        )
        self._pool.setMouseTracking(True)

        # Thin toggle bar above pool — not a wrapper, just a separate widget
        class _PoolToggleBar(QWidget):
            def __init__(bar_self, parent=None):
                super().__init__(parent)
                bar_self.setFixedHeight(14)
                bar_self.setCursor(Qt.PointingHandCursor)
            def paintEvent(bar_self, event):
                p = QPainter(bar_self)
                r = bar_self.rect()
                p.setRenderHint(QPainter.Antialiasing)
                p.setPen(Qt.NoPen)
                p.setBrush(QColor('#252525'))
                collapsed = self._pool_collapsed
                if collapsed:
                    # когда пул скрыт — полный скруглённый прямоугольник
                    path = QPainterPath()
                    path.addRoundedRect(QRectF(r).adjusted(0.5, 0.5, -0.5, -0.5), 3, 3)
                else:
                    # когда пул виден — только верх+бока, низ плоский (стык с пулом)
                    path = QPainterPath()
                    path.moveTo(r.left() + 3, r.top() + 0.5)
                    path.arcTo(QRectF(r.left() + 0.5, r.top() + 0.5, 6, 6), 90, 90)
                    path.lineTo(r.left() + 0.5, r.bottom() + 1)
                    path.lineTo(r.right() + 0.5, r.bottom() + 1)
                    path.arcTo(QRectF(r.right() - 6 + 0.5, r.top() + 0.5, 6, 6), 0, 90)
                    path.closeSubpath()
                p.drawPath(path)
                # бордер
                border_pen = QPen(QColor('#3C3C3C'))
                border_pen.setWidthF(1.0)
                p.setPen(border_pen)
                p.setBrush(Qt.NoBrush)
                if collapsed:
                    p.drawRoundedRect(QRectF(r).adjusted(0.5, 0.5, -0.5, -0.5), 3, 3)
                else:
                    border_path = QPainterPath()
                    border_path.moveTo(r.left() + 0.5, r.bottom())
                    border_path.arcTo(QRectF(r.left() + 0.5, r.top() + 0.5, 6, 6), 180, -90)
                    border_path.lineTo(r.right() - 3, r.top() + 0.5)
                    border_path.arcTo(QRectF(r.right() - 6 + 0.5, r.top() + 0.5, 6, 6), 90, -90)
                    border_path.lineTo(r.right() + 0.5, r.bottom())
                    p.drawPath(border_path)
                # шеврон
                cx = bar_self.width() // 2
                pen = QPen(QColor('#666666'))
                pen.setWidthF(1.5)
                pen.setCapStyle(Qt.RoundCap)
                p.setPen(pen)
                if collapsed:
                    p.drawLine(QPointF(cx-5, 9), QPointF(cx, 5))
                    p.drawLine(QPointF(cx, 5), QPointF(cx+5, 9))
                else:
                    p.drawLine(QPointF(cx-5, 5), QPointF(cx, 9))
                    p.drawLine(QPointF(cx, 9), QPointF(cx+5, 5))
                p.end()
            def mousePressEvent(bar_self, event):
                if event.button() == Qt.LeftButton:
                    self._toggle_pool()

        self._pool_toggle_bar = _PoolToggleBar()
        self._pool_toggle_bar_full = _PoolToggleBar()  # полноширинная — когда пул скрыт
        self._pool_toggle_bar_full.hide()
        self._pool_collapsed = False
        # Оборачиваем кнопку и пул в контейнер без отступа между ними
        class _PoolContainer(QWidget):
            def minimumSizeHint(self):
                h = super().minimumSizeHint()
                return QSize(0, h.height())
            def minimumWidth(self):
                return 0
        _pool_container = _PoolContainer()
        _pool_container.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Preferred)
        _pool_container_layout = QVBoxLayout(_pool_container)
        _pool_container_layout.setContentsMargins(0, 0, 0, 0)
        _pool_container_layout.setSpacing(0)
        # полноширинная кнопка — видна когда пул скрыт
        _pool_container_layout.addWidget(self._pool_toggle_bar_full)
        # центрированная кнопка + пул
        _pool_h_layout = QHBoxLayout()
        _pool_h_layout.setContentsMargins(0, 0, 0, 0)
        _pool_h_layout.setSpacing(0)
        _pool_h_layout.addStretch()
        _inner_vbox = QVBoxLayout()
        _inner_vbox.setContentsMargins(0, 0, 0, 0)
        _inner_vbox.setSpacing(0)
        _inner_vbox.addWidget(self._pool_toggle_bar)
        _inner_vbox.addWidget(self._pool)
        _pool_h_layout.addLayout(_inner_vbox)
        _pool_h_layout.addStretch()
        _pool_container_layout.addLayout(_pool_h_layout)
        self._main_layout.addWidget(_pool_container)

        # Wire drag/drop through event filter
        self._install_dnd()

    # ── DnD ──────────────────────────────────────────────────────────
    def _install_dnd(self):
        self._pool.viewport().installEventFilter(self)
        self._pool.setProperty('tier_key', '__pool__')
        self._pool.installEventFilter(self)  # для скролл событий
        self._drag_item_id    = None
        self._drag_cover_pix  = None
        self._drag_title      = None
        self._drag_entry      = None
        self._drag_source_lw  = None
        self._drag_source_key = None
        self._drag_source_row = -1
        self._drag_active     = False
        self._drag_start_pos  = None
        self._drag_ghost      = None
        # Preview (drop indicator) state
        self._preview_lw      = None   # QListWidget куда вставлен preview
        self._preview_row     = -1     # строка preview-item в этом lw

    def _connect_tier_dnd(self, row_widget):
        row_widget.list_widget.viewport().installEventFilter(self)
        row_widget.list_widget.setProperty('tier_key', row_widget.tier_key)

    def _lw_for_viewport(self, vp):
        for key, row in self._tier_rows.items():
            if vp is row.list_widget.viewport():
                return row.list_widget, key
        if vp is self._pool.viewport():
            return self._pool, '__pool__'
        return None, None

    def _get_store_for_lw(self, lw, key):
        if key == '__pool__':
            return self._pool_store
        return self._tier_store.get(key, [])

    def eventFilter(self, obj, event):
        lw, tier_key = self._lw_for_viewport(obj)
        if lw is None:
            return False
        t = event.type()

        if t == QEvent.MouseButtonPress and event.button() == Qt.LeftButton:
            it = lw.itemAt(event.pos())
            if it:
                row   = lw.row(it)
                store = self._get_store_for_lw(lw, tier_key)
                entry = store[row] if 0 <= row < len(store) else None
                self._drag_start_pos  = event.pos()
                self._drag_source_lw  = lw
                self._drag_source_key = tier_key
                self._drag_source_row = row
                self._drag_item_id    = it.data(Qt.UserRole)
                self._drag_cover_pix  = entry[1] if entry else None
                self._drag_title      = entry[0].get('title', '') if entry else ''
                self._drag_entry      = entry
                self._drag_active     = False
            return False

        if t == QEvent.MouseMove and self._drag_item_id is not None:
            if not self._drag_active:
                if self._drag_start_pos is None:
                    return False
                if (event.pos() - self._drag_start_pos).manhattanLength() < 8:
                    return False
                self._drag_active = True
                self._set_item_dragging(self._drag_source_lw, self._drag_source_row, True)
                self._drag_source_lw.setRowHidden(self._drag_source_row, True)
                self._start_ghost(self._drag_cover_pix, self._drag_title)
            if self._drag_ghost:
                local = self.mapFromGlobal(QCursor.pos())
                gh = self._drag_ghost
                gh.move(local.x() - gh.width() // 2, local.y() - gh.height() // 2)
            self._update_preview()
            return True

        if t == QEvent.MouseButtonRelease and event.button() == Qt.LeftButton:
            if self._drag_active:
                self._finish_drag()
            else:
                self._cancel_drag()
            return True

        if t == QEvent.Wheel:
            # If cursor is over the pool — let pool scroll itself normally
            if obj is self._pool.viewport() or obj is self._pool:
                QTimer.singleShot(50, self._request_visible_covers)
                return False
            # Otherwise redirect wheel to tiers_scroll so tier rows don't scroll themselves
            QApplication.sendEvent(self._tiers_scroll.verticalScrollBar(), event)
            QTimer.singleShot(50, self._request_visible_covers)
            return True

        if obj is self._pool and t not in (QEvent.Paint, QEvent.Resize, QEvent.Move):
            sb = self._pool.verticalScrollBar()
            if not hasattr(self, '_pool_last_scroll'):
                self._pool_last_scroll = -1
            val = sb.value()
            if val != self._pool_last_scroll:
                self._pool_last_scroll = val
                self._scroll_debounce.start()
            return False

        return False

    def _set_item_dragging(self, lw, row, state):
        it = lw.item(row)
        if it:
            it.setData(Qt.UserRole + 3, state)
            lw.update(lw.indexFromItem(it))

    def _finish_drag(self):
        if self._drag_ghost:
            self._drag_ghost.hide()
            self._drag_ghost.deleteLater()
            self._drag_ghost = None

        src_lw     = self._drag_source_lw
        src_key    = self._drag_source_key
        src_row    = self._drag_source_row
        item_id    = self._drag_item_id
        drag_entry = self._drag_entry

        # Запоминаем позицию placeholder до очистки
        preview_lw  = self._preview_lw
        preview_row = self._preview_row

        self._set_item_dragging(src_lw, src_row, False)
        # НЕ делаем setRowHidden здесь — иначе Qt немедленно вызовет paint()
        # пока _preview_row ещё активен, делегат вычислит неправильный store_row
        # и покажет текст вместо обложки на один кадр.
        target_lw, target_key = self._find_lw_under_cursor(QCursor.pos())

        # Корректируем preview_row с учётом того что src стал виден обратно
        # Скрытые строки не меняют row-индексы в QListWidget, поэтому корректировка не нужна —
        # setRowHidden не меняет индексы, только скрывает визуально.

        # Удаляем placeholder — сначала, до того как показываем src элемент
        if preview_lw is not None and preview_row >= 0:
            if 0 <= preview_row < preview_lw.count():
                it = preview_lw.item(preview_row)
                if it and it.data(Qt.UserRole + 5):
                    preview_lw.takeItem(preview_row)

        self._preview_lw  = None
        self._preview_row = -1
        # Только теперь показываем src — _preview_row уже сброшен,
        # делегат получит правильный store_row
        src_lw.setRowHidden(src_row, False)
        if hasattr(self, '_preview_overlay'):
            self._preview_overlay.hide()

        saved_drag_cover_pix = self._drag_cover_pix  # сохраняем до _cancel_drag
        self._cancel_drag()

        if target_lw is None or drag_entry is None:
            # Элемент вернулся на место — если pix был evict'нут во время drag,
            # восстанавливаем его из saved_drag_cover_pix чтобы не мелькал текст
            if drag_entry is not None and drag_entry[1] is None and saved_drag_cover_pix is not None:
                drag_entry[1] = saved_drag_cover_pix
                drag_entry[2] = None  # cropped пересчитается из восстановленного pix
            return

        src_store = self._get_store_for_lw(src_lw, src_key)
        if src_row >= len(src_store):
            return
        # Guard: verify item_id still matches store entry (protects against reload during drag)
        if src_store[src_row][0].get('id') != item_id:
            return

        # Определяем insert_row — placeholder удалён, src ещё скрыт в lw
        if preview_lw is target_lw and preview_row >= 0:
            insert_row = preview_row
        else:
            local      = target_lw.viewport().mapFromGlobal(QCursor.pos())
            drop_idx   = target_lw.indexAt(local)
            insert_row = drop_idx.row() if drop_idx.isValid() else target_lw.count()

        if src_lw is target_lw:
            entry = src_store.pop(src_row)
            src_lw.takeItem(src_row)
            if insert_row > src_row:
                insert_row -= 1
            src_store.insert(insert_row, entry)
            src_lw.insertItem(insert_row, self._make_list_item(item_id))
            QTimer.singleShot(50, lambda k=target_key: self._save_tier_order(k))
            QTimer.singleShot(10, self._update_tier_layout)
        else:
            entry = src_store.pop(src_row)
            src_lw.takeItem(src_row)
            tgt_store = self._get_store_for_lw(target_lw, target_key)
            if len(entry) > 6: entry[6] = None  # invalidate parts cache
            # Если cropped ещё не вычислен (элемент пула был вне viewport) —
            # вычисляем его прямо сейчас, до insertItem, чтобы первый paint
            # тира сразу рисовал картинку, а не текст
            if entry[1] is not None and not entry[1].isNull() and (entry[2] is None or entry[2].isNull()):
                sc     = _get_dpr()
                phys_w = round(TIER_COVER_W * sc)
                phys_h = round(TIER_COVER_H * sc)
                scaled = entry[1].scaled(phys_w, phys_h,
                                         Qt.KeepAspectRatioByExpanding,
                                         Qt.SmoothTransformation)
                sx = (scaled.width()  - phys_w) // 2
                sy = (scaled.height() - phys_h) // 2
                cropped = scaled.copy(sx, sy, phys_w, phys_h)
                cropped.setDevicePixelRatio(sc)
                entry[2] = cropped
            tgt_store.insert(insert_row, entry)
            target_lw.insertItem(insert_row, self._make_list_item(item_id))
            if target_key == '__pool__':
                if self._active_set_id is None:
                    self.db.remove_item_tier(item_id, self._category_id)
                else:
                    self.db.remove_tier_set_item(self._active_set_id, item_id)
            else:
                visible_ids = [target_lw.item(i).data(Qt.UserRole)
                               for i in range(target_lw.count())
                               if target_lw.item(i)]
                if self._active_set_id is None:
                    self.db.move_and_reorder_tier(item_id, self._category_id,
                                                  target_key, visible_ids)
                else:
                    self.db.move_and_reorder_tier_set(self._active_set_id, item_id,
                                                      target_key, visible_ids)
            QTimer.singleShot(10, self._update_tier_layout)

    def _make_list_item(self, item_id):
        it = QListWidgetItem()
        it.setData(Qt.UserRole, item_id)
        it.setSizeHint(QSize(TIER_COVER_W + 2, TIER_COVER_H))
        return it

    def _start_ghost(self, pix, title):
        sc = _get_dpr()
        phys_w = round(TIER_COVER_W * sc)
        phys_h = round(TIER_COVER_H * sc)

        canvas = QPixmap(phys_w, phys_h)
        canvas.fill(Qt.transparent)
        canvas.setDevicePixelRatio(sc)

        p = QPainter(canvas)
        p.setRenderHint(QPainter.SmoothPixmapTransform)
        p.setOpacity(0.80)
        if pix and not pix.isNull():
            # pix уже HiDPI (DPR=sc), масштабируем в физические пиксели
            scaled = pix.scaled(phys_w, phys_h,
                                Qt.KeepAspectRatioByExpanding, Qt.SmoothTransformation)
            sx = (scaled.width()  - phys_w) // 2
            sy = (scaled.height() - phys_h) // 2
            src = scaled.copy(sx, sy, phys_w, phys_h)
            # рисуем в логических координатах (painter учитывает DPR)
            p.drawPixmap(QRect(0, 0, TIER_COVER_W, TIER_COVER_H), src)
        else:
            p.fillRect(QRect(0, 0, TIER_COVER_W, TIER_COVER_H), QColor('#3a3a3a'))
            if title:
                p.setPen(QColor('#ccc'))
                p.setFont(QFont('Segoe UI', 7))
                p.drawText(QRect(2, 2, TIER_COVER_W - 4, TIER_COVER_H - 4),
                           Qt.AlignCenter | Qt.TextWordWrap, title)
        p.end()

        gh = QLabel(self)
        gh.setFixedSize(TIER_COVER_W, TIER_COVER_H)
        gh.setAttribute(Qt.WA_TransparentForMouseEvents)
        gh.setPixmap(canvas)
        gh.raise_()
        gh.show()
        self._drag_ghost = gh

    def _clear_preview(self):
        """Удалить placeholder из lw."""
        if self._preview_lw is not None and self._preview_row >= 0:
            lw = self._preview_lw
            if 0 <= self._preview_row < lw.count():
                it = lw.item(self._preview_row)
                if it and it.data(Qt.UserRole + 5):
                    lw.takeItem(self._preview_row)
                    QTimer.singleShot(0, self._update_tier_layout)
        self._preview_lw  = None
        self._preview_row = -1

    def _update_preview(self):
        """Вставить/переместить placeholder под курсором во время drag.
        Src-item скрыт через setRowHidden, поэтому индексы чистые."""
        if not self._drag_active or self._drag_item_id is None:
            return

        target_lw, target_key = self._find_lw_under_cursor(QCursor.pos())

        if target_lw is None:
            self._clear_preview()
            return

        local    = target_lw.viewport().mapFromGlobal(QCursor.pos())
        drop_idx = target_lw.indexAt(local)
        insert_row = drop_idx.row() if drop_idx.isValid() else target_lw.count()

        # Если placeholder уже в этом lw — убираем его влияние на insert_row
        if self._preview_lw is target_lw and self._preview_row >= 0:
            real_insert = insert_row
            if real_insert > self._preview_row:
                real_insert -= 1
            if real_insert == self._preview_row:
                return  # позиция не изменилась
            lw = self._preview_lw
            if 0 <= self._preview_row < lw.count():
                it = lw.item(self._preview_row)
                if it and it.data(Qt.UserRole + 5):
                    lw.takeItem(self._preview_row)
            insert_row = real_insert
            self._preview_lw  = None
            self._preview_row = -1
        elif self._preview_lw is not None:
            # Placeholder в другом lw — убираем
            old_lw, old_row = self._preview_lw, self._preview_row
            if 0 <= old_row < old_lw.count():
                it = old_lw.item(old_row)
                if it and it.data(Qt.UserRole + 5):
                    old_lw.takeItem(old_row)
                    QTimer.singleShot(0, self._update_tier_layout)
            self._preview_lw  = None
            self._preview_row = -1

        # Вставляем placeholder
        ph = QListWidgetItem()
        ph.setData(Qt.UserRole,     self._drag_item_id)
        ph.setData(Qt.UserRole + 5, True)
        ph.setSizeHint(QSize(TIER_COVER_W + 2, TIER_COVER_H))
        target_lw.insertItem(insert_row, ph)

        self._preview_lw  = target_lw
        self._preview_row = insert_row

        QTimer.singleShot(0, self._update_tier_layout)

    def resizeEvent(self, event):
        super().resizeEvent(event)
        self._layout_debounce.start()

    def showEvent(self, event):
        super().showEvent(event)
        QTimer.singleShot(0,   self._update_tier_layout)
        QTimer.singleShot(150, self._update_tier_layout)

    def _update_tier_layout(self):
        """Точный расчёт: list_widget = cols*cell (без остатка), лейбл = остаток."""
        if not self._tier_rows:
            return
        cell = TIER_COVER_W + 2
        sep  = 1
        label_min = cell
        label_max = cell * 2

        avail_w = self._tiers_scroll.viewport().width()
        if avail_w <= 0:
            return


        covers_space = avail_w - label_min - sep
        cols = max(1, covers_space // cell)
        lw_w = cols * cell + 1
        label_w = avail_w - lw_w - sep
        label_w = max(label_min, min(label_max, label_w))
        lw_w = avail_w - label_w - sep

        # Если ни один тир не заполнен до переноса (max элементов < cols),
        # лейбл не нужно растягивать — фиксируем его в минимум (ширина одного фильма).
        max_items = max(
            (len(self._tier_store.get(key, [])) for key in self._tier_rows),
            default=0
        )
        if max_items < cols:
            label_w = label_min
            lw_w = avail_w - label_w - sep

        for key, row_w in self._tier_rows.items():
            row_w.update_height(cols, label_w, lw_w)

        self._update_pool_height()
        self._tiers_container.adjustSize()
        self._tiers_container.update()
        QTimer.singleShot(100, self._request_visible_covers)

    def _save_tier_order(self, tier_key):
        if tier_key == '__pool__':
            return
        row_w = self._tier_rows.get(tier_key)
        if row_w:
            ids = row_w.item_ids()
            if self._active_set_id is None:
                self.db.reorder_tier(self._category_id, tier_key, ids)
            else:
                self.db.reorder_tier_set(self._active_set_id, tier_key, ids)

    def _find_lw_under_cursor(self, global_pos):
        # Сначала определяем какой виджет реально виден на экране в данной точке.
        # widgetAt учитывает z-order, clip region и viewport scroll area —
        # тир, прокрученный за пределы _tiers_scroll, не попадёт сюда.
        widget_at = QApplication.widgetAt(global_pos)

        # Проверяем тиры
        for key, row in self._tier_rows.items():
            vp = row.list_widget.viewport()
            # Виджет должен быть видим на экране И координата попадать в его rect
            if widget_at is vp and vp.rect().contains(vp.mapFromGlobal(global_pos)):
                return row.list_widget, key

        # Проверяем пул
        vp = self._pool.viewport()
        if widget_at is vp and vp.rect().contains(vp.mapFromGlobal(global_pos)):
            return self._pool, '__pool__'

        # Fallback: если widgetAt вернул дочерний виджет внутри viewport'а
        # (например, кастомный делегат создал child-widget), ищем через parentWidget
        if widget_at is not None:
            parent = widget_at.parentWidget()
            while parent is not None:
                for key, row in self._tier_rows.items():
                    if parent is row.list_widget.viewport():
                        vp = parent
                        if vp.rect().contains(vp.mapFromGlobal(global_pos)):
                            return row.list_widget, key
                if parent is self._pool.viewport():
                    vp = parent
                    if vp.rect().contains(vp.mapFromGlobal(global_pos)):
                        return self._pool, '__pool__'
                parent = parent.parentWidget()

        return None, None

    def _cancel_drag(self):
        if self._drag_ghost:
            self._drag_ghost.hide()
            self._drag_ghost.deleteLater()
            self._drag_ghost = None
        self._clear_preview()
        if self._drag_source_lw and self._drag_source_row >= 0:
            self._drag_source_lw.setRowHidden(self._drag_source_row, False)
            self._set_item_dragging(self._drag_source_lw, self._drag_source_row, False)
        self._drag_item_id    = None
        self._drag_cover_pix  = None
        self._drag_title      = None
        self._drag_entry      = None
        self._drag_source_lw  = None
        self._drag_source_key = None
        self._drag_source_row = -1
        self._drag_active     = False
        self._drag_start_pos  = None

    # ── Load ─────────────────────────────────────────────────────────
    def restore_pool_state(self):
        """Restore pool collapsed state from DB."""
        mw = self.window()
        if mw and hasattr(mw, 'db'):
            collapsed = mw.db.get_setting('tier_pool_collapsed', 'false') == 'true'
            self._pool_collapsed = collapsed
            self._pool.setVisible(not collapsed)
            self._pool_toggle_bar.setVisible(not collapsed)
            self._pool_toggle_bar_full.setVisible(collapsed)
            self._update_pool_toggle_icon()

    def load_category(self, category_id, sort_by='watch_date', ascending=False,
                      favorites_only=False, search_text='',
                      date_from=None, date_to=None):
        self._category_id = category_id
        self._tiers = self.db.get_tier_config(category_id)
        if hasattr(self, '_cb_map'):
            for cb_id in list(self._cb_map.keys()):
                CoverLoaderThread.instance().cancel(cb_id)
            self._cb_map.clear()
        if hasattr(self, '_cover_pending'):
            self._cover_pending.clear()
        self._date_from = date_from
        self._date_to   = date_to
        self._rebuild_tier_rows()
        self._populate_items(sort_by=sort_by, ascending=ascending,
                             favorites_only=favorites_only, search_text=search_text)

    def _rebuild_tier_rows(self):
        # Clear existing
        while self._tiers_layout.count():
            item = self._tiers_layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()
        self._tier_rows.clear()

        for t in self._tiers:
            key   = t['key']
            row_w = TierRowWidget(t['key'], t['label'], t['color'], self._tiers_container)
            # Делегат со store_getter — замыкание захватывает key по значению
            delegate = TierCoverDelegate(
                self,
                (lambda k: lambda: self._tier_store.get(k, []))(key),
                row_w.list_widget,
                pool=False
            )
            row_w.set_delegate(delegate)
            self._tiers_layout.addWidget(row_w)
            self._tier_rows[key] = row_w
            self._connect_tier_dnd(row_w)

        self._tiers_layout.setAlignment(Qt.AlignTop)

        # Пересоздаём делегат пула каждый раз чтобы избежать переиспользования Qt
        pool_delegate = TierCoverDelegate(self, lambda: self._pool_store, self._pool, pool=True)
        self._pool.setItemDelegate(pool_delegate)

    # ── Store — данные элементов ──────────────────────────────────────
    # _tier_store[tier_key] = [ [item_dict, pix_or_None, cropped_or_None], ... ]
    # _pool_store           = [ [item_dict, pix_or_None, cropped_or_None], ... ]

    def _build_stores(self, items_by_id, tier_assignments, assigned_ids, sorted_items=None):
        """Собрать _tier_store и _full_pool_store из данных БД."""
        self._tier_store = {}
        for t in self._tiers:
            key = t['key']
            entries = []
            for item_id in tier_assignments.get(key, []):
                item = items_by_id.get(item_id)
                if item:
                    entries.append([item, None, None])
                    assigned_ids.add(item_id)
            self._tier_store[key] = entries

        # _full_pool_store — все неотсортированные в нужном порядке (без поиска)
        pool_items = sorted_items if sorted_items is not None else list(items_by_id.values())
        self._full_pool_store = []
        pool_ids = []
        for item in pool_items:
            if item['id'] not in assigned_ids:
                self._full_pool_store.append([item, None, None])
                pool_ids.append(item['id'])

        # Загружаем users и cf_data батчем — для корректной работы predicate поиска
        users_map = self.db.get_users_for_items(pool_ids) if pool_ids else {}
        cf_map    = self.db.get_custom_fields_for_items_batch(pool_ids) if pool_ids else {}
        cf_fields = self.db.get_custom_fields()
        _empty    = []
        self._pool_meta = {
            item_id: (
                users_map.get(item_id, _empty),
                [(f, cf_map[item_id][f['id']]) for f in cf_fields
                 if item_id in cf_map and f['id'] in cf_map[item_id]]
            )
            for item_id in pool_ids
        }

        # _pool_store будет задан в _fill_pool_widget (после применения поиска)

    # ── Populate — создаём пустые QListWidgetItem ──────────────────────
    def _populate_items(self, sort_by='watch_date', ascending=False,
                        favorites_only=False, search_text=''):
        if not self._category_id:
            return

        # Все элементы без фильтров — для drag-and-drop и _build_stores
        self._all_items  = [dict(r) for r in self.db.get_items(self._category_id, date_from=self._date_from, date_to=self._date_to)]
        items_by_id      = {item['id']: item for item in self._all_items}
        # Берём расстановку из нужного сета
        if self._active_set_id is None:
            tier_assignments = self.db.get_tier_items(self._category_id)
        else:
            tier_assignments = self.db.get_tier_set_items(self._active_set_id)
        assigned_ids     = set()

        # Запоминаем текущие параметры пула
        self._pool_sort_by   = sort_by
        self._pool_ascending = ascending
        self._pool_favorites = favorites_only
        self._pool_search    = search_text

        # Отсортированный список элементов (sort/fav, без текстового поиска)
        sorted_items = [dict(r) for r in self.db.get_items(
            self._category_id, '', sort_by, ascending, favorites_only,
            date_from=self._date_from, date_to=self._date_to
        )]

        self._build_stores(items_by_id, tier_assignments, assigned_ids,
                           sorted_items=sorted_items)

        # Заполняем тир-ряды пустыми item'ами
        for t in self._tiers:
            key   = t['key']
            row_w = self._tier_rows.get(key)
            if not row_w:
                continue
            row_w.list_widget.setUpdatesEnabled(False)
            row_w.list_widget.model().blockSignals(True)
            row_w.list_widget.clear()
            for store_entry in self._tier_store.get(key, []):
                it = QListWidgetItem()
                it.setData(Qt.UserRole, store_entry[0]['id'])
                it.setSizeHint(QSize(TIER_COVER_W + 2, TIER_COVER_H))
                row_w.list_widget.addItem(it)
            row_w.list_widget.model().blockSignals(False)
            row_w.list_widget.setUpdatesEnabled(True)

        # Вычисляем единую ширину для всех тиров после layout
        QTimer.singleShot(0,   self._update_tier_layout)
        QTimer.singleShot(100, self._update_tier_layout)

        # Заполняем пул (с поддержкой поиска)
        self._fill_pool_widget(search_text)

        self._ensure_cover_loader()
        self._reconnect_pool_scroll()

        QTimer.singleShot(0,   self._request_visible_covers)
        QTimer.singleShot(250, self._request_visible_covers)

    def _toggle_pool(self):
        self._pool_collapsed = not self._pool_collapsed
        self._pool.setVisible(not self._pool_collapsed)
        self._pool_toggle_bar.setVisible(not self._pool_collapsed)
        self._pool_toggle_bar_full.setVisible(self._pool_collapsed)
        if not self._pool_collapsed:
            self._update_pool_height()
        self._update_pool_toggle_icon()
        mw = self.window()
        if mw and hasattr(mw, 'db'):
            mw.db.set_setting('tier_pool_collapsed',
                              'true' if self._pool_collapsed else 'false')

    def _update_pool_toggle_icon(self):
        self._pool_toggle_bar.update()
        self._pool_toggle_bar_full.update()

    def _update_pool_height(self):
        """Пересчитать высоту пула по аналогии с TierRowWidget.update_height."""
        n = self._pool.count()
        cell_w = TIER_COVER_W + 2
        cell_h = TIER_COVER_H
        avail_w = self._tiers_scroll.viewport().width()
        if avail_w <= 0:
            avail_w = self._pool.width()
        cols = max(1, avail_w // cell_w)
        MAX_POOL_ROWS = 2
        grid_rows = min(MAX_POOL_ROWS, max(1, (n + cols - 1) // cols))
        gap = TIER_ROW_GAP if grid_rows >= 2 else 0
        self._pool.setGridSize(QSize(cell_w, cell_h + gap))
        display_rows = max(2, grid_rows)
        total_h = cell_h * display_rows + TIER_ROW_GAP * (display_rows - 1)
        self._pool.setFixedHeight(total_h)
        # фиксируем ширину точно под cols ячеек только если первый ряд полный (n >= cols)
        # иначе — растягиваем на полную доступную ширину
        if n >= cols:
            sb_w = self._pool.verticalScrollBar().sizeHint().width()
            exact_w = cols * cell_w + 3 + sb_w
            self._pool.setFixedWidth(exact_w)
            self._pool_toggle_bar.setFixedWidth(exact_w)
        else:
            self._pool.setMinimumWidth(0)
            self._pool.setMaximumWidth(16777215)
            self._pool_toggle_bar.setMinimumWidth(0)
            self._pool_toggle_bar.setMaximumWidth(16777215)
            # форсируем растяжение на полную ширину
            if avail_w > 0:
                self._pool.setMinimumWidth(avail_w)
                self._pool_toggle_bar.setMinimumWidth(avail_w)

    def _fill_pool_widget(self, search_text=''):
        """Заполнить QListWidget пула из _full_pool_store, скрывая не совпадающие."""
        self._pool.setUpdatesEnabled(False)
        self._pool.model().blockSignals(True)
        self._pool.clear()
        for store_entry in self._full_pool_store:
            it = QListWidgetItem()
            it.setData(Qt.UserRole, store_entry[0]['id'])
            it.setSizeHint(QSize(TIER_COVER_W + 2, TIER_COVER_H))
            self._pool.addItem(it)
        self._pool.model().blockSignals(False)
        self._pool.setUpdatesEnabled(True)

        # _pool_store совпадает с _full_pool_store — делегат использует row напрямую
        self._pool_store = self._full_pool_store

        # Пересчитываем высоту под актуальное кол-во рядов
        self._update_pool_height()

        # Применяем текстовый фильтр поиска
        predicate = self._search_predicate_fn(search_text) if search_text.strip() else None
        self._apply_pool_search(search_text, predicate)

    def reload_pool(self, sort_by=None, ascending=None, favorites_only=None, search_text=None,
                    date_from=None, date_to=None):
        """Перезагрузить только пул (без тир-рядов): сортировка/фильтр/поиск."""
        if not self._category_id:
            return
        # Подхватываем переданные параметры, иначе оставляем текущие
        if sort_by        is not None: self._pool_sort_by   = sort_by
        if ascending      is not None: self._pool_ascending = ascending
        if favorites_only is not None: self._pool_favorites = favorites_only
        if search_text    is not None: self._pool_search    = search_text
        # date_from/date_to всегда обновляем — None означает "без фильтра"
        self._date_from = date_from
        self._date_to   = date_to

        assigned_ids = set()
        for entries in self._tier_store.values():
            for e in entries:
                assigned_ids.add(e[0]['id'])

        # Пересортированный/отфильтрованный пул из БД (sort+fav, без поиска)
        sorted_items = [dict(r) for r in self.db.get_items(
            self._category_id, '', self._pool_sort_by,
            self._pool_ascending, self._pool_favorites,
            date_from=getattr(self, '_date_from', None),
            date_to=getattr(self, '_date_to', None),
        )]

        # Сохраняем кэш обложек из полного стора
        cover_cache = {e[0]['id']: (e[1], e[2]) for e in self._full_pool_store if e[1]}

        self._full_pool_store = []
        pool_ids = []
        for item in sorted_items:
            if item['id'] not in assigned_ids:
                pix, crop = cover_cache.get(item['id'], (None, None))
                self._full_pool_store.append([item, pix, crop])
                pool_ids.append(item['id'])

        # Обновляем мета-данные для поиска
        users_map = self.db.get_users_for_items(pool_ids) if pool_ids else {}
        cf_map    = self.db.get_custom_fields_for_items_batch(pool_ids) if pool_ids else {}
        cf_fields = self.db.get_custom_fields()
        _empty    = []
        self._pool_meta = {
            item_id: (
                users_map.get(item_id, _empty),
                [(f, cf_map[item_id][f['id']]) for f in cf_fields
                 if item_id in cf_map and f['id'] in cf_map[item_id]]
            )
            for item_id in pool_ids
        }

        self._fill_pool_widget(self._pool_search)
        QTimer.singleShot(0,   self._request_visible_covers)
        QTimer.singleShot(150, self._request_visible_covers)

    def _apply_pool_search(self, search_text, predicate=None):
        """Скрыть/показать элементы пула по тексту поиска (без пересоздания виджетов)."""
        n = self._pool.count()
        self._pool.setUpdatesEnabled(False)
        try:
            if not search_text.strip():
                for row in range(n):
                    self._pool.setRowHidden(row, False)
            else:
                for row in range(n):
                    if row >= len(self._full_pool_store):
                        break
                    entry = self._full_pool_store[row]
                    item_id = entry[0]['id']
                    users, cf_data = (self._pool_meta or {}).get(item_id, ([], []))
                    # Формат entry совместимый с predicate: [item_data, users, cf_data, ...]
                    wrapped = [entry[0], users, cf_data]
                    hide = not predicate(wrapped) if predicate else False
                    self._pool.setRowHidden(row, hide)
        finally:
            self._pool.setUpdatesEnabled(True)
        # После изменения видимости строк Qt перерисовывает viewport —
        # только потом indexAt() вернёт корректный диапазон для загрузки обложек.
        # singleShot(0) попадает в ту же итерацию event loop (до repaint),
        # поэтому дублируем с задержкой чтобы гарантированно попасть после layout pass.
        QTimer.singleShot(0,   self._request_visible_covers)
        QTimer.singleShot(200, self._request_visible_covers)

    def _search_predicate_fn(self, search_text):
        """Получить predicate от MainWindow (он там уже реализован полностью)."""
        mw = self.window()
        if mw and hasattr(mw, '_build_search_predicate'):
            return mw._build_search_predicate(search_text)
        return lambda entry: True

    def add_item_to_pool(self, item_id, sort_by=None, ascending=None,
                         favorites_only=None, search_text=None,
                         date_from=None, date_to=None):
        """Добавить один новый элемент с учётом текущей сортировки/фильтра."""
        # Просто перезагружаем пул — он лёгкий (только пул, без тир-рядов)
        self.reload_pool(sort_by=sort_by, ascending=ascending,
                         favorites_only=favorites_only, search_text=search_text,
                         date_from=date_from, date_to=date_to)

    def _request_cover_for_pool_row(self, row, item_id, cover_path):
        """Запросить обложку для конкретной строки пула."""
        self._ensure_cover_loader()
        self._cb_counter += 1
        cb_id = self._cb_counter
        self._cb_map[cb_id] = ('pool', None, row)
        CoverLoaderThread.instance().put_task(cover_path, cb_id, 'tier_cover')

    # ── Cover loading — только viewport ───────────────────────────────
    def _ensure_cover_loader(self):
        if hasattr(self, '_cover_loader_ready'):
            return
        self._cover_loader_ready = True
        self._cb_counter = 0
        self._cb_map     = {}
        # Use unique connection to prevent duplicate signal connections on reload
        try:
            CoverLoaderThread.instance().cover_ready.disconnect(self._on_cover_ready)
        except TypeError:
            pass
        CoverLoaderThread.instance().cover_ready.connect(self._on_cover_ready)
        self._cover_pending = []
        self._cover_batch_timer = QTimer(self)
        self._cover_batch_timer.setInterval(30)
        self._cover_batch_timer.timeout.connect(self._flush_cover_updates)
        self._cover_batch_timer.start()
        # Debounce скролла
        self._scroll_debounce = QTimer(self)
        self._scroll_debounce.setSingleShot(True)
        self._scroll_debounce.setInterval(80)  # при быстром скролле ждём остановки
        self._scroll_debounce.timeout.connect(self._request_visible_covers)
        self._reconnect_pool_scroll()
        
    def _reconnect_pool_scroll(self):
        sb = self._pool.verticalScrollBar()
        try:
            sb.valueChanged.disconnect(self._on_pool_scroll_value)
        except TypeError:
            pass
        sb.valueChanged.connect(self._on_pool_scroll_value)
        try:
            sb.rangeChanged.disconnect(self._on_pool_range_changed)
        except TypeError:
            pass
        sb.rangeChanged.connect(self._on_pool_range_changed)

    def _on_pool_scroll_value(self, _val):
        """Скроллбар пула изменил позицию — запускаем дебаунс без передачи int."""
        self._scroll_debounce.start()

    def _on_pool_range_changed(self, min_val, max_val):
        """Scrollbar получил новый range — перезапрашиваем видимые обложки."""
        QTimer.singleShot(0, self._request_visible_covers)

    def _get_visible_rows(self, lw):
        """Видимые строки для wrapping grid (горизонтальный пул)."""
        vp   = lw.viewport()
        rect = vp.rect()
        n    = lw.count()
        if n == 0:
            return 0, 0

        # Для wrapping grid: берём все 4 угла viewport чтобы найти крайние индексы
        top_left     = lw.indexAt(rect.topLeft())
        top_right    = lw.indexAt(rect.topRight())
        bottom_left  = lw.indexAt(QPoint(rect.left(),  rect.bottom()))
        bottom_right = lw.indexAt(QPoint(rect.right(), rect.bottom()))

        rows = []
        for idx in (top_left, top_right, bottom_left, bottom_right):
            if idx.isValid():
                rows.append(idx.row())

        if not rows:
            return 0, min(59, n - 1)

        top    = min(rows)
        bottom = max(rows)

        # Если bottomRight не нашёлся (пустое место после последнего элемента) — берём последний
        if bottom == top and bottom_left.isValid():
            bottom = min(n - 1, bottom + 60)

        buf = 30
        return max(0, top - buf), min(n - 1, bottom + buf)

    def _request_visible_covers(self):
        self._ensure_cover_loader()

        # Тир-ряды — виртуальная подгрузка с учётом видимости в _tiers_scroll
        sa_vp      = self._tiers_scroll.viewport()
        sa_vp_rect = sa_vp.rect()

        # Отменяем старые задачи тиров
        old_tier_ids = [cid for cid, v in list(self._cb_map.items()) if v[0] == 'tier']
        for cid in old_tier_ids:
            self._cb_map.pop(cid, None)
            CoverLoaderThread.instance().cancel(cid)

        for key, row_w in self._tier_rows.items():
            store = self._tier_store.get(key, [])
            lw    = row_w.list_widget
            n     = lw.count()
            if n == 0:
                continue

            # Проверяем, виден ли вообще этот тир-ряд в scroll area
            row_geom_in_sa = sa_vp.mapFromGlobal(row_w.mapToGlobal(QPoint(0, 0)))
            row_rect_in_sa = QRect(row_geom_in_sa, row_w.size())
            if not row_rect_in_sa.intersects(sa_vp_rect):
                # Ряд не виден — evict его обложки из памяти
                for entry in store:
                    if entry[1] is not None:
                        entry[1] = None
                        entry[2] = None
                        if len(entry) > 6: entry[6] = None  # invalidate parts cache
                continue

            # Ряд виден — определяем какая часть его viewport реально видна в _tiers_scroll
            vp   = lw.viewport()
            vp_w = vp.width()

            # Переводим видимую область scroll area в координаты viewport тир-ряда
            sa_visible_in_vp_tl = vp.mapFromGlobal(sa_vp.mapToGlobal(sa_vp_rect.topLeft()))
            sa_visible_in_vp_br = vp.mapFromGlobal(sa_vp.mapToGlobal(sa_vp_rect.bottomRight()))
            clip_y0 = max(0, sa_visible_in_vp_tl.y())
            clip_y1 = min(vp.height() - 1, sa_visible_in_vp_br.y())

            if clip_y0 > clip_y1:
                continue

            candidate_rows = set()
            for fy in range(clip_y0, clip_y1 + 1, max(1, (clip_y1 - clip_y0) // 8)):
                for fx in [0, vp_w // 4, vp_w // 2, 3 * vp_w // 4, vp_w - 1]:
                    idx = lw.indexAt(QPoint(fx, fy))
                    if idx.isValid():
                        candidate_rows.add(idx.row())
            # Добавляем нижнюю границу явно
            for fx in [0, vp_w // 4, vp_w // 2, 3 * vp_w // 4, vp_w - 1]:
                idx = lw.indexAt(QPoint(fx, clip_y1))
                if idx.isValid():
                    candidate_rows.add(idx.row())

            if not candidate_rows:
                r0, r1 = 0, n - 1
            else:
                # Вычисляем cols напрямую из геометрии
                cols = 1
                if n > 1:
                    r0v = lw.visualRect(lw.model().index(0, 0))
                    r1v = lw.visualRect(lw.model().index(1, 0))
                    if r1v.top() == r0v.top() and r0v.width() > 0:
                        cols = max(1, vp_w // r0v.width())
                BUF  = cols * 2
                r0   = max(0, min(candidate_rows) - BUF)
                r1   = min(n - 1, max(candidate_rows) + BUF)

            # Evict далёкие обложки
            EVICT = max(60, (r1 - r0 + 1) * 2)
            for row, entry in enumerate(store):
                if entry[1] is not None and (row < r0 - EVICT or row > r1 + EVICT):
                    entry[1] = None
                    entry[2] = None
                    if len(entry) > 6: entry[6] = None  # invalidate parts cache

            # Грузим видимые (LIFO)
            rows_to_load = [r for r in range(r0, r1 + 1)
                            if r < len(store) and store[r][1] is None
                            and store[r][0].get('cover_path')]
            for row in reversed(rows_to_load):
                self._cb_counter += 1
                cb_id = self._cb_counter
                self._cb_map[cb_id] = ('tier', key, row)
                CoverLoaderThread.instance().put_task(
                    store[row][0]['cover_path'], cb_id, 'tier_cover')

        # Пул — виртуальная подгрузка видимых обложек
        store = self._pool_store
        if not store:
            return

        lw = self._pool
        vp = lw.viewport()
        # lw.count() включает скрытые строки — используем его для граничных проверок,
        # но реально видимых строк может быть меньше (поиск скрывает часть через setRowHidden).
        n  = lw.count()
        if n == 0:
            return

        vp_w, vp_h = vp.width(), vp.height()

        # ── БАГ 1: cols вычислялся по строкам 0 и 1, которые могут быть СКРЫТЫ поиском.
        # Находим два первых ВИДИМЫХ индекса для корректного вычисления ширины колонки.
        cols = 1
        visible_indices_for_cols = []
        for r in range(n):
            if not lw.isRowHidden(r):
                visible_indices_for_cols.append(r)
            if len(visible_indices_for_cols) == 2:
                break
        if len(visible_indices_for_cols) >= 2:
            rv0 = lw.visualRect(lw.model().index(visible_indices_for_cols[0], 0))
            rv1 = lw.visualRect(lw.model().index(visible_indices_for_cols[1], 0))
            if rv1.top() == rv0.top() and rv0.width() > 0:
                cols = max(1, vp_w // rv0.width())
        elif len(visible_indices_for_cols) == 1:
            rv0 = lw.visualRect(lw.model().index(visible_indices_for_cols[0], 0))
            if rv0.width() > 0:
                cols = max(1, vp_w // rv0.width())

        # ── БАГ 2: indexAt возвращает row в терминах МОДЕЛИ (включая скрытые строки).
        # candidate_rows содержит правильные индексы модели — это ок, store индексируется так же.
        # Проверяем 15 точек по viewport чтобы покрыть wrapping grid.
        candidate_rows = set()
        for fy in [0, vp_h // 4, vp_h // 2, 3 * vp_h // 4, vp_h - 1]:
            for fx in [0, vp_w // 4, vp_w // 2, 3 * vp_w // 4, vp_w - 1]:
                idx = lw.indexAt(QPoint(fx, fy))
                if idx.isValid():
                    candidate_rows.add(idx.row())

        if not candidate_rows:
            return

        top    = max(0, min(candidate_rows))
        bottom = min(n - 1, max(candidate_rows))

        # Буфер — 2 строки сверху и снизу
        BUF = cols * 2
        top    = max(0, top - BUF)
        bottom = min(n - 1, bottom + BUF)

        # ── БАГ 3: range(top, bottom+1) включает скрытые строки поиска.
        # При поиске видимые строки могут быть разрежены: например строки 0,5,12,20...
        # Буфер top-BUF..bottom+BUF захватывает правильный диапазон модели,
        # но нужно ТАКЖЕ загрузить все видимые строки вне этого диапазона,
        # которые уже отрендерены на экране (indexAt мог не захватить крайние элементы
        # в сетке при разреженных скрытых строках).
        # Решение: собираем все видимые строки в диапазоне [top, bottom],
        # плюс расширяем буфер по видимым строкам (не по номерам подряд).
        visible_in_range = [r for r in range(top, bottom + 1) if not lw.isRowHidden(r)]

        # Расширяем буфер: берём BUF видимых строк до top и после bottom
        buf_before = []
        count_before = 0
        for r in range(top - 1, -1, -1):
            if not lw.isRowHidden(r):
                buf_before.append(r)
                count_before += 1
                if count_before >= BUF:
                    break
        buf_after = []
        count_after = 0
        for r in range(bottom + 1, n):
            if not lw.isRowHidden(r):
                buf_after.append(r)
                count_after += 1
                if count_after >= BUF:
                    break

        rows_visible_set = set(visible_in_range + buf_before + buf_after)

        # Отменяем старые задачи пула
        old_pool_ids = [cid for cid, v in list(self._cb_map.items()) if v[0] == 'pool']
        for cid in old_pool_ids:
            self._cb_map.pop(cid, None)
            CoverLoaderThread.instance().cancel(cid)

        # Выгружаем из памяти строки которые не в видимом наборе (с запасом)
        EVICT_THRESHOLD = BUF * 4
        for row, entry in enumerate(store):
            if entry[1] is not None and row not in rows_visible_set:
                # Evict только если далеко от любого видимого (не просто не в наборе)
                min_visible = min(rows_visible_set) if rows_visible_set else 0
                max_visible = max(rows_visible_set) if rows_visible_set else 0
                if row < min_visible - EVICT_THRESHOLD or row > max_visible + EVICT_THRESHOLD:
                    entry[1] = None
                    entry[2] = None
                    if len(entry) > 6: entry[6] = None  # invalidate parts cache

        # Грузим видимые + буфер (LIFO — в обратном порядке = видимые первыми)
        loader = CoverLoaderThread.instance()
        rows_to_load = [r for r in rows_visible_set
                        if r < len(store) and store[r][1] is None
                        and store[r][0].get('cover_path')]
        # Сортируем: сначала те что ближе к центру видимой области (приоритет)
        if rows_visible_set:
            center = (min(rows_visible_set) + max(rows_visible_set)) // 2
            rows_to_load.sort(key=lambda r: abs(r - center), reverse=True)  # reverse=LIFO
        for row in rows_to_load:
            self._cb_counter += 1
            cb_id = self._cb_counter
            self._cb_map[cb_id] = ('pool', None, row)
            loader.put_task(store[row][0]['cover_path'], cb_id, 'tier_cover')

    def _on_cover_ready(self, cb_id, pixmap):
        entry = self._cb_map.pop(cb_id, None)
        if not entry:
            return
        src_type, key, store_row = entry

        if src_type == 'tier':
            store = self._tier_store.get(key, [])
            if store_row >= len(store):
                return
            store[store_row][1] = pixmap
            store[store_row][2] = None   # сброс кропа
            row_w = self._tier_rows.get(key)
            if row_w:
                self._cover_pending.append((row_w.list_widget, store_row))
        else:
            store = self._pool_store
            if store_row >= len(store):
                return
            store[store_row][1] = pixmap
            store[store_row][2] = None
            # Обновляем сразу — без батчинга, иначе скролл уходит дальше
            idx = self._pool.model().index(store_row, 0)
            if idx.isValid():
                self._pool.update(idx)

    def _flush_cover_updates(self):
        if not self._cover_pending:
            return
        pending, self._cover_pending = self._cover_pending, []
        # Группируем по lw чтобы вызывать update реже
        lw_rows = {}
        for lw, row in pending:
            lw_rows.setdefault(id(lw), (lw, []))[1].append(row)
        for _, (lw, rows) in lw_rows.items():
            for row in rows:
                idx = lw.model().index(row, 0)
                if idx.isValid():
                    lw.update(idx)

    # ── Settings ─────────────────────────────────────────────────────
    def _open_settings(self):
        def _on_tiers_change(new_tiers):
            self.db.set_tier_config(self._category_id, new_tiers)
            self.load_category(
                self._category_id,
                sort_by=self._pool_sort_by,
                ascending=self._pool_ascending,
                favorites_only=self._pool_favorites,
                search_text=self._pool_search,
            )

        dlg = TierConfigDialog(self._tiers, self.translations, self,
                               on_change=_on_tiers_change,
                               main_window=self.window())
        dlg.exec_()

    def switch_set(self, set_id):
        """Switch active tier-list set. set_id=None means Main."""
        self._active_set_id = set_id
        self.load_category(
            self._category_id,
            sort_by=self._pool_sort_by,
            ascending=self._pool_ascending,
            favorites_only=self._pool_favorites,
            search_text=self._pool_search,
            date_from=self._date_from,
            date_to=self._date_to,
        )

    def clear(self):
        self._category_id = None
        while self._tiers_layout.count():
            item = self._tiers_layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()
        self._tier_rows.clear()
        self._pool.clear()

class _NoManualResizeMixin(_AdaptiveHeightMixin):
    """Lock window width, allow dynamic height for content changes."""
    def _lock_size(self):
        self.setMaximumSize(16777215, 16777215)
        self.adjustSize()
        w = max(self.sizeHint().width(), self.minimumWidth())
        h = max(self.sizeHint().height(), self.minimumHeight())
        # Сохраняем реальную высоту содержимого до того как setFixedSize/setWindowFlags могут её сбросить
        self._content_hint_h = h
        self.setFixedSize(w, h)

    def _refit(self):
        """Перерахувати висоту після show/hide вкладеного контенту."""
        # Если скролл уже применён — не трогаем высоту, иначе сломаем скролл-обёртку
        if getattr(self, '_scroll_applied', False):
            self.setUpdatesEnabled(False)
            self.setUpdatesEnabled(True)
            self.update()
            return
        self.setUpdatesEnabled(False)
        self.setMaximumSize(16777215, 16777215)
        self.adjustSize()
        w = max(self.sizeHint().width(), self.minimumWidth())
        h = max(self.sizeHint().height(), self.minimumHeight())
        self.setFixedSize(w, h)
        self.setUpdatesEnabled(True)
        self.update()

    def show(self):
        self._lock_size()
        super().show()

    def exec_(self):
        self._lock_size()
        return super().exec_()

    def showEvent(self, event):
        super().showEvent(event)
        self._apply_scroll_if_needed()

class ImportDiffDialog(_NoManualResizeMixin, QDialog):
    """
    Universal diff dialog shown before any import.

    Displays three sections (custom fields, options, users) grouped under
    collapsible-style headers.  Each row has a checkbox so the user can
    deselect individual changes.

    After exec_() == Accepted, read back:
        .apply_new_fields     → bool
        .apply_changed_fields → set of variable names to update
        .apply_new_options    → bool
        .apply_changed_options→ set of (variable, old_label) to rename
        .apply_new_users      → bool
    """

    # ── tiny helpers ──────────────────────────────────────────────────
    @staticmethod
    def _attr_label(attr):
        return {
            'name':                 'Name',
            'icon':                 'Icon',
            'field_type':           'Type',
            'type_options':         'Type options',
            'show_in_list':         'Show in list',
            'show_in_list_compact': 'Show in compact',
            'show_in_detail':       'Show in detail',
            'show_in_context_menu': 'Context menu',
            'context_menu_label':   'Context label',
            'show_name_in_list':    'Show name',
            'name_color':           'Name colour',
            'search_filter':        'Search prefix',
        }.get(attr, attr)

    @staticmethod
    def _section_header(text, parent=None):
        lbl = QLabel(text)
        lbl.setStyleSheet(
            'font-weight: bold; color: #ffffff; '
            'background: #2d2d2d; padding: 4px 6px; '
            'border-radius: 3px; margin-top: 6px;'
        )
        return lbl

    @staticmethod
    def _no_changes_label(text='No changes'):
        lbl = QLabel(f'  {text}')
        lbl.setStyleSheet('color: #666; font-size: 11px; padding: 2px 6px;')
        return lbl

    # ── constructor ───────────────────────────────────────────────────
    def __init__(self, diff, translations=None, parent=None, icons_dir=None, zip_src=None, icons_prefix=None):
        super().__init__(parent)
        self._tr  = translations or {}
        self._diff = diff
        self._icons_dir = icons_dir
        self._zip_src = zip_src
        self._icons_prefix = icons_prefix

        self.setWindowTitle(self._tr.get('import_diff_title', 'Import — Preview Changes'))
        self.setMinimumWidth(520)
        self.setMinimumHeight(360)

        root = QVBoxLayout(self)
        root.setSpacing(4)

        # Subtitle
        sub = QLabel(self._tr.get(
            'import_diff_subtitle',
            'Review what will be added or changed. Uncheck items to skip them.'
        ))
        sub.setWordWrap(True)
        sub.setStyleSheet('color: #aaa; font-size: 11px; padding-bottom: 4px;')
        root.addWidget(sub)

        # Scrollable content
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setFrameShape(QScrollArea.NoFrame)
        scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        scroll.setMaximumHeight(480)

        content = QWidget()
        self._vbox = QVBoxLayout(content)
        self._vbox.setSpacing(2)
        self._vbox.setContentsMargins(4, 4, 4, 4)

        # Checkbox refs
        self._cb_new_fields    = []   # list of (QCheckBox, field_row)
        self._cb_chg_fields    = []   # list of (QCheckBox, db_f, csv_row, diffs)
        self._cb_new_options   = []   # list of (QCheckBox, var, label)
        self._cb_chg_options   = []   # list of (QCheckBox, var, old_label, new_label)
        self._cb_new_users     = []   # list of (QCheckBox, name)

        self._build_content()

        self._vbox.addStretch()
        scroll.setWidget(content)
        root.addWidget(scroll, 1)

        # Buttons
        btn_row = QHBoxLayout()
        btn_row.addStretch()
        ok_btn     = QPushButton(self._tr.get('import_apply', 'Apply'))
        cancel_btn = QPushButton(self._tr.get('cancel', 'Cancel'))
        ok_btn.setDefault(True)
        ok_btn.clicked.connect(self.accept)
        cancel_btn.clicked.connect(self.reject)
        btn_row.addWidget(ok_btn)
        btn_row.addWidget(cancel_btn)
        root.addLayout(btn_row)

    # ── content builder ───────────────────────────────────────────────
    def _build_content(self):
        diff  = self._diff
        tr    = self._tr

        FTYPE_LABEL = {
            'boolean': self._tr.get('ftype_boolean', 'Checkbox'),
            'string':  self._tr.get('ftype_string',  'Text'),
            'integer': self._tr.get('ftype_integer', 'Integer'),
            'slider':  self._tr.get('ftype_slider',  'Slider'),
            'select':  self._tr.get('ftype_select',  'Select list'),
            'marks':   self._tr.get('ftype_marks',   'Marks (checkboxes)'),
            'date':    self._tr.get('ftype_date',    'Date'),
        }

        def _icon_pixmap(v, size=18):
            v = str(v or '')
            if not v:
                return None
            sc   = _get_dpr()
            phys = round(size * sc)
            def _scale(qpx):
                if qpx.isNull():
                    return None
                scaled = qpx.scaled(phys, phys, Qt.KeepAspectRatio, Qt.SmoothTransformation)
                scaled.setDevicePixelRatio(sc)
                return scaled
            if v.startswith('file:base64:') and v.count(':') >= 3:
                try:
                    raw = base64.b64decode(v.split(':', 3)[3])
                    qpx = QPixmap(); qpx.loadFromData(raw)
                    return _scale(qpx)
                except Exception:
                    pass
                return None
            if v.startswith('file:folder:'):
                fname = v.split(':', 2)[2]
                if self._zip_src and self._icons_prefix:
                    try:
                        with zipfile.ZipFile(self._zip_src, 'r') as zf:
                            data = zf.read(self._icons_prefix + fname)
                        qpx = QPixmap()
                        qpx.loadFromData(data)
                        return _scale(qpx)
                    except Exception:
                        pass
                for candidate in [
                    os.path.join(self._icons_dir, fname) if self._icons_dir else None,
                    str(DATA_DIR / '.assets' / fname),
                ]:
                    if candidate and os.path.exists(candidate):
                        return _scale(QPixmap(candidate))
                return None
            if v.startswith('file:'):
                abs_p = to_absolute_path(v[5:])
                if abs_p and os.path.exists(abs_p):
                    return _scale(QPixmap(abs_p))
            return None

        def _icon_widget(icon_val, emoji_fallback=''):
            lbl = QLabel()
            lbl.setFixedSize(18, 18)
            lbl.setAlignment(Qt.AlignCenter)
            v = str(icon_val or '')
            px = _icon_pixmap(v) if v.startswith('file:') else None
            if px:
                lbl.setPixmap(px)
            elif v and not v.startswith('file:'):
                # plain emoji or text icon — show it directly
                lbl.setText(v)
                lbl.setStyleSheet('font-size: 12px;')
            elif emoji_fallback:
                lbl.setText(emoji_fallback)
                lbl.setStyleSheet('font-size: 12px;')
            return lbl

        def _sub_label(html):
            lbl = QLabel(html)
            lbl.setTextFormat(Qt.RichText)
            lbl.setStyleSheet('font-size: 11px; color: #888; padding: 0 6px 1px 28px;')
            lbl.setWordWrap(True)
            return lbl

        def _field_row_widget(icon_val, name, var, ftype, checked, default_checked=True):
            """Build a checkbox row: [cb] [icon] Name  [var · Type]"""
            row_w = QWidget()
            row_l = QHBoxLayout(row_w)
            row_l.setContentsMargins(6, 1, 6, 1)
            row_l.setSpacing(4)
            cb = QCheckBox()
            cb.setChecked(checked)
            row_l.addWidget(cb)
            row_l.addWidget(_icon_widget(icon_val, '🧩'))
            type_str = FTYPE_LABEL.get(ftype, ftype)
            name_lbl = QLabel(
                f'<span style="font-size:12px;">{self._esc(name)}</span>'
                f'  <span style="color:#888; font-size:11px;">'
                f'[{self._esc(var)} · {self._esc(type_str)}]</span>'
            )
            name_lbl.setTextFormat(Qt.RichText)
            row_l.addWidget(name_lbl, 1)
            return row_w, cb

        # ── Custom fields — new ───────────────────────────────────────
        new_fields = diff.get('new_fields', [])
        if new_fields:
            self._vbox.addWidget(self._section_header(
                tr.get('diff_new_fields', '✚ New custom fields')
            ))
            for row in new_fields:
                var   = row.get('variable', '')
                name  = row.get('name', var)
                ftype = row.get('field_type', 'string')
                icon  = row.get('icon', '')

                row_w, cb = _field_row_widget(icon, name, var, ftype, checked=True)
                self._vbox.addWidget(row_w)

                self._cb_new_fields.append((cb, row))

        # ── Custom fields — changed ───────────────────────────────────
        chg_fields = diff.get('changed_fields', [])
        if chg_fields:
            self._vbox.addWidget(self._section_header(
                tr.get('diff_changed_fields', '✎ Changed custom fields')
            ))
            for db_f, csv_row, diffs in chg_fields:
                var   = db_f['variable']
                name  = db_f['name']
                ftype = db_f.get('field_type', 'string')
                icon  = csv_row.get('icon', db_f.get('icon', ''))

                row_w, cb = _field_row_widget(icon, name, var, ftype, checked=False)
                self._vbox.addWidget(row_w)

                for attr in diffs:
                    db_raw  = db_f.get(attr) or ''
                    csv_raw = csv_row.get(attr) or ''
                    if attr == 'icon':
                        icon_row = QWidget()
                        icon_l   = QHBoxLayout(icon_row)
                        icon_l.setContentsMargins(28, 0, 6, 1)
                        icon_l.setSpacing(4)
                        attr_lbl = QLabel(f'{self._attr_label(attr)}:')
                        attr_lbl.setStyleSheet('font-size: 11px; color: #888;')
                        icon_l.addWidget(attr_lbl)
                        for val, color in ((db_raw, '#e06060'), (csv_raw, '#60c060')):
                            ico_lbl = QLabel()
                            ico_lbl.setFixedSize(18, 18)
                            ico_lbl.setAlignment(Qt.AlignCenter)
                            px = _icon_pixmap(val)
                            if px:
                                ico_lbl.setPixmap(px)
                            else:
                                ico_lbl.setText('∅' if not val else '?')
                                ico_lbl.setStyleSheet(f'color:{color}; font-size:11px;')
                            icon_l.addWidget(ico_lbl)
                            if val is db_raw:
                                arr = QLabel('→')
                                arr.setStyleSheet('color:#888; font-size:11px;')
                                icon_l.addWidget(arr)
                        icon_l.addStretch()
                        self._vbox.addWidget(icon_row)
                    else:
                        _empty_html = '<span style="color:#555; font-style:italic;">empty</span>'
                        db_show  = self._esc(str(db_raw))  if db_raw  else None
                        csv_show = self._esc(str(csv_raw)) if csv_raw else None
                        db_html  = f'<span style="color:#e06060;">{db_show}</span>'  if db_show  else _empty_html
                        csv_html = f'<span style="color:#60c060;">{csv_show}</span>' if csv_show else _empty_html
                        self._vbox.addWidget(_sub_label(
                            f'{self._attr_label(attr)}:  '
                            f'{db_html}'
                            f' → '
                            f'{csv_html}'
                        ))

                self._cb_chg_fields.append((cb, db_f, csv_row, diffs))

        # ── Field options — new ───────────────────────────────────────
        new_opts = diff.get('new_options', [])
        if new_opts:
            self._vbox.addWidget(self._section_header(
                tr.get('diff_new_options', '✚ New field options')
            ))
            opts_by_var = OrderedDict()
            for var, label in new_opts:
                opts_by_var.setdefault(var, []).append(label)
            var_to_name = {r.get('variable', ''): r.get('name', r.get('variable', ''))
                           for r in diff.get('new_fields', [])}
            for var, labels in opts_by_var.items():
                field_name = var_to_name.get(var, var)
                grp_lbl = QLabel(
                    f'  {self._esc(field_name)}'
                    f'  <span style="color:#666; font-size:11px;">[{self._esc(var)}]</span>'
                )
                grp_lbl.setTextFormat(Qt.RichText)
                grp_lbl.setStyleSheet('font-size: 12px; color: #ccc; padding: 2px 6px 0 6px;')
                self._vbox.addWidget(grp_lbl)
                for label in labels:
                    cb = QCheckBox(label)
                    cb.setChecked(True)
                    cb.setStyleSheet('padding: 1px 6px 1px 24px; font-size: 12px;')
                    self._vbox.addWidget(cb)
                    self._cb_new_options.append((cb, var, label))

        # ── Field options — renamed ───────────────────────────────────
        chg_opts = diff.get('changed_options', [])
        if chg_opts:
            self._vbox.addWidget(self._section_header(
                tr.get('diff_changed_options', '✎ Renamed field options')
            ))
            # Группируем по полю и показываем имя поля как заголовок
            _chg_by_var = OrderedDict()
            for var, old_label, new_label in chg_opts:
                _chg_by_var.setdefault(var, []).append((old_label, new_label))
            # Имена полей из БД
            _db_fields_map = {dict(f)['variable']: dict(f)['name'] for f in diff.get('_db_fields', [])}
            # Также ищем в changed_fields и new_fields для полноты
            for _dbf, _csvr, _ in diff.get('changed_fields', []):
                _db_fields_map[_dbf['variable']] = _dbf['name']
            for _nf in diff.get('new_fields', []):
                _db_fields_map[_nf.get('variable', '')] = _nf.get('name', _nf.get('variable', ''))
            for var, pairs in _chg_by_var.items():
                field_name = _db_fields_map.get(var, var)
                grp_lbl = QLabel(
                    f'  {self._esc(field_name)}'
                    f'  <span style="color:#666; font-size:11px;">[{self._esc(var)}]</span>'
                )
                grp_lbl.setTextFormat(Qt.RichText)
                grp_lbl.setStyleSheet('font-size: 12px; color: #ccc; padding: 2px 6px 0 6px;')
                self._vbox.addWidget(grp_lbl)
                for old_label, new_label in pairs:
                    cb = QCheckBox(f'"{old_label}"  →  "{new_label}"')
                    cb.setChecked(False)
                    cb.setStyleSheet('padding: 1px 6px 1px 24px; font-size: 12px;')
                    self._vbox.addWidget(cb)
                    self._cb_chg_options.append((cb, var, old_label, new_label))

        # ── Users — new ───────────────────────────────────────────────
        new_users = diff.get('new_users', [])
        if new_users:
            self._vbox.addWidget(self._section_header(
                tr.get('diff_new_users', '✚ New users')
            ))
            for name in new_users:
                cb = QCheckBox(f'👤  {name}')
                cb.setChecked(True)
                cb.setStyleSheet('padding: 1px 6px; font-size: 12px;')
                self._vbox.addWidget(cb)
                self._cb_new_users.append((cb, name))

        if not any([new_fields, chg_fields, new_opts, chg_opts, new_users]):
            self._vbox.addWidget(self._no_changes_label(
                tr.get('diff_nothing', 'Nothing to import.')
            ))
    # ── result accessors (call after exec_() == Accepted) ─────────────
    @property
    def apply_new_fields(self):
        # True if at least one new-field cb is checked (apply_csv_apply
        # uses the per-row flag via the checked set below)
        return any(cb.isChecked() for cb, _ in self._cb_new_fields)

    @property
    def apply_changed_fields(self):
        return {db_f['variable'] for cb, db_f, _, _ in self._cb_chg_fields if cb.isChecked()}

    @property
    def apply_new_options(self):
        return any(cb.isChecked() for cb, _, _ in self._cb_new_options)

    @property
    def apply_changed_options(self):
        return {(var, old) for cb, var, old, _ in self._cb_chg_options if cb.isChecked()}

    @property
    def apply_new_users(self):
        return any(cb.isChecked() for cb, _ in self._cb_new_users)

    # Selected new_fields / new_users subsets (for granular control)
    @property
    def selected_new_fields(self):
        return [row for cb, row in self._cb_new_fields if cb.isChecked()]

    @property
    def selected_new_users(self):
        return [name for cb, name in self._cb_new_users if cb.isChecked()]

    @property
    def selected_new_options(self):
        return [(var, label) for cb, var, label in self._cb_new_options if cb.isChecked()]

    # ── helpers ───────────────────────────────────────────────────────
    @staticmethod
    def _esc(text):
        """HTML-escape for inline RichText labels."""
        return (text
                .replace('&', '&amp;')
                .replace('<', '&lt;')
                .replace('>', '&gt;')
                [:80])   # truncate very long values

    # ── class method: show and return applied sets ────────────────────
    @classmethod
    def run(cls, diff, translations=None, parent=None, icons_dir=None, zip_src=None, icons_prefix=None):
        """
        Show the dialog.
        Returns (accepted: bool, dialog: ImportDiffDialog).
        Caller reads dialog.apply_* properties.
        Returns (False, None) if nothing to show.
        """
        has_anything = any([
            diff.get('new_fields'),
            diff.get('changed_fields'),
            diff.get('new_options'),
            diff.get('changed_options'),
            diff.get('new_users'),
        ])
        if not has_anything:
            return True, None   # nothing to diff — proceed silently

        dlg = cls(diff, translations=translations, parent=parent, icons_dir=icons_dir, zip_src=zip_src, icons_prefix=icons_prefix)
        accepted = dlg.exec_() == QDialog.Accepted
        return accepted, dlg


class CustomFieldDialog(_AdaptiveHeightMixin, QDialog):
    """Диалог создания/редактирования кастомного поля"""

    FIELD_TYPES = [
        ('boolean',  'checkbox', 'ftype_boolean'),
        ('string',   'string',   'ftype_string'),
        ('integer',  'integer',  'ftype_integer'),
        ('slider',   'slider',   'ftype_slider'),
        ('select',   'select',   'ftype_select'),
        ('marks',    'marks',    'ftype_marks'),
        ('date',     'date',     'ftype_date'),
    ]
    FTYPE_DEFAULTS = {
        'ftype_boolean': 'Checkbox',
        'ftype_string':  'Text',
        'ftype_integer': 'Integer',
        'ftype_slider':  'Slider',
        'ftype_select':  'Select list',
        'ftype_marks':   'Marks (checkboxes)',
        'ftype_date':    'Date',
    }

    def __init__(self, parent, db, translations, field_id=None):
        super().__init__(parent)
        self.db = db
        self.translations = translations
        self._field_id = field_id
        self.is_edit = field_id is not None
        self._file_icon = [None]
        self._original_icon_file = [None]   # оригинальный файл иконки при редактировании
        self._pending_icon_delete = []       # промежуточные файлы для удаления после OK
        self.setWindowTitle(
            translations.get('edit_custom_field', 'Edit Custom Field')
            if self.is_edit else
            translations.get('new_custom_field', 'New Custom Field')
        )
        self.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        self.setWindowFlags(self.windowFlags() & ~Qt.WindowMaximizeButtonHint & ~Qt.WindowContextHelpButtonHint)
        self.setFixedWidth(400)
        self.init_ui()
        if self.is_edit:
            self.load_data()

    def showEvent(self, event):
        super().showEvent(event)
        self._apply_scroll_if_needed()

    def _refit(self):
        if getattr(self, '_scroll_applied', False):
            self.update()
            return
        if self.isVisible():
            self.setUpdatesEnabled(False)
            try:
                self.setMinimumHeight(0)
                self.setMaximumHeight(16777215)
                self.adjustSize()
            finally:
                self.setUpdatesEnabled(True)
                self.update()

    def init_ui(self):
        layout = QVBoxLayout(self)
        layout.setSizeConstraint(QVBoxLayout.SetDefaultConstraint)
        self.setSizePolicy(QSizePolicy.Fixed, QSizePolicy.Preferred)

        if self.is_edit:
            self._current_field = self.db.get_custom_field_by_id(self._field_id)
            fd = dict(self._current_field) if self._current_field else {}
            ftype = fd.get('field_type', 'string')
            self._edit_field_type = ftype
            type_label_map = {
                ft: self.translations.get(tr_key, self.FTYPE_DEFAULTS.get(tr_key, tr_key))
                for ft, _, tr_key in self.FIELD_TYPES
            }

            var_row = QHBoxLayout()
            var_row.setSpacing(4)
            var_row.addWidget(QLabel(self.translations.get('custom_field_variable', 'Variable:')))
            var_lbl = QLabel(fd.get('variable', ''))
            var_lbl.setStyleSheet('color: #aaa;')
            var_row.addWidget(var_lbl)
            var_row.addStretch()
            layout.addLayout(var_row)

            type_row = QHBoxLayout()
            type_row.setSpacing(4)
            type_row.addWidget(QLabel(self.translations.get('custom_field_type', 'Type:')))
            tl = QLabel(type_label_map.get(ftype, ftype))
            tl.setStyleSheet('color: #aaa;')
            type_row.addWidget(tl)
            type_row.addStretch()
            layout.addLayout(type_row)

        layout.addWidget(QLabel(self.translations.get('name', 'Name')))
        self.name_edit = QLineEdit()
        layout.addWidget(self.name_edit)

        layout.addWidget(QLabel(self.translations.get('icon', 'Icon')))
        icon_row = QHBoxLayout()
        icon_row.setSpacing(0)
        self.icon_preview = QLabel()
        self.icon_preview.setFixedSize(32, 32)
        self.icon_preview.setAlignment(Qt.AlignCenter)
        icon_row.addWidget(self.icon_preview)

        self.icon_edit = QLineEdit()
        self.icon_edit.setPlaceholderText('🧩')
        icon_row.addWidget(self.icon_edit)

        icon_pick_btn = QPushButton('📂')
        icon_pick_btn.setFixedSize(32, self.icon_edit.sizeHint().height())
        icon_row.addWidget(icon_pick_btn)

        self.icon_remove_btn = QPushButton()
        self._icon_btn_h = self.icon_edit.sizeHint().height()
        self.icon_remove_btn.setFixedSize(26, self._icon_btn_h)
        self.icon_remove_btn.setIcon(_make_close_icon())
        self.icon_remove_btn.setIconSize(QSize(14, 14))
        self.icon_remove_btn.setFixedSize(0, 0)  # скрыт через размер, не setVisible
        icon_row.addWidget(self.icon_remove_btn)

        layout.addLayout(icon_row)

        self._name_color = ['#ffffff']  # default white

        # Вся строка — один QWidget, добавленный через addWidget.
        # Это гарантирует что при setVisible(False) не остаётся spacing в QVBoxLayout.
        # Кнопка цвета находится в той же строке справа от чекбокса.
        self._color_btn_row = QWidget()
        name_row = QHBoxLayout(self._color_btn_row)
        name_row.setContentsMargins(0, 0, 0, 0)
        name_row.setSpacing(6)
        self.show_name_in_list_cb = QCheckBox(self.translations.get('show_field_name_in_list', 'Show field name instead of icon in list'))
        name_row.addWidget(self.show_name_in_list_cb)
        self._color_btn = QPushButton()
        self._color_btn.setFixedHeight(22)
        self._color_btn.setFixedWidth(0)   # скрыт через нулевую ширину, без setVisible
        name_row.addWidget(self._color_btn)
        name_row.addStretch()
        layout.addWidget(self._color_btn_row)

        def _update_color_btn():
            c = self._name_color[0]
            self._color_btn.setStyleSheet(
                f'background-color: {c}; border: 1px solid #888; border-radius: 3px;'
            )

        def _on_pick_color():

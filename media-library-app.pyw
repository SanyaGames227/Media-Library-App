    def _do_backup(self, reason='manual'):
        """Создать резервную копию БД если соответствующая настройка включена.
        reason: 'delete_user' | 'delete_field' | 'delete_item' | 'delete_category' | 'delete_tier' | 'weekly' | 'manual'
        """
        setting_map = {
            'delete_user':     'backup_on_delete_user',
            'delete_field':    'backup_on_delete_field',
            'delete_item':     'backup_on_delete_item',
            'delete_category': 'backup_on_delete_category',
            'delete_tier':     'backup_on_delete_tier',
        }
        if reason in setting_map:
            if self.db.get_setting(setting_map[reason], '1') != '1':
                return
        suffix = '.bak.auto' if reason == 'weekly' else '.bak'
        try:
            shutil.copy2(str(DB_PATH), str(DB_PATH) + suffix)
        except Exception:
            pass

    def _start_weekly_backup_check(self):
        """Запускает проверку еженедельного бэкапа в фоновом потоке через 3 сек после старта."""
        if self.db.get_setting('backup_weekly', '1') != '1':
            return

        class _WeeklyBackupWorker(QThread):
            def __init__(self2, db_path, last_ts):
                super().__init__()
                self2._db_path = db_path
                self2._last_ts = last_ts

            def run(self2):
                self2.setTerminationEnabled(False)  # не убивать поток принудительно
                now = time.time()
                week = 7 * 24 * 3600
                if now - self2._last_ts >= week:
                    try:
                        shutil.copy2(str(self2._db_path), str(self2._db_path) + '.bak.auto')
                    except Exception:
                        pass
                    # Записываем новый timestamp через сигнал не можем — запишем напрямую
                    # (SQLite из отдельного потока: открываем отдельное соединение)
                    try:
                        con = sqlite3.connect(str(self2._db_path))
                        con.execute(
                            "INSERT OR REPLACE INTO settings (key, value) VALUES ('backup_last_weekly', ?)",
                            (str(int(now)),))
                        con.commit()
                        con.close()
                    except Exception:
                        pass

        last_raw = self.db.get_setting('backup_last_weekly', '0')
        try:
            last_ts = float(last_raw)
        except Exception:
            last_ts = 0.0
        self._weekly_backup_worker = _WeeklyBackupWorker(DB_PATH, last_ts)
        QTimer.singleShot(3000, self._weekly_backup_worker.start)


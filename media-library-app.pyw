                target_w=self.COVER_W, target_h=self.COVER_H))
            self.cover_label.setStyleSheet("border: 1px solid #555; border-radius: 4px;")
        else:
            self.cover_label.clear()
            self.cover_label.setStyleSheet("border: 1px solid #555; border-radius: 4px; background-color: #3c3c3c;")

        raw = item_data['title']
        t = _display_title(raw)
        if item_data.get('year') and item_data['year'] != 0:
            t += f" ({item_data['year']})"
        self.title_label.setText(t)
        self.title_label.setMinimumHeight(0)
        self.title_label.setMaximumHeight(16777215)
        self.title_label.updateGeometry()
        self.title_label.show()

        tr = self.translations.get

        rating = item_data.get('rating')
        fav = ' (🩷)' if item_data.get('is_favorite') else ''
        if rating:
            self._vbox.addWidget(self._rating_widget(rating, fav, label_text=tr('rating', 'Rating')))
        elif item_data.get('is_favorite'):
            self._vbox.addWidget(self._lbl(f"{tr('rating','Rating')}: {tr('not_rated','Not rated')}{fav}", color="#aaa"))

        if item_data.get('watch_date'):
            self._vbox.addWidget(self._lbl(f"{tr('watch_date','Watch Date')}: {_fmt_date(item_data['watch_date'], _DATE_FMT)}"))

        vc = item_data.get('view_count', 1)
        if vc:
            self._vbox.addWidget(self._lbl(f"{tr('view_count','View Count')}: {vc}"))

        if item_data.get('time_spent') and item_data['time_spent'] > 0:
            self._vbox.addWidget(self._lbl(f"{tr('time_spent','Time Spent')}: {item_data['time_spent']}{tr('hours','h')}"))

        if users_data:
            self._vbox.addWidget(self._lbl_token_wrap(
                tr('watched_with', 'Watched with'),
                [u['name'] for u in users_data]
            ))

        if item_data.get('notes'):
            notes_container = QWidget()
            notes_container.setStyleSheet('background: transparent;')
            notes_vbox = QVBoxLayout(notes_container)
            notes_vbox.setContentsMargins(0, 0, 0, 0)
            notes_vbox.setSpacing(0)

            # Заголовок Notes: лейбл + кнопка разворачивания
            _notes_hdr = QWidget()
            _notes_hdr.setStyleSheet('background: transparent;')
            _notes_hdr_hbox = QHBoxLayout(_notes_hdr)
            _notes_hdr_hbox.setContentsMargins(0, 0, 0, 0)
            _notes_hdr_hbox.setSpacing(0)

            notes_lbl = self._lbl(f"{tr('notes','Notes')}:", bold=True, radii=(4,0,0,0))
            _notes_hdr_hbox.addWidget(notes_lbl, 1)

            _expand_btn = QPushButton()
            _expand_btn.setIcon(_make_expand_icon(size=14))
            _expand_btn.setIconSize(QSize(14, 14))
            # Высота кнопки = высота _PlainLabel: font_height + 2*PAD_V
            _btn_h = QFontMetrics(self.font()).height() + 8
            _expand_btn.setFixedSize(22, _btn_h)
            _expand_btn.setFocusPolicy(Qt.NoFocus)
            _expand_btn.setStyleSheet(
                'QPushButton { background-color: #2e2e2e; border: none;'
                ' border-top-left-radius: 0px; border-top-right-radius: 4px;'
                ' border-bottom-left-radius: 0px; border-bottom-right-radius: 0px;'
                ' padding: 0px; margin: 0px; }'
                'QPushButton:hover { background-color: #3a3a3a; }'
                'QPushButton:pressed { background-color: #444444; }'
            )
            _notes_text  = item_data['notes']
            _item_title  = _display_title(item_data.get('title', ''))
            _item_id     = item_data.get('id')
            _tr_ref      = self.translations
            _self_ref    = self

            def _open_note_editor(checked=False, t=_notes_text, ti=_item_title,
                                  iid=_item_id, tr2=_tr_ref, panel=_self_ref):
                dlg = NoteEditorWindow(text=t, title=ti, translations=tr2, parent=None)
                dlg.setWindowModality(Qt.ApplicationModal)
                if dlg.exec_() == QDialog.Accepted:
                    panel.db.update_item(iid, notes=dlg.get_text())
                    # Перечитываем из БД чтобы _last_item_data был актуальным
                    fresh = dict(panel.db.get_item_by_id(iid) or {})
                    if fresh:
                        users = panel.db.get_item_users(iid)
                        cf_fields = panel.db.get_custom_fields_cached()
                        cf_list = [(f, panel.db.get_custom_field_value(iid, f['id'])) for f in cf_fields] if cf_fields else None
                        panel.show_item(fresh, users, cf_list)

            _expand_btn.clicked.connect(_open_note_editor)
            _notes_hdr_hbox.addWidget(_expand_btn)

            notes_vbox.addWidget(_notes_hdr)

            te = QTextEdit()
            te.setPlainText(item_data['notes'])
            te.setReadOnly(True)
            te.setMaximumHeight(100)
            te.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Maximum)
            te.setStyleSheet(
                "QTextEdit { color:#ffffff; background-color:#3c3c3c; "
                "border: none; "
                "border-top-left-radius:0px; border-top-right-radius:0px; "
                "border-bottom-left-radius:4px; border-bottom-right-radius:4px; padding:4px; }"
            )

            old_filter = getattr(self, '_notes_wheel_filter', None)
            if old_filter:
                self._sa.viewport().removeEventFilter(old_filter)

            sa_ref = self._sa
            te_ref = te

            # Фильтр на viewport внешней панели: если курсор над te и te ещё не в конце —
            # перенаправляем скролл в te, не даём панели скроллиться
            class _NotesWheelFilter(QObject):
                def eventFilter(self_, obj, event):
                    if event.type() == QEvent.Wheel:
                        cursor_pos = te_ref.mapFromGlobal(event.globalPos())
                        if not te_ref.rect().contains(cursor_pos):
                            return False
                        sb = te_ref.verticalScrollBar()
                        # te не имеет скроллируемого контента — пропускаем к панели
                        if sb.maximum() <= sb.minimum():
                            return False
                        # Скроллим te только если не достигли края
                        going_down = event.angleDelta().y() < 0
                        at_bottom = sb.value() >= sb.maximum()
                        at_top = sb.value() <= sb.minimum()
                        if not (going_down and at_bottom) and not (not going_down and at_top):
                            step = sb.singleStep() * 3
                            sb.setValue(sb.value() + (-step if going_down else step))
                        # В любом случае блокируем панель пока курсор над te
                        return True
                    return False

            _filter = _NotesWheelFilter(sa_ref)
            sa_ref.viewport().installEventFilter(_filter)
            self._notes_wheel_filter = _filter  # держим ссылку и снимем при следующем show_item

            notes_vbox.addWidget(te)
            self._vbox.addWidget(notes_container)


        if custom_fields_data:
            for fd, val in custom_fields_data:
                if val is None:
                    continue
                fd = dict(fd)
                ftype = fd.get('field_type', 'string')
                dv = val
                if ftype == 'boolean':
                    dv = '✓' if val == '1' else None
                elif ftype in ('integer', 'slider'):
                    try:
                        dv = None if int(val) == 0 else val
                    except Exception:
                        pass
                elif ftype in ('marks', 'select'):
                    dv = _resolve_display_value(self.db, fd, val) if self.db else val
                if dv is None:
                    continue
                if ftype in ('marks', 'select') and dv:
                    # Разбиваем на токены и рендерим с неразрывными пробелами внутри
                    try:
                        tokens = json.loads(dv) if dv.startswith('[') else [t.strip() for t in dv.split(',') if t.strip()]
                    except Exception:
                        tokens = [t.strip() for t in dv.split(',') if t.strip()]
                    self._vbox.addWidget(self._lbl_token_wrap(fd['name'], tokens))
                elif ftype == 'string' and dv and '\n' in dv:
                    # Многострочный текст — рендерим как блок заметок
                    _sf_container = QWidget()
                    _sf_container.setStyleSheet('background: transparent;')
                    _sf_vbox = QVBoxLayout(_sf_container)
                    _sf_vbox.setContentsMargins(0, 0, 0, 0)
                    _sf_vbox.setSpacing(0)
                    # Заголовок + кнопка expand
                    _sf_hdr = QWidget()
                    _sf_hdr.setStyleSheet('background: transparent;')
                    _sf_hdr_hbox = QHBoxLayout(_sf_hdr)
                    _sf_hdr_hbox.setContentsMargins(0, 0, 0, 0)
                    _sf_hdr_hbox.setSpacing(0)
                    _sf_lbl = self._lbl(f"{fd['name']}:", bold=True, radii=(4,0,0,0))
                    _sf_hdr_hbox.addWidget(_sf_lbl, 1)
                    _sf_exp_btn = QPushButton()
                    _sf_exp_btn.setIcon(_make_expand_icon(size=14))
                    _sf_exp_btn.setIconSize(QSize(14, 14))
                    _btn_h2 = QFontMetrics(self.font()).height() + 8
                    _sf_exp_btn.setFixedSize(22, _btn_h2)
                    _sf_exp_btn.setFocusPolicy(Qt.NoFocus)
                    _sf_exp_btn.setStyleSheet(
                        'QPushButton { background-color: #2e2e2e; border: none;'
                        ' border-top-left-radius: 0px; border-top-right-radius: 4px;'
                        ' border-bottom-left-radius: 0px; border-bottom-right-radius: 0px;'
                        ' padding: 0px; margin: 0px; }'
                        'QPushButton:hover { background-color: #3a3a3a; }'
                        'QPushButton:pressed { background-color: #444444; }'
                    )
                    _sf_text   = dv
                    _sf_fname  = fd['name']
                    _sf_tr_ref = self.translations
                    def _open_sf_viewer(checked=False, _t=_sf_text, _n=_sf_fname, _tr=_sf_tr_ref):
                        dlg = NotePreviewWindow(text=_t, title=_n, translations=_tr, parent=None)
                        dlg.setWindowModality(Qt.ApplicationModal)
                        dlg.exec_()
                    _sf_exp_btn.clicked.connect(_open_sf_viewer)
                    _sf_hdr_hbox.addWidget(_sf_exp_btn)
                    _sf_vbox.addWidget(_sf_hdr)
                    _sf_te = QTextEdit()
                    _sf_te.setPlainText(dv)
                    _sf_te.setReadOnly(True)
                    _sf_te.setMaximumHeight(100)
                    _sf_te.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Maximum)
                    _sf_te.setStyleSheet(
                        "QTextEdit { color:#ffffff; background-color:#3c3c3c; "
                        "border: none; "
                        "border-top-left-radius:0px; border-top-right-radius:0px; "
                        "border-bottom-left-radius:4px; border-bottom-right-radius:4px; padding:4px; }"
                    )
                    _sf_vbox.addWidget(_sf_te)
                    self._vbox.addWidget(_sf_container)
                else:
                    self._vbox.addWidget(self._lbl(f"{fd['name']}: {dv}", wrap=True))

        self._update_items_width()
        self._sa.setUpdatesEnabled(True)
        self.setUpdatesEnabled(True)
        self.update()

    def refresh(self):
        """Перерисовывает панель с теми же данными — например после смены формата даты."""
        if hasattr(self, '_last_item_data') and self._last_item_data:
            self.show_item(self._last_item_data, self._last_users_data, self._last_cf_data)

    def clear_item(self):
        old_filter = getattr(self, '_notes_wheel_filter', None)
        if old_filter:
            self._sa.viewport().removeEventFilter(old_filter)
            self._notes_wheel_filter = None
        self.cover_label.clear()
        self.cover_label.setStyleSheet("border: 1px solid #555; border-radius: 4px; background-color: #3c3c3c;")
        self.title_label.setText("")
        self.title_label.hide()
        while self._vbox.count():
            c = self._vbox.takeAt(0)
            if c.widget():
                c.widget().deleteLater()


class _CategoryBgOverlay(QWidget):
    """Виджет фонового изображения категории — рисуется под элементами списка."""

    BG_COLOR = QColor('#2b2b2b')  # дефолтный фон когда картинка не задана

    def __init__(self, parent):
        super().__init__(parent)
        self.setAttribute(Qt.WA_TransparentForMouseEvents)
        self._pixmap  = None
        self._overlay = 0.65
        self.setGeometry(parent.rect())
        self.lower()
        self.show()

    def set_bg(self, abs_path: str, overlay: float):
        self._overlay = max(0.0, min(1.0, overlay))
        if abs_path and os.path.exists(abs_path):
            self._pixmap = QPixmap(abs_path)
            if self._pixmap.isNull():
                self._pixmap = None
        else:
            self._pixmap = None
        self.lower()
        self.update()

    def clear_bg(self):
        self._pixmap = None
        self.lower()
        self.update()

    def resizeEvent(self, event):
        self.setGeometry(self.parent().rect())
        super().resizeEvent(event)

    def paintEvent(self, event):
        p = QPainter(self)
        vp = self.rect()

        if not self._pixmap:
            # Нет картинки — рисуем дефолтный фон как раньше
            p.fillRect(vp, self.BG_COLOR)
            p.end()
            return

        p.setRenderHint(QPainter.SmoothPixmapTransform)
        scaled = self._pixmap.scaled(
            vp.width(), vp.height(),
            Qt.KeepAspectRatioByExpanding,
            Qt.SmoothTransformation
        )
        x = (vp.width()  - scaled.width())  // 2
        y = (vp.height() - scaled.height()) // 2
        p.drawPixmap(x, y, scaled)

        if self._overlay > 0:
            p.fillRect(vp, QColor(0, 0, 0, int(self._overlay * 255)))
        p.end()



                                else: new_val = d_date.date().toString('yyyy-MM-dd')
                                ok = True
                        else:  # string
                            dlg, grp_lay = _make_cf_dialog(lbl)
                            str_edit = QLineEdit('')
                            grp_lay.addWidget(str_edit)
                            str_edit.returnPressed.connect(dlg.accept)
                            if dlg.exec_() == QDialog.Accepted:
                                new_val = str_edit.text().strip() or None
                                ok = True
                        if ok:
                            _bulk_cf_save_all(_bulk_ids, fid, new_val)

                    act.triggered.connect(_on_bulk_cf_action)
                    menu.addAction(act)

            # ── Duplicate + Delete ─────────────────────────────────────────────
            menu.addSeparator()
            if not self.all_categories_mode:
                dup_action = QAction(self.translations.get('duplicate', 'Duplicate'), self)
                dup_action.triggered.connect(lambda: self.duplicate_selected_items())
                menu.addAction(dup_action)
            del_action = QAction(self.translations.get('delete', 'Delete'), self)
            del_action.triggered.connect(lambda: self.delete_selected_items())
            menu.addAction(del_action)

            _saved_proxy_rows = self._selected_proxy_rows()
            menu.exec_(self.items_list.mapToGlobal(position))
            # Восстанавливаем мульти-выделение — Qt сбрасывает его после exec_()
            self._restoring_selection = True
            try:
                sm = self.items_list.selectionModel()
                sm.clearSelection()
                for row in _saved_proxy_rows:
                    idx = self._item_proxy.index(row, 0)
                    sm.select(idx, sm.Select)
            finally:
                self._restoring_selection = False
            self._restore_category_selection()
            return
        
        menu = QMenu()
        
        edit_action = QAction(self.translations.get('edit', 'Edit'), self)
        edit_action.triggered.connect(lambda: self.edit_item())
        menu.addAction(edit_action)
        
        users = self.db.get_users()
        if users:
            watch_with_menu = menu.addMenu(self.translations.get('mark_watched_with', 'Mark Watched With'))
            item_id = _ctx_item_id
            current_users = [u['id'] for u in self.db.get_item_users(item_id)]
            
            for user in users:
                user_action = QAction(user['name'], self)
                user_action.setCheckable(True)
                user_action.setChecked(user['id'] in current_users)
                user_action.triggered.connect(
                    lambda checked, u=user: self.toggle_user_for_item(item_id, u['id'], checked)
                )
                watch_with_menu.addAction(user_action)
        
        item_data = self.db.get_item_by_id(_ctx_item_id)
        fav_text = (
            self.translations.get('remove_from_favorites', 'Remove from Favorites')
            if dict(item_data).get("is_favorite")
            else self.translations.get('add_to_favorites', 'Add to Favorites')
        )
        fav_action = QAction(fav_text, self)
        fav_action.triggered.connect(lambda: self.toggle_favorite(_ctx_item_id))
        menu.addAction(fav_action)

        item_id = _ctx_item_id

        if not self.all_categories_mode:
            duplicate_action = QAction(self.translations.get('duplicate', 'Duplicate'), self)
            duplicate_action.triggered.connect(lambda: self._do_duplicate_item(_ctx_item_id))
            menu.addAction(duplicate_action)

        cf_fields = [dict(f) for f in self.db.get_custom_fields() if dict(f).get('show_in_context_menu')]
        if cf_fields:
            menu.addSeparator()
        def _cf_save_and_refresh(iid, fid, new_val):
            self.db.set_custom_field_value(iid, fid, new_val)
            self.load_item(iid)
            if self._current_item_id() == iid:
                self.on_item_selected_by_id(iid)

        for fd in cf_fields:
            fid = fd['id']
            label = fd.get('context_menu_label') or fd['name']
            ftype = fd.get('field_type', 'string')
            type_opts_raw = fd.get('type_options') or ''
            if ftype == 'select':
                db_opts = self.db.get_field_options(fid)
                if not db_opts:
                    continue
                sub = menu.addMenu(label)
                current_val = self.db.get_custom_field_value(item_id, fid)
                if current_val is not None:
                    clear_act = QAction('–', self)
                    clear_act.triggered.connect(lambda checked=False, _iid=item_id, _fid=fid: _cf_save_and_refresh(_iid, _fid, None))
                    sub.addAction(clear_act)
                    sub.addSeparator()
                for opt in db_opts:
                    act = QAction(opt['label'], self)
                    if str(current_val) == str(opt['id']):
                        act.setText('• ' + opt['label'])
                    act.triggered.connect(lambda checked=False, _iid=item_id, _fid=fid, _oid=opt['id']: _cf_save_and_refresh(_iid, _fid, str(_oid)))
                    sub.addAction(act)
            elif ftype == 'marks':
                db_opts = self.db.get_field_options(fid)
                if not db_opts:
                    continue
                sub = menu.addMenu(label)
                current_val = self.db.get_custom_field_value(item_id, fid)
                try:
                    checked_ids = json.loads(current_val) if current_val else []
                    if not isinstance(checked_ids, list): checked_ids = []
                except Exception:
                    checked_ids = []
                db_opts = self.db.get_field_options(fid)
                for opt in db_opts:
                    m_act = QAction(opt['label'], self)
                    m_act.setCheckable(True)
                    m_act.setChecked(str(opt['id']) in [str(x) for x in checked_ids])
                    m_act.triggered.connect(lambda checked=False, _iid=item_id, _fid=fid, _oid=opt['id']: self._ctx_toggle_mark(_iid, _fid, _oid))
                    sub.addAction(m_act)
            elif ftype == 'boolean':
                current_val = self.db.get_custom_field_value(item_id, fid)
                act = QAction(label, self)
                act.setCheckable(True)
                act.setChecked(current_val == '1')
                act.triggered.connect(lambda checked, _iid=item_id, _fid=fid: _cf_save_and_refresh(_iid, _fid, '1' if checked else None))
                menu.addAction(act)
            else:
                act = QAction(label, self)
                def _on_cf_action(checked=False, fid=fid, ftype=ftype, lbl=label, type_opts_raw=type_opts_raw, item_id=item_id):
                    current_val = self.db.get_custom_field_value(item_id, fid)
                    new_val = None
                    ok = False

                    # Общий хелпер для создания диалога с QGroupBox — как в ItemDialog
                    def _make_cf_dialog(title):
                        d = QDialog(self)
                        d.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
                        d.setWindowTitle(title)
                        d.setWindowFlags(d.windowFlags() & ~Qt.WindowMaximizeButtonHint & ~Qt.WindowContextHelpButtonHint)
                        d.setFixedWidth(260)
                        lay = QVBoxLayout()
                        d.setLayout(lay)
                        grp = QGroupBox(title)
                        grp_lay = QVBoxLayout(grp)
                        grp_lay.setContentsMargins(8, 6, 8, 6)
                        grp_lay.setSpacing(4)
                        lay.addWidget(grp)
                        btn_row = QHBoxLayout()
                        btn_row.addStretch()
                        ok_btn = QPushButton(self.translations.get('ok', 'OK'))
                        cancel_btn = QPushButton(self.translations.get('cancel', 'Cancel'))
                        ok_btn.setDefault(True)
                        ok_btn.clicked.connect(d.accept)
                        cancel_btn.clicked.connect(d.reject)
                        btn_row.addWidget(ok_btn)
                        btn_row.addWidget(cancel_btn)
                        lay.addLayout(btn_row)
                        return d, grp_lay

                    if ftype == 'integer':
                        try:
                            cur_int = int(current_val) if current_val else 0
                        except Exception:
                            cur_int = 0
                        dlg, grp_lay = _make_cf_dialog(lbl)

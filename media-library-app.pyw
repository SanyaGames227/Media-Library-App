            except Exception as e:
                self._show_dialog_error(self, self.translations.get('import_error', 'Import failed: {}').format(e))
                return
            try:
                diff = self.db.import_csv_diff(parsed)
            except Exception as e:
                self._show_dialog_error(self, self.translations.get('import_error', 'Import failed: {}').format(e))
                return
            accepted, diff_dlg = ImportDiffDialog.run(diff, translations=self.translations, parent=self,
                icons_dir=icons_dir if os.path.isdir(icons_dir or '') else None,
                zip_src=imp_zip_src_path[0],
                icons_prefix=(os.path.splitext(os.path.basename(file_path))[0] + '_icons/') if imp_zip_src_path[0] else None)
            if not accepted:
                # Clean up ZIP temp dir if any
                return
            if diff_dlg is not None:
                apply_nf = diff_dlg.selected_new_fields
                apply_cf = diff_dlg.apply_changed_fields
                apply_no = diff_dlg.selected_new_options
                apply_co = diff_dlg.apply_changed_options
                apply_nu = diff_dlg.selected_new_users
            else:
                apply_nf = diff.get('new_fields', [])
                apply_cf = set()
                apply_no = diff.get('new_options', [])
                apply_co = set()
                apply_nu = diff.get('new_users', [])
            dlg.hide()
            # Применяем фон только если у текущей категории его нет
            _cur_cat_row = self.db.conn.cursor().execute(
                'SELECT bg_path FROM categories WHERE id = ?', (self.current_category_id,)
            ).fetchone()
            _apply_bg_inner = bool(imp_zip_src_path[0]) and (
                not _cur_cat_row or not (_cur_cat_row[0] or '').strip()
            )
            worker = ImportWorker(
                db=self.db,
                file_path=file_path,
                category_id=self.current_category_id,
                translations=self.translations,
                import_images=import_images,
                jpg_quality=self.jpg_quality,
                parsed=parsed, diff=diff,
                apply_new_fields=apply_nf,
                apply_changed_fields=apply_cf,
                apply_new_options=apply_no,
                apply_changed_options=apply_co,
                apply_new_users=apply_nu,
                images_dir=images_dir,
                icons_dir=icons_dir,
                zip_src_path=imp_zip_src_path[0],
                covers_prefix=(
                    ((os.path.dirname(file_path) + '/' if os.path.dirname(file_path) else '')
                     + os.path.splitext(os.path.basename(file_path))[0] + '_covers/').lower()
                ) if imp_zip_src_path[0] else None,
                icons_prefix=(
                    (os.path.dirname(file_path) + '/' if os.path.dirname(file_path) else '')
                    + os.path.splitext(os.path.basename(file_path))[0] + '_icons/'
                ) if imp_zip_src_path[0] else None,
                apply_bg=_apply_bg_inner,
            )
            _imported = [0]
            def _on_import_done(count):
                _imported[0] = count
            worker.finished.connect(_on_import_done)
            self._run_with_progress(self, self.translations.get('importing', 'Importing...'), worker)
            if worker._cancel_event.is_set():
                pass  # cancelled — DB was not modified (exception aborted before commit)
            else:
                # Обновляем фон категории если он был применён при импорте
                self._update_cat_bg(self.current_category_id)
                self.load_items()
                # Если активен тирлист — перезагружаем и его
                if getattr(self, '_tier_mode', False) and self.current_category_id:
                    self.tier_list_widget.load_category(self.current_category_id, **self._tier_load_params())
                self.db.invalidate_custom_fields_cache()
                _fields_added   = len(apply_nf)
                _fields_updated = len(apply_cf)
                _items_added    = _imported[0] or 0
                _users_added    = len(apply_nu) if apply_nu else 0
                parts = []
                if _items_added:    parts.append(self.translations.get('import_success', 'Imported {} items').format(_items_added))
                if _fields_added:   parts.append(self.translations.get('diff_new_fields_short', 'Added {} fields').format(_fields_added))
                if _fields_updated: parts.append(self.translations.get('diff_changed_fields_short', 'Updated {} fields').format(_fields_updated))
                if _users_added:    parts.append(self.translations.get('import_success_users', 'Imported {} users').format(_users_added))
                msg = '\n'.join(parts) if parts else self.translations.get('import_no_items', 'Import complete.')
                self._show_dialog_info(self, msg)
        else:  # export tab
            fmt = fmt_combo.currentText()
            # ZIP — всегда полный экспорт: обложки + кастомные поля + иконки
            _export_images = (fmt == 'ZIP')
            _export_cf     = (fmt == 'ZIP')
            _use_zip       = (fmt == 'ZIP')
            _icons_only    = False
            csv_icon_mode  = 'folder' if fmt == 'ZIP' else 'none'
            _export_covers = (fmt == 'ZIP')
            html_img_mode = ('folder' if html_rb_folder.isChecked() else
                             'none'   if html_rb_none.isChecked()   else 'base64')
            txt_template = txt_tpl_edit.toPlainText().strip() or default_tpl
            self.db.set_setting('txt_export_template', txt_template)

            # ── empty category guard ──────────────────────────────────
            # Пропускаем для папки и мульти — там несколько категорий
            if not _multi and not _folder_export:
                _chk = self.db.get_items(_exp_category_ids[0], limit=1)
                if not _chk:
                    self._show_dialog_warning(dlg, self.translations.get('export_empty_category',
                            'Nothing to export: the category is empty.'))
                    return

            # ── preserve current sort for export ──────────────────────
            _exp_sort_by  = self._current_sort_by()
            _exp_sort_asc = self.sort_ascending
            # manual sort in HTML always forces ASC
            if _exp_sort_by == 'manual':
                _exp_sort_asc = True

            # _folder_export тоже использует MultiExportWorker (несколько категорий)
            _use_multi_worker = _multi or _folder_export
            if fmt == 'ZIP':
                if _folder_name:
                    _safe = "".join(c for c in _folder_name if c.isalnum() or c in ' _-').strip()[:50]
                    _def_name = f'{_safe}_folder.zip' if _safe else f'folder_export.zip'
                elif _multi:
                    _def_name = f'export_{len(_exp_category_ids)}_categories.zip'
                else:
                    _def_name = f'{category_name}.zip'
                file_path, _ = QFileDialog.getSaveFileName(self, '', _def_name, 'ZIP Files (*.zip)')
            elif fmt == 'HTML':
                if _multi:
                    _def_name = f'export_{len(_exp_category_ids)}_categories_html.zip'
                else:
                    _def_name = f'{category_name}.html'
                _html_filter = 'ZIP Files (*.zip)' if _multi else 'HTML Files (*.html)'
                file_path, _ = QFileDialog.getSaveFileName(self, '', _def_name, _html_filter)
            else:
                _def_name = f'export_{len(_exp_category_ids)}_categories.txt' if _multi else f'{category_name}.txt'
                file_path, _ = QFileDialog.getSaveFileName(self, '', _def_name, 'Text Files (*.txt)')
            if not file_path:
                return
            dlg.hide()
            try:
                if fmt == 'ZIP':
                    if _use_multi_worker:
                        worker = MultiExportWorker(
                            db=self.db,
                            category_ids=_exp_category_ids,
                            file_path=file_path,
                            translations=self.translations,
                            export_images=_export_covers,
                            export_custom_fields=csv_cf_cb.isChecked(),
                            icon_mode=csv_icon_mode,
                            jpg_quality=self.jpg_quality,
                            sort_by=_exp_sort_by,
                            ascending=_exp_sort_asc,
                            folder_name=_folder_name if _folder_export else None,
                            folder_info_by_cat=getattr(self, '_pending_folder_info_by_cat', {}),
                        )
                        self._pending_folder_info_by_cat = {}
                    else:
                        worker = ExportWorker(
                            db=self.db,
                            category_id=_exp_category_ids[0],
                            file_path=file_path,
                            translations=self.translations,
                            export_images=_export_covers,
                            export_custom_fields=csv_cf_cb.isChecked(),
                            icon_mode=csv_icon_mode,
                            jpg_quality=self.jpg_quality,
                            as_zip=_use_zip,
                            sort_by=_exp_sort_by,
                            ascending=_exp_sort_asc,
                        )
                    _exp_ok = [False]
                    worker.finished.connect(lambda: _exp_ok.__setitem__(0, True))
                    self._run_with_progress(self, self.translations.get('exporting', 'Exporting...'), worker)
                    if _exp_ok[0]:
                        if _use_multi_worker:
                            _n = len(_exp_category_ids)
                            _msg = self.translations.get('export_success_multi',
                                '{} categories exported successfully').format(_n)
                        else:
                            _msg = self.translations.get('export_success', 'Exported successfully')
                        # Clear saved selection BEFORE showing dialog so CatSelectionFilter
                        # doesn't restore multi-selection when the dialog closes
                        self._export_cleared_multiselection = True
                        try:
                            for _ef in getattr(QApplication.instance(), '_cat_sel_filters', []):
                                _ef.suppress_restore()
                        except Exception:
                            pass
                        self._show_dialog_info(self, _msg)
                        self._restore_category_selection()
                    elif worker._cancel_event.is_set():
                        pass  # cancelled — no message, files already cleaned up by worker
                elif fmt == 'HTML':
                    _app_icon_b64 = None
                    try:
                        _icon = self._make_app_icon()
                        _pix  = _icon.pixmap(64, 64)
                        if not _pix.isNull():
                            _buf = QBuffer()
                            _buf.open(QBuffer.WriteOnly)
                            _pix.save(_buf, 'PNG')
                            _app_icon_b64 = base64.b64encode(_buf.data().data()).decode()
                    except Exception:
                        pass
                    if _multi:
                        # Мульти HTML: один диалог прогресса, MultiHtmlExportWorker внутри ZIP
                        _tmp = tempfile.mkdtemp()
                        try:
                            _mhw = MultiHtmlExportWorker(
                                category_ids=_exp_category_ids,
                                tmp_dir=_tmp,
                                img_mode=html_img_mode,
                                sort_by=_exp_sort_by,
                                ascending=_exp_sort_asc,
                                translations=self.translations,
                                app_icon_b64=_app_icon_b64,
                                db_getter=Database,
                                date_fmt=_DATE_FMT)
                            _mhw_ok = [False]
                            _mhw_cancelled = [False]
                            _mhw.finished.connect(lambda: _mhw_ok.__setitem__(0, True))
                            _mhw.cancelled.connect(lambda: _mhw_cancelled.__setitem__(0, True))
                            _mhw.error.connect(lambda e: self._show_dialog_error(self, self.translations.get('export_error', 'Export failed: {}').format(e)))
                            self._run_with_progress(self,
                                self.translations.get('exporting', 'Exporting...'), _mhw)
                            if _mhw_ok[0] and _mhw.html_files:
                                # Пакуем всю папку _tmp — включая _covers/_icons подпапки
                                with zipfile.ZipFile(file_path, 'w', zipfile.ZIP_STORED) as _zout:
                                    for _root, _dirs, _files in os.walk(_tmp):
                                        for _fname in _files:
                                            _fpath = os.path.join(_root, _fname)
                                            _arcname = os.path.relpath(_fpath, _tmp)
                                            _zout.write(_fpath, _arcname)
                                self._show_dialog_info(self, self.translations.get('export_success_multi',
                                        '{} categories exported successfully').format(len(_exp_category_ids)))
                                self._restore_category_selection()
                        finally:
                            shutil.rmtree(_tmp, ignore_errors=True)
                    else:
                        _html_worker = HtmlExportWorker(
                            category_id=_exp_category_ids[0], file_path=file_path,
                            img_mode=html_img_mode, sort_by=_exp_sort_by,
                            ascending=_exp_sort_asc, translations=self.translations,
                            app_icon_b64=_app_icon_b64, date_fmt=_DATE_FMT)
                        _html_ok = [False]
                        _html_worker.finished.connect(lambda: _html_ok.__setitem__(0, True))
                        _html_worker.error.connect(lambda e: self._show_dialog_error(self, self.translations.get('export_error', 'Export failed: {}').format(e)))
                        self._run_with_progress(self,
                            self.translations.get('exporting', 'Exporting...'), _html_worker)
                        if _html_ok[0]:
                            self._show_dialog_info(self, self.translations.get('export_success', 'Exported successfully'))
                            self._restore_category_selection()
                        elif _html_worker._cancel_event.is_set():
                            pass  # отменено — без сообщения
                else:
                    # TXT: одиночный или мульти (все категории в одном файле с заголовками)
                    if _multi:
                        _txt_lines = []
                        for _cid in _exp_category_ids:
                            _cursor = self.db.conn.cursor()
                            _cursor.execute('SELECT name FROM categories WHERE id = ?', (_cid,))
                            _crow = _cursor.fetchone()
                            _cname = _crow['name'] if _crow else str(_cid)
                            _citems = self.db.get_items(_cid, sort_by=_exp_sort_by, ascending=_exp_sort_asc)
                            # Заголовок категории
                            _sep = '=' * max(len(_cname), 20)
                            _txt_lines.append(_sep)
                            _txt_lines.append(_cname)
                            _txt_lines.append(_sep)
                            # Рендерим через _export_txt во временный буфер
                            _tmp_f = tempfile.NamedTemporaryFile(mode='w', suffix='.txt',
                                                              encoding='utf-8', delete=False)
                            _tmp_f.close()
                            try:
                                self._export_txt(_tmp_f.name, _citems, txt_template)
                                with open(_tmp_f.name, encoding='utf-8') as _tf3:
                                    _txt_lines.append(_tf3.read())
                            finally:
                                try: os.remove(_tmp_f.name)
                                except Exception: pass
                            _txt_lines.append('')  # пустая строка между категориями
                        with open(file_path, 'w', encoding='utf-8') as _fout:
                            _fout.write('\n'.join(_txt_lines))
                        self._show_dialog_info(self, self.translations.get('export_success_multi',
                                '{} categories exported successfully').format(len(_exp_category_ids)))
                        self._restore_category_selection()
                    else:
                        _items = self.db.get_items(_exp_category_ids[0],
                            sort_by=_exp_sort_by, ascending=_exp_sort_asc)
                        self._export_txt(file_path, _items, txt_template)
                        self._show_dialog_info(self, self.translations.get('export_success', 'Exported successfully'))
                        self._restore_category_selection()
            except Exception as e:
                self._show_dialog_error(self, self.translations.get('export_error', 'Export failed: {}').format(e))


    def _export_txt_blocks(self, file_path, items, blocks):
        """Block-based TXT export — each block has prefix/suffix/skip_empty."""
        custom_fields = {dict(f)['variable']: dict(f) for f in self.db.get_custom_fields_cached()}
        _all_ids = [dict(r)['id'] for r in items]
        _users_map = self.db.get_users_for_items(_all_ids)
        _cf_map = self.db.get_custom_fields_for_items_batch(_all_ids)

        lines = []
        for row in items:
            item = dict(row)
            users_str = ', '.join(u['name'] for u in _users_map.get(item['id'], []))
            notes_val = item.get('notes') or ''
            rate_val = str(item.get('rating') or '')
            if rate_val == '0':
                rate_val = ''

            var_values = {
                'title':       item.get('title') or '',
                'year':        str(item.get('year') or ''),
                'year_watch':  _fmt_date(item.get('watch_date') or '', _DATE_FMT),
                'rate':        rate_val,
                'users':       users_str,
                'view_count':  str(item.get('view_count') or ''),
                'is_favorite': '🩷' if item.get('is_favorite') else '',
                'notes':       notes_val,
            }
            cf_vals_db = _cf_map.get(item['id'], {})
            for var_name, fd in custom_fields.items():
                val = cf_vals_db.get(fd['id'])
                if val is None:
                    var_values[var_name] = ''
                elif fd.get('field_type') == 'boolean':
                    var_values[var_name] = '✓' if val == '1' else ''
                elif fd.get('field_type') in ('select', 'marks'):
                    resolved = _resolve_display_value(self.db, fd, val)
                    var_values[var_name] = resolved or ''
                else:
                    var_values[var_name] = val or ''

            parts = []
            for b in blocks:
                if b['var'] == '__sep__':
                    parts.append(b.get('text', ' '))
                    continue
                v = b['var']
                val = var_values.get(v, '')
                skip = b.get('skip_empty', True)
                if skip and not val:
                    continue
                pre = b.get('prefix', '')
                suf = b.get('suffix', '')
                if v == 'notes' and val:
                    parts.append(f'{pre}{val}{suf}' if pre else f'| {val}')
                else:
                    parts.append(f'{pre}{val}{suf}')

            # strip trailing separators
            line = ''.join(parts).strip()
            lines.append(line)

        with open(file_path, 'w', encoding='utf-8') as f:
            f.write('\n'.join(lines))



    def _export_txt(self, file_path, items, line_tpl=None, blocks=None):
        # If blocks provided, use block-based rendering (skip_empty per field)
        if blocks:
            self._export_txt_blocks(file_path, items, blocks)
            return
        if not line_tpl:
            line_tpl = '{title} [{year}] ({year_watch}) - [{rate}/10] [{users}] [♻️ {view_count}] {is_favorite}{notes:inline}'

        _SMART_VARS = ('year', 'year_watch', 'rate', 'users', 'view_count', 'is_favorite')

        def _is_bracketed(tpl, var_name):
            """Проверяем, обёрнута ли переменная в скобки вручную: [{var}], ({var}), <{var}> и т.п."""
            pattern = r'[\[\(\<\{].*?\{' + re.escape(var_name) + r'\}.*?[\]\)\>\}]'
            return bool(re.search(pattern, tpl))

        custom_fields = {dict(f)['variable']: dict(f) for f in self.db.get_custom_fields_cached()}

        _all_ids_tpl = [dict(r)['id'] for r in items]
        _users_map_tpl = self.db.get_users_for_items(_all_ids_tpl)
        _cf_map_tpl = self.db.get_custom_fields_for_items_batch(_all_ids_tpl)

        lines = []
        for row in items:
            item = dict(row)
            users = _users_map_tpl.get(item['id'], [])
            users_str = ', '.join([u['name'] for u in users])
            is_fav = '🩷' if item.get('is_favorite') else ''
            notes_val = item.get('notes') or ''

            var_values = {
                'year':       str(item.get('year') or ''),
                'year_watch': _fmt_date(item.get('watch_date') or '', _DATE_FMT),
                'rate':       str(item.get('rating') or ''),
                'users':      users_str,
                'view_count': str(item.get('view_count') or ''),
                'is_favorite': is_fav,
            }
            if var_values['rate'] == '0':
                var_values['rate'] = ''
            if var_values['view_count'] in ('', '0', '1'):
                var_values['view_count'] = ''

            cf_vals_db = _cf_map_tpl.get(item['id'], {})
            for var_name, fd in custom_fields.items():
                fid = fd['id']
                val = cf_vals_db.get(fid)
                if val is None:
                    var_values[var_name] = ''
                elif fd.get('field_type') == 'boolean':
                    var_values[var_name] = '✓' if val == '1' else ''
                elif fd.get('field_type') in ('select', 'marks'):
                    resolved = _resolve_display_value(self.db, fd, val)
                    var_values[var_name] = resolved if resolved else ''
                else:
                    var_values[var_name] = val

            tpl = line_tpl

            # notes и notes:inline — с удалением пустых скобок как у SMART_VARS
            for _notes_var, _notes_resolved in (
                ('{notes:inline}',
                 (re.sub(r'\n+', ' ↵ ', notes_val.replace('\r', '')).strip() if notes_val else '')),
                ('{notes}', notes_val),
            ):
                if _notes_var not in tpl:
                    continue
                _var_key = _notes_var[1:-1]  # 'notes' или 'notes:inline'
                if not _notes_resolved:
                    # Удаляем скобки вместе с содержимым если переменная пустая
                    tpl = re.sub(
                        r'[\[\(\<]([^\[\]\(\)\<\>]*?)' + re.escape(_notes_var) + r'([^\[\]\(\)\<\>]*?)[\]\)\>]',
                        '', tpl
                    )
                    tpl = tpl.replace(_notes_var, '')
                else:
                    tpl = tpl.replace(_notes_var, _notes_resolved)

            for var in _SMART_VARS:
                placeholder = '{' + var + '}'
                if placeholder not in tpl:
                    continue
                val = var_values[var]
                if _is_bracketed(tpl, var):
                    if not val:
                        tpl = re.sub(
                            r'[\[\(\<]([^\[\]\(\)\<\>]*?)' + re.escape(placeholder) + r'([^\[\]\(\)\<\>]*?)[\]\)\>]',
                            '', tpl
                        )
                        tpl = tpl.replace(placeholder, '')
                else:
                    if val:
                        tpl = tpl.replace(placeholder, f'[{placeholder}]')
                    else:
                        tpl = tpl.replace(placeholder, '')

            for var_name in custom_fields:
                placeholder = '{' + var_name + '}'
                if placeholder not in tpl:
                    continue
                val = var_values.get(var_name, '')
                if _is_bracketed(tpl, var_name):
                    if not val:
                        tpl = re.sub(
                            r'[\[\(\<]([^\[\]\(\)\<\>]*?)' + re.escape(placeholder) + r'([^\[\]\(\)\<\>]*?)[\]\)\>]',
                            '', tpl
                        )
                        tpl = tpl.replace(placeholder, '')
                else:
                    if not val:
                        tpl = tpl.replace(placeholder, '')

            try:
                tpl = tpl.format(
                    title=item.get('title') or '',
                    **var_values,
                )
            except KeyError:
                pass

            line = re.sub(r'  +', ' ', tpl)  # collapse multiple spaces
            # remove separator only when it was left orphaned by empty vars (2+ spaces around it)
            line = re.sub(r'(^\s*)[\-\|]+(\s+)', '', line)  # orphan at start
            line = re.sub(r'(\s+)[\-\|]+(\s*$)', '', line)  # orphan at end
            line = re.sub(r'  +', ' ', line).strip()  # final cleanup
            lines.append(line)

        with open(file_path, 'w', encoding='utf-8') as f:
            f.write('\n'.join(lines))
            
    # ------------------------------------------------------------------
    # Export / Import  — Users list

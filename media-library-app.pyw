    def _set_date_filter(self, date_from, date_to, label):
        """Применяет фильтр по дате — работает и в обычном режиме, и в тир-режиме."""
        self._date_from = date_from
        self._date_to   = date_to
        _all_time_lbl = self.translations.get('all_time', 'All time')
        _lbl = label if date_from else _all_time_lbl
        self._date_filter_btn.setText(_lbl)
        # Сохраняем по категории (отдельный ключ для tier-режима)
        s = QSettings('MediaLibrary', 'DateFilter')
        _is_tier = getattr(self, '_tier_mode', False)
        cat_key = (str(self.current_category_id) if self.current_category_id else 'global') + ('_tier' if _is_tier else '')
        s.setValue(f'date_from_{cat_key}', date_from or '')
        s.setValue(f'date_to_{cat_key}',   date_to   or '')
        s.setValue(f'label_{cat_key}',     label      or '')
        if getattr(self, '_tier_mode', False) and self.tier_list_widget:
            self.tier_list_widget.load_category(
                self.current_category_id, **self._tier_load_params())
        else:
            self.load_items()
        self.update_stats()
        QTimer.singleShot(0, self.items_list.setFocus)


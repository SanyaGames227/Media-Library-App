                        sl_lbl.setFixedWidth(32)
                        sl.valueChanged.connect(lambda v, lb=sl_lbl: lb.setText(str(v)))
                        sl_row.addWidget(sl)
                        sl_row.addWidget(sl_lbl)
                        grp_lay.addLayout(sl_row)
                        if dlg.exec_() == QDialog.Accepted:

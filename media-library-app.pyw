        date_h_layout.addWidget(self.date_mode_combo)
        
        self.date_year_spin = QSpinBox()
        self.date_year_spin.setRange(1900, 2100)
        self.date_year_spin.setValue(QDate.currentDate().year())
        self.date_year_spin.setMinimumWidth(0)
        date_h_layout.addWidget(self.date_year_spin)
        
        self.date_month_combo = QComboBox()
        months = ['01','02','03','04','05','06','07','08','09','10','11','12']
        self.date_month_combo.addItems(months)
        self.date_month_combo.setCurrentIndex(QDate.currentDate().month() - 1)
        self.date_month_combo.setMinimumWidth(0)
        date_h_layout.addWidget(self.date_month_combo)
        
        self.date_edit = QDateEdit()
        self.date_edit.setCalendarPopup(True)
        self.date_edit.setDate(QDate.currentDate())
        _date_display_fmt = {
            'ISO': 'yyyy-MM-dd',
            'DMY': 'dd.MM.yyyy',
            'MDY': 'MM/dd/yyyy',
            'YMD': 'yyyy.MM.dd',
        }.get(_DATE_FMT, 'yyyy-MM-dd')
        self.date_edit.setDisplayFormat(_date_display_fmt)
        self.date_edit.setMinimumWidth(0)
        date_h_layout.addWidget(self.date_edit)
        
        date_h_layout.addStretch()
        
        # Для MDY/DMY — месяц логически "первый", переставляем виджеты в layout
        if _DATE_FMT in ('MDY', 'DMY'):
            date_h_layout.removeWidget(self.date_year_spin)
            date_h_layout.removeWidget(self.date_month_combo)
            date_h_layout.insertWidget(1, self.date_month_combo)
            date_h_layout.insertWidget(2, self.date_year_spin)
        
        # Память для восстановления значений при переключении режима даты
        self._date_mem_year  = QDate.currentDate().year()
        self._date_mem_month = QDate.currentDate().month()
        self._date_mem_full  = QDate.currentDate()
        self._date_mode_prev = -1  # предыдущий режим (для сохранения перед сменой)

        def _update_date_fields(idx):
            prev = self._date_mode_prev
            # Сохраняем текущее состояние виджетов перед сменой
            if prev == 1:
                self._date_mem_year = self.date_year_spin.value()
            elif prev == 2:
                self._date_mem_year  = self.date_year_spin.value()
                self._date_mem_month = self.date_month_combo.currentIndex() + 1
            elif prev == 3:
                self._date_mem_full  = self.date_edit.date()
                # Синхронизируем год/месяц из полной даты, чтобы при откате они были актуальны
                self._date_mem_year  = self.date_edit.date().year()
                self._date_mem_month = self.date_edit.date().month()
            self._date_mode_prev = idx

            # Восстанавливаем значения для нового режима
            if idx == 1:
                self.date_year_spin.setValue(self._date_mem_year)
            elif idx == 2:
                self.date_year_spin.setValue(self._date_mem_year)
                self.date_month_combo.setCurrentIndex(self._date_mem_month - 1)
            elif idx == 3:
                # Если переходим с режима год/год+месяц — собираем дату из памяти
                if prev in (1, 2):
                    restored = QDate(self._date_mem_year, self._date_mem_month, 1)
                    # Берём день из сохранённой полной даты если год и месяц совпадают
                    if (self._date_mem_full.year() == self._date_mem_year and
                            self._date_mem_full.month() == self._date_mem_month):
                        restored = self._date_mem_full
                    self.date_edit.setDate(restored if restored.isValid() else QDate.currentDate())
                else:
                    self.date_edit.setDate(self._date_mem_full)

            self.date_year_spin.setVisible(1 <= idx <= 2)
            self.date_month_combo.setVisible(idx == 2)
            self.date_edit.setVisible(idx == 3)

        self.date_mode_combo.currentIndexChanged.connect(_update_date_fields)
        # Для нового фильма — полная дата (сегодня), для редактирования — без даты по умолчанию
        # (load_data потом выставит реальное значение если оно есть)
        if self.item_data:

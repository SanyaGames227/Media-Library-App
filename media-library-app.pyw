                            ok_btn.clicked.connect(d.accept)
                            cancel_btn.clicked.connect(d.reject)
                            btn_row.addWidget(ok_btn)
                            btn_row.addWidget(cancel_btn)
                            lay.addLayout(btn_row)
                            return d, grp_lay

                        if ftype == 'integer':
                            dlg, grp_lay = _make_cf_dialog(lbl)
                            int_spin = QSpinBox()
                            int_spin.setRange(-999999, 999999)
                            int_spin.setValue(0)
                            grp_lay.addWidget(int_spin)
                            if dlg.exec_() == QDialog.Accepted:
                                new_val = str(int_spin.value())
                                ok = True
                        elif ftype == 'slider':
                            try:
                                opts = json.loads(type_opts_raw)
                                mn, mx = int(opts.get('min', 0)), int(opts.get('max', 10))
                            except Exception:
                                mn, mx = 0, 10
                            dlg, grp_lay = _make_cf_dialog(lbl)
                            sl_row = QHBoxLayout()
                            sl = QSlider(Qt.Horizontal)
                            sl.setRange(mn, mx)
                            sl.setValue(mn)
                            sl_lbl = QLabel(str(mn))
                            sl_lbl.setFixedWidth(32)
                            sl.valueChanged.connect(lambda v, lb=sl_lbl: lb.setText(str(v)))
                            sl_row.addWidget(sl)
                            sl_row.addWidget(sl_lbl)
                            grp_lay.addLayout(sl_row)
                            if dlg.exec_() == QDialog.Accepted:
                                new_val = str(sl.value())
                                ok = True
                        elif ftype == 'date':
                            dlg, grp_lay = _make_cf_dialog(lbl)
                            d_mode = QComboBox()
                            d_mode.addItems(['–', self.translations.get('date_mode_year', 'Year'), self.translations.get('date_mode_yearmonth', 'Year + Month'), self.translations.get('date_mode_full', 'Full date')])
                            d_year = QSpinBox(); d_year.setRange(1800, 2200); d_year.setValue(QDate.currentDate().year()); d_year.setFixedWidth(65)
                            d_month = QComboBox(); d_month.addItems(['01','02','03','04','05','06','07','08','09','10','11','12']); d_month.setFixedWidth(50)
                            d_date = QDateEdit(); d_date.setCalendarPopup(True); d_date.setDate(QDate.currentDate()); d_date.setDisplayFormat('yyyy-MM-dd'); d_date.setFixedWidth(110)
                            d_row = QHBoxLayout()
                            d_row.addWidget(d_mode); d_row.addWidget(d_year); d_row.addWidget(d_month); d_row.addWidget(d_date); d_row.addStretch()
                            def _upd_d(idx, dy=d_year, dm=d_month, dd=d_date, dlg_=dlg):
                                dy.setVisible(1 <= idx <= 2)
                                dm.setVisible(idx == 2)
                                dd.setVisible(idx == 3)
                                QTimer.singleShot(0, dlg_.adjustSize)
                            d_mode.currentIndexChanged.connect(_upd_d); _upd_d(d_mode.currentIndex())
                            grp_lay.addLayout(d_row)
                            if dlg.exec_() == QDialog.Accepted:
                                idx = d_mode.currentIndex()
                                if idx == 0: new_val = None
                                elif idx == 1: new_val = str(d_year.value())

        cursor = self.conn.cursor()
        cursor.execute('SELECT field_id, value FROM custom_field_values WHERE item_id=?', (item_id,))
        return {row['field_id']: row['value'] for row in cursor.fetchall()}

    def get_custom_fields_for_items_batch(self, item_ids):
        """Вернуть {item_id: {field_id: value}} для списка элементов"""
        _t0 = time.perf_counter()
        if not item_ids:
            return {}
        cursor = self.conn.cursor()
        result = {}
        item_ids = list(item_ids)
        for i in range(0, len(item_ids), 999):
            chunk = item_ids[i:i+999]
            placeholders = ','.join('?' * len(chunk))
            cursor.execute(
                f'SELECT item_id, field_id, value FROM custom_field_values WHERE item_id IN ({placeholders})',
                chunk
            )
            for item_id, field_id, value in cursor.fetchall():
                result.setdefault(item_id, {})[field_id] = value
        print(f"[DBG] ◀ db.get_custom_fields_for_items_batch: {(time.perf_counter()-_t0)*1000:.1f} ms  items={len(item_ids)}")
        return result
    
    def _parse_search_conditions(self, search_text):
        """Парсит строку поиска и возвращает (conditions, params).

        Синтаксис title-поиска:
          слово / "фраза"       — AND (пробел = AND)
          a | b                 — OR  (низший приоритет)
          !слово / !"фраза"     — NOT
          (a | b) c             — группировка скобками
          y:2020  yw:2020  n:текст  u:имя  prefix:значение — префиксные фильтры

        Приоритет: NOT > AND > OR
        """
        conditions = []
        params = []
        search_text = search_text.strip()
        if not search_text:
            return conditions, params

        cf_prefix_map = {}
        try:
            for f in self.get_custom_fields():
                fd = dict(f)
                sf = fd.get('search_filter')
                if sf:
                    cf_prefix_map[sf.lower()] = fd['id']
        except Exception:
            pass

        # Сортируем по убыванию длины, чтобы «yw» матчился раньше «y»
        _all_pfx_sorted = sorted(
            ['y', 'yw', 'n', 'u', 'r'] + list(cf_prefix_map.keys()),
            key=lambda p: -len(p)
        )
        _pfx_pat_sql = '|'.join(re.escape(p) for p in _all_pfx_sorted)
        _prefixed_re_sql = re.compile(
            rf'(!?)({_pfx_pat_sql}):"([^"]*)"'          # quoted: пустые "" допустимы
            rf'|(!?)({_pfx_pat_sql}):(\S+)'             # plain: есть значение
            rf'|(!?)({_pfx_pat_sql}):(?=\s|$)',         # bare: n: без значения
            re.IGNORECASE
        )

        note_terms, year_terms, watch_year_terms, rating_terms, user_terms, cf_terms = [], [], [], [], [], {}
        consumed_spans_sql = []

        for m in _prefixed_re_sql.finditer(search_text):
            g = m.groups()
            # g[0..2]  = quoted branch:  bang, pfx, val
            # g[3..5]  = plain  branch:  bang, pfx, val
            # g[6..7]  = bare   branch:  bang, pfx  (val implicitly '')
            if g[2] is not None:      # quoted branch: bang=g[0], pfx=g[1], val=g[2]
                negate_sql = g[0] == '!'
                prefix = g[1].lower()
                val = g[2]            # может быть пустой строкой (n:"")
            elif g[5] is not None:    # plain branch: bang=g[3], pfx=g[4], val=g[5]
                negate_sql = g[3] == '!'
                prefix = g[4].lower()
                val = g[5]
            else:                     # bare branch: bang=g[6], pfx=g[7], val=''
                negate_sql = g[6] == '!'
                prefix = g[7].lower()
                val = ''
            consumed_spans_sql.append((m.start(), m.end()))
            if prefix == 'n':
                note_terms.append((negate_sql, val))
            elif prefix == 'yw':
                watch_year_terms.append((negate_sql, val))
            elif prefix == 'y':
                year_terms.append((negate_sql, val))
            elif prefix == 'r':
                rating_terms.append((negate_sql, val))
            elif prefix == 'u':
                user_terms.append((negate_sql, val))
            elif prefix in cf_prefix_map:
                cf_terms.setdefault(prefix, []).append((negate_sql, val))

        _rem_chars = list(search_text)
        for start, end in sorted(consumed_spans_sql, reverse=True):
            _rem_chars[start:end] = [' '] * (end - start)
        remainder = ''.join(_rem_chars).strip()

        # Токенизатор: возвращает список токенов
        def tokenize(text):
            token_re = re.compile(r'!"([^"]+)"|"([^"]+)"|(\()|(\))|(\|)|!([^\s()|]+)|([^\s()|]+)')
            tokens = []
            for m in token_re.finditer(text):
                neg_phrase, phrase, lparen, rparen, pipe, neg_word, word = m.groups()
                if neg_phrase is not None:
                    tokens.append(('NEG_PHRASE', neg_phrase))
                elif phrase is not None:
                    tokens.append(('PHRASE', phrase))
                elif lparen is not None:
                    tokens.append(('LPAREN', '('))
                elif rparen is not None:
                    tokens.append(('RPAREN', ')'))
                elif pipe is not None:
                    tokens.append(('PIPE', '|'))
                elif neg_word is not None:
                    tokens.append(('NEG', neg_word))
                elif word is not None:
                    tokens.append(('WORD', word))
            return tokens

        # Рекурсивный спуск: expr = or_expr
        # or_expr  = and_expr (| and_expr)*
        # and_expr = atom+
        # atom     = !atom | (expr) | WORD | PHRASE
        #
        # Каждый узел возвращает SQL-фрагмент и params-список

        def build_ilike(field, val):
            # Для title ищем через title_search() — убирает 'sort:' префикс,
            # но включает само значение sort:-части в поиск
            if field == 'title':
                return 'ilike(?, title_search(title))', [val]
            return f'ilike(?, {field})', [val]

        def parse_expr(tokens, pos, field='title'):
            return parse_or(tokens, pos, field)

        def parse_or(tokens, pos, field):
            left_cond, left_params, pos = parse_and(tokens, pos, field)
            while pos < len(tokens) and tokens[pos][0] == 'PIPE':
                pos += 1  # consume |
                right_cond, right_params, pos = parse_and(tokens, pos, field)
                left_cond = f'({left_cond} OR {right_cond})'
                left_params = left_params + right_params
            return left_cond, left_params, pos

        def parse_and(tokens, pos, field):
            cond, p, pos = parse_atom(tokens, pos, field)
            parts_cond = [cond]
            parts_params = list(p)
            while pos < len(tokens) and tokens[pos][0] not in ('PIPE', 'RPAREN'):
                c, p, pos = parse_atom(tokens, pos, field)
                parts_cond.append(c)
                parts_params.extend(p)
            if len(parts_cond) == 1:
                return parts_cond[0], parts_params, pos
            combined = '(' + ' AND '.join(parts_cond) + ')'
            return combined, parts_params, pos

        def parse_atom(tokens, pos, field):
            if pos >= len(tokens):
                return '1=1', [], pos
            kind, val = tokens[pos]
            if kind == 'LPAREN':
                pos += 1
                cond, p, pos = parse_or(tokens, pos, field)
                if pos < len(tokens) and tokens[pos][0] == 'RPAREN':
                    pos += 1
                return cond, p, pos
            elif kind in ('PHRASE', 'WORD'):
                pos += 1
                c, p = build_ilike(field, val)
                return c, p, pos
            elif kind in ('NEG_PHRASE', 'NEG'):
                # NOT-токен внутри OR/AND — просто пропускаем
                # (они обрабатываются отдельно на верхнем уровне)
                pos += 1
                return '1=1', [], pos
            else:
                pos += 1
                return '1=1', [], pos

        if remainder:
            tokens = tokenize(remainder)
            # Разделяем токены на два прохода:
            # 1. NOT-токены → всегда AND NOT (вытаскиваем, удаляем соседние PIPE)
            # 2. Позитивные токены + PIPE/скобки → парсим как OR/AND
            not_conds = []
            not_params_list = []
            filtered = []

            i = 0
            while i < len(tokens):
                kind, val = tokens[i]
                if kind in ('NEG_PHRASE', 'NEG'):
                    c, p = build_ilike('title', val)
                    not_conds.append(f'NOT {c}')
                    not_params_list.extend(p)
                    # Убираем PIPE слева (если был)
                    had_left_pipe = filtered and filtered[-1][0] == 'PIPE'
                    if had_left_pipe:
                        filtered.pop()
                    # Пропускаем PIPE справа только если был левый PIPE
                    # (т.е. NOT стоял между двумя OR-членами через пробел — он "занял" правый PIPE)
                    # Если левого PIPE не было — правый PIPE оставляем, он связывает соседей
                    if i + 1 < len(tokens) and tokens[i + 1][0] == 'PIPE':
                        if had_left_pipe:
                            i += 1  # пропускаем правый PIPE — левый уже удалён
                        # иначе — оставляем правый PIPE чтобы связать соседей
                else:
                    filtered.append((kind, val))
                i += 1

            # Убираем висячие PIPE в начале/конце filtered
            while filtered and filtered[0][0] == 'PIPE':
                filtered.pop(0)
            while filtered and filtered[-1][0] == 'PIPE':
                filtered.pop()
            # Убираем двойные PIPE (если два NOT стояли рядом между позитивными)
            deduped = []
            for tok in filtered:
                if tok[0] == 'PIPE' and deduped and deduped[-1][0] == 'PIPE':
                    continue
                deduped.append(tok)
            filtered = deduped

            if filtered:
                cond, p, _ = parse_or(filtered, 0, 'title')
                if cond and cond != '1=1':
                    conditions.append(cond)
                    params.extend(p)

            for c in not_conds:
                conditions.append(c)
            params.extend(not_params_list)

        for (negate_n, t) in note_terms:
            if t == '':
                # empty sentinel: n: = заметки НЕ пустые, !n: = пустые
                if negate_n:
                    conditions.append("(notes IS NULL OR trim(notes) = '')")
                else:
                    conditions.append("(notes IS NOT NULL AND trim(notes) != '')")
                continue
            tokens = tokenize(t)
            cond, p, _ = parse_expr(tokens, 0, 'notes')
            if cond and cond != '1=1':
                if negate_n:
                    conditions.append(f'NOT ({cond})')
                else:
                    conditions.append(cond)
                params.extend(p)

        CMP_OPS_SQL = ('>=', '<=', '>', '<')

        def _sql_year_cond(t, field):
            """Вернуть (sql_cond, sql_params) для числового/текстового года с операторами.
            Для watch_date поддерживает нормализацию форматов через _normalise_yw."""
            t = t.strip()
            if not t:
                return None, []
            for op in CMP_OPS_SQL:
                if t.startswith(op):
                    operand = t[len(op):]
                    if not operand:
                        return None, []
                    if field == 'year':
                        return f'(CAST(year AS INTEGER) {op} CAST(? AS INTEGER))', [operand]
                    else:
                        iso = _normalise_yw(operand) or operand
                        iso_len = len(iso)
                        # Сравниваем только столько символов, сколько задано в запросе
                        return (
                            f'(substr(watch_date,1,{iso_len}) {op} ?)',
                            [iso]
                        )
            # Без оператора — точное совпадение для year, ISO-нормализация для watch_date
            if field == 'year':
                return '(CAST(year AS INTEGER) = CAST(? AS INTEGER))', [t]
            else:
                iso = _normalise_yw(t)
                if iso is None:
                    # не распознан формат — fallback: LIKE по оригиналу
                    return '(watch_date LIKE ?)', [f'%{t}%']
                # LIKE по ISO-фрагменту (начало строки, т.к. watch_date = YYYY-MM-DD)
                return '(watch_date LIKE ?)', [f'{iso}%']

        for (negate_y, t) in year_terms:
            if t == '':
                # empty sentinel: y: = год задан, !y: = год не задан
                if negate_y:
                    conditions.append("(year IS NULL OR year = 0 OR year = '')")
                else:
                    conditions.append("(year IS NOT NULL AND year != 0 AND year != '')")
                continue
            cond, p = _sql_year_cond(t, 'year')
            if cond:
                conditions.append(f'NOT ({cond})' if negate_y else cond)
                params.extend(p)

        for (negate_yw, t) in watch_year_terms:
            if t == '':
                # empty sentinel: yw: = дата просмотра есть, !yw: = нет
                if negate_yw:
                    conditions.append("(watch_date IS NULL OR watch_date = '')")
                else:
                    conditions.append("(watch_date IS NOT NULL AND watch_date != '')")
                continue
            cond, p = _sql_year_cond(t, 'watch_date')
            if cond:
                conditions.append(f'NOT ({cond})' if negate_yw else cond)
                params.extend(p)

        CMP_OPS_RATING = ('>=', '<=', '>', '<')

        for (negate_r, t) in rating_terms:
            t = t.strip()
            if t == '':
                # empty sentinel: r: = рейтинг выставлен (!= 0), !r: = не выставлен
                if negate_r:
                    conditions.append('(rating IS NULL OR rating = 0)')
                else:
                    conditions.append('(rating IS NOT NULL AND rating != 0)')
                continue
            matched_op = None
            for op in CMP_OPS_RATING:
                if t.startswith(op):
                    matched_op = op
                    t = t[len(op):]
                    break
            if not t:
                continue
            if matched_op:
                cond = f'(CAST(rating AS REAL) {matched_op} CAST(? AS REAL))'
            else:
                # Точное сравнение — r:1 должен находить только 1, а не 10
                cond = '(CAST(rating AS REAL) = CAST(? AS REAL))'
            conditions.append(f'NOT ({cond})' if negate_r else cond)
            params.append(t)

        for (negate_u, t) in user_terms:
            if t == '':
                # empty sentinel: u: = есть хоть один пользователь, !u: = нет
                subq_empty = 'EXISTS (SELECT 1 FROM item_users iu WHERE iu.item_id = items.id)'
                conditions.append('NOT ' + subq_empty if negate_u else subq_empty)
                continue
            for name in t.split():
                negate = name.startswith('!')
                val = name[1:] if negate else name
                if not val:
                    continue
                if '|' in val:
                    parts = [p for p in val.split('|') if p.strip()]
                    if not parts:
                        continue
                    or_conds = ' OR '.join(['ilike(?, u.name)'] * len(parts))
                    subq = f'EXISTS (SELECT 1 FROM item_users iu JOIN users u ON u.id = iu.user_id WHERE iu.item_id = items.id AND ({or_conds}))'
                else:
                    subq = 'EXISTS (SELECT 1 FROM item_users iu JOIN users u ON u.id = iu.user_id WHERE iu.item_id = items.id AND ilike(?, u.name))'
                    parts = [val]
                conditions.append('NOT ' + subq if negate else subq)
                params.extend(parts)

        _SEL = (
            "EXISTS ("
            "SELECT 1 FROM custom_field_options cfo "
            "WHERE cfo.field_id=? AND ilike(?, cfo.label) "
            "AND ("
            "CAST(cfo.id AS TEXT) = (SELECT value FROM custom_field_values WHERE item_id=items.id AND field_id=?) "
            "OR (SELECT value FROM custom_field_values WHERE item_id=items.id AND field_id=?) "
            "LIKE ('%\"' || CAST(cfo.id AS TEXT) || '\"%')"
            ")"
            ")"
        )
        _STR = (
            "EXISTS ("
            "SELECT 1 FROM custom_field_values cfv "
            "WHERE cfv.item_id=items.id AND cfv.field_id=? AND ilike(?, cfv.value)"
            ")"
        )
        _CF_EXISTS = (
            "EXISTS (SELECT 1 FROM custom_field_values cfv "
            "WHERE cfv.item_id=items.id AND cfv.field_id=? "
            "AND cfv.value IS NOT NULL AND trim(cfv.value) NOT IN ('', '0', '[]'))"
        )
        for prefix, vals in cf_terms.items():
            fid = cf_prefix_map.get(prefix)
            if fid is None:
                continue
            try:
                fd = dict(self.get_custom_field_by_id(fid))
                ftype = fd.get('field_type', 'string')
            except Exception:
                ftype = 'string'
            for (negate, v) in vals:
                if not v.strip():
                    # empty sentinel: prefix: = поле заполнено, !prefix: = пусто
                    conditions.append('NOT ' + _CF_EXISTS if negate else _CF_EXISTS)
                    params.append(fid)
                    continue
                parts = [p for p in v.split('|') if p.strip()] if '|' in v else [v]
                if not parts:
                    continue
                cond_parts = []
                if ftype in ('select', 'marks'):
                    for p in parts:
                        cond_parts.append(_SEL)
                        params.extend([fid, p, fid, fid])
                else:
                    for p in parts:
                        cond_parts.append(_STR)
                        params.extend([fid, p])
                subq = '(' + ' OR '.join(cond_parts) + ')'
                conditions.append('NOT ' + subq if negate else subq)

        return conditions, params
    def get_items(self, category_id=None, search_text='', sort_by='watch_date', ascending=False, favorites_only=False, limit=None, offset=0, date_from=None, date_to=None):
        _t0 = time.perf_counter()
        cursor = self.conn.cursor()
        params = []
        conditions = ['1=1']

        if category_id:
            conditions.append('category_id = ?')
            params.append(category_id)
        if favorites_only:
            conditions.append('is_favorite = 1')
        if date_from:
            conditions.append('substr(watch_date,1,length(?)) >= substr(?,1,length(watch_date))')
            params.extend([date_from, date_from])
        if date_to:
            conditions.append('substr(watch_date,1,length(?)) <= substr(?,1,length(watch_date))')
            params.extend([date_to, date_to])
        if search_text:
            s_cond, s_params = self._parse_search_conditions(search_text)
            conditions.extend(s_cond)
            params.extend(s_params)

        order = 'ASC' if ascending else 'DESC'
        if sort_by == 'manual':
            order_clause = 'custom_position ASC'
        elif sort_by == 'shuffle':
            order_clause = 'RANDOM()'
        elif sort_by == 'title':
            order_clause = f'natsort_title(title) {order}'
        elif sort_by == 'watch_date':
            # Нормализуем watch_date: '2024' → '2024-01-01', '2024-03' → '2024-03-01'
            # чтобы фильмы с разными форматами одной даты правильно группировались
            order_clause = f'norm_watch_date(watch_date) {order}, natsort_title(title) {order}'
        elif sort_by == 'year':
            order_clause = f'{sort_by} {order}, natsort_title(title) {order}'
        elif sort_by == 'rating':
            order_clause = f'rating {order}, natsort_title(title) {order}'
        else:
            order_clause = f'watch_date {order}, custom_position ASC'

        query = f'SELECT id, category_id, title, year, cover_path, watch_date, notes, rating, is_favorite, time_spent, view_count, custom_position FROM items WHERE {" AND ".join(conditions)} ORDER BY {order_clause}'

        if limit is not None:
            query += f' LIMIT {int(limit)} OFFSET {int(offset)}'

        cursor.execute(query, params)
        # Быстрее чем [dict(sqlite3.Row) for r in fetchall()] —
        # получаем имена колонок один раз, затем zip на каждую строку
        cols = [d[0] for d in cursor.description]
        rows = [dict(zip(cols, r)) for r in cursor.fetchall()]
        print(f"[DBG] ◀ db.get_items: {(time.perf_counter()-_t0)*1000:.1f} ms  rows={len(rows)}  cat={category_id}  sort={sort_by}")
        return rows

    def get_watch_years(self, category_id=None):
        """Return sorted list of years present in watch_date for a category."""
        cursor = self.conn.cursor()
        params = []
        cond = "watch_date IS NOT NULL AND watch_date != ''"
        if category_id:
            cond += ' AND category_id = ?'
            params.append(category_id)
        cursor.execute(
            f"SELECT DISTINCT substr(watch_date, 1, 4) as yr FROM items "
            f"WHERE {cond} AND length(watch_date) >= 4 "
            f"ORDER BY yr DESC", params
        )
        return [r[0] for r in cursor.fetchall() if r[0] and r[0].isdigit()]

    def get_items_count(self, category_id=None, search_text='', favorites_only=False, date_from=None, date_to=None):
        cursor = self.conn.cursor()
        params = []
        conditions = ['1=1']

        if category_id:
            conditions.append('category_id = ?')
            params.append(category_id)
        if favorites_only:
            conditions.append('is_favorite = 1')
        if date_from:
            conditions.append('substr(watch_date,1,length(?)) >= substr(?,1,length(watch_date))')
            params.extend([date_from, date_from])
        if date_to:
            conditions.append('substr(watch_date,1,length(?)) <= substr(?,1,length(watch_date))')
            params.extend([date_to, date_to])
        if search_text:
            s_cond, s_params = self._parse_search_conditions(search_text)
            conditions.extend(s_cond)
            params.extend(s_params)

        cursor.execute(f'SELECT COUNT(*) FROM items WHERE {" AND ".join(conditions)}', params)
        return cursor.fetchone()[0]
    

    def get_items_by_ids(self, item_ids):
        """Получить данные элементов по списку id"""
        if not item_ids:
            return {}
        cursor = self.conn.cursor()
        result = {}
        item_ids = list(item_ids)
        for i in range(0, len(item_ids), 999):
            chunk = item_ids[i:i+999]
            placeholders = ','.join('?' * len(chunk))
            cursor.execute(f'SELECT * FROM items WHERE id IN ({placeholders})', chunk)
            for row in cursor.fetchall():
                result[row['id']] = row
        return result
    
    def add_item(self, category_id, title, year=None, cover_path=None, 
                 watch_date=None, notes=None, rating=None, user_ids=None, 
                 is_favorite=False, time_spent=0, view_count=1):
        cursor = self.conn.cursor()
        cursor.execute('SELECT MAX(custom_position) FROM items WHERE category_id = ?', (category_id,))
        max_pos = cursor.fetchone()[0]
        next_pos = (max_pos or 0) + 1
        cursor.execute('''
            INSERT INTO items (category_id, title, year, cover_path, watch_date, notes, rating, is_favorite, time_spent, view_count, custom_position)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', (category_id, title, year, cover_path, watch_date, notes, rating, is_favorite, time_spent, view_count, next_pos))
        item_id = cursor.lastrowid
        if user_ids:
            for user_id in user_ids:
                cursor.execute('INSERT INTO item_users (item_id, user_id) VALUES (?, ?)', (item_id, user_id))
        self.commit()
        return item_id
    
    def update_item(self, item_id, **kwargs):
        cursor = self.conn.cursor()
        fields = []
        values = []
        for field in ['title', 'year', 'cover_path', 'watch_date', 'notes', 'rating', 'is_favorite', 'time_spent', 'view_count']:
            if field in kwargs:
                fields.append(f'{field} = ?')
                values.append(kwargs[field])
        if fields:
            values.append(item_id)
            query = f'UPDATE items SET {", ".join(fields)} WHERE id = ?'
            cursor.execute(query, values)
        if 'user_ids' in kwargs:
            cursor.execute('DELETE FROM item_users WHERE item_id = ?', (item_id,))
            for user_id in kwargs['user_ids']:
                cursor.execute('INSERT INTO item_users (item_id, user_id) VALUES (?, ?)', (item_id, user_id))
        self.commit()

    
    def delete_item(self, item_id):
        cursor = self.conn.cursor()
        cursor.execute('DELETE FROM item_users WHERE item_id = ?', (item_id,))
        cursor.execute('DELETE FROM items WHERE id = ?', (item_id,))
        self.commit()

    def delete_items_batch(self, item_ids):
        """Удаляет список элементов одной транзакцией."""
        if not item_ids:
            return
        cursor = self.conn.cursor()
        item_ids = list(item_ids)
        for i in range(0, len(item_ids), 999):
            chunk = item_ids[i:i+999]
            placeholders = ','.join('?' * len(chunk))
            cursor.execute(f'DELETE FROM item_users WHERE item_id IN ({placeholders})', chunk)
            cursor.execute(f'DELETE FROM custom_field_values WHERE item_id IN ({placeholders})', chunk)
            cursor.execute(f'DELETE FROM items WHERE id IN ({placeholders})', chunk)
        self.commit()

    def add_items_batch(self, rows, cf_rows=None, user_rows=None):
        """Вставляет список элементов одной транзакцией.
        rows: [(category_id, title, year, cover_path, watch_date, notes, rating,
                is_favorite, time_spent, view_count, custom_position), ...]
        cf_rows: [(item_index_in_rows, field_id, value), ...]  — кастомные поля
        user_rows: [(item_index_in_rows, user_id), ...]        — пользователи
        Возвращает список новых id в том же порядке что и rows."""
        if not rows:
            return []
        cursor = self.conn.cursor()
        # Узнаём max id ДО вставки — надёжнее чем lastrowid после executemany
        cursor.execute('SELECT COALESCE(MAX(id), 0) FROM items')
        id_before = cursor.fetchone()[0]
        cursor.executemany('''
            INSERT INTO items (category_id, title, year, cover_path, watch_date,
                               notes, rating, is_favorite, time_spent, view_count, custom_position)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ''', rows)
        first_id = id_before + 1
        new_ids = list(range(first_id, first_id + len(rows)))
        if user_rows:
            cursor.executemany(
                'INSERT OR IGNORE INTO item_users (item_id, user_id) VALUES (?, ?)',
                [(new_ids[idx], uid) for idx, uid in user_rows]
            )
        if cf_rows:
            cursor.executemany(
                'INSERT OR REPLACE INTO custom_field_values (item_id, field_id, value) VALUES (?, ?, ?)',
                [(new_ids[idx], fid, val) for idx, fid, val in cf_rows]
            )
        self.commit()
        return new_ids


    
    def reorder_position(self, table, item_id, prev_id, next_id):
        """Универсальный метод: обновить позицию одного элемента в любой таблице."""
        cursor = self.conn.cursor()

        # Инициализируем если все нули
        cursor.execute(f'SELECT COUNT(*) FROM {table} WHERE position != 0')
        if cursor.fetchone()[0] == 0:
            cursor.execute(f'SELECT id FROM {table} ORDER BY id ASC')
            ids = [r[0] for r in cursor.fetchall()]
            cursor.executemany(
                f'UPDATE {table} SET position = ? WHERE id = ?',
                [(float(i + 1), iid) for i, iid in enumerate(ids)]
            )

        if prev_id is None and next_id is None:
            new_pos = 1.0
        elif prev_id is None:
            cursor.execute(f'SELECT position FROM {table} WHERE id = ?', (next_id,))
            row = cursor.fetchone()
            next_pos_val = float(row[0]) if row else 1.0
            # Всегда ставим на 1.0 меньше следующего — гарантируем позицию ПЕРЕД ним
            new_pos = next_pos_val - 1.0
        elif next_id is None:
            cursor.execute(f'SELECT position FROM {table} WHERE id = ?', (prev_id,))
            row = cursor.fetchone()
            new_pos = (row[0] if row else 1.0) + 1.0
        else:
            cursor.execute(f'SELECT position FROM {table} WHERE id = ?', (prev_id,))
            prev_pos = (cursor.fetchone() or [0.0])[0]
            cursor.execute(f'SELECT position FROM {table} WHERE id = ?', (next_id,))
            next_pos = (cursor.fetchone() or [prev_pos + 2.0])[0]
            new_pos = (prev_pos + next_pos) / 2.0

            if abs(next_pos - prev_pos) < 0.0001:
                cursor.execute(f'SELECT id FROM {table} ORDER BY position ASC')
                ids = [r[0] for r in cursor.fetchall()]
                cursor.executemany(
                    f'UPDATE {table} SET position = ? WHERE id = ?',
                    [(float(i + 1), iid) for i, iid in enumerate(ids)]
                )
                try:
                    new_pos = (float(ids.index(prev_id) + 1) + float(ids.index(next_id) + 1)) / 2.0
                except ValueError:
                    new_pos = float(len(ids)) + 1.0

        cursor.execute(f'UPDATE {table} SET position = ? WHERE id = ?', (new_pos, item_id))
        self.conn.commit()
    
    def get_item_users(self, item_id):
        cursor = self.conn.cursor()
        cursor.execute('''
            SELECT u.* FROM users u
            JOIN item_users iu ON u.id = iu.user_id
            WHERE iu.item_id = ?
            ORDER BY u.position ASC
        ''', (item_id,))
        return cursor.fetchall()
    
    def get_item_by_id(self, item_id):
        cursor = self.conn.cursor()
        cursor.execute('SELECT * FROM items WHERE id = ?', (item_id,))
        return cursor.fetchone()

    def get_item_full(self, item_id):
        """Вернуть (item_dict, users_list, cf_values_dict) за три быстрых запроса
        вместо четырёх отдельных вызовов."""
        cursor = self.conn.cursor()
        cursor.execute('SELECT * FROM items WHERE id = ?', (item_id,))
        item = cursor.fetchone()
        if not item:
            return None, [], {}
        cursor.execute('''
            SELECT u.id, u.name FROM users u
            JOIN item_users iu ON u.id = iu.user_id
            WHERE iu.item_id = ?
            ORDER BY u.position ASC
        ''', (item_id,))
        users = [dict(r) for r in cursor.fetchall()]
        cursor.execute('SELECT field_id, value FROM custom_field_values WHERE item_id=?', (item_id,))
        cf_values = {row['field_id']: row['value'] for row in cursor.fetchall()}
        return dict(item), users, cf_values


    def get_users_for_items(self, item_ids):
            """Загрузить пользователей для списка элементов за ОДИН запрос"""
            _t0 = time.perf_counter()
            if not item_ids:
                return {}
            cursor = self.conn.cursor()
            result = {}
            item_ids = list(item_ids)
            for i in range(0, len(item_ids), 999):
                chunk = item_ids[i:i+999]
                placeholders = ','.join('?' * len(chunk))
                cursor.execute(f'''
                    SELECT iu.item_id, u.id, u.name FROM users u
                    JOIN item_users iu ON u.id = iu.user_id
                    WHERE iu.item_id IN ({placeholders})
                    ORDER BY u.position ASC
                ''', chunk)
                for item_id, user_id, user_name in cursor.fetchall():
                    if item_id not in result:
                        result[item_id] = []
                    result[item_id].append({'id': user_id, 'name': user_name})
            print(f"[DBG] ◀ db.get_users_for_items: {(time.perf_counter()-_t0)*1000:.1f} ms  items={len(item_ids)}")
            return result

    # -------------------------------------------------------------------------
    # Universal CSV engine
    # -------------------------------------------------------------------------

    # Section markers — written as bare lines (outside csv rows) so csv.writer
    # never touches them.  A line is a section header iff it matches exactly.
    SECTION_CATEGORY             = '#CATEGORY'
    SECTION_CUSTOM_FIELDS        = '#CUSTOM_FIELDS'
    SECTION_CUSTOM_FIELD_OPTIONS = '#CUSTOM_FIELD_OPTIONS'
    SECTION_USERS                = '#USERS'
    SECTION_ITEMS                = '#ITEMS'
    SECTION_TIER_CONFIG          = '#TIER_CONFIG'
    SECTION_TIER_ITEMS           = '#TIER_ITEMS'
    SECTION_TIER_SETS            = '#TIER_SETS'
    SECTION_TIER_SET_ITEMS       = '#TIER_SET_ITEMS'
    ALL_SECTIONS = {
        SECTION_CATEGORY,
        SECTION_CUSTOM_FIELDS,
        SECTION_CUSTOM_FIELD_OPTIONS,
        SECTION_USERS,
        SECTION_ITEMS,
        SECTION_TIER_CONFIG,
        SECTION_TIER_ITEMS,
        SECTION_TIER_SETS,
        SECTION_TIER_SET_ITEMS,
    }

    # ------------------------------------------------------------------
    # Export helpers
    # ------------------------------------------------------------------

    def export_csv_build(self, category_id,
                         include_items=True,
                         include_custom_fields=True,
                         include_users=False,
                         icon_mode='base64',        # 'none' | 'base64' | 'folder'
                         icons_dir=None,            # required when icon_mode=='folder'
                         export_images=False,
                         images_dir=None,
                         bg_dir=None,              # папка для фона категории
                         sort_by='watch_date',
                         ascending=False,
                         include_category_info=False,
                         progress_callback=None,    # callable(done, total, msg) или None
                         translations=None):
        """
        Build a list of raw text lines for a universal CSV export.
        Returns (lines: list[str], warnings: list[str]).
        Caller writes lines to a file with '\\n'.join(lines).

        icon_mode applies to custom field file-icons.
        images_dir / icons_dir must be str paths when folder mode is used.
        """
        lines = []
        warnings = []

        def _csv_line(*values):
            """Encode one CSV row → string (no trailing newline)."""
            buf = io.StringIO()
            w = csv.writer(buf, quoting=csv.QUOTE_ALL)
            w.writerow(['' if v is None else str(v) for v in values])
            return buf.getvalue().rstrip('\r\n')

        def _icon_export(icon_str):
            """Return exported icon value given icon_mode."""
            if not icon_str or not icon_str.startswith('file:'):
                return icon_str or ''
            abs_p = to_absolute_path(icon_str[5:])
            if not os.path.exists(abs_p):
                return ''
            if icon_mode == 'none':
                return ''
            if icon_mode == 'base64':
                try:
                    with open(abs_p, 'rb') as fh:
                        b64 = base64.b64encode(fh.read()).decode('utf-8')
                    ext = os.path.splitext(abs_p)[1].lower().lstrip('.')
                    return f'file:base64:{ext}:{b64}'
                except Exception as e:
                    warnings.append(f'Icon export failed ({abs_p}): {e}')
                    return ''
            if icon_mode == 'folder' and icons_dir:
                try:
                    fname = os.path.basename(abs_p)
                    dest = os.path.join(icons_dir, fname)
                    # Avoid collision: if file exists but content differs, use unique name
                    if os.path.exists(dest):
                        if not filecmp.cmp(abs_p, dest, shallow=False):
                            base, ext = os.path.splitext(fname)
                            fname = f'{base}_{uuid.uuid4().hex[:8]}{ext}'
                            dest = os.path.join(icons_dir, fname)
                            shutil.copy2(abs_p, dest)
                    else:
                        shutil.copy2(abs_p, dest)
                    return f'file:folder:{fname}'
                except Exception as e:
                    warnings.append(f'Icon copy failed ({abs_p}): {e}')
                    return ''
            return icon_str

        # ── #CATEGORY ─────────────────────────────────────────────────
        if include_category_info and category_id is not None:
            cursor = self.conn.cursor()
            cursor.execute('SELECT name, icon, bg_path, bg_overlay FROM categories WHERE id = ?', (category_id,))
            _cat_row = cursor.fetchone()
            if _cat_row:
                _cat_name = _cat_row[0] or ''
                _cat_icon_raw = _cat_row[1] or '🏷'
                _cat_bg_path_raw = _cat_row[2] or ''
                _cat_bg_overlay  = _cat_row[3] if _cat_row[3] is not None else 0.65
                # Export category icon to _icons folder as _category.ext
                _cat_icon_exported = _cat_icon_raw
                if _cat_icon_raw.startswith('file:') and icon_mode == 'folder' and icons_dir:
                    _abs_icon = to_absolute_path(_cat_icon_raw[5:])
                    if os.path.exists(_abs_icon):
                        _ext = os.path.splitext(_abs_icon)[1] or '.png'
                        _dest_name = f'_category{_ext}'
                        _dest = os.path.join(icons_dir, _dest_name)
                        try:
                            os.makedirs(icons_dir, exist_ok=True)
                            shutil.copy2(_abs_icon, _dest)
                            _cat_icon_exported = f'file:folder:{_dest_name}'
                        except Exception as e:
                            warnings.append(f'Category icon export failed: {e}')
                            _cat_icon_exported = ''
                elif _cat_icon_raw.startswith('file:') and icon_mode == 'base64':
                    _cat_icon_exported = _icon_export(_cat_icon_raw)
                # Export category background image to _bg folder
                _cat_bg_exported = ''
                if _cat_bg_path_raw and bg_dir:
                    _abs_bg = to_absolute_path(_cat_bg_path_raw)
                    if os.path.exists(_abs_bg):
                        try:
                            os.makedirs(bg_dir, exist_ok=True)
                            _bg_fname = os.path.basename(_abs_bg)
                            _bg_dest  = os.path.join(bg_dir, _bg_fname)
                            shutil.copy2(_abs_bg, _bg_dest)
                            _cat_bg_exported = _bg_fname
                        except Exception as e:
                            warnings.append(f'Category bg export failed: {e}')
                lines.append(self.SECTION_CATEGORY)
                lines.append(_csv_line('name', 'icon', 'bg_path', 'bg_overlay'))
                lines.append(_csv_line(_cat_name, _cat_icon_exported,
                                       _cat_bg_exported, _cat_bg_overlay))

        # ── #CUSTOM_FIELDS ────────────────────────────────────────────
        if include_custom_fields:
            fields = self.get_custom_fields()
            if fields:
                lines.append(self.SECTION_CUSTOM_FIELDS)
                # header
                lines.append(_csv_line(
                    'variable', 'name', 'icon', 'field_type', 'type_options',
                    'show_in_list', 'show_in_list_compact', 'show_in_detail',
                    'show_in_context_menu', 'context_menu_label',
                    'show_name_in_list', 'name_color', 'search_filter'
                ))
                for f in fields:
                    f = dict(f)
                    lines.append(_csv_line(
                        f['variable'], f['name'], _icon_export(f.get('icon') or ''),
                        f['field_type'], f.get('type_options') or '',
                        f['show_in_list'], f['show_in_list_compact'], f['show_in_detail'],
                        f['show_in_context_menu'], f.get('context_menu_label') or '',
                        f.get('show_name_in_list', 0), f.get('name_color') or '#ffffff',
                        f.get('search_filter') or ''
                    ))

                # ── #CUSTOM_FIELD_OPTIONS ─────────────────────────────
                lines.append(self.SECTION_CUSTOM_FIELD_OPTIONS)
                lines.append(_csv_line('variable', 'option_id', 'label', 'position'))
                for f in fields:
                    f = dict(f)
                    if f['field_type'] not in ('select', 'marks'):
                        continue
                    opts = self.get_field_options(f['id'])
                    for opt in opts:
                        lines.append(_csv_line(
                            f['variable'], opt['id'], opt['label'], opt['position']
                        ))

        # ── #USERS ────────────────────────────────────────────────────
        if include_users:
            users = self.get_users()
            if users:
                lines.append(self.SECTION_USERS)
                lines.append(_csv_line('name', 'position'))
                for u in users:
                    lines.append(_csv_line(u['name'], u['position']))

        # ── #ITEMS ────────────────────────────────────────────────────
        if include_items and category_id is not None:
            items = self.get_items(category_id, sort_by=sort_by, ascending=ascending)
            all_ids = [dict(r)['id'] for r in items]
            users_map = self.get_users_for_items(all_ids)
            cf_map = self.get_custom_fields_for_items_batch(all_ids) if include_custom_fields else {}
            fields_list = [dict(f) for f in self.get_custom_fields()] if include_custom_fields else []

            lines.append(self.SECTION_ITEMS)
            cf_headers = [f'cf_{f["variable"]}' for f in fields_list]
            lines.append(_csv_line(
                'id', 'title', 'year', 'watch_date', 'notes', 'rating',
                'is_favorite', 'time_spent', 'view_count', 'users', 'cover',
                *cf_headers
            ))

            _items_total = len(items)
            for _item_idx, row in enumerate(items):
                item = dict(row)
                item_id = item['id']
                users = users_map.get(item_id, [])

                cover_filename = ''
                abs_cover = to_absolute_path(item.get('cover_path'))
                if export_images and abs_cover and os.path.exists(abs_cover) and images_dir:
                    ext = os.path.splitext(abs_cover)[1] or '.jpg'
                    safe = "".join(
                        c for c in (item.get('title') or 'cover')
                        if c.isalnum() or c in ' _-'
                    ).strip()[:50].strip()
                    safe = safe or 'cover'
                    # id guarantees uniqueness even if two titles produce same safe name
                    cover_filename = f"{item_id}_{safe}{ext}"
                    dest = os.path.join(images_dir, cover_filename)
                    try:
                        shutil.copy2(abs_cover, dest)
                    except Exception as e:
                        warnings.append(f'Cover copy failed: {e}')
                        cover_filename = ''
                    if progress_callback:
                        _tr = translations or {}
                        _copying_msg = _tr.get('progress_copying_covers', 'Copying covers')
                        progress_callback(_item_idx + 1, _items_total,
                            f'{_copying_msg} {_item_idx + 1}/{_items_total}...')

                item_cf = cf_map.get(item_id, {})
                cf_values = []
                for f in fields_list:
                    fid = f['id']
                    cf_values.append(item_cf.get(fid) or '')

                lines.append(_csv_line(
                    item_id,
                    item.get('title', ''),
                    item.get('year', ''),
                    item.get('watch_date', ''),
                    item.get('notes', ''),
                    item.get('rating', ''),
                    '1' if item.get('is_favorite') else '0',
                    item.get('time_spent', 0),
                    item.get('view_count', 1),
                    ';'.join(u['name'] for u in users),
                    cover_filename,
                    *cf_values
                ))

        # ── #TIER_CONFIG ──────────────────────────────────────────────
        if include_items and category_id is not None:
            tiers = self.get_tier_config(category_id)
            if tiers:
                lines.append(self.SECTION_TIER_CONFIG)
                lines.append(_csv_line('key', 'label', 'color'))
                for t in tiers:
                    lines.append(_csv_line(t['key'], t['label'], t['color']))

        # ── #TIER_ITEMS ───────────────────────────────────────────────
        if include_items and category_id is not None:
            tier_assignments = self.get_tier_items(category_id)
            # Build title→id map for matching on import
            id_to_title = {dict(r)['id']: dict(r)['title'] for r in self.get_items(category_id)}
            has_any = any(tier_assignments.values())
            if has_any:
                lines.append(self.SECTION_TIER_ITEMS)
                lines.append(_csv_line('tier_key', 'item_id', 'item_title', 'position'))
                for tier_key, item_ids in tier_assignments.items():
                    for pos, item_id in enumerate(item_ids):
                        title = id_to_title.get(item_id, '')
                        if title:
                            lines.append(_csv_line(tier_key, item_id, title, pos))

        # ── #TIER_SETS ────────────────────────────────────────────────
        if include_items and category_id is not None:
            sets = self.get_tier_list_sets(category_id)
            if sets:
                lines.append(self.SECTION_TIER_SETS)
                lines.append(_csv_line('set_name', 'order_idx'))
                for s in sets:
                    lines.append(_csv_line(s['name'], s['order_idx']))

        # ── #TIER_SET_ITEMS ───────────────────────────────────────────
        if include_items and category_id is not None:
            sets = self.get_tier_list_sets(category_id)
            if sets:
                id_to_title = {dict(r)['id']: dict(r)['title'] for r in self.get_items(category_id)}
                has_any_set_items = False
                set_item_lines = []
                for s in sets:
                    placements = self.get_tier_set_items(s['id'])
                    for tier_key, item_ids in placements.items():
                        for pos, item_id in enumerate(item_ids):
                            title = id_to_title.get(item_id, '')
                            if title:
                                set_item_lines.append(_csv_line(s['name'], tier_key, item_id, title, pos))
                                has_any_set_items = True
                if has_any_set_items:
                    lines.append(self.SECTION_TIER_SET_ITEMS)
                    lines.append(_csv_line('set_name', 'tier_key', 'item_id', 'item_title', 'position'))
                    lines.extend(set_item_lines)

        return lines, warnings

    def export_csv_write(self, file_path, lines):
        """Write lines produced by export_csv_build to file_path."""
        with open(file_path, 'w', encoding='utf-8', newline='') as fh:
            fh.write('\n'.join(lines))
            if lines:
                fh.write('\n')

    # ------------------------------------------------------------------
    # Import helpers
    # ------------------------------------------------------------------

    def import_csv_parse(self, file_path, file_text=None):
        """
        Parse a universal CSV file.
        file_text: if provided, use this string instead of reading file_path.
        Returns a dict:
        {
          'custom_fields':        [dict, ...],   # column→value rows
          'custom_field_options': [dict, ...],
          'users':                [dict, ...],
          'items':                [dict, ...],
        }
        Raises ValueError with a human-readable message on format errors.
        """
        result = {
            'category':             [],
            'custom_fields':        [],
            'custom_field_options': [],
            'users':                [],
            'items':                [],
            'tier_config':          [],
            'tier_items':           [],
            'tier_sets':            [],
            'tier_set_items':       [],
        }

        section_key = {
            self.SECTION_CATEGORY:             'category',
            self.SECTION_CUSTOM_FIELDS:        'custom_fields',
            self.SECTION_CUSTOM_FIELD_OPTIONS: 'custom_field_options',
            self.SECTION_USERS:                'users',
            self.SECTION_ITEMS:                'items',
            self.SECTION_TIER_CONFIG:          'tier_config',
            self.SECTION_TIER_ITEMS:           'tier_items',
            self.SECTION_TIER_SETS:            'tier_sets',
            self.SECTION_TIER_SET_ITEMS:       'tier_set_items',
        }

        # Split file into section blocks first, then parse each as CSV
        try:
            if file_text is not None:
                raw = file_text
            else:
                try:
                    with open(file_path, 'r', encoding='utf-8-sig', newline='') as fh:
                        raw = fh.read()
                except UnicodeDecodeError:
                    with open(file_path, 'r', encoding='cp1251', newline='') as fh:
                        raw = fh.read()
        except Exception as e:
            raise ValueError(f'Cannot read file: {e}')

        # Split on section markers — must handle newlines inside quoted CSV fields.
        # Strategy: find section marker positions in raw text, then slice substrings.
        import re as _re
        # Build pattern that matches any section marker at start of line
        _section_pattern = _re.compile(
            r'^(' + '|'.join(_re.escape(s) for s in self.ALL_SECTIONS) + r')\s*$',
            _re.MULTILINE
        )
        # Find all section markers and their positions
        _matches = list(_section_pattern.finditer(raw))
        blocks = {}
        for _i, _m in enumerate(_matches):
            _sec_name = _m.group(1).strip()
            _sec_key = section_key.get(_sec_name)
            if not _sec_key:
                continue
            # Content starts after the marker line (skip the \n after marker)
            _start = _m.end()
            if _start < len(raw) and raw[_start] in ('\r', '\n'):
                _start += 1
            if _start < len(raw) and raw[_start] == '\n':
                _start += 1
            # Content ends at next section marker (or end of file)
            _end = _matches[_i + 1].start() if _i + 1 < len(_matches) else len(raw)
            _block_text = raw[_start:_end].rstrip('\r\n')
            if _block_text:
                blocks[_sec_key] = _block_text

        # Parse each block as CSV — DictReader handles quoted newlines correctly
        for key, text in blocks.items():
            if not text:
                continue
            try:
                reader = csv.DictReader(io.StringIO(text))
                rows = []
                for row in reader:
                    rows.append({k.strip(): (v.strip().replace('\\n', '\n').strip() if v else '') for k, v in row.items()})
                result[key] = rows
            except Exception as e:
                raise ValueError(f'CSV parse error in section {key}: {e}')

        print(f"[DBG PARSE] file={str(file_path)[-40:] if file_path else 'text'} sections={list(blocks.keys())} items={len(result.get('items',[]))}")
        return result

    def import_csv_resolve_icon(self, icon_str, icons_dir=None, zip_src=None, icons_prefix=None):
        """
        Resolve an exported icon value back to a local file: path or emoji.
        icon_str formats:
          ''                    → ''
          'emoji'               → 'emoji'  (pass-through)
          'file:base64:ext:...' → write file, return 'file:rel/path'
          'file:folder:fname'   → return 'file:rel/path' using icons_dir
          'file:/abs/path'      → copy to ICONS_DIR, return 'file:rel/path'
        """
        if not icon_str:
            return ''
        if not icon_str.startswith('file:'):
            return icon_str   # plain emoji

        parts = icon_str.split(':', 3)
        if len(parts) < 2:
            return ''

        mode = parts[1] if len(parts) > 1 else ''

        if mode == 'base64' and len(parts) == 4:
            ext, b64data = parts[2], parts[3]
            try:
                raw = base64.b64decode(b64data)
                fname = f'icon_{uuid.uuid4().hex}.{ext}'
                dest = str(ICONS_DIR / fname)
                os.makedirs(os.path.dirname(dest), exist_ok=True)
                with open(dest, 'wb') as fh:
                    fh.write(raw)
                return f'file:{to_relative_path(dest)}'
            except Exception:
                return ''

        if mode == 'folder' and len(parts) >= 3:
            fname = parts[2]
            ext = os.path.splitext(fname)[1] or '.png'
            # Prefer keeping original filename so repeated import/export diffs stay clean.
            # Fall back to uuid only if the name is already taken by a different file.
            preferred = str(ICONS_DIR / fname)
            def _pick_dest(data_or_src_path, is_bytes=True):
                """Return dest path: reuse existing if identical, else uuid."""
                if os.path.exists(preferred):
                    if is_bytes:
                        try:
                            if open(preferred, 'rb').read() == data_or_src_path:
                                return preferred  # identical — reuse
                        except Exception:
                            pass
                    else:
                        try:
                            if filecmp.cmp(preferred, data_or_src_path, shallow=False):
                                return preferred
                        except Exception:
                            pass
                    # Different content — use uuid to avoid stomping another entity's file
                    return str(ICONS_DIR / f'icon_{uuid.uuid4().hex}{ext}')
                return preferred
            # Read directly from ZIP if available
            if zip_src and icons_prefix:
                member = icons_prefix + fname
                try:
                    with zipfile.ZipFile(zip_src, 'r') as zf:
                        data = zf.read(member)
                    dest = _pick_dest(data, is_bytes=True)
                    if dest != preferred or not os.path.exists(dest):
                        with open(dest, 'wb') as fh:
                            fh.write(data)
                    return f'file:{to_relative_path(dest)}'
                except Exception:
                    pass
            # Fallback: read from icons_dir folder on disk
            if icons_dir:
                abs_p = os.path.join(icons_dir, fname)
                if os.path.exists(abs_p):
                    try:
                        dest = _pick_dest(abs_p, is_bytes=False)
                        if dest != preferred or not os.path.exists(dest):
                            shutil.copy2(abs_p, dest)
                        return f'file:{to_relative_path(dest)}'
                    except Exception:
                        pass
            return ''


        # 'file:/abs/path' — legacy or direct path: copy to fresh uuid so this
        # entity owns its own file independently of whoever else may reference it.
        abs_p = to_absolute_path(icon_str[5:])
        if os.path.exists(abs_p):
            ext = os.path.splitext(abs_p)[1] or '.png'
            unique_fname = f'icon_{uuid.uuid4().hex}{ext}'
            dest = str(ICONS_DIR / unique_fname)
            try:
                shutil.copy2(abs_p, dest)
                return f'file:{to_relative_path(dest)}'
            except Exception:
                return ''  # copy failed — don't return path to non-existent file
        return ''

    def import_csv_diff(self, parsed):
        """
        Compare parsed CSV data against current DB state.
        Returns a dict of changes:
        {
          'new_fields':     [dict],   # fields not in DB
          'changed_fields': [(db_row, csv_row, [changed_attr, ...])],
          'new_options':    [(variable, label)],   # options not in DB
          'changed_options':[(variable, old_label, new_label)],  # label changed by id
          'new_users':      [name],
          'new_items':      [dict],   # always — items are always "new"
          'duplicate_items':[dict],   # items whose title already exists in category
        }
        """
        cursor = self.conn.cursor()

        # ── custom fields ─────────────────────────────────────────────
        existing_fields = {dict(f)['variable']: dict(f) for f in self.get_custom_fields()}
        new_fields = []
        changed_fields = []

        # Attributes compared for CHANGED fields (existing field in DB).
        # Insignificant UI-only attrs (show_in_list, column_width, position etc.)
        # are intentionally excluded — user's local preferences are preserved.
        FIELD_ATTRS_TEXT = [
            'name',               # display label
            'field_type',         # type (text/number/date/…)
            'type_options',       # options JSON for select/multiselect
            'context_menu_label', # label shown in context menu
            'name_color',         # colour tag
            'search_filter',      # searchable flag
            'placeholder',        # input hint text
            'default_value',      # default value
            'min_value',          # numeric/slider min
            'max_value',          # numeric/slider max
            'step',               # slider step
            'is_required',        # required flag
        ]
        # Integer-like attrs: treat None/empty/0 all as equivalent
        FIELD_ATTRS_INT = {
            'search_filter', 'is_required',
        }

        def _norm_icon(val):
            """Normalise icon for comparison.
            - file:base64:ext:DATA  → sha256 of decoded bytes (content hash)
            - file:folder:fname     → 'fname'  (just filename)
            - file:/abs/path        → basename (just filename)
            - emoji / empty         → as-is
            """
            v = str(val or '')
            if v.startswith('file:base64:'):
                parts = v.split(':', 3)
                if len(parts) == 4:
                    try:
                        return 'sha256:' + hashlib.sha256(base64.b64decode(parts[3])).hexdigest()
                    except Exception:
                        pass
                return f'file:base64:{parts[2]}' if len(parts) >= 3 else 'file:base64'
            if v.startswith('file:folder:'):
                parts = v.split(':', 2)
                return os.path.basename(parts[2]) if len(parts) >= 3 else v
            if v.startswith('file:'):
                return os.path.basename(v[5:])
            return v

        def _norm_int(val):
            try:
                return int(val or 0)
            except (ValueError, TypeError):
                return 0

        for row in parsed.get('custom_fields', []):
            var = row.get('variable', '').strip()
            if not var:
                continue
            if var not in existing_fields:
                new_fields.append(row)
            else:
                db_f = existing_fields[var]
                diffs = []
                # Compare icon separately with normalisation
                if _norm_icon(db_f.get('icon')) != _norm_icon(row.get('icon')):
                    diffs.append('icon')
                # Compare text/int attrs
                for attr in FIELD_ATTRS_TEXT:
                    if attr in FIELD_ATTRS_INT:
                        if _norm_int(db_f.get(attr)) != _norm_int(row.get(attr)):
                            diffs.append(attr)
                    else:
                        db_val  = str(db_f.get(attr) or '')
                        csv_val = str(row.get(attr) or '')
                        if db_val != csv_val:
                            diffs.append(attr)
                if diffs:
                    changed_fields.append((db_f, row, diffs))

        # ── field options ─────────────────────────────────────────────
        new_options = []
        changed_options = []

        # Build lookup: variable → {option_id: label}
        opt_by_var = {}
        for f in self.get_custom_fields():
            f = dict(f)
            if f['field_type'] in ('select', 'marks'):
                opts = self.get_field_options(f['id'])
                opt_by_var[f['variable']] = {
                    opt['id']: opt['label'] for opt in opts
                }
                # also label→id for existence check
                opt_by_var[f['variable'] + '__bylabel'] = {
                    opt['label']: opt['id'] for opt in opts
                }

        for row in parsed.get('custom_field_options', []):
            var = row.get('variable', '').strip()
            label = row.get('label', '').strip()
            try:
                opt_id = int(row.get('option_id', 0))
            except (ValueError, TypeError):
                opt_id = 0

            if var not in opt_by_var:
                # Field doesn't exist yet — options added automatically in import_csv_apply step 1b
                continue

            by_id = opt_by_var.get(var, {})
            by_label = opt_by_var.get(var + '__bylabel', {})

            if label in by_label:
                # Label already exists in DB → no change needed, skip
                pass
            elif opt_id in by_id:
                # Same ID exists but label differs → treat as rename
                changed_options.append((var, by_id[opt_id], label))
            else:
                # Neither label nor ID matches → genuinely new option
                new_options.append((var, label))

        # ── users ─────────────────────────────────────────────────────
        cursor.execute('SELECT name FROM users')
        existing_names = {r['name'] for r in cursor.fetchall()}
        new_users = [
            r['name'] for r in parsed.get('users', [])
            if r.get('name', '').strip() and r['name'].strip() not in existing_names
        ]

        return {
            'new_fields':      new_fields,
            'changed_fields':  changed_fields,
            'new_options':     new_options,
            'changed_options': changed_options,
            'new_users':       new_users,
            '_db_fields':      list(existing_fields.values()),  # для UI: имена полей
        }

    def import_csv_apply(self, parsed, diff, category_id,
                          apply_new_fields=None,        # list of field rows to add (None = all)
                          apply_changed_fields=None,    # set of variables to update
                          apply_new_options=None,       # list of (var, label) to add (None = all)
                          apply_changed_options=None,   # set of (var, old_label) to update
                          apply_new_users=None,         # list of user names to add (None = all)
                          import_images=False,
                          images_dir=None,
                          icons_dir=None,
                          zip_src=None,
                          icons_prefix=None,
                          jpg_quality=85,
                          progress_cb=None,             # optional callable(pct:int, msg:str)
                          translations=None):           # optional dict for i18n
        """
        Apply parsed+diffed data to the database.
        apply_new_fields:     list of field rows to insert, or None to insert all from diff.
        apply_changed_fields: set of variable names whose attrs should be overwritten.
        apply_new_options:    list of (var, label) pairs to add, or None to add all from diff.
        apply_changed_options: set of (variable, old_label) pairs to rename.
        apply_new_users:      list of user name strings to add, or None to add all from diff.
        Returns imported_item_count.
        """
        # Normalise: None means "use everything from diff"
        if apply_new_fields is None:
            apply_new_fields = diff.get('new_fields', [])
        if apply_changed_fields is None:
            apply_changed_fields = set()
        if apply_new_options is None:
            apply_new_options = diff.get('new_options', [])
        if apply_changed_options is None:
            apply_changed_options = set()
        if apply_new_users is None:
            apply_new_users = diff.get('new_users', [])

        cursor = self.conn.cursor()

        # ── 1. Apply new / changed custom fields ──────────────────────
        # Build variable→field_id map (will grow as we add new fields)
        var_to_id = {dict(f)['variable']: dict(f)['id'] for f in self.get_custom_fields()}

        if apply_new_fields:
            for row in apply_new_fields:
                var = row.get('variable', '').strip()
                if not var:
                    continue
                icon = self.import_csv_resolve_icon(row.get('icon', ''), icons_dir, zip_src=zip_src, icons_prefix=icons_prefix)
                try:
                    fid = self.add_custom_field(
                        name=row.get('name', var),
                        variable=var,
                        icon=icon,
                        field_type=row.get('field_type', 'string'),
                        type_options=row.get('type_options') or None,
                        show_in_list=int(row.get('show_in_list', 0)),
                        show_in_list_compact=int(row.get('show_in_list_compact', 0)),
                        show_in_detail=int(row.get('show_in_detail', 1)),
                        show_in_context_menu=int(row.get('show_in_context_menu', 0)),
                        context_menu_label=row.get('context_menu_label') or None,
                        show_name_in_list=int(row.get('show_name_in_list', 0)),
                        name_color=row.get('name_color') or '#ffffff',
                        search_filter=row.get('search_filter') or None,
                    )
                    var_to_id[var] = fid
                except ValueError:
                    pass  # variable conflict — already exists, skip

        # Update changed fields attrs
        for db_f, csv_row, _diffs in diff['changed_fields']:
            var = db_f['variable']
            if var not in apply_changed_fields:
                continue
            icon = self.import_csv_resolve_icon(csv_row.get('icon', ''), icons_dir, zip_src=zip_src, icons_prefix=icons_prefix)
            self.update_custom_field(
                field_id=db_f['id'],
                name=csv_row.get('name', db_f['name']),
                icon=icon,
                type_options=csv_row.get('type_options') or None,
                show_in_list=int(csv_row.get('show_in_list', db_f['show_in_list'])),
                show_in_list_compact=int(csv_row.get('show_in_list_compact', db_f['show_in_list_compact'])),
                show_in_detail=int(csv_row.get('show_in_detail', db_f['show_in_detail'])),
                show_in_context_menu=int(csv_row.get('show_in_context_menu', db_f['show_in_context_menu'])),
                context_menu_label=csv_row.get('context_menu_label') or None,
                show_name_in_list=int(csv_row.get('show_name_in_list', db_f.get('show_name_in_list', 0))),
                name_color=csv_row.get('name_color') or '#ffffff',
                search_filter=csv_row.get('search_filter') or None,
            )

        # Refresh var→id after potential additions
        var_to_id = {dict(f)['variable']: dict(f)['id'] for f in self.get_custom_fields()}

        # ── 1b. Auto-add ALL options for newly created fields ──────────
        # (these were skipped in diff because the field didn't exist in DB yet)
        new_field_vars = {row.get('variable', '').strip() for row in (apply_new_fields or [])}
        if new_field_vars:
            for opt_row in parsed.get('custom_field_options', []):
                var   = opt_row.get('variable', '').strip()
                label = opt_row.get('label', '').strip()
                if var in new_field_vars and label:
                    fid = var_to_id.get(var)
                    if fid is not None:
                        self.add_field_option(fid, label)

        # ── 2. Apply field options ─────────────────────────────────────
        # Build: variable → {label: option_id} for quick lookup
        def _rebuild_opt_map():
            opt_map = {}  # variable → {label: opt_id, opt_id: label}
            for f in self.get_custom_fields():
                f = dict(f)
                if f['field_type'] not in ('select', 'marks'):
                    continue
                opts = self.get_field_options(f['id'])
                opt_map[f['variable']] = {
                    'by_label': {opt['label']: opt['id'] for opt in opts},
                    'by_id':    {opt['id']:    opt['label'] for opt in opts},
                }
            return opt_map

        opt_map = _rebuild_opt_map()

        # Add new options
        if apply_new_options:
            for var, label in apply_new_options:
                fid = var_to_id.get(var)
                if fid is None:
                    continue
                if label not in opt_map.get(var, {}).get('by_label', {}):
                    self.add_field_option(fid, label)
            opt_map = _rebuild_opt_map()

        # Rename changed options
        for var, old_label, new_label in diff['changed_options']:
            key = (var, old_label)
            if key not in apply_changed_options:
                continue
            by_label = opt_map.get(var, {}).get('by_label', {})
            if old_label in by_label:
                opt_id = by_label[old_label]
                self.rename_field_option(opt_id, new_label)
        opt_map = _rebuild_opt_map()

        # Build option_id remap: csv_option_id → db_option_id
        # (needed when csv was exported from a different DB instance)
        opt_id_remap = {}  # (variable, csv_opt_id) → db_opt_id
        for row in parsed.get('custom_field_options', []):
            var = row.get('variable', '').strip()
            label = row.get('label', '').strip()
            try:
                csv_oid = int(row.get('option_id', 0))
            except (ValueError, TypeError):
                continue
            db_oid = opt_map.get(var, {}).get('by_label', {}).get(label)
            if db_oid is not None:
                opt_id_remap[(var, csv_oid)] = db_oid

        # ── 3. Apply new users ─────────────────────────────────────────
        user_cache = {}
        cursor.execute('SELECT id, name FROM users')
        for r in cursor.fetchall():
            user_cache[r['name']] = r['id']

        if apply_new_users:
            for name in apply_new_users:
                if name not in user_cache:
                    try:
                        cursor.execute('SELECT MAX(position) FROM users')
                        max_pos = (cursor.fetchone()[0] or 0) + 1
                        cursor.execute('INSERT OR IGNORE INTO users (name, position) VALUES (?, ?)', (name, max_pos))
                    except Exception:
                        pass
            self.commit()
            cursor.execute('SELECT id, name FROM users')
            user_cache = {r['name']: r['id'] for r in cursor.fetchall()}

        # ── 4 & 5: Import items (skip entirely if no category) ────────
        print(f"[DBG APPLY] category_id={category_id} items={len(parsed.get('items',[]))} rows_sample={[r.get('title','') for r in parsed.get('items',[])[:3]]}")
        if not parsed.get('items') or category_id is None:
            self.commit()
            return 0

        # ── 4. Check existing titles for duplicate detection ───────────
        cursor.execute('SELECT title FROM items WHERE category_id=?', (category_id,))
        existing_titles = {r['title'] for r in cursor.fetchall()}

        # ── 5. Import items ────────────────────────────────────────────
        cursor.execute('SELECT MAX(custom_position) FROM items WHERE category_id=?', (category_id,))
        start_pos = (cursor.fetchone()[0] or 0) + 1

        # Rebuild after fields were added in steps 1-3
        cf_fields = [dict(f) for f in self.get_custom_fields()]
        var_to_id = {f['variable']: f['id'] for f in cf_fields}  # refresh
        cf_col_map = {f'cf_{f["variable"]}': f for f in cf_fields}

        rows_to_insert = []
        item_users_list = []   # parallel: list of [user_id, ...]
        item_cf_list = []      # parallel: list of {field_id: value}
        csv_title_to_final = {}  # original csv title → final title (с суффиксом если был дубль)
        exported_ids = []      # parallel: exported item_id from CSV (or None)

        _all_items = parsed.get('items', [])
        items_total = len(_all_items)
        if progress_cb:
            _tr = translations or {}
            progress_cb(10, _tr.get('progress_processing', 'Processing') + f' {items_total}...')
        for _item_idx, item_row in enumerate(_all_items):
            title = item_row.get('title', '').strip()
            if not title:
                continue

            # Handle duplicate title — суффикс добавляется только при конфликте
            # с уже существующими в БД записями (не с теми что добавляются в этом импорте)
            if title in existing_titles:
                _copy_sfx = _tr.get('copy_suffix', '-copy')
                _parts = title.split('|')
                _first = _parts[0].rstrip()
                _rest  = ('|' + '|'.join(_parts[1:])) if len(_parts) > 1 else ''
                candidate = _first + ' ' + _copy_sfx + _rest
                n = 2
                while candidate in existing_titles:
                    candidate = _first + ' ' + _copy_sfx + str(n) + _rest
                    n += 1
                title = candidate
                # Резервируем только переименованный вариант чтобы не было двух одинаковых -копий
                existing_titles.add(title)
            csv_title_to_final[item_row.get('title', '').strip()] = title

            # Parse scalar fields
            def _int(key, default=None):
                v = item_row.get(key, '')
                try:
                    return int(v) if v and v.strip() else default
                except (ValueError, TypeError):
                    return default

            year       = _int('year')
            rating     = min(_int('rating', 0) or 0, 10) or None
            is_fav     = 1 if item_row.get('is_favorite', '0') == '1' else 0
            time_spent = _int('time_spent', 0) or 0
            view_count = _int('view_count', 1) or 1
            watch_date = item_row.get('watch_date') or None
            notes      = item_row.get('notes') or None

            # Cover
            cover_dest = None
            cover_filename = item_row.get('cover', '').strip()
            if import_images and cover_filename and images_dir:
                src = os.path.join(images_dir, cover_filename)
                if os.path.exists(src):
                    src_in_covers = os.path.normcase(os.path.abspath(src)).startswith(
                        os.path.normcase(os.path.abspath(str(COVERS_DIR)))
                    )
                    if src_in_covers:
                        # Already in COVERS_DIR with a uuid name — use as-is.
                        cover_dest = to_relative_path(src)
                    else:
                        # Move into COVERS_DIR with uuid — no copy, no PIL, zero CPU.
                        src_ext = os.path.splitext(src)[1].lower() or '.jpg'
                        dest_name = f'cover_{uuid.uuid4().hex}{src_ext}'
                        abs_dest = str(COVERS_DIR / dest_name)
                        try:
                            os.rename(src, abs_dest)
                            cover_dest = to_relative_path(abs_dest)
                        except OSError:
                            try:
                                shutil.copy2(src, abs_dest)
                                cover_dest = to_relative_path(abs_dest)
                            except Exception:
                                cover_dest = None
            if progress_cb and items_total > 0:
                pct = 10 + int((_item_idx + 1) / items_total * 80)
                _tr = translations or {}
                _proc = _tr.get('progress_processing', 'Processing')
                progress_cb(pct, f'{_proc} {_item_idx + 1} / {items_total}...')

            # Users
            user_ids = []
            for uname in (item_row.get('users') or '').split(';'):
                uname = uname.strip()
                if uname and uname in user_cache:
                    user_ids.append(user_cache[uname])

            # Custom field values with option_id remapping
            cf_vals = {}
            for col, f in cf_col_map.items():
                raw_val = item_row.get(col, '')
                if not raw_val:
                    continue
                ftype = f['field_type']
                var   = f['variable']
                fid   = var_to_id.get(var)
                if fid is None:
                    continue

                if ftype == 'select':
                    # raw_val is a single option_id (as string)
                    try:
                        csv_oid = int(raw_val)
                        db_oid = opt_id_remap.get((var, csv_oid), csv_oid)
                        cf_vals[fid] = str(db_oid)  # always store as str
                    except (ValueError, TypeError):
                        cf_vals[fid] = str(raw_val)

                elif ftype == 'marks':
                    # raw_val is JSON list of option_ids
                    try:
                        csv_ids = json.loads(raw_val)
                        if isinstance(csv_ids, list):
                            db_ids = [
                                str(opt_id_remap.get((var, int(i)), int(i)))
                                for i in csv_ids
                            ]
                            cf_vals[fid] = json.dumps(db_ids)
                        else:
                            cf_vals[fid] = raw_val
                    except Exception:
                        cf_vals[fid] = raw_val
                else:
                    cf_vals[fid] = raw_val

            rows_to_insert.append((
                category_id, title, year, cover_dest,
                watch_date, notes, rating, is_fav,
                time_spent, view_count,
                start_pos + len(rows_to_insert)
            ))
            item_users_list.append(user_ids)
            item_cf_list.append(cf_vals)
            _eid = item_row.get('id', '') or item_row.get('item_id', '')
            exported_ids.append(int(_eid) if str(_eid).strip().isdigit() else None)

        if not rows_to_insert:
            return 0

        # Insert items one by one to get reliable lastrowid per row
        inserted_ids = []
        for row_data in rows_to_insert:
            cursor.execute('''
                INSERT INTO items
                  (category_id, title, year, cover_path, watch_date,
                   notes, rating, is_favorite, time_spent, view_count, custom_position)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            ''', row_data)
            inserted_ids.append(cursor.lastrowid)

        # Map exported_id → local newly-inserted id (for correct tier placement with duplicate titles)
        exported_id_to_local = {}
        for exp_id, local_id in zip(exported_ids, inserted_ids):
            if exp_id is not None:
                exported_id_to_local[exp_id] = local_id

        user_pairs = []
        cf_pairs   = []
        for item_id, (user_ids, cf_vals) in zip(inserted_ids, zip(item_users_list, item_cf_list)):
            for uid in user_ids:
                user_pairs.append((item_id, uid))
            for fid, val in cf_vals.items():
                cf_pairs.append((item_id, fid, val))

        if user_pairs:
            cursor.executemany(
                'INSERT OR IGNORE INTO item_users (item_id, user_id) VALUES (?, ?)',
                user_pairs
            )
        if cf_pairs:
            cursor.executemany(
                'INSERT OR REPLACE INTO custom_field_values (item_id, field_id, value) VALUES (?, ?, ?)',
                cf_pairs
            )

        self.commit()
        self.invalidate_custom_fields_cache()

        # ── Tier config ───────────────────────────────────────────────
        # Apply tier config: merge imported tiers with existing ones by key
        tier_config_rows = parsed.get('tier_config', [])
        if tier_config_rows and category_id is not None:
            existing_tiers = self.get_tier_config(category_id)
            existing_by_key = {t['key']: t for t in existing_tiers}
            # Add new tiers that don't exist yet; update label/color for existing
            merged = list(existing_tiers)
            merged_keys = {t['key'] for t in merged}
            for row in tier_config_rows:
                key = row.get('key', '').strip()
                if not key:
                    continue
                if key in existing_by_key:
                    # Update label and color for existing tier
                    for t in merged:
                        if t['key'] == key:
                            t['label'] = row.get('label', t['label'])
                            t['color'] = row.get('color', t['color'])
                elif key not in merged_keys:
                    # New tier — append
                    merged.append({
                        'key':   key,
                        'label': row.get('label', key),
                        'color': row.get('color', '#aaaaaa'),
                    })
                    merged_keys.add(key)
            self.set_tier_config(category_id, merged)

        # ── Tier item assignments ─────────────────────────────────────
        # Build title→id map (needed for both tier_items and tier_set_items)
        title_to_ids = {}  # title → list of local_ids (to handle duplicates)
        if category_id is not None:
            for item_id, row_data in zip(inserted_ids, rows_to_insert):
                title_to_ids.setdefault(row_data[1], []).append(item_id)
            for row in self.get_items(category_id):
                r = dict(row)
                if r['id'] not in inserted_ids:
                    title_to_ids.setdefault(r['title'], []).append(r['id'])

        def _resolve_item(exported_id_str, title_str):
            """Resolve exported_id+title to local item_id."""
            exp_id = int(exported_id_str) if str(exported_id_str).strip().isdigit() else None
            # First: check exported_id_to_local (newly inserted items)
            if exp_id is not None and exp_id in exported_id_to_local:
                return exported_id_to_local[exp_id]
            # Second: title match — if unique, return it
            final_title = csv_title_to_final.get(title_str, title_str)
            candidates = title_to_ids.get(final_title, [])
            if candidates:
                return candidates[0]
            return None

        # Match items by title, assign to tiers by key
        tier_item_rows = parsed.get('tier_items', [])
        if tier_item_rows and category_id is not None:
            tier_assignments = {}
            for row in sorted(tier_item_rows,
                              key=lambda r: int(r.get('position', 0)) if str(r.get('position', 0)).isdigit() else 0):
                key   = row.get('tier_key', '').strip()
                title = row.get('item_title', '').strip()
                exported_id_str = row.get('item_id', '')
                if not key:
                    continue
                item_id = _resolve_item(exported_id_str, title)
                if item_id is None:
                    continue
                tier_assignments.setdefault(key, []).append(item_id)

            cursor.execute('BEGIN')
            for tier_key, item_ids in tier_assignments.items():
                for pos, item_id in enumerate(item_ids):
                    cursor.execute(
                        'INSERT OR REPLACE INTO tier_items '
                        '(item_id, category_id, tier_key, position) VALUES (?,?,?,?)',
                        (item_id, category_id, tier_key, pos)
                    )
            self.conn.commit()

        # ── Tier list sets (named lists) ──────────────────────────────
        tier_sets_rows = parsed.get('tier_sets', [])
        if tier_sets_rows and category_id is not None:
            # Build name→id map for existing sets
            existing_sets = self.get_tier_list_sets(category_id)
            existing_by_name = {s['name']: s['id'] for s in existing_sets}
            # name→id map to use when importing set_items
            set_name_to_id = dict(existing_by_name)
            for row in tier_sets_rows:
                name = row.get('set_name', '').strip()
                if not name:
                    continue
                if name not in existing_by_name:
                    new_id = self.add_tier_list_set(category_id, name)
                    set_name_to_id[name] = new_id
                    existing_by_name[name] = new_id

            # ── Tier set item placements ──────────────────────────────
            tier_set_item_rows = parsed.get('tier_set_items', [])
            if tier_set_item_rows:
                # Use same _resolve_item helper (already defined above)
                from collections import defaultdict
                set_tier_assignments = defaultdict(list)
                for row in sorted(tier_set_item_rows,
                                  key=lambda r: int(r.get('position', 0))
                                  if str(r.get('position', 0)).isdigit() else 0):
                    sname = row.get('set_name', '').strip()
                    tkey  = row.get('tier_key', '').strip()
                    title = row.get('item_title', '').strip()
                    exported_id_str = row.get('item_id', '')
                    if not sname or not tkey:
                        continue
                    set_id = set_name_to_id.get(sname)
                    item_id = _resolve_item(exported_id_str, title)
                    if set_id is None or item_id is None:
                        continue
                    set_tier_assignments[(set_id, tkey)].append(item_id)

                cursor.execute('BEGIN')
                for (set_id, tier_key), item_ids in set_tier_assignments.items():
                    for pos, item_id in enumerate(item_ids):
                        cursor.execute(
                            'INSERT OR REPLACE INTO tier_list_set_placements '
                            '(set_id, item_id, tier_key, position) VALUES (?,?,?,?)',
                            (set_id, item_id, tier_key, pos)
                        )
                self.conn.commit()

        return len(rows_to_insert)



class HeartButton(QPushButton):
    """Кнопка с нарисованным сердцем — закрашенное (активно) или контур (неактивно)."""

    def __init__(self, active=False, parent=None):
        super().__init__(parent)
        self._active = active
        self.setFixedSize(28, 28)

    def setActive(self, active):
        self._active = active
        self.update()

    def _heart_path(self, cx, cy, size):
        s = size
        path = QPainterPath()
        path.moveTo(cx, cy + s * 0.3)
        # левая половина снизу вверх
        path.cubicTo(cx,           cy + s * 0.1,
                     cx - s * 0.5, cy,
                     cx - s * 0.5, cy - s * 0.2)
        path.cubicTo(cx - s * 0.5, cy - s * 0.55,
                     cx - s * 0.1, cy - s * 0.6,
                     cx,           cy - s * 0.35)
        # правая половина сверху вниз (зеркально)
        path.cubicTo(cx + s * 0.1, cy - s * 0.6,
                     cx + s * 0.5, cy - s * 0.55,
                     cx + s * 0.5, cy - s * 0.2)
        path.cubicTo(cx + s * 0.5, cy,
                     cx,           cy + s * 0.1,
                     cx,           cy + s * 0.3)
        path.closeSubpath()
        return path


    def paintEvent(self, event):
        super().paintEvent(event)
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        w, h = self.width(), self.height()
        cx, cy = w / 2, h / 2 + 1
        size = 13
        color = QColor(255, 255, 255) if self.underMouse() else QColor(255, 255, 255)
        path = self._heart_path(cx, cy, size)
        if self._active:
            # включено — закрашенное сердце
            p.setPen(Qt.NoPen)
            p.setBrush(color)
            p.drawPath(path)
        else:
            # выключено — контур двумя отдельными половинами (нет стыка внизу)
            s = size
            pen = QPen(color)
            pen.setWidthF(1.5)
            pen.setJoinStyle(Qt.RoundJoin)
            pen.setCapStyle(Qt.FlatCap)
            p.setPen(pen)
            p.setBrush(Qt.NoBrush)

            # левая половина: от нижней точки вверх до середины верхушки
            left = QPainterPath()
            left.moveTo(cx - s * 0.04, cy + s * 0.22)
            left.cubicTo(cx,           cy + s * 0.1,
                         cx - s * 0.5, cy,
                         cx - s * 0.5, cy - s * 0.2)
            left.cubicTo(cx - s * 0.5, cy - s * 0.55,
                         cx - s * 0.1, cy - s * 0.6,
                         cx,           cy - s * 0.35)
            p.drawPath(left)

            # правая половина: от середины верхушки вниз
            right = QPainterPath()
            right.moveTo(cx, cy - s * 0.35)
            right.cubicTo(cx + s * 0.1, cy - s * 0.6,
                          cx + s * 0.5, cy - s * 0.55,
                          cx + s * 0.5, cy - s * 0.2)
            right.cubicTo(cx + s * 0.5, cy,
                          cx,           cy + s * 0.1,
                          cx + s * 0.04, cy + s * 0.22)
            p.drawPath(right)
        p.end()


class ViewButton(QPushButton):
    """Кнопка переключения вида — рисует ☰ (три линии) или ◧ (квадрат с половиной) через QPainter."""

    def __init__(self, compact=False, parent=None):
        super().__init__(parent)
        self._compact = compact
        self.setFixedSize(28, 28)

    def setCompact(self, compact):
        self._compact = compact
        self.update()

    def paintEvent(self, event):
        super().paintEvent(event)
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        w, h = self.width(), self.height()
        cx, cy = w / 2, h / 2
        color = QColor(255, 255, 255) if self.underMouse() else QColor(220, 220, 220)
        p.setPen(Qt.NoPen)
        p.setBrush(color)

        if not self._compact:
            # ☰ — три горизонтальные линии, строго по центру
            lw, lh, gap = 13, 2, 3
            total_h = 3 * lh + 2 * gap
            x0 = round(cx - lw / 2)
            y0 = round(cy - total_h / 2)
            for i in range(3):
                y = y0 + i * (lh + gap)
                p.drawRect(QRectF(x0, y, lw, lh))
        else:
            # ◧ — прямоугольник с левой закрашенной половиной
            rw, rh = 13, 11
            x0 = cx - rw / 2
            y0 = cy - rh / 2
            pen = QPen(color)
            pen.setWidthF(1.5)
            p.setPen(pen)
            p.setBrush(Qt.NoBrush)
            p.drawRect(QRectF(x0, y0, rw, rh))
            p.setPen(Qt.NoPen)
            p.setBrush(color)
            p.drawRect(QRectF(x0, y0, rw / 2, rh))

        p.end()



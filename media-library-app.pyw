                icon, _icon_tmp_files = get_icon()
                # Промежуточные файлы уже не нужны (сохранён последний)
                for _p in (_icon_tmp_files or []):
                    _safe_delete_file(_p, self.db.conn)
                if not icon:
                    icon = DEFAULT_FOLD if rb_folder.isChecked() else DEFAULT_CAT
                if name:
                    try:
                        # Запоминаем состояние ДО добавления
                        _was_empty    = self.categories_list.count() == 0
                        _had_no_sel   = self.current_category_id is None
                        _should_jump  = _was_empty or _had_no_sel

                        if rb_folder.isChecked():
                            self.db.add_folder(name, icon)
                            _should_jump = False  # в папку не переходим
                        else:
                            use_new_bg  = new_bg_cb.isChecked() and _new_bg_path[0]
                            final_new_bg = to_relative_path(_new_bg_path[0]) if use_new_bg else None
                            _new_cat_id = self.db.add_category(name, icon,
                                                 bg_path=final_new_bg,
                                                 bg_overlay=_new_bg_overlay[0])
                        self._reload_after_cat_change()

                        # Переходим в новую категорию если раньше ничего не было выбрано
                        if _should_jump and not rb_folder.isChecked():
                            for _i in range(self.categories_list.count()):
                                _it = self.categories_list.item(_i)
                                if _it and _it.data(Qt.UserRole) == _new_cat_id:
                                    self.categories_list.setCurrentRow(_i)
                                    self.on_category_selected(_it)
                                    break
                    except Exception as _e:
                        self._show_dialog_warning(self, str(_e))
            else:
                # Import tab
                if _imp_paths[0]:
                    self.import_categories_new(
                        paths=_imp_paths[0],
                        import_images_override=_imp_img_cb.isChecked())
                else:
                    self._show_dialog_warning(self, self.translations.get('no_file_selected', 'No file selected'))
        else:
            # Отмена — удаляем все временные иконки (текущую + промежуточные)
            _, _icon_tmp_files = get_icon()
            # get_icon() при cancel вернёт текущий файл; удаляем все что в ICONS_DIR и не оригинал
            if _file_icon_new[0] and _file_icon_new[0] != _original_file_new[0]:
                _safe_delete_file(_file_icon_new[0], self.db.conn)
            for _p in (_icon_tmp_files or []):
                _safe_delete_file(_p, self.db.conn)
            # Удаляем новый bg если был загружен
            if _new_bg_path[0]:
                try: os.remove(_new_bg_path[0])
                except Exception: pass
    
    def manage_users(self):
        """Управление пользователями — инлайн редактирование как в TierConfigDialog."""
        dialog = QDialog(self)
        dialog.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        dialog.setWindowTitle(self.translations.get('users', 'Users'))
        dialog.setMinimumSize(280, 320)

        layout = QVBoxLayout()
        layout.setContentsMargins(12, 12, 12, 12)
        layout.setSpacing(8)

        users_list = SortableListWidget(translations=self.translations)
        users_list.setDropIndicatorShown(True)
        users_list.setContextMenuPolicy(Qt.CustomContextMenu)
        users_list.set_label_func(lambda item: item.text() if item else '')
        users_list.setItemDelegate(SimpleListDelegate(users_list))
        users_list.setMouseTracking(True)
        users_list.viewport().setMouseTracking(True)
        users_list.setSelectionMode(QListWidget.ExtendedSelection)
        layout.addWidget(users_list)

        def _make_item(user_id, name):
            it = QListWidgetItem(name)
            it.setData(Qt.UserRole, user_id)   # existing: int id; new: None
            it.setFlags(it.flags() | Qt.ItemIsEditable)
            return it

        def load_users():
            users_list.clear()
            for user in self.db.get_users():
                users_list.addItem(_make_item(user['id'], user['name']))

        def add_user():
            users_list.clearSelection()
            it = _make_item(None, '')
            users_list.addItem(it)
            users_list.setCurrentItem(it)
            users_list.editItem(it)

        def delete_user():
            items = users_list.selectedItems()
            if not items:
                return
            msg = (self.translations.get('delete_user_confirm', 'Delete this user?')
                   if len(items) == 1
                   else self.translations.get('delete_confirm_multi', 'Delete {} items?').format(len(items)))
            if self._show_dialog_confirm(dialog, msg):
                uids = [it.data(Qt.UserRole) for it in items if it.data(Qt.UserRole) is not None]
                if uids:
                    self._do_backup('delete_user')
                    self.db.delete_users_batch(uids)
                for it in items:
                    users_list.takeItem(users_list.row(it))
                if self.compact_view or self.detail_panel.isVisible():
                    self.load_items()

        def save_users():
            """Persist all renames/additions/reorder in a single transaction."""
            rows = []
            for i in range(users_list.count()):
                it = users_list.item(i)
                name = it.text().strip()
                if not name:
                    continue
                rows.append((i + 1, it.data(Qt.UserRole), name))

            # validate uniqueness before touching DB
            names = [r[2] for r in rows]
            if len(names) != len(set(n.lower() for n in names)):
                self._show_dialog_warning(dialog, self.translations.get('user_exists', 'A user with this name already exists'))
                return

            cursor = self.db.conn.cursor()
            try:
                cursor.execute('BEGIN')
                for pos, uid, name in rows:
                    if uid is None:
                        # new user
                        cursor.execute(
                            'INSERT INTO users (name, position) VALUES (?, ?)', (name, pos))
                    else:
                        # update name + position in one shot
                        cursor.execute(
                            'UPDATE users SET name = ?, position = ? WHERE id = ?',
                            (name, pos, uid))
                self.db.conn.commit()
            except sqlite3.IntegrityError:
                self.db.conn.rollback()
                self._show_dialog_warning(dialog, self.translations.get('user_exists', 'A user with this name already exists'))
                return

            self.load_items()
            dialog.accept()

        def on_users_dropped():
            dragged_ids = set(getattr(users_list, '_dragged_multi_ids', []) or [])
            pairs = []
            for i in range(users_list.count()):
                it = users_list.item(i)
                if it:
                    uid = it.data(Qt.UserRole)
                    if uid is not None:
                        pairs.append((float(i + 1), uid))
            if pairs:
                cursor = self.db.conn.cursor()
                cursor.executemany('UPDATE users SET position = ? WHERE id = ?', pairs)
                self.db.conn.commit()
            if dragged_ids:
                for i in range(users_list.count()):
                    it = users_list.item(i)
                    if it and it.data(Qt.UserRole) in dragged_ids:
                        it.setSelected(True)
        users_list.dropped.connect(on_users_dropped)

        def show_user_menu(position):
            item = users_list.itemAt(position)
            if not item:
                return
            if item not in users_list.selectedItems():
                users_list.clearSelection()
                item.setSelected(True)
            menu = QMenu()
            if len(users_list.selectedItems()) == 1:
                edit_action = QAction(self.translations.get('edit', 'Edit'), dialog)
                edit_action.triggered.connect(lambda: users_list.editItem(item))
                menu.addAction(edit_action)
                menu.addSeparator()
            delete_action = QAction(self.translations.get('delete', 'Delete'), dialog)
            delete_action.triggered.connect(delete_user)
            menu.addAction(delete_action)
            menu.exec_(users_list.mapToGlobal(position))

        # ── inline-edit delegate with ✓ / ✗ buttons ──────────────────
        _editing = {'item': None, 'original': ''}

        class _InlineEditDelegate(QStyledItemDelegate):
            def createEditor(self_, parent, option, index):
                # container widget: [QLineEdit] [✓] [✗]
                container = QWidget(parent)
                container.setAutoFillBackground(True)
                h = QHBoxLayout(container)
                h.setContentsMargins(2, 1, 2, 1)
                h.setSpacing(2)
                le = QLineEdit()
                le.setFrame(True)
                h.addWidget(le)

                def _make_icon(draw_fn):
                    pix = _make_hires_pixmap(14)
                    p = QPainter(pix)
                    p.setRenderHint(QPainter.Antialiasing)
                    pen = QPen(QColor(255, 255, 255))
                    pen.setWidthF(1.5)
                    pen.setCapStyle(Qt.RoundCap)
                    p.setPen(pen)
                    draw_fn(p)
                    p.end()
                    return QIcon(pix)

                def _draw_check(p):
                    p.drawLine(QPointF(2, 7), QPointF(5.5, 11))
                    p.drawLine(QPointF(5.5, 11), QPointF(12, 3))

                btn_ok = QPushButton()
                btn_ok.setFixedSize(24, 22)
                btn_ok.setFocusPolicy(Qt.NoFocus)
                btn_ok.setIcon(_make_icon(_draw_check))
                btn_ok.setIconSize(QSize(14, 14))

                btn_no = None

                h.addWidget(btn_ok)

                container._le    = le
                container._ok    = btn_ok

                def _confirm():
                    text = le.text().strip()
                    it = _editing.get('item')
                    if text and it is not None:
                        uid = it.data(Qt.UserRole)
                        try:
                            cursor = self.db.conn.cursor()
                            if uid is None:
                                cursor.execute('SELECT MAX(position) FROM users')
                                pos = (cursor.fetchone()[0] or 0) + 1
                                cursor.execute('INSERT INTO users (name, position) VALUES (?, ?)', (text, pos))
                                self.db.conn.commit()
                                it.setData(Qt.UserRole, cursor.lastrowid)
                            else:
                                cursor.execute('UPDATE users SET name = ? WHERE id = ?', (text, uid))
                                self.db.conn.commit()
                            it.setText(text)
                            self.load_items()
                        except sqlite3.IntegrityError:
                            self.db.conn.rollback()
                            le.setText(_editing.get('original', ''))
                            self._show_dialog_warning(dialog, self.translations.get('user_exists', 'A user with this name already exists'))
                            return
                    elif not text:
                        it = _editing.get('item')
                        # Новый элемент (ещё не сохранён в БД) с пустым именем — удаляем из списка
                        if it is not None and _editing.get('original', '') == '' and it.data(Qt.UserRole) is None:
                            self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)
                            row = users_list.row(it)
                            if row >= 0:
                                users_list.takeItem(row)
                            _editing['item'] = None
                            return
                        le.setText(_editing.get('original', ''))
                    self_.commitData.emit(container)
                    self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)

                def _discard():
                    it = _editing.get('item')
                    if it is not None and _editing['original'] == '' and it.data(Qt.UserRole) is None:
                        row = users_list.row(it)
                        if row >= 0:
                            self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)
                            users_list.takeItem(row)
                            _editing['item'] = None
                            return
                    le.setText(_editing.get('original', ''))
                    self_.closeEditor.emit(container, QStyledItemDelegate.NoHint)

                container.setFocusProxy(le)
                container._confirm_fn = _confirm
                btn_ok.clicked.connect(_confirm)
                return container

            def eventFilter(self_, obj, event):
                if event.type() == QEvent.KeyPress and event.key() in (Qt.Key_Return, Qt.Key_Enter):
                    editor = self_._current_editor if hasattr(self_, '_current_editor') else None
                    if editor and hasattr(editor, '_confirm_fn'):
                        editor._confirm_fn()
                        return True
                return super().eventFilter(obj, event)

            def setEditorData(self_, editor, index):
                self_._current_editor = editor
                editor._le.setText(index.data(Qt.DisplayRole) or '')
                editor._le.selectAll()

            def setModelData(self_, editor, model, index):
                text = editor._le.text().strip()
                if text:
                    model.setData(index, text, Qt.DisplayRole)
                elif _editing.get('original'):
                    model.setData(index, _editing['original'], Qt.DisplayRole)
                else:
                    it = _editing.get('item')
                    if it is not None and it.data(Qt.UserRole) is None:
                        QTimer.singleShot(0, lambda: (
                            users_list.takeItem(users_list.row(it))
                            if users_list.row(it) >= 0 else None
                        ))

            def updateEditorGeometry(self_, editor, option, index):
                editor.setGeometry(option.rect)

        _delegate = _InlineEditDelegate(users_list)
        users_list.setItemDelegate(_delegate)
        users_list.viewport().installEventFilter(_delegate)
        users_list.setItemDelegate(_delegate)

        def _on_edit_started(item):
            _editing['item'] = item
            _editing['original'] = item.text()

        # patch editItem to track state
        _orig_edit_item = users_list.editItem
        def _patched_edit_item(it):
            _on_edit_started(it)
            _orig_edit_item(it)
        users_list.editItem = _patched_edit_item

        users_list.customContextMenuRequested.connect(show_user_menu)
        users_list.itemDoubleClicked.connect(lambda it: users_list.editItem(it))

        def _users_key_press(event):
            if event.key() in (Qt.Key_Return, Qt.Key_Enter):
                sel = users_list.selectedItems()
                if len(sel) == 1:
                    users_list.editItem(sel[0])
            elif event.key() == Qt.Key_Delete:
                delete_user()
            else:
                QListWidget.keyPressEvent(users_list, event)
        users_list.keyPressEvent = _users_key_press


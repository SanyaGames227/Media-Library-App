        self._last_users_data   = users_data
        self._last_cf_data      = custom_fields_data
        # Блокируем перерисовку всего DetailPanel — не видно промежуточных состояний
        self.setUpdatesEnabled(False)
        self._sa.setUpdatesEnabled(False)
        while self._vbox.count():
            c = self._vbox.takeAt(0)

    def delete_folder(self, folder_id):
        """Удалить папку; категории внутри сохраняют свой порядок."""
        cursor = self.conn.cursor()

        # Получаем позицию самой папки
        cursor.execute('SELECT position FROM categories WHERE id = ?', (folder_id,))
        folder_row = cursor.fetchone()
        folder_pos = float(folder_row[0]) if folder_row else 0.0

        # Получаем следующий элемент после папки (не дочерний) — его позиция
        # нужна, чтобы вставить детей в правильный диапазон
        cursor.execute(
            'SELECT position FROM categories WHERE position > ? AND folder_id IS NOT ? '
            'AND (folder_id IS NULL OR folder_id != ?) '
            'AND is_folder = 0 '
            'ORDER BY position ASC LIMIT 1',
            (folder_pos, folder_id, folder_id)
        )
        next_row = cursor.fetchone()
        # Также проверяем следующую папку
        cursor.execute(
            'SELECT position FROM categories WHERE position > ? AND is_folder = 1 AND id != ? '
            'ORDER BY position ASC LIMIT 1',
            (folder_pos, folder_id)
        )
        next_folder_row = cursor.fetchone()

        next_pos_candidates = []
        if next_row:
            next_pos_candidates.append(float(next_row[0]))
        if next_folder_row:
            next_pos_candidates.append(float(next_folder_row[0]))
        next_pos = min(next_pos_candidates) if next_pos_candidates else folder_pos + 1.0

        # Дочерние категории в порядке их текущих позиций
        cursor.execute(
            'SELECT id FROM categories WHERE folder_id = ? ORDER BY position ASC',
            (folder_id,)
        )
        child_ids = [r[0] for r in cursor.fetchall()]

        # Расставляем детей в диапазон (folder_pos, next_pos) равномерно
        n = len(child_ids)
        for i, cid in enumerate(child_ids):
            step = (next_pos - folder_pos) / (n + 1)
            new_pos = folder_pos + step * (i + 1)
            cursor.execute('UPDATE categories SET position = ?, folder_id = NULL WHERE id = ?',
                           (new_pos, cid))

        # Собираем иконку ДО удаления, удаляем файл ПОСЛЕ
        cursor.execute('SELECT icon FROM categories WHERE id = ?', (folder_id,))
        frow = cursor.fetchone()
        folder_icon_path = None
        if frow and frow['icon'] and frow['icon'].startswith('file:'):
            folder_icon_path = to_absolute_path(frow['icon'][5:])

        cursor.execute('DELETE FROM categories WHERE id = ?', (folder_id,))
        self.commit()

        if folder_icon_path:
            _safe_delete_file(folder_icon_path, self.conn)
    

class StatsButton(QPushButton):
    """Кнопка открытия окна статистики — вертикальные столбы разной высоты."""
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setFixedSize(28, 28)

    def paintEvent(self, event):
        super().paintEvent(event)
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        w, h = self.width(), self.height()
        color = QColor('#ffffff') if self.underMouse() else QColor(180, 180, 180)
        p.setPen(Qt.NoPen)
        p.setBrush(color)
        # Три вертикальных столба разной высоты
        bar_w   = 4
        gap     = 3
        heights = [6, 12, 9]
        total_w = len(heights) * bar_w + (len(heights) - 1) * gap
        x0      = (w - total_w) // 2
        base_y  = h - 7
        for i, bh in enumerate(heights):
            x = x0 + i * (bar_w + gap)
            p.drawRoundedRect(x, base_y - bh, bar_w, bh, 1, 1)
        p.end()



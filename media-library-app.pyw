        class IconButton(QPushButton):
            def __init__(self, icon_type, parent=None):
                super().__init__(parent)
                self.icon_type = icon_type  # 'user' или 'fields'
                self.setFixedHeight(32)

            def paintEvent(self, event):
                super().paintEvent(event)
                p = QPainter(self)
                p.setRenderHint(QPainter.Antialiasing)
                w, h = self.width(), self.height()
                cx, cy = w // 2, h // 2
                color = QColor('#aaaaaa') if not self.underMouse() else QColor('#dddddd')
                p.setPen(Qt.NoPen)
                p.setBrush(color)

                if self.icon_type == 'user':
                    head_r = 5
                    p.drawEllipse(QPointF(cx, cy - 6), head_r, head_r)
                    path = QPainterPath()
                    path.moveTo(cx - 10, cy + 13)
                    path.cubicTo(cx - 10, cy + 4, cx - 5, cy + 2, cx, cy + 2)
                    path.cubicTo(cx + 5, cy + 2, cx + 10, cy + 4, cx + 10, cy + 13)
                    path.closeSubpath()
                    p.drawPath(path)

                elif self.icon_type == 'fields':
                    p.setPen(Qt.NoPen)
                    p.setBrush(QColor('#555555'))
                    p.drawRoundedRect(cx - 11, cy - 10, 22, 20, 2, 2)
                    line_color = QColor('#aaaaaa') if not self.underMouse() else QColor('#dddddd')
                    p.setBrush(line_color)
                    for i, (lx, lw) in enumerate([(3, 6), (3, 10), (3, 8)]):
                        y = cy - 5 + i * 6
                        p.setBrush(QColor('#888888'))
                        p.drawRoundedRect(cx - 11 + lx, y, lw - 2, 3, 1, 1)
                        p.setBrush(line_color)
                        p.drawRoundedRect(cx - 11 + lx + lw, y, 22 - lx - lw - 3, 3, 1, 1)

                elif self.icon_type == 'gear':
                    p.setPen(Qt.NoPen)
                    p.setBrush(color)
                    teeth = 8
                    outer_r = 9.0
                    inner_r = 6.5
                    hole_r = 3.0
                    gear_path = QPainterPath()
                    angle_step = 2 * math.pi / teeth
                    tooth_half = angle_step * 0.3
                    for i in range(teeth):
                        base_angle = i * angle_step
                        a0 = base_angle - tooth_half
                        a1 = base_angle - tooth_half * 0.4
                        a2 = base_angle + tooth_half * 0.4
                        a3 = base_angle + tooth_half
                        pts = [
                            (cx + inner_r * math.cos(a0), cy + inner_r * math.sin(a0)),
                            (cx + outer_r * math.cos(a1), cy + outer_r * math.sin(a1)),
                            (cx + outer_r * math.cos(a2), cy + outer_r * math.sin(a2)),
                            (cx + inner_r * math.cos(a3), cy + inner_r * math.sin(a3)),
                        ]
                        if i == 0:
                            gear_path.moveTo(*pts[0])
                        else:
                            gear_path.lineTo(*pts[0])
                        gear_path.lineTo(*pts[1])
                        gear_path.lineTo(*pts[2])
                        gear_path.lineTo(*pts[3])
                    gear_path.closeSubpath()
                    hole = QPainterPath()
                    hole.addEllipse(QPointF(cx, cy), hole_r, hole_r)
                    gear_path = gear_path.subtracted(hole)
                    p.drawPath(gear_path)

                p.end()


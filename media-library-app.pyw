        self.cover_label.setCursor(Qt.ArrowCursor)

    def _search_cover_online(self):
        """Поиск обложки через Bing Images — QListView + фоновая загрузка превью."""
        # ── Модель ──────────────────────────────────────────────────────────
        class _ImageModel(QAbstractListModel):
            ROLE_URL       = Qt.UserRole
            ROLE_THUMB     = Qt.UserRole + 1
            ROLE_TITLE     = Qt.UserRole + 2
            ROLE_THUMB_URL = Qt.UserRole + 3

            def __init__(self2):
                super().__init__()
                self2._items = []   # [(full_url, thumb_url, title)]
                self2._pixmaps = {} # thumb_url -> QPixmap

            def rowCount(self2, parent=QModelIndex()):
                return len(self2._items)

            def data(self2, index, role=Qt.DisplayRole):
                if not index.isValid() or index.row() >= len(self2._items):
                    return None
                full_url, thumb_url, title = self2._items[index.row()]
                if role == self2.ROLE_URL:       return full_url
                if role == self2.ROLE_THUMB:     return self2._pixmaps.get(thumb_url)
                if role == self2.ROLE_TITLE:     return title
                if role == self2.ROLE_THUMB_URL: return thumb_url
                return None

            def add_items(self2, items):
                if not items:
                    return
                first = len(self2._items)
                last  = first + len(items) - 1
                self2.beginInsertRows(QModelIndex(), first, last)
                self2._items.extend(items)
                self2.endInsertRows()

            def set_pixmap(self2, thumb_url, pix):
                for i, (_, turl, _) in enumerate(self2._items):
                    if turl == thumb_url:
                        self2._pixmaps[thumb_url] = pix
                        idx = self2.index(i)
                        self2.dataChanged.emit(idx, idx, [self2.ROLE_THUMB])
                        break

            def clear(self2):
                self2.beginResetModel()
                self2._items.clear()
                self2._pixmaps.clear()
                self2.endResetModel()

        # ── Делегат ─────────────────────────────────────────────────────────
        THUMB_W, THUMB_H = 80, 120
        ITEM_W,  ITEM_H  = THUMB_W + 8, THUMB_H + 8

        class _ImageDelegate(QStyledItemDelegate):
            def paint(self2, painter, option, index):
                painter.save()
                rect = option.rect

                # Фон выделения
                if option.state & QStyle.State_Selected:
                    painter.fillRect(rect, QColor('#555555'))
                elif option.state & QStyle.State_MouseOver:
                    painter.fillRect(rect, QColor('#3c3c3c'))

                pix = index.data(_ImageModel.ROLE_THUMB)
                img_rect = QRect(rect.x() + 4, rect.y() + 4, THUMB_W, THUMB_H)

                if pix and not pix.isNull():
                    scaled = pix.scaled(THUMB_W, THUMB_H,
                                        Qt.KeepAspectRatio, Qt.SmoothTransformation)
                    # Центрируем внутри img_rect
                    ox = img_rect.x() + (THUMB_W - scaled.width())  // 2
                    oy = img_rect.y() + (THUMB_H - scaled.height()) // 2
                    painter.drawPixmap(ox, oy, scaled)
                else:
                    painter.fillRect(img_rect, QColor('#1e1e1e'))
                    painter.setPen(QColor('#555'))
                    painter.drawText(img_rect, Qt.AlignCenter, '…')

                painter.restore()

            def sizeHint(self2, option, index):
                return QSize(ITEM_W, ITEM_H)

        # ── Поток загрузки превью ────────────────────────────────────────────
        class _ThumbLoader(QThread):
            loaded = pyqtSignal(str, QImage)   # thumb_url, image

            def __init__(self2, items):
                super().__init__()
                self2._items   = items   # [(full_url, thumb_url, title)]
                self2._stopped = False

            def stop(self2):
                self2._stopped = True

            def run(self2):
                self2.setTerminationEnabled(False)  # не убивать поток принудительно
                for _, thumb_url, _ in self2._items:
                    if self2._stopped:
                        break
                    try:
                        req = urllib.request.Request(thumb_url, headers={
                            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)',
                            'Referer':    'https://www.bing.com/'})
                        try:
                            with urllib.request.urlopen(req, timeout=6) as resp:
                                data = resp.read()
                        except Exception:
                            ctx = ssl.create_default_context()
                            ctx.check_hostname = False
                            ctx.verify_mode    = ssl.CERT_NONE
                            with urllib.request.urlopen(req, timeout=6, context=ctx) as resp:
                                data = resp.read()
                        img = QImage()
                        if img.loadFromData(data):
                            self2.loaded.emit(thumb_url, img)
                    except Exception:
                        pass

        # ── Диалог ──────────────────────────────────────────────────────────
        search_dlg = QDialog(self)
        search_dlg.setWindowFlags(search_dlg.windowFlags() & ~Qt.WindowContextHelpButtonHint)

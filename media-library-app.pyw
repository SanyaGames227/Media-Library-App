# Глобальный in-memory кеш для emoji пиксмапов (ключ: (emoji, size, font_size))
_EMOJI_PIX_CACHE: dict = {}
_APP_DPR: float = 1.0   # обновляется после создания QApplication
_APP_SCALE: float = 1.0  # QT_SCALE_FACTOR — для масштаба Pillow

def _get_dpr() -> float:
    """Повертає реальний devicePixelRatio екрану для чіткого рендерингу піксмапів."""
    app = QApplication.instance()
    if app:
        screen = app.primaryScreen()
        if screen:
            return screen.devicePixelRatio()
    return _APP_SCALE

def _make_hires_pixmap(size: int) -> 'QPixmap':
    """Створює прозорий QPixmap з правильним devicePixelRatio для чіткості на HiDPI."""
    sc  = _get_dpr()
    pix = QPixmap(round(size * sc), round(size * sc))
    pix.setDevicePixelRatio(sc)
    pix.fill(Qt.transparent)
    return pix
_DATE_FMT: str = 'ISO'  # обновляется MainWindow при старте и при сохранении настроек

def _fmt_date(date_str: str, fmt: str = 'ISO') -> str:
    """Форматирует дату из ISO (yyyy-MM-dd / yyyy-MM / yyyy) в нужный формат.
    fmt: 'ISO' | 'DMY' | 'MDY' | 'YMD'
    Неполные даты (только год, год+месяц) форматируются без лишних частей.
    """
    if not date_str:
        return date_str
    s = str(date_str).strip()
    parts = s.split('-')
    if fmt == 'ISO' or len(parts) == 0:
        return s
    year  = parts[0] if len(parts) > 0 else ''
    month = parts[1] if len(parts) > 1 else ''
    day   = parts[2] if len(parts) > 2 else ''
    if not month:          # только год
        return year
    if not day:            # год + месяц
        if fmt == 'MDY':   return f'{month}/{year}'
        if fmt == 'DMY':   return f'{month}/{year}'
        if fmt == 'YMD':   return f'{year}/{month}'
        return s
    # полная дата
    if fmt == 'DMY':       return f'{day}.{month}.{year}'
    if fmt == 'MDY':       return f'{month}/{day}/{year}'
    if fmt == 'YMD':       return f'{year}.{month}.{day}'
    return s



_SORT_PREFIX_RE = re.compile(r'(?:^|\|)\s*sort:([^|]*)', re.IGNORECASE)

def _extract_sort_key(raw: str) -> str:
    """Возвращает sort-ключ из raw title.
    'Человек-Паук|Людина-Павук|sort:Spider Man' → 'Spider Man'
    Если sort: не задан — возвращает первую часть (до первого |).
    """
    m = _SORT_PREFIX_RE.search(raw)
    if m:
        key = m.group(1).strip()
        if key:
            return key
    return raw.split('|')[0].strip() if '|' in raw else raw

def _display_title(raw: str) -> str:
    """Первое отображаемое название (без sort:-частей)."""
    parts = [p.strip() for p in raw.split('|')
             if p.strip() and not p.strip().lower().startswith('sort:')]
    return parts[0] if parts else raw

def _search_titles(raw: str) -> list:
    """Все части для поиска: обычные названия + содержимое sort:, без самого слова sort:."""
    result = []
    for p in raw.split('|'):
        p = p.strip()
        if not p:
            continue
        if p.lower().startswith('sort:'):
            val = p[5:].strip()
            if val:
                result.append(val)
        else:
            result.append(p)
    return result

def _normalise_yw(s: str):
    """Нормализует пользовательский ввод даты/периода в ISO-фрагмент для сравнения с watch_date.

    Поддерживаемые форматы → результат:
      2026              → '2026'
      2026-02           → '2026-02'
      2026-02-20        → '2026-02-20'
      20.02.2026        → '2026-02-20'   (DMY точки)
      20-02-2026        → '2026-02-20'   (DMY дефисы)
      02/20/2026        → '2026-02-20'   (MDY слэши)
      02/2026, 2026/02  → '2026-02'
      2026.02.20        → '2026-02-20'   (YMD точки)
      2.2026, 2026.2    → '2026-02'
    Возвращает None если формат не распознан.
    """
    import re as _re
    s = s.strip()
    if not s:
        return None
    # ISO: YYYY / YYYY-MM / YYYY-MM-DD
    if _re.fullmatch(r'\d{4}', s):
        return s
    if _re.fullmatch(r'\d{4}-\d{2}', s):
        return s
    if _re.fullmatch(r'\d{4}-\d{2}-\d{2}', s):
        return s
    # YYYY/MM или MM/YYYY
    m = _re.fullmatch(r'(\d{1,4})/(\d{1,4})', s)
    if m:
        a, b = m.group(1), m.group(2)
        if len(a) == 4:
            return f'{a}-{b.zfill(2)}'
        if len(b) == 4:
            return f'{b}-{a.zfill(2)}'
    # DD.MM.YYYY или DD-MM-YYYY
    m = _re.fullmatch(r'(\d{1,2})[.\-](\d{1,2})[.\-](\d{4})', s)
    if m:
        day, mon, year = m.group(1), m.group(2), m.group(3)
        return f'{year}-{mon.zfill(2)}-{day.zfill(2)}'
    # MM/DD/YYYY
    m = _re.fullmatch(r'(\d{1,2})/(\d{1,2})/(\d{4})', s)
    if m:
        mon, day, year = m.group(1), m.group(2), m.group(3)
        return f'{year}-{mon.zfill(2)}-{day.zfill(2)}'
    # YYYY.MM.DD или YYYY/MM/DD
    m = _re.fullmatch(r'(\d{4})[./](\d{1,2})[./](\d{1,2})', s)
    if m:
        year, mon, day = m.group(1), m.group(2), m.group(3)
        return f'{year}-{mon.zfill(2)}-{day.zfill(2)}'
    # MM.YYYY или YYYY.MM
    m = _re.fullmatch(r'(\d{1,2})\.(\d{4})', s)
    if m:
        return f'{m.group(2)}-{m.group(1).zfill(2)}'
    m = _re.fullmatch(r'(\d{4})\.(\d{1,2})', s)
    if m:
        return f'{m.group(1)}-{m.group(2).zfill(2)}'
    return None

_REFRESH_ICON_PIX_CACHE: dict = {}  # size -> QPixmap (оставляем для обратной совместимости)

def draw_refresh_icon(painter, x: float, y: float, size: float, color: 'QColor'):
    """Рисует иконку refresh (двойная дуга) напрямую в painter — чётко на любом DPI."""
    k = size / 16.0
    cx = x + size / 2.0
    cy = y + size / 2.0
    r  = 5.5 * k
    pen = QPen(color)
    pen.setWidthF(2.1 * k)
    pen.setCapStyle(Qt.RoundCap)
    s, a = 4.0 * k, 2.45
    painter.save()
    painter.setRenderHint(QPainter.Antialiasing, True)
    for arc_start, adx, ady in [(15, -1.50 * k, 1.50 * k), (195, 1.50 * k, -1.50 * k)]:
        painter.setPen(pen)
        painter.setBrush(Qt.NoBrush)
        painter.drawArc(QRectF(cx - r, cy - r, r * 2, r * 2), int(arc_start * 16), int(130 * 16))
        ang  = math.radians(arc_start + 130)
        tx   = cx + r * math.cos(ang) + adx
        ty   = cy - r * math.sin(ang) + ady
        tang = ang - math.pi / 2 + math.radians(171.0)
        path = QPainterPath()
        path.moveTo(tx, ty)
        path.lineTo(tx + s * math.cos(tang + a), ty - s * math.sin(tang + a))
        path.lineTo(tx + s * math.cos(tang - a), ty - s * math.sin(tang - a))
        path.closeSubpath()
        painter.setBrush(QBrush(color))
        painter.setPen(Qt.NoPen)
        painter.drawPath(path)
    painter.restore()


def _get_refresh_icon_pix(size: int) -> 'QPixmap':
    """Устарело — используй draw_refresh_icon. Оставлено для совместимости."""
    if size in _REFRESH_ICON_PIX_CACHE:
        return _REFRESH_ICON_PIX_CACHE[size]
    pix = _make_hires_pixmap(size)
    p   = QPainter(pix)
    draw_refresh_icon(p, 0, 0, size, QColor('#CDCDCD'))
    p.end()
    _REFRESH_ICON_PIX_CACHE[size] = pix
    return pix


def _make_plus_icon(color='#aaaaaa', stroke=1.8) -> 'QIcon':
    """Глобальная иконка + для кнопок добавления."""
    pix = _make_hires_pixmap(16)
    p   = QPainter(pix)
    p.setRenderHint(QPainter.Antialiasing)
    pen = QPen(QColor(color))
    pen.setWidthF(stroke)
    pen.setCapStyle(Qt.RoundCap)
    p.setPen(pen)
    p.drawLine(QLineF(3, 8, 13, 8))
    p.drawLine(QLineF(8, 3, 8, 13))
    p.end()
    return QIcon(pix)


def _make_close_icon(size=14, color='#ffffff', stroke=1.5) -> 'QIcon':
    """Глобальная иконка × для кнопок удаления/закрытия.
    Рисуется через _make_hires_pixmap — чёткая на любом DPI."""
    pix = _make_hires_pixmap(size)
    p   = QPainter(pix)
    p.setRenderHint(QPainter.Antialiasing)
    pen = QPen(QColor(color))
    pen.setWidthF(stroke)
    pen.setCapStyle(Qt.RoundCap)
    p.setPen(pen)
    m = size * 0.22   # отступ от края
    e = size - m      # конец линии
    p.drawLine(QPointF(m, m), QPointF(e, e))
    p.drawLine(QPointF(e, m), QPointF(m, e))
    p.end()
    return QIcon(pix)




def _make_reset_icon() -> 'QIcon':
    """Иконка Reset — две дуги со стрелками (🔄 стиль)."""
    _rpix = _make_hires_pixmap(16)
    _rp   = QPainter(_rpix)
    _rp.setRenderHint(QPainter.Antialiasing)
    _rpen = QPen(QColor('#aaaaaa'))
    _rpen.setWidthF(2.1)
    _rpen.setCapStyle(Qt.RoundCap)
    _s, _a = 4.0, 2.45
    # Arc 1
    _rp.setPen(_rpen); _rp.setBrush(Qt.NoBrush)
    _rp.drawArc(QRectF(2.50, 2.50, 11.00, 11.00), int(15.00*16), int(130.00*16))
    _ang  = math.radians(15.00 + 130.00)
    _tx   = 8.00 + 5.50 * math.cos(_ang) + -1.50
    _ty   = 8.00 - 5.50 * math.sin(_ang) + 1.50
    _tang = _ang - math.pi/2 + math.radians(171.00)
    _h = QPainterPath(); _h.moveTo(_tx, _ty)
    _h.lineTo(_tx + _s*math.cos(_tang+_a), _ty - _s*math.sin(_tang+_a))
    _h.lineTo(_tx + _s*math.cos(_tang-_a), _ty - _s*math.sin(_tang-_a))
    _h.closeSubpath()
    _rp.setBrush(QBrush(QColor('#aaaaaa'))); _rp.setPen(Qt.NoPen); _rp.drawPath(_h)
    # Arc 2
    _rp.setPen(_rpen); _rp.setBrush(Qt.NoBrush)
    _rp.drawArc(QRectF(2.50, 2.50, 11.00, 11.00), int(195.00*16), int(130.00*16))
    _ang  = math.radians(195.00 + 130.00)
    _tx   = 8.00 + 5.50 * math.cos(_ang) + 1.50
    _ty   = 8.00 - 5.50 * math.sin(_ang) + -1.50
    _tang = _ang - math.pi/2 + math.radians(171.00)
    _h = QPainterPath(); _h.moveTo(_tx, _ty)
    _h.lineTo(_tx + _s*math.cos(_tang+_a), _ty - _s*math.sin(_tang+_a))
    _h.lineTo(_tx + _s*math.cos(_tang-_a), _ty - _s*math.sin(_tang-_a))
    _h.closeSubpath()
    _rp.setBrush(QBrush(QColor('#aaaaaa'))); _rp.setPen(Qt.NoPen); _rp.drawPath(_h)
    _rp.end()
    return QIcon(_rpix)

def _star_polygon_path(cx: float, cy: float, r_outer: float, r_inner: float) -> 'QPainterPath':
    """Возвращает QPainterPath пятиконечной звезды с центром (cx, cy)."""
    path = QPainterPath()
    for i in range(10):
        angle = math.radians(-90 + i * 36)
        r = r_outer if i % 2 == 0 else r_inner
        x = cx + r * math.cos(angle)
        y = cy + r * math.sin(angle)
        if i == 0:
            path.moveTo(x, y)
        else:
            path.lineTo(x, y)
    path.closeSubpath()
    return path

def draw_star_rating(painter, x, y, rating,
                     star_size=13, color_full=None, color_empty=None,
                     stroke_color=None, stroke_width=0.6, baseline=None, cap_height=None):
    """Рисует 5 звёздочек (рейтинг 0-10). Возвращает ширину.
    baseline: если задан — центр звёзд выровнен по baseline текста (ascent/2 выше baseline).
    """
    if color_full is None:
        color_full = QColor(255, 255, 255)
    if color_empty is None:
        color_empty = QColor(80, 80, 80)
    if stroke_color is None:
        stroke_color = QColor(0, 0, 0)

    gap = 0
    r_out = star_size / 2.0
    r_in  = r_out * 0.42
    total_w = 5 * star_size + 4 * gap

    # Если задан baseline — центр звезды совпадает с серединой заглавных букв.
    # Середина cap zone = baseline - cap_height/2. cap_height передаётся снаружи
    # через fm.capHeight(), иначе используем 0.7 * star_size как приближение.
    if baseline is not None:
        cap_center = baseline - (cap_height / 2.0 if cap_height else star_size * 0.35)
        y = cap_center - star_size / 2.0

    painter.save()
    painter.setRenderHint(QPainter.Antialiasing, True)

    full_stars = rating // 2
    half_star  = rating % 2

    stroke_pen = QPen(stroke_color, stroke_width)
    stroke_pen.setJoinStyle(Qt.MiterJoin)

    for i in range(5):
        cx = x + i * (star_size + gap) + r_out
        cy = y + r_out
        star_path = _star_polygon_path(cx, cy, r_out, r_in)

        if i < full_stars:
            painter.setPen(Qt.NoPen)
            painter.setBrush(color_full)
            painter.drawPath(star_path)
        elif i == full_stars and half_star:
            painter.setPen(Qt.NoPen)
            painter.setBrush(color_empty)
            painter.drawPath(star_path)
            painter.save()
            painter.setClipRect(QRect(int(x + i * (star_size + gap)), int(y),
                                      star_size // 2, star_size))
            painter.setBrush(color_full)
            painter.drawPath(star_path)
            painter.restore()
        else:
            painter.setPen(Qt.NoPen)
            painter.setBrush(color_empty)
            painter.drawPath(star_path)

        painter.setPen(stroke_pen)
        painter.setBrush(Qt.NoBrush)
        painter.drawPath(star_path)

    painter.restore()
    return total_w



def render_emoji_pixmap(emoji: str, size: int = 20, font_size: int = 12) -> 'QPixmap':
    """Рендер emoji в QPixmap с in-memory кешем."""
    sc        = _get_dpr()
    cache_key = (emoji, size, font_size, sc)
    cached    = _EMOJI_PIX_CACHE.get(cache_key)
    if cached is not None:
        return cached
    pix = _make_hires_pixmap(size)
    p   = QPainter(pix)
    f   = QFont()
    f.setPointSize(font_size)
    p.setFont(f)
    if emoji and len(emoji) == 1 and ord(emoji) < 0x2000:
        p.setPen(QColor(255, 255, 255))
    p.drawText(QRect(0, 0, size, size), Qt.AlignCenter, emoji)
    p.end()
    _EMOJI_PIX_CACHE[cache_key] = pix
    return pix


def draw_check_icon(painter, x: float, y: float, size: float, color: 'QColor'):
    """Рисует галочку напрямую в painter — чётко на любом DPI.
    Пропорции совпадают с inline-edit кнопкой подтверждения."""
    orig = 14.0
    scale = size / orig
    ox = x + size * 0.05
    oy = y

    painter.save()
    painter.setRenderHint(QPainter.Antialiasing, True)
    pen = QPen(color)
    pen.setWidthF(max(1.2, size * 0.12))
    pen.setCapStyle(Qt.RoundCap)
    pen.setJoinStyle(Qt.RoundJoin)
    painter.setPen(pen)
    painter.setBrush(Qt.NoBrush)
    painter.drawLine(
        QPointF(ox + 2   * scale, oy + 7  * scale),
        QPointF(ox + 5.5 * scale, oy + 11 * scale)
    )
    painter.drawLine(
        QPointF(ox + 5.5 * scale, oy + 11 * scale),
        QPointF(ox + 12  * scale, oy + 3  * scale)
    )
    painter.restore()


def draw_person_icon(painter, x: float, y: float, size: float, color: 'QColor'):
    pad       = size * 0.15
    inner     = size - pad * 2
    orig_span = 24.0
    scale     = inner / orig_span
    cx        = x + size / 2
    cy        = y + pad + inner * (11.0 / orig_span)
    head_r    = 5 * scale

    painter.save()
    painter.setRenderHint(QPainter.Antialiasing, True)
    painter.setPen(Qt.NoPen)
    painter.setBrush(QBrush(color))
    painter.drawEllipse(QPointF(cx, cy - 6 * scale), head_r, head_r)
    path = QPainterPath()
    path.moveTo(cx - 10 * scale, cy + 13 * scale)
    path.cubicTo(cx - 10 * scale, cy +  4 * scale,
                 cx -  5 * scale, cy +  2 * scale, cx, cy + 2 * scale)
    path.cubicTo(cx +  5 * scale, cy +  2 * scale,
                 cx + 10 * scale, cy +  4 * scale,
                 cx + 10 * scale, cy + 13 * scale)
    path.closeSubpath()
    painter.drawPath(path)
    painter.restore()


def to_relative_path(abs_path: str) -> str:
    """Конвертирует абсолютный путь к обложке/иконке в относительный (от DATA_DIR).
    Если путь уже относительный или None — возвращает как есть."""
    if not abs_path:
        return abs_path
    try:
        rel = Path(abs_path).relative_to(DATA_DIR)
        return str(rel).replace('\\', '/')
    except ValueError:
        return abs_path

def to_absolute_path(rel_path: str) -> str:
    """Конвертирует относительный путь (от DATA_DIR) в абсолютный.
    Если путь уже абсолютный или None — возвращает как есть."""
    if not rel_path:
        return rel_path
    p = Path(rel_path)
    if p.is_absolute():
        return rel_path
    return str(DATA_DIR / p)



def _safe_delete_file(abs_path: str, db_conn=None) -> bool:
    """Delete a file only if no DB row still references it.

    Checks both covers (items.cover_path) and icons (categories.icon,
    custom_fields.icon) so we never delete a file that is still in use.
    Returns True if the file was deleted (or did not exist), False if it
    is still referenced and was left on disk.
    """
    if not abs_path or not os.path.exists(abs_path):
        return True
    if db_conn is not None:
        rel = to_relative_path(abs_path)
        try:
            cur = db_conn.cursor()
            # Check covers
            cur.execute(
                'SELECT COUNT(*) FROM items WHERE cover_path = ? OR cover_path = ?',
                (rel, abs_path)
            )
            if cur.fetchone()[0] > 0:
                return False
            # Check category / folder icons
            cur.execute(
                "SELECT COUNT(*) FROM categories WHERE icon IN (?, ?, ?, ?)",
                (f'file:{rel}', f'file:{abs_path}', rel, abs_path)
            )
            if cur.fetchone()[0] > 0:
                return False
            # Check custom field icons
            cur.execute(
                "SELECT COUNT(*) FROM custom_fields WHERE icon IN (?, ?, ?, ?)",
                (f'file:{rel}', f'file:{abs_path}', rel, abs_path)
            )
            if cur.fetchone()[0] > 0:
                return False
        except Exception:
            pass  # if check fails, be safe and don't delete
            return False
    try:
        os.remove(abs_path)
        return True
    except Exception:
        return False



def _process_category_bg(src_path: str) -> str:
    """Обработать и сохранить фоновое изображение категории.

    - Конвертирует в RGB JPEG quality=90
    - Уменьшает по высоте до 4K (3840px) если больше
    - Сохраняет в CATEGORY_BG_DIR с уникальным именем
    - Возвращает абсолютный путь к сохранённому файлу
    """
    img = Image.open(src_path)
    if img.mode != 'RGB':
        img = img.convert('RGB')
    MAX_H = 3840
    w, h = img.size
    if h > MAX_H:
        new_w = int(w * MAX_H / h)
        img = img.resize((new_w, MAX_H), Image.Resampling.LANCZOS)
    filename = f"cat_bg_{uuid.uuid4().hex}.jpg"
    dest = str(CATEGORY_BG_DIR / filename)
    img.save(dest, 'JPEG', quality=90)
    return dest


def _show_dialog(parent, title, text, kind, yes_no=False, translations=None, extra_buttons=None):
    """Универсальный кастомный диалог сообщения с иконкой.
    extra_buttons: [(label, action), ...] где action = 'accept'|'reject'|'cancel'
    Если задан extra_buttons — возвращает строку action нажатой кнопки.
    """
    tr = translations or {}

    dlg = QDialog(parent)
    dlg.setWindowTitle(title)
    _wf = (Qt.Dialog | Qt.MSWindowsFixedSizeDialogHint
           | Qt.WindowTitleHint | Qt.WindowCloseButtonHint | Qt.CustomizeWindowHint)
    dlg.setWindowFlags(_wf)
    dlg.setProperty('_custom_wflags', int(_wf))

    lay = QVBoxLayout(dlg)
    lay.setContentsMargins(16, 16, 16, 12)
    lay.setSpacing(12)
    lay.setSizeConstraint(QVBoxLayout.SetFixedSize)

    content_row = QHBoxLayout()
    content_row.setSpacing(12)

    icon_lbl = QLabel()
    icon_lbl.setFixedSize(32, 32)
    _DLGICON_SVG = {
        'info':     ('<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">'
                     '<circle cx="16" cy="16" r="15" fill="#1a6fb5" stroke="#4a9fd4" stroke-width="1.2"/>'
                     '<text x="16" y="23" font-family="Arial,sans-serif" font-size="20" font-weight="bold" '
                     'fill="white" text-anchor="middle">i</text></svg>'),
        'warning':  ('<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">'
                     '<polygon points="16,2 30,28 2,28" fill="#c8860a" stroke="#e6a020" stroke-width="1.2" stroke-linejoin="round"/>'
                     '<text x="16" y="26" font-family="Arial,sans-serif" font-size="18" font-weight="bold" '
                     'fill="white" text-anchor="middle">!</text></svg>'),
        'question': ('<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">'
                     '<circle cx="16" cy="16" r="15" fill="#1a6fb5" stroke="#4a9fd4" stroke-width="1.2"/>'
                     '<text x="16" y="23" font-family="Arial,sans-serif" font-size="20" font-weight="bold" '
                     'fill="white" text-anchor="middle">?</text></svg>'),
        'critical': ('<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">'
                     '<circle cx="16" cy="16" r="15" fill="#b52020" stroke="#d44a4a" stroke-width="1.2"/>'
                     '<text x="16" y="23" font-family="Arial,sans-serif" font-size="20" font-weight="bold" '
                     'fill="white" text-anchor="middle">&#x2715;</text></svg>'),
    }
    _sc = _get_dpr()
    _phys = round(32 * _sc)
    _renderer = QSvgRenderer(_DLGICON_SVG.get(kind, _DLGICON_SVG['info']).encode('utf-8'))
    _icon_pix = QPixmap(_phys, _phys)
    _icon_pix.fill(Qt.transparent)
    _ip = QPainter(_icon_pix)
    _renderer.render(_ip)
    _ip.end()
    _icon_pix.setDevicePixelRatio(_sc)
    icon_lbl.setPixmap(_icon_pix)
    icon_lbl.setAlignment(Qt.AlignVCenter | Qt.AlignHCenter)
    content_row.addWidget(icon_lbl)

    lbl = QLabel(text)
    lbl.setWordWrap(True)
    lbl.setMinimumWidth(220)
    lbl.setAlignment(Qt.AlignVCenter)
    content_row.addWidget(lbl, 1)
    lay.addLayout(content_row)

    _clicked_action = [None]

    row = QHBoxLayout()
    row.addStretch()
    if extra_buttons:
        for label, action in extra_buttons:
            btn = QPushButton(label)
            _a = action
            def _make_click(a):
                def _click():
                    _clicked_action[0] = a
                    dlg.accept()
                return _click
            btn.clicked.connect(_make_click(_a))
            row.addWidget(btn)
            row.addSpacing(4)
    elif yes_no:
        yes_btn = QPushButton(tr.get('yes', 'Yes'))
        no_btn  = QPushButton(tr.get('no',  'No'))
        yes_btn.clicked.connect(dlg.accept)
        no_btn.clicked.connect(dlg.reject)
        row.addWidget(yes_btn)
        row.addWidget(no_btn)
    else:
        ok_btn = QPushButton(tr.get('ok', 'OK'))
        ok_btn.clicked.connect(dlg.accept)
        row.addWidget(ok_btn)
    lay.addLayout(row)

    # Override paintEvent to paint over any system-drawn lines
    def _dlg_paint(event):
        p = QPainter(dlg)
        bg = dlg.palette().color(dlg.palette().Window)
        p.fillRect(dlg.rect(), bg)
        p.end()
    dlg.paintEvent = _dlg_paint

    dlg.exec_()
    if extra_buttons:
        return _clicked_action[0] or 'cancel'
    return dlg.result() == QDialog.Accepted



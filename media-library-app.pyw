        if dlg.exec_() == QDialog.Accepted:
            self.notes_edit.setText(dlg.get_text())

    def get_data(self):
        """Получение введенных данных"""
        user_ids = []
        for checkbox in self.user_checkboxes:
            if checkbox.isChecked():
                user_ids.append(checkbox.property('user_id'))
        
        mode = self.date_mode_combo.currentIndex()
        if mode == 0:
            watch_date = None
        elif mode == 1:
            watch_date = str(self.date_year_spin.value())
        elif mode == 2:
            watch_date = f"{self.date_year_spin.value()}-{self.date_month_combo.currentText()}"
        else:
            watch_date = self.date_edit.date().toString('yyyy-MM-dd')

        return {
            'title': self.title_edit.text(),
            'year': self.year_spin.value() if self.year_spin.value() != 0 else None,
            'cover_path': self.cover_path,
            'watch_date': watch_date,
            'notes': self.notes_edit.toPlainText(),
            'rating': self.rating_slider.value() if self.rating_slider.value() > 0 else None,
            'user_ids': user_ids,
            'is_favorite': self.favorite_checkbox.isChecked(),
            'time_spent': self.time_spin.value(),
            'view_count': self.view_count_spin.value(),
            'custom_field_values': self._collect_cf_values(),
        }

    def _collect_cf_values(self):
        """Собирает значения кастомных полей {field_id: value_str or None}"""
        result = {}
        if not hasattr(self, '_cf_widgets'):
            return result
        for fid, w in self._cf_widgets.items():
            field = self.db.get_custom_field_by_id(fid)
            if not field:
                continue
            ftype = dict(field).get('field_type', 'string')
            if ftype == 'boolean':
                result[fid] = '1' if w.isChecked() else None
            elif ftype == 'integer':
                val = w.value()
                result[fid] = str(val) if val != 0 else None
            elif ftype == 'slider':
                result[fid] = str(w._slider.value())
            elif ftype == 'select':
                opt_id = w.currentData()
                result[fid] = str(opt_id) if opt_id is not None else None
            elif ftype == 'marks':
                checked_ids = [str(cb.property('option_id')) for cb in w._checkboxes
                               if cb.isChecked() and cb.property('option_id') is not None]
                result[fid] = json.dumps(checked_ids) if checked_ids else None
            elif ftype == 'date':
                idx = w._d_mode.currentIndex()
                if idx == 0:
                    result[fid] = None
                elif idx == 1:
                    result[fid] = str(w._d_year.value())
                elif idx == 2:
                    result[fid] = f"{w._d_year.value()}-{w._d_month.currentText()}"
                else:
                    result[fid] = w._d_date.date().toString('yyyy-MM-dd')
            else:
                txt = w.text()  # НЕ strip() — иначе съедаются \n
                result[fid] = txt if txt else None
        return result

    def accept(self):
        """Сохраняем диалог. Удаление старых обложек происходит в edit_item после update_item_with_cf."""
        super().accept()

    def reject(self):
        """При отмене — удаляем новую обложку и все промежуточные если они были загружены"""
        # Удаляем текущую обложку если она новая (не та что была при открытии)
        if self.cover_path and self.cover_path != self.old_cover_path:
            _safe_delete_file(to_absolute_path(self.cover_path), self.db.conn)
        # Удаляем промежуточные обложки (результаты замен, от которых тоже отказались)
        for path in self._pending_delete_covers:
            if path and path != self.old_cover_path:
                _safe_delete_file(to_absolute_path(path), self.db.conn)
        super().reject()

class DetailPanel(QWidget):

                self._show_dialog_warning(self, self.translations.get('no_file_selected', 'No file selected'))
                return
            if not imp_zip_src_path[0] and not os.path.isfile(file_path):
                self._show_dialog_error(self, self.translations.get('import_file_not_found', 'File not found: {}').format(file_path))
                return
            import_images = imp_img_cb.isChecked()
            zip_src = imp_zip_src_path[0]
            if zip_src:
                # ZIP import — read CSV text directly from ZIP, no tmp dir
                csv_member = file_path  # file_path holds the member name when ZIP
                try:
                    with zipfile.ZipFile(zip_src, 'r') as _zf:
                        raw_bytes = _zf.read(csv_member)
                    try:
                        file_text = raw_bytes.decode('utf-8-sig')
                    except UnicodeDecodeError:
                        file_text = raw_bytes.decode('cp1251')
                except Exception as _e:
                    self._show_dialog_error(self, str(_e)); return
                base_name  = os.path.splitext(os.path.basename(csv_member))[0]
                icons_dir  = None   # icons read from ZIP by import_csv_resolve_icon
                images_dir = None   # covers extracted directly from ZIP by worker
            else:
                file_text = None
                base_name  = os.path.splitext(os.path.basename(file_path))[0]
                file_dir   = os.path.dirname(file_path)
                _covers_new = os.path.join(file_dir, base_name + '_covers')
                _covers_old = os.path.join(file_dir, base_name)
                images_dir = _covers_new if os.path.isdir(_covers_new) else _covers_old
                icons_dir  = os.path.join(file_dir, base_name + '_icons')
                if import_images and not os.path.isdir(images_dir):
                    images_dir = None
            try:
                parsed = self.db.import_csv_parse(file_path, file_text=file_text)
            except ValueError as e:
                self._show_dialog_error(self, self.translations.get('import_error', 'Import failed: {}').format(e))

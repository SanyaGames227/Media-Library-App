                id INTEGER PRIMARY KEY AUTOINCREMENT,
                category_id INTEGER NOT NULL,
                name TEXT NOT NULL,
                order_idx INTEGER DEFAULT 0
            )
        ''')
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS tier_list_set_placements (
                set_id INTEGER NOT NULL,
                item_id INTEGER NOT NULL,
                tier_key TEXT NOT NULL,
                position INTEGER DEFAULT 0,
                PRIMARY KEY (set_id, item_id)
            )
        ''')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_tlsets_cat ON tier_list_sets(category_id)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_tlplace_set ON tier_list_set_placements(set_id)')

        self.conn.commit()

    def get_field_options(self, field_id):
        """Возвращает список опций поля [(id, label, position), ...] отсортированных по position."""
        cursor = self.conn.cursor()
        cursor.execute('SELECT id, label, position FROM custom_field_options WHERE field_id=? ORDER BY position ASC', (field_id,))
        return cursor.fetchall()

    def add_field_option(self, field_id, label):
        cursor = self.conn.cursor()
        cursor.execute('SELECT MAX(position) as mx FROM custom_field_options WHERE field_id=?', (field_id,))
        mx = cursor.fetchone()['mx']
        pos = (mx or 0) + 1
        cursor.execute('INSERT INTO custom_field_options (field_id, label, position) VALUES (?,?,?)', (field_id, label, pos))
        self.commit()
        self.invalidate_options_cache(field_id)
        return cursor.lastrowid

    def rename_field_option(self, option_id, new_label):
        cursor = self.conn.cursor()
        cursor.execute('SELECT field_id FROM custom_field_options WHERE id=?', (option_id,))
        row = cursor.fetchone()
        cursor.execute('UPDATE custom_field_options SET label=? WHERE id=?', (new_label, option_id))
        self.commit()
        if row:
            self.invalidate_options_cache(row['field_id'])

    def delete_field_option(self, option_id, field_id, field_type):
        """Удаляет опцию и чистит значения в элементах."""
        cursor = self.conn.cursor()
        sid = str(option_id)
        if field_type == 'select':
            cursor.execute('DELETE FROM custom_field_values WHERE field_id=? AND value=?', (field_id, sid))
        elif field_type == 'marks':
            cursor.execute('SELECT item_id, value FROM custom_field_values WHERE field_id=?', (field_id,))
            rows = cursor.fetchall()
            for row in rows:
                try:
                    ids = json.loads(row['value'])
                    if not isinstance(ids, list): ids = []
                except Exception:
                    ids = []
                ids = [i for i in ids if i != sid]
                if ids:
                    cursor.execute('UPDATE custom_field_values SET value=? WHERE item_id=? AND field_id=?',
                                   (json.dumps(ids), row['item_id'], field_id))
                else:
                    cursor.execute('DELETE FROM custom_field_values WHERE item_id=? AND field_id=?',
                                   (row['item_id'], field_id))
        cursor.execute('DELETE FROM custom_field_options WHERE id=?', (option_id,))
        self.commit()
        self.invalidate_options_cache(field_id)

    def reorder_field_options(self, field_id, ordered_ids):
        """Сохраняет новый порядок опций."""
        cursor = self.conn.cursor()
        for pos, opt_id in enumerate(ordered_ids):
            cursor.execute('UPDATE custom_field_options SET position=? WHERE id=?', (pos, opt_id))
        self.commit()
        self.invalidate_options_cache(field_id)



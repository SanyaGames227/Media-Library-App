        def _on_create_shortcut():
            try:
                script_path = Path(__file__).resolve()
                icon_dir = DATA_DIR / '.assets'
                icon_dir.mkdir(parents=True, exist_ok=True)

                if platform.system() == 'Linux':
                    # ── Linux: .desktop файл ─────────────────────────────
                    png_path = icon_dir / 'icon.png'
                    pix = self._make_app_icon().pixmap(256, 256)
                    pix.save(str(png_path), 'PNG')
                    desktop_dir = Path.home() / 'Desktop'
                    desktop_dir.mkdir(exist_ok=True)
                    df = desktop_dir / 'media-library.desktop'
                    df.write_text(
                        '[Desktop Entry]\nVersion=1.0.0\nType=Application\n'
                        'Name=Media Library\n'
                        f'Exec=python3 "{script_path}"\n'
                        f'Icon={png_path}\n'
                        f'Path={script_path.parent}\n'
                        'Terminal=false\nCategories=Utility;\n',
                        encoding='utf-8')
                    df.chmod(0o755)
                    self._show_dialog_info(dialog, self.translations.get('shortcut_created',
                            'Shortcut created on Desktop.\nIcon: {}').format(png_path))
                    return

                if platform.system() != 'Windows':
                    self._show_dialog_info(dialog, self.translations.get('shortcut_unsupported',
                            'Not supported on this platform.'))
                    return

                # ── Windows: иконка ──────────────────────────────────────
                ico_path = icon_dir / 'icon.ico'
                if not ico_path.exists():
                    def _draw_ml_pix(size, show_ml=True):
                        pix = QPixmap(size, size)
                        pix.fill(Qt.transparent)
                        p = QPainter(pix)
                        p.setRenderHint(QPainter.Antialiasing)
                        S = size; r = S * 0.20
                        bg = QPainterPath()
                        bg.addRoundedRect(QRectF(0, 0, S, S), r, r)
                        bg_grad = QLinearGradient(0, 0, S, S)
                        bg_grad.setColorAt(0.0, QColor(15, 26, 46))
                        bg_grad.setColorAt(1.0, QColor(10, 16, 28))
                        p.setPen(Qt.NoPen); p.setBrush(bg_grad); p.drawPath(bg)
                        tg = QLinearGradient(0, S * 0.7, S, S * 0.2)
                        tg.setColorAt(0.0, QColor(42, 106, 90))
                        tg.setColorAt(0.5, QColor(74, 154, 170))
                        tg.setColorAt(1.0, QColor(106, 122, 255))
                        fs = int(S * 0.40) if S >= 64 else int(S * 0.42)
                        font = QFont('Segoe UI', fs); font.setWeight(QFont.Bold)
                        tp = QPainterPath()
                        tp.addText(0, 0, font, 'ML' if show_ml else 'M')
                        br = tp.boundingRect()
                        dx = (S - br.width()) / 2 - br.x()
                        dy = (S - br.height()) / 2 - br.y()
                        tp.translate(dx, dy)
                        p.fillPath(tp, tg)
                        if S >= 64 and show_ml:
                            uw = S * 0.56; uh = max(1.5, S * 0.045)
                            bar = QPainterPath()
                            bar.addRoundedRect(QRectF((S - uw) / 2,
                                dy + br.height() + S * 0.06, uw, uh), uh/2, uh/2)
                            p.fillPath(bar, tg)
                        if S >= 32:
                            bp = QPainterPath()
                            bp.addRoundedRect(QRectF(0.5, 0.5, S-1, S-1), r, r)
                            p.setBrush(Qt.NoBrush)
                            p.setPen(QPen(QColor(42, 106, 90, 80), 1.0))
                            p.drawPath(bp)
                        p.end(); return pix

                    sizes_spec = [(16, False), (32, True), (64, True), (128, True), (256, True)]
                    png_list = []
                    for sz, ml in sizes_spec:
                        buf = QBuffer(); buf.open(QIODevice.WriteOnly)
                        _draw_ml_pix(sz, ml).save(buf, 'PNG')
                        png_list.append(bytes(buf.data())); buf.close()
                    num = len(png_list)
                    hdr_sz = 6 + num * 16
                    offsets, off = [], hdr_sz
                    for d in png_list: offsets.append(off); off += len(d)
                    ico = struct.pack('<HHH', 0, 1, num)
                    for i, (sz, _) in enumerate(sizes_spec):
                        w = sz if sz < 256 else 0
                        ico += struct.pack('<BBBBHHII', w, w, 0, 0, 1, 32,
                                          len(png_list[i]), offsets[i])
                    for d in png_list: ico += d
                    ico_path.write_bytes(ico)

                # ── Windows: ярлык ───────────────────────────────────────
                desktop = Path.home() / 'Desktop'
                lnk_path = desktop / 'Media Library.lnk'
                target   = str(script_path)
                work_dir = str(script_path.parent)
                icon_str = str(ico_path)

                try:
                    # win32com — мгновенно, без внешних процессов
                    from win32com.client import Dispatch as _win32_Dispatch
                    ws = _win32_Dispatch('WScript.Shell')
                    s  = ws.CreateShortCut(str(lnk_path))
                    s.TargetPath       = target
                    s.WorkingDirectory = work_dir
                    s.IconLocation     = icon_str
                    s.save()
                except ImportError:
                    # Fallback: PowerShell с -NoProfile (~0.3с вместо ~1.5с)
                    ps = (
                        f'$s=New-Object -ComObject WScript.Shell;'
                        f'$l=$s.CreateShortcut("{lnk_path}");'
                        f'$l.TargetPath="{target}";'
                        f'$l.WorkingDirectory="{work_dir}";'
                        f'$l.IconLocation="{icon_str}";'
                        f'$l.Save()'
                    )
                    subprocess.run(
                        ['powershell', '-NoProfile', '-NonInteractive', '-Command', ps],
                        check=True, creationflags=subprocess.CREATE_NO_WINDOW)

                self._show_dialog_info(dialog, self.translations.get('shortcut_created',
                        'Shortcut created on Desktop.\nIcon: {}').format(icon_str))

            except Exception as _e:
                self._show_dialog_error(dialog, str(_e))


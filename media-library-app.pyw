    def load_data(self):
        fd = dict(self._current_field) if self._current_field else {}
        self.name_edit.setText(fd.get('name', ''))

        icon_val = fd.get('icon') or ''
        if icon_val.startswith('file:'):
            abs_path = to_absolute_path(icon_val[5:])
            self._file_icon[0] = abs_path
            self._original_icon_file[0] = abs_path   # запоминаем оригинал
            self.icon_edit.setEnabled(False)
            self.icon_edit.setPlaceholderText(self.translations.get('file_selected', 'File selected'))
            self.icon_remove_btn.setFixedSize(26, self._icon_btn_h)
            if os.path.exists(abs_path):
                pix = _smooth_scale_pixmap(abs_path, 32)
                if not pix.isNull():
                    self.icon_preview.setPixmap(pix)
        else:
            if icon_val:
                self.icon_edit.setText(icon_val)

        ftype = fd.get('field_type', 'string')
        type_opts_raw = fd.get('type_options') or ''
        if ftype == 'slider':
            try:
                opts = json.loads(type_opts_raw)
                self.slider_min.setValue(int(opts.get('min', 0)))
                self.slider_max.setValue(int(opts.get('max', 10)))
            except Exception:
                pass
        elif ftype == 'select':
            for opt in self.db.get_field_options(self._field_id):
                it = QListWidgetItem(opt['label'])
                it.setData(Qt.UserRole, opt['id'])
                it.setFlags(it.flags() | Qt.ItemIsEditable)
                self.select_items_list.addItem(it)
        elif ftype == 'marks':
            for opt in self.db.get_field_options(self._field_id):
                it = QListWidgetItem(opt['label'])
                it.setData(Qt.UserRole, opt['id'])
                it.setFlags(it.flags() | Qt.ItemIsEditable)
                self.marks_items_list.addItem(it)

        self.show_in_list_cb.setChecked(bool(fd.get('show_in_list', 0)))
        self.show_in_list_compact_cb.setChecked(bool(fd.get('show_in_list_compact', 0)))
        self.show_in_list_compact_cb.setVisible(True) if bool(fd.get('show_in_list', 0)) else self.show_in_list_compact_cb.setVisible(False)

        self.show_in_context_menu_cb.setChecked(bool(fd.get('show_in_context_menu', 0)))
        self.context_menu_label_edit.setText(fd.get('context_menu_label') or '')
        self.context_menu_label_widget.setVisible(True) if bool(fd.get('show_in_context_menu', 0)) else self.context_menu_label_widget.setVisible(False)
        self.show_name_in_list_cb.setChecked(bool(fd.get('show_name_in_list', 0)))
        nc = fd.get('name_color') or '#ffffff'
        self._name_color[0] = nc
        self._color_btn.setFixedWidth(22 if bool(fd.get('show_name_in_list', 0)) else 0)
        self._color_btn.setStyleSheet(
            f'background-color: {nc}; border: 1px solid #888; border-radius: 3px;'
        )
        sf = fd.get('search_filter') or ''
        self.search_filter_cb.setChecked(bool(sf))
        self.search_filter_edit.setText(sf)
        self.search_filter_widget.setVisible(True) if bool(sf) else self.search_filter_widget.setVisible(False)

    _RESERVED_PREFIXES = {'n', 'y', 'yw', 'u', 'r'}

    def _on_accept(self):
        if not self.name_edit.text().strip():
            _show_dialog_warning(self, self.translations.get('name_required', 'Name is required'), self.translations)
            return
        if self.search_filter_cb.isChecked():
            sf = self.search_filter_edit.text().strip().lower()
            if not sf:
                _show_dialog_warning(self, self.translations.get('search_filter_empty', 'Search prefix cannot be empty'), self.translations)
                return
            if not re.match(r'^[a-z0-9]+$', sf):
                _show_dialog_warning(self, self.translations.get('search_filter_invalid', 'Search prefix must contain only letters and digits'), self.translations)
                return
            if sf in self._RESERVED_PREFIXES:
                _show_dialog_warning(self, self.translations.get('search_filter_reserved', f'Prefix "{sf}" is reserved. Please use a different one.'), self.translations)
                return
            all_fields = self.db.get_custom_fields()
            for field in all_fields:
                field = dict(field)
                if field.get('search_filter') == sf and field.get('id') != self._field_id:
                    conflict_name = field["name"]
                    msg = self.translations.get('search_filter_taken', 'Prefix "{sf}" is already used by field "{name}".')
                    msg = msg.replace('{sf}', sf).replace('{name}', conflict_name)
                    _show_dialog_warning(self, msg, self.translations)
                    return
        if not self.is_edit:
            var = self.var_edit.text().strip()
            if not var:
                _show_dialog_warning(self, self.translations.get('variable_required', 'Variable name is required'), self.translations)
                return
            if not re.match(r'^[a-zA-Z_][a-zA-Z0-9_]*$', var):
                _show_dialog_warning(self, self.translations.get('variable_invalid', 'Variable must contain only letters, digits, and underscores, and must start with a letter or underscore'), self.translations)
                return
        self.accept()

    def reject(self):
        """При отмене — удаляем текущий и все промежуточные временные файлы иконок."""
        new_file = self._file_icon[0]
        if new_file and new_file != self._original_icon_file[0]:
            _safe_delete_file(new_file, self.db.conn)
        for _p in self._pending_icon_delete:
            _safe_delete_file(_p, self.db.conn)
        super().reject()

    def get_data(self):

        ftype = self.type_combo.currentData() if not self.is_edit else self._edit_field_type
        type_options = None
        if ftype == 'slider':
            type_options = json.dumps({'min': self.slider_min.value(), 'max': self.slider_max.value()})
        elif ftype in ('select', 'marks'):
            lw = self.select_items_list if ftype == 'select' else self.marks_items_list
            # Собираем опции из виджета — [(opt_id_or_None, label), ...]
            # opt_id=None означает новую запись (включая временные '_new_*'), int — существующую
            items = []
            for i in range(lw.count()):
                it = lw.item(i)
                if it and it.text().strip():
                    uid = it.data(Qt.UserRole)
                    # временные id '_new_*' нормализуем обратно в None
                    if isinstance(uid, str) and uid.startswith('_new_'):
                        uid = None
                    items.append((uid, it.text().strip()))
            type_options = json.dumps({'items': [label for _, label in items]})
            # Сохраняем полный список с id для apply_options
            self._pending_options = items

        if self._file_icon[0]:
            icon = f'file:{to_relative_path(self._file_icon[0])}'
        else:
            icon = self.icon_edit.text().strip() or '🧩'

        return {
            'name': self.name_edit.text().strip(),
            'variable': self.var_edit.text().strip() if not self.is_edit else None,
            'icon': icon,
            'field_type': ftype,
            'type_options': type_options,
            'show_in_list': 1 if self.show_in_list_cb.isChecked() else 0,
            'show_in_list_compact': 1 if self.show_in_list_compact_cb.isChecked() else 0,
            'show_in_detail': 1,  # завжди показуємо в детальній панелі
            'show_in_context_menu': 1 if self.show_in_context_menu_cb.isChecked() else 0,
            'context_menu_label': self.context_menu_label_edit.text().strip() or None,
            'show_name_in_list': 1 if self.show_name_in_list_cb.isChecked() else 0,
            'name_color': self._name_color[0] if self.show_name_in_list_cb.isChecked() else '#ffffff',
            'search_filter': self.search_filter_edit.text().strip().lower() if self.search_filter_cb.isChecked() else None,
        }


class CoverDropWidget(QWidget):
    """Кликабельная область обложки с upload-дизайном когда обложки нет."""
    clicked = pyqtSignal()
    remove_clicked = pyqtSignal()

    def __init__(self, parent=None, translations=None):
        super().__init__(parent)
        self.setFixedSize(150, 225)
        self._pixmap = None
        self._hovered = False
        self._tr = translations or {}
        self.setMouseTracking(True)
        self.setCursor(Qt.ArrowCursor)

    def setPixmap(self, pixmap):
        self._pixmap = pixmap
        self.update()

    def clear(self):
        self._pixmap = None
        self.update()

    def hasPixmap(self):
        return self._pixmap is not None and not self._pixmap.isNull()

    def _remove_btn_rect(self):
        """Rect of the ✕ button in top-right corner."""
        return QRect(self.width() - 26, 6, 20, 20)

    def mousePressEvent(self, event):
        if event.button() == Qt.LeftButton:
            if self.hasPixmap() and self._remove_btn_rect().contains(event.pos()):
                self.remove_clicked.emit()
            else:
                self.clicked.emit()

    def enterEvent(self, event):
        self._hovered = True
        self.update()

    def leaveEvent(self, event):
        self._hovered = False
        self.update()

    def mouseMoveEvent(self, event):
        if self.hasPixmap():
            if self._remove_btn_rect().contains(event.pos()):
                self.setCursor(Qt.PointingHandCursor)
            else:
                self.setCursor(Qt.ArrowCursor)
        self.update()

    def paintEvent(self, event):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        W, H = self.width(), self.height()
        r = 8

        if self.hasPixmap():
            # Draw cover image with rounded corners at physical resolution
            sc = _get_dpr()
            phys_w = round((W - 2) * sc)
            phys_h = round((H - 2) * sc)
            src = self._pixmap
            scaled = src.scaled(phys_w, phys_h,
                Qt.KeepAspectRatioByExpanding, Qt.SmoothTransformation)
            sx = (scaled.width()  - phys_w) // 2
            sy = (scaled.height() - phys_h) // 2
            cropped = scaled.copy(sx, sy, phys_w, phys_h)
            cropped.setDevicePixelRatio(sc)
            path = QPainterPath()
            path.addRoundedRect(QRectF(1, 1, W - 2, H - 2), r, r)
            p.setClipPath(path)
            p.drawPixmap(QRect(1, 1, W - 2, H - 2), cropped)
            p.setClipping(False)

            # Hover overlay
            if self._hovered:
                p.fillPath(path, QColor(0, 0, 0, 40))

            # Border
            p.setPen(QPen(QColor(0x55, 0x55, 0x55), 1))
            p.setBrush(Qt.NoBrush)
            p.drawRoundedRect(QRectF(0.5, 0.5, W - 1, H - 1), r, r)

            # ✕ remove button
            btn = self._remove_btn_rect()
            p.setPen(Qt.NoPen)
            p.setBrush(QColor(30, 30, 30, 200))
            p.drawEllipse(btn)
            p.setPen(QPen(QColor(200, 200, 200), 1.5, Qt.SolidLine, Qt.RoundCap))
            m = 6
            p.drawLine(btn.x() + m, btn.y() + m, btn.right() - m, btn.bottom() - m)
            p.drawLine(btn.right() - m, btn.y() + m, btn.x() + m, btn.bottom() - m)

        else:
            # Hover bg
            bg_color = QColor(52, 52, 52) if self._hovered else QColor(42, 42, 42)
            p.setPen(Qt.NoPen)
            p.setBrush(bg_color)
            path = QPainterPath()
            path.addRoundedRect(QRectF(0, 0, W, H), r, r)
            p.drawPath(path)

            # Dashed border — same color as icon
            border_color = QColor(80, 80, 80)
            pen = QPen(border_color)
            pen.setStyle(Qt.DashLine)
            pen.setWidth(1)
            p.setPen(pen)
            p.setBrush(Qt.NoBrush)
            p.drawRoundedRect(QRectF(1, 1, W - 2, H - 2), r, r)

            # Text
            p.setPen(QColor(220, 220, 220) if self._hovered else QColor(200, 200, 200))
            font = QFont('Segoe UI', 9)
            p.setFont(font)
            p.drawText(QRect(0, H // 2 - 10, W, 20), Qt.AlignCenter, self._tr.get('click_to_upload', 'Click to upload'))
            font2 = QFont('Segoe UI', 8)
            p.setFont(font2)
            p.setPen(QColor(110, 110, 110) if self._hovered else QColor(90, 90, 90))
            p.drawText(QRect(0, H // 2 + 8, W, 20), Qt.AlignCenter, self._tr.get('or_use_button_below', 'or use the button below'))

        p.end()


# ── Нумерация строк для редактора/превью заметок ────────────────────────────

def _make_expand_icon(size=14, color='#aaaaaa') -> 'QIcon':
    """Иконка «развернуть» — две диагональные стрелки от центра к углам."""
    pix = _make_hires_pixmap(size)
    p   = QPainter(pix)
    p.setRenderHint(QPainter.Antialiasing)
    pen = QPen(QColor(color))
    pen.setWidthF(1.6)
    pen.setCapStyle(Qt.RoundCap)
    p.setPen(pen)
    m, e, a = 2.5, size - 2.5, 3.5   # margin, edge, arrow-leg size
    # Стрелка ↗ (правый верхний угол)
    p.drawLine(QPointF(size / 2, size / 2), QPointF(e, m))
    p.drawLine(QPointF(e, m), QPointF(e - a, m))
    p.drawLine(QPointF(e, m), QPointF(e, m + a))
    # Стрелка ↙ (левый нижний угол)
    p.drawLine(QPointF(size / 2, size / 2), QPointF(m, e))
    p.drawLine(QPointF(m, e), QPointF(m + a, e))
    p.drawLine(QPointF(m, e), QPointF(m, e - a))
    p.end()
    return QIcon(pix)


def _make_collapse_icon(size=14, color='#aaaaaa') -> 'QIcon':
    """Иконка «свернуть» — две стрелки к центру."""
    pix = _make_hires_pixmap(size)
    p   = QPainter(pix)
    p.setRenderHint(QPainter.Antialiasing)
    pen = QPen(QColor(color))
    pen.setWidthF(1.6)
    pen.setCapStyle(Qt.RoundCap)
    p.setPen(pen)
    m, e, a = 2.5, size - 2.5, 3.5
    c = size / 2
    # Стрелка ↙ (от правого верхнего к центру)
    p.drawLine(QPointF(e, m), QPointF(c, c))
    p.drawLine(QPointF(c, c), QPointF(c - a * 0.7, c))
    p.drawLine(QPointF(c, c), QPointF(c, c - a * 0.7))
    # Стрелка ↗ (от левого нижнего к центру)
    p.drawLine(QPointF(m, e), QPointF(c, c))
    p.drawLine(QPointF(c, c), QPointF(c + a * 0.7, c))
    p.drawLine(QPointF(c, c), QPointF(c, c + a * 0.7))
    p.end()
    return QIcon(pix)


# ── Переведённое контекстное меню для текстовых виджетов ──────────────────────

_TRANSLATIONS_REF = {}   # заполняется при инициализации главного окна

def _translated_context_menu(widget, event, tr):
    """Показывает переведённое контекстное меню для QLineEdit / QPlainTextEdit / QTextEdit."""
    menu = widget.createStandardContextMenu()
    _map = {
        'Undo':       tr.get('ctx_undo',       'Undo'),
        'Redo':       tr.get('ctx_redo',       'Redo'),
        'Cut':        tr.get('ctx_cut',        'Cut'),
        'Copy':       tr.get('ctx_copy',       'Copy'),
        'Paste':      tr.get('ctx_paste',      'Paste'),
        'Delete':     tr.get('ctx_delete',     'Delete'),
        'Select All': tr.get('ctx_select_all', 'Select All'),
    }
    for action in menu.actions():
        raw = action.text()
        parts = raw.replace('&', '').split('\t')
        txt = parts[0].strip()
        shortcut = '\t' + parts[1] if len(parts) > 1 else ''
        for en, loc in _map.items():
            if txt == en or txt.endswith(en):
                action.setText(loc + shortcut)
                break
    menu.exec_(event.globalPos())


class _TranslatedLineEdit(QLineEdit):
    """QLineEdit с переведённым контекстным меню."""
    def contextMenuEvent(self, event):
        _translated_context_menu(self, event, _TRANSLATIONS_REF)


class _TranslatedPlainTextEdit:
    """Миксин — переопределяет contextMenuEvent для QPlainTextEdit."""
    def contextMenuEvent(self, event):
        _translated_context_menu(self, event, _TRANSLATIONS_REF)


class _TranslatedTextEdit(QTextEdit):
    """QTextEdit с переведённым контекстным меню."""
    def contextMenuEvent(self, event):
        _translated_context_menu(self, event, _TRANSLATIONS_REF)


# Monkey-patch: все QLineEdit, QTextEdit и QPlainTextEdit получают переведённое меню
def _ctx_menu_patch(self, event):
    _translated_context_menu(self, event, _TRANSLATIONS_REF)

from PyQt5.QtWidgets import QPlainTextEdit as _QPlainTextEdit
QLineEdit.contextMenuEvent      = _ctx_menu_patch
QTextEdit.contextMenuEvent      = _ctx_menu_patch
_QPlainTextEdit.contextMenuEvent = _ctx_menu_patch


class _StringFieldWidget(QWidget):
    """Виджет для кастомного поля типа 'string' (Текст).

    Режимы:
    - Однострочный: QLineEdit + кнопка expand (всегда видима)
    - Многострочный: QPlainTextEdit (авторазмер, 3–8 строк) + кнопка expand

    Переключение происходит динамически при вводе/удалении символа \\n.
    """

    _MIN_LINES = 6
    _MAX_LINES = 6

    def __init__(self, translations=None, field_name='', parent=None):
        super().__init__(parent)
        self._tr = translations or {}
        self._field_name = field_name
        self._multiline = False

        self._layout = QHBoxLayout(self)
        self._layout.setContentsMargins(0, 0, 0, 0)
        self._layout.setSpacing(4)

        # Однострочное поле (стартовое)
        self._line_edit = QLineEdit()
        self._line_edit.textChanged.connect(self._on_line_changed)
        # Перехватываем Shift+Enter / Enter в QLineEdit — переключаем в многострочный
        self._line_edit.installEventFilter(self)

        # Многострочное поле (создаём сразу, скрываем)
        from PyQt5.QtWidgets import QPlainTextEdit as _PTE
        self._text_edit = _PTE()
        self._text_edit.setFixedHeight(self._calc_te_height(self._MIN_LINES))
        self._text_edit.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)
        self._text_edit.textChanged.connect(self._on_text_changed)
        self._text_edit.hide()

        # Кнопка expand — всегда видима
        self._expand_btn = QPushButton()
        self._expand_btn.setIcon(_make_expand_icon(size=16))
        self._expand_btn.setIconSize(QSize(16, 16))
        self._expand_btn.setFixedSize(24, 24)
        self._expand_btn.setFocusPolicy(Qt.NoFocus)
        self._expand_btn.setToolTip(self._tr.get('expand_preview', 'Expand'))
        self._expand_btn.clicked.connect(self._open_fullscreen)

        self._layout.addWidget(self._expand_btn)
        self._layout.addWidget(self._line_edit)
        self._layout.addWidget(self._text_edit)

    def eventFilter(self, obj, event):
        if obj is self._line_edit and event.type() == QEvent.KeyPress:
            if event.key() in (Qt.Key_Return, Qt.Key_Enter):
                # Enter в однострочном поле — переходим в многострочный
                pos = self._line_edit.cursorPosition()
                self._switch_to_multiline(cursor_pos=pos)
                # Вставляем перенос строки точно в позицию курсора
                self._text_edit.insertPlainText('\n')
                return True
        return super().eventFilter(obj, event)

    # ── helpers ───────────────────────────────────────────────────────────────

    def _calc_te_height(self, lines):
        fm = QFontMetrics(self._text_edit.font())
        line_h = fm.height()
        return int((line_h * lines + 12) * 0.80)

    def _switch_to_multiline(self, cursor_pos=None):
        if self._multiline:
            return
        text = self._line_edit.text()
        pos = cursor_pos if cursor_pos is not None else self._line_edit.cursorPosition()
        self._line_edit.hide()
        self._text_edit.setPlainText(text)
        # Восстанавливаем позицию курсора
        from PyQt5.QtGui import QTextCursor
        cur = self._text_edit.textCursor()
        cur.setPosition(min(pos, len(text)))
        self._text_edit.setTextCursor(cur)
        self._text_edit.show()
        self._text_edit.setFocus()
        self._multiline = True
        self._adjust_te_height()

    def _switch_to_singleline(self):
        if not self._multiline:
            return
        text = self._text_edit.toPlainText()
        pos = self._text_edit.textCursor().position()
        self._text_edit.hide()
        self._line_edit.setText(text)
        self._line_edit.setCursorPosition(min(pos, len(text)))
        self._line_edit.show()
        self._line_edit.setFocus()
        self._multiline = False

    def _adjust_te_height(self):
        doc = self._text_edit.document()
        lines = doc.blockCount()
        # Минимум _MIN_LINES строк всегда, максимум _MAX_LINES до скролла
        clamped = max(self._MIN_LINES, min(lines, self._MAX_LINES))
        self._text_edit.setFixedHeight(self._calc_te_height(clamped))

    # ── slots ─────────────────────────────────────────────────────────────────

    def _on_line_changed(self, text):
        if '\n' in text:
            self._switch_to_multiline()

    def _on_text_changed(self):
        self._adjust_te_height()
        # Проверяем blockCount а не '\n' in text —
        # toPlainText() не включает trailing \n, поэтому Enter в конце
        # строки не детектился бы как многострочный
        if self._text_edit.document().blockCount() <= 1:
            self._switch_to_singleline()

    def _open_fullscreen(self):
        text = self.get_text()
        dlg = NoteEditorWindow(
            text=text,
            title=self._field_name,
            translations=self._tr,
            parent=None,
        )
        dlg.setWindowTitle(self._field_name or self._tr.get('ftype_string', 'Text'))
        dlg.setWindowModality(Qt.ApplicationModal)
        if dlg.exec_() == QDialog.Accepted:
            self.set_text(dlg.get_text())

    # ── public API ────────────────────────────────────────────────────────────

    def get_text(self):
        if self._multiline:
            return self._text_edit.toPlainText()
        return self._line_edit.text()

    def set_text(self, text):
        if text and '\n' in text:
            self._text_edit.setPlainText(text)
            if not self._multiline:
                self._line_edit.hide()
                self._text_edit.show()
                self._multiline = True
            self._adjust_te_height()
        else:
            self._line_edit.setText(text or '')
            if self._multiline:
                self._text_edit.hide()
                self._line_edit.show()
                self._multiline = False

    # Совместимость с QLineEdit.setText / .text() для старого кода
    def text(self):
        return self.get_text()

    def setText(self, text):
        self.set_text(text)


class _LineNumberedEditor(QWidget):
    """QPlainTextEdit с панелью номеров строк.

    Архитектура: LineNumberArea — дочерний виджет _editor (не сосед в layout).
    _editor занимает весь виджет; левый отступ viewport'а резервируется через
    setViewportMargins. LineNumberArea позиционируется поверх этого отступа
    через resizeEvent + _update_line_area_width.
    """

    def __init__(self, read_only=False, parent=None):
        super().__init__(parent)

        from PyQt5.QtWidgets import QPlainTextEdit

        class _PlainTextEditTranslated(_TranslatedPlainTextEdit, QPlainTextEdit):
            pass

        # ── редактор ──────────────────────────────────────────────────────────
        self._editor = _PlainTextEditTranslated(self)
        self._editor.setReadOnly(read_only)
        self._editor.setFrameShape(QFrame.NoFrame)
        self._editor.setLineWrapMode(QPlainTextEdit.NoWrap)
        # Явные цвета из глобальной палитры приложения.
        # palette(mid) / palette(light) в QSS не резолвятся корректно когда на
        # виджет уже установлен stylesheet — Qt переключается на CSS-рендеринг
        # и игнорирует QPalette. Берём hex-значения напрямую.
        _app_pal   = QApplication.palette()
        _fg        = _app_pal.color(QPalette.Text).name()
        self._editor.setStyleSheet(
            f'QPlainTextEdit {{ border: none; padding: 0px;'
            f' background: #3F3F3F; color: {_fg}; }}'
        )
        # Шрифт по умолчанию — будет переопределён снаружи через apply_note_font()
        f = QFont()
        f.setFamily('Courier New')
        f.setStyleHint(QFont.Monospace)
        f.setPointSize(11)
        self._editor.setFont(f)
        self._editor.setTabStopDistance(QFontMetrics(self._editor.font()).horizontalAdvance(' ') * 4)

        # ── панель номеров строк — child editor'а, плавает поверх margin ──────
        self._line_area = _LineNumberArea(self._editor)
        self._line_area.set_lne(self)

        # ── layout: editor занимает весь виджет ───────────────────────────────
        lay = QVBoxLayout(self)
        lay.setContentsMargins(0, 0, 0, 0)
        lay.setSpacing(0)
        lay.addWidget(self._editor)

        self._editor.blockCountChanged.connect(self._update_geometry)
        self._editor.updateRequest.connect(self._on_update_request)
        self._update_geometry()

    # ── public proxy ──────────────────────────────────────────────────────────
    def setPlainText(self, text):  self._editor.setPlainText(text)
    def toPlainText(self):         return self._editor.toPlainText()
    def setReadOnly(self, v):      self._editor.setReadOnly(v)
    def setFont(self, f):
        self._editor.setFont(f)
        self._editor.setTabStopDistance(QFontMetrics(f).horizontalAdvance(' ') * 4)
        self._update_geometry()
    def document(self):            return self._editor.document()

    # ── geometry ──────────────────────────────────────────────────────────────
    def _lna_width(self):
        digits = max(3, len(str(max(1, self._editor.blockCount()))))
        return 6 + QFontMetrics(self._editor.font()).horizontalAdvance('9') * digits + 6

    def _update_geometry(self, _=0):
        w = self._lna_width()
        self._editor.setViewportMargins(w, 0, 0, 0)
        vp = self._editor.viewport()
        vp_pos = vp.mapTo(self._editor, vp.rect().topLeft())
        self._line_area.setGeometry(0, vp_pos.y(), w, self._editor.height() - vp_pos.y())

    def _on_update_request(self, rect, dy):
        if dy:
            self._line_area.scroll(0, dy)
        else:
            self._line_area.update(0, rect.y(), self._line_area.width(), rect.height())
        if rect.contains(self._editor.viewport().rect()):
            self._update_geometry()

    def resizeEvent(self, event):
        super().resizeEvent(event)
        self._update_geometry()

    # ── рисование номеров ─────────────────────────────────────────────────────
    def _paint_line_numbers(self, event):
        painter = QPainter(self._line_area)
        pal = self._editor.palette()
        # Фон — чуть темнее base
        painter.fillRect(event.rect(), QColor('#242424'))

        block  = self._editor.firstVisibleBlock()
        bnum   = block.blockNumber()
        offset = self._editor.contentOffset()
        top    = self._editor.blockBoundingGeometry(block).translated(offset).top()
        w      = self._line_area.width() - 4   # отступ от правого края
        fh     = QFontMetrics(self._editor.font()).height()

        painter.setFont(self._editor.font())
        c = pal.color(QPalette.WindowText)
        c.setAlphaF(0.45)
        painter.setPen(c)

        while block.isValid() and top <= event.rect().bottom():
            bh = self._editor.blockBoundingRect(block).height()
            if block.isVisible() and (top + bh) >= event.rect().top():
                painter.drawText(
                    0, round(top), w, fh,
                    Qt.AlignRight | Qt.AlignTop,
                    str(bnum + 1)
                )
            block = block.next()
            bnum += 1
            top  += bh

        painter.end()


class _LineNumberArea(QWidget):
    """Панель номеров строк — дочерний виджет QPlainTextEdit."""

    def __init__(self, editor_widget):
        super().__init__(editor_widget)
        self._lne = None   # устанавливается снаружи через set_lne()

    def set_lne(self, lne):
        self._lne = lne

    def sizeHint(self):
        return QSize(0, 0)   # размер управляется через setGeometry из _LineNumberedEditor

    def paintEvent(self, event):
        if self._lne is not None:
            self._lne._paint_line_numbers(event)


# ── Вспомогательные функции для шрифта/масштаба заметок ──────────────────────

def _get_note_font_settings(db=None):
    """Читает настройки шрифта заметок из БД. Возвращает (family, size, bold, italic)."""
    if db is None:
        db = Database()
    family = db.get_setting('note_font_family', 'Courier New')
    size   = int(db.get_setting('note_font_size', '10') or 10)
    bold   = db.get_setting('note_font_bold', 'false') == 'true'
    italic = db.get_setting('note_font_italic', 'false') == 'true'
    return family, size, bold, italic

def _save_note_font_settings(db, family, size, bold, italic):
    db.set_setting('note_font_family', family)
    db.set_setting('note_font_size', str(size))
    db.set_setting('note_font_bold', 'true' if bold else 'false')
    db.set_setting('note_font_italic', 'true' if italic else 'false')

def _build_note_font(family, size, bold, italic):
    f = QFont()
    f.setFamily(family)
    f.setPointSize(max(6, size))
    f.setBold(bold)
    f.setItalic(italic)
    return f

def _get_note_zoom(db=None):
    if db is None:
        db = Database()
    return int(db.get_setting('note_zoom', '100') or 100)

def _save_note_zoom(db, zoom):
    db.set_setting('note_zoom', str(zoom))


# ── Общий миксин для тулбара заметок ─────────────────────────────────────────

class _NoteWindowMixin:
    """Добавляет тулбар (Файл / Вид) в окна NoteEditorWindow и NotePreviewWindow."""

    _NOTE_ZOOM_STEP = 10
    _NOTE_ZOOM_MIN  = 50
    _NOTE_ZOOM_MAX  = 300

    def _build_note_toolbar(self, layout, tr, read_only):
        """Создаёт тулбар и добавляет его в layout. Возвращает toolbar QWidget."""
        from PyQt5.QtWidgets import QMenuBar
        self._note_tr = tr
        self._note_db = Database()

        # Читаем сохранённые настройки
        fam, fsize, fbold, fitalic = _get_note_font_settings(self._note_db)
        self._note_zoom = _get_note_zoom(self._note_db)

        # Строим QMenuBar
        menubar = QMenuBar(self)
        menubar.setNativeMenuBar(False)

        # ── Меню Файл ──
        file_menu = menubar.addMenu(tr.get('menu_file', 'File'))
        act_save_as = QAction(tr.get('menu_save_as', 'Save as…'), self)
        act_save_as.triggered.connect(self._note_save_as)
        file_menu.addAction(act_save_as)

        # ── Меню Вид ──
        view_menu = menubar.addMenu(tr.get('menu_view', 'View'))

        zoom_menu = view_menu.addMenu(tr.get('menu_zoom', 'Zoom'))

        act_zoom_in = QAction(tr.get('menu_zoom_in', 'Zoom In') + '\tCtrl++', self)
        act_zoom_in.setShortcut(QKeySequence('Ctrl++'))
        act_zoom_in.triggered.connect(self._note_zoom_in)
        zoom_menu.addAction(act_zoom_in)

        act_zoom_out = QAction(tr.get('menu_zoom_out', 'Zoom Out') + '\tCtrl+-', self)
        act_zoom_out.setShortcut(QKeySequence('Ctrl+-'))
        act_zoom_out.triggered.connect(self._note_zoom_out)
        zoom_menu.addAction(act_zoom_out)

        zoom_menu.addSeparator()

        act_zoom_reset = QAction(tr.get('menu_zoom_reset', 'Reset Zoom') + '\tCtrl+0', self)
        act_zoom_reset.setShortcut(QKeySequence('Ctrl+0'))
        act_zoom_reset.triggered.connect(self._note_zoom_reset)
        zoom_menu.addAction(act_zoom_reset)

        act_font = QAction(tr.get('menu_font', 'Font…'), self)
        act_font.triggered.connect(self._note_choose_font)
        view_menu.addAction(act_font)

        layout.setMenuBar(menubar)

        # Применяем шрифт + масштаб
        self._apply_note_font_zoom(fam, fsize, fbold, fitalic, self._note_zoom)

    def _apply_note_font_zoom(self, family, size, bold, italic, zoom):
        """Применяет шрифт с учётом масштаба к _editor_widget."""
        effective_size = max(6, round(size * zoom / 100))
        f = _build_note_font(family, effective_size, bold, italic)
        self._editor_widget.setFont(f)
        # Сохраняем базовые значения (без масштаба)
        self._note_base_family = family
        self._note_base_size   = size
        self._note_base_bold   = bold
        self._note_base_italic = italic

    def _note_save_as(self):
        tr = self._note_tr
        default_name = getattr(self, '_note_title', '') or ''
        # Убираем символы недопустимые в именах файлов
        for ch in r'\/:*?"<>|':
            default_name = default_name.replace(ch, '_')
        path, _ = QFileDialog.getSaveFileName(self, '', default_name, 'Text Files (*.txt)')
        if path:
            try:
                with open(path, 'w', encoding='utf-8') as fh:
                    fh.write(self._editor_widget.toPlainText())
            except Exception as e:
                QMessageBox.warning(self, tr.get('error', 'Error'), str(e))

    def _note_zoom_in(self):
        self._note_zoom = min(self._NOTE_ZOOM_MAX, self._note_zoom + self._NOTE_ZOOM_STEP)
        _save_note_zoom(self._note_db, self._note_zoom)
        self._apply_note_font_zoom(self._note_base_family, self._note_base_size,
                                   self._note_base_bold, self._note_base_italic, self._note_zoom)

    def _note_zoom_out(self):
        self._note_zoom = max(self._NOTE_ZOOM_MIN, self._note_zoom - self._NOTE_ZOOM_STEP)
        _save_note_zoom(self._note_db, self._note_zoom)
        self._apply_note_font_zoom(self._note_base_family, self._note_base_size,
                                   self._note_base_bold, self._note_base_italic, self._note_zoom)

    def _note_zoom_reset(self):
        self._note_zoom = 100
        _save_note_zoom(self._note_db, self._note_zoom)
        self._apply_note_font_zoom(self._note_base_family, self._note_base_size,
                                   self._note_base_bold, self._note_base_italic, self._note_zoom)

    def _note_choose_font(self):
        from PyQt5.QtWidgets import QFontDialog
        current = _build_note_font(self._note_base_family, self._note_base_size,
                                   self._note_base_bold, self._note_base_italic)
        # QFontDialog.getFont возвращает (font, ok) — порядок зависит от версии PyQt5.
        # Используем статичный вызов с распаковкой через временный диалог.
        dlg = QFontDialog(current, self)
        if dlg.exec_() == QDialog.Accepted:
            font = dlg.selectedFont()
            fam    = font.family()
            fsize  = font.pointSize()
            fbold  = font.bold()
            fitalic = font.italic()
            _save_note_font_settings(self._note_db, fam, fsize, fbold, fitalic)
            self._apply_note_font_zoom(fam, fsize, fbold, fitalic, self._note_zoom)


# ── Отдельное окно редактора заметок (из ItemDialog) ─────────────────────────

class NoteEditorWindow(_NoteWindowMixin, QDialog):
    """Полноэкранный редактор заметок с нумерацией строк и тулбаром."""

    def __init__(self, text='', translations=None, title='', parent=None):
        super().__init__(
            parent,
            Qt.Dialog | Qt.WindowTitleHint | Qt.WindowSystemMenuHint
            | Qt.WindowCloseButtonHint | Qt.WindowMaximizeButtonHint
        )
        tr = translations or {}
        self._note_title = _display_title(title) if title else ''
        self.setWindowTitle(tr.get('notes', 'Notes'))
        self.resize(960, 680)
        self.setMinimumSize(960, 680)

        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(0)

        self._editor_widget = _LineNumberedEditor(read_only=False, parent=self)
        self._editor_widget.setPlainText(text)
        self._initial_text = text
        layout.addWidget(self._editor_widget)

        # Тулбар с меню
        self._build_note_toolbar(layout, tr, read_only=False)

        # Кнопки — стандартные QPushButton без лишнего стиля
        btn_row = QHBoxLayout()
        btn_row.setContentsMargins(10, 8, 10, 10)
        btn_row.addStretch()

        btn_ok = QPushButton(tr.get('save', 'Save'))
        btn_ok.setFixedWidth(90)
        btn_ok.setDefault(True)
        btn_ok.clicked.connect(self.accept)

        btn_cancel = QPushButton(tr.get('cancel', 'Cancel'))
        btn_cancel.setFixedWidth(90)
        btn_cancel.clicked.connect(self.reject)

        btn_row.addWidget(btn_ok)
        btn_row.addSpacing(8)
        btn_row.addWidget(btn_cancel)
        layout.addLayout(btn_row)

    def get_text(self):
        return self._editor_widget.toPlainText()

    def closeEvent(self, event):
        if self._editor_widget.toPlainText() != self._initial_text:
            tr = self._note_tr
            msg = (tr.get('note_unsaved_changes', 'There are unsaved changes.') + '\n'
                   + tr.get('note_save_prompt', 'Save the note?'))
            result = _show_dialog(
                self,
                tr.get('confirm', 'Confirm'),
                msg,
                'question',
                translations=tr,
                extra_buttons=[
                    (tr.get('save',    'Save'),    'accept'),
                    (tr.get('discard', 'Discard'), 'reject'),
                    (tr.get('cancel',  'Cancel'),  'cancel'),
                ]
            )
            if result == 'accept':
                event.ignore()
                self.done(QDialog.Accepted)
            elif result == 'reject':
                self._initial_text = self._editor_widget.toPlainText()
                event.accept()
            else:
                event.ignore()
        else:
            event.accept()


# ── Отдельное окно превью заметок (из DetailPanel) ────────────────────────────

class NotePreviewWindow(_NoteWindowMixin, QDialog):
    """Read-only превью заметок с нумерацией строк, тулбаром и кнопкой полного экрана."""

    def __init__(self, text='', title='', translations=None, parent=None):
        super().__init__(
            parent,
            Qt.Dialog | Qt.WindowTitleHint | Qt.WindowSystemMenuHint
            | Qt.WindowCloseButtonHint | Qt.WindowMaximizeButtonHint
        )
        tr = translations or {}
        notes_label = tr.get('notes', 'Notes')
        # title уже прошёл через _display_title снаружи
        self._note_title = title
        self.setWindowTitle(f"{notes_label} — {title}" if title else notes_label)
        self.resize(960, 680)
        self.setMinimumSize(960, 680)
        # Принудительно применяем Fusion-стиль к диалогу, чтобы QScrollBar
        # внутри QPlainTextEdit рисовался Qt-движком, а не нативным Windows.
        # Без этого, когда диалог открывается как отдельное окно верхнего уровня,
        # Windows перехватывает рендер скроллбара и рисует его в системном стиле.
        from PyQt5.QtWidgets import QStyleFactory
        self.setStyle(QStyleFactory.create('Fusion'))
        self.setPalette(QApplication.palette())

        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(0)

        self._editor_widget = _LineNumberedEditor(read_only=True, parent=self)
        self._editor_widget.setPlainText(text)
        layout.addWidget(self._editor_widget)

        # Тулбар с меню
        self._build_note_toolbar(layout, tr, read_only=True)



                context_menu_label TEXT DEFAULT NULL,
                position INTEGER DEFAULT 0,
                show_name_in_list INTEGER DEFAULT 0,
                name_color TEXT DEFAULT '#ffffff',
                search_filter TEXT DEFAULT NULL
            )
        ''')

        cursor.execute('''
            CREATE TABLE IF NOT EXISTS custom_field_values (
                item_id INTEGER NOT NULL,
                field_id INTEGER NOT NULL,
                value TEXT,
                PRIMARY KEY (item_id, field_id),
                FOREIGN KEY (item_id) REFERENCES items(id),
                FOREIGN KEY (field_id) REFERENCES custom_fields(id)
            )
        ''')

        cursor.execute('''
            CREATE TABLE IF NOT EXISTS custom_field_options (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                field_id INTEGER NOT NULL,
                label TEXT NOT NULL,
                position INTEGER DEFAULT 0,
                FOREIGN KEY (field_id) REFERENCES custom_fields(id)
            )
        ''')

        cursor.execute('CREATE INDEX IF NOT EXISTS idx_items_category ON items(category_id)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_items_title ON items(title)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_items_watch_date ON items(watch_date)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_items_rating ON items(rating)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_cfo_field ON custom_field_options(field_id)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_item_users_item ON item_users(item_id)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_cfv_item ON custom_field_values(item_id)')

        # ── Tier List ──────────────────────────────────────────────────
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS tier_items (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                item_id INTEGER NOT NULL,
                category_id INTEGER NOT NULL,

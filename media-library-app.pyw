    def _on_categories_dropped(self):
        """Обработка перетаскивания в списке категорий.

        Вся логика позиций считается по intended_row — строке которую мы записали
        в dragMoveEvent, а не по визуальному списку после Qt-перемещения (он ненадёжен).
        """
        # Сбрасываем флаг drag ДО load_categories — иначе on_category_selected
        # (вызываемый внутри load_categories) проигнорирует восстановление выделения.
        self.categories_list._drag_was_performed = False
        cat_list = self.categories_list
        moved_id = cat_list._last_dragged_data
        if moved_id is None:
            self._restore_category_selection()
            return

        # Мульти-drag: берём все перетаскиваемые ID
        multi_ids = getattr(cat_list, '_dragged_multi_ids', None) or [moved_id]
        # Фильтруем папки через БД — надёжнее чем через виджет
        if len(multi_ids) > 1:
            _c_tmp = self.db.conn.cursor()
            _valid = set()
            _mid_list = list(multi_ids)
            for _i in range(0, len(_mid_list), 999):
                _chunk = _mid_list[_i:_i+999]
                _c_tmp.execute(
                    'SELECT id FROM categories WHERE id IN ({}) AND is_folder = 0'.format(
                        ','.join('?' * len(_chunk))
                    ), _chunk
                )
                _valid.update(r[0] for r in _c_tmp.fetchall())
            multi_ids = [mid for mid in multi_ids if mid in _valid]

        # Одиночный drag — оригинальная логика
        if len(multi_ids) <= 1:
            self._on_categories_dropped_single(moved_id)
            return

        # Мульти drag: перемещаем все как группу
        intended_row   = getattr(cat_list, '_saved_intended_drop_row', -1)
        onto_folder_id = getattr(cat_list, '_drop_onto_folder_id', None)
        cat_list._drop_onto_folder_id = None

        c = self.db.conn.cursor()
        c.execute('SELECT id, name, is_folder, folder_id, position FROM categories ORDER BY position ASC')
        all_db = [dict(r) for r in c.fetchall()]

        folder_ids = {r['id'] for r in all_db if r['is_folder']}
        children_of = {}
        for r in all_db:
            if not r['is_folder'] and r['folder_id'] in folder_ids:
                children_of.setdefault(r['folder_id'], []).append(r['id'])

        # Строим flat список (визуальный порядок)
        flat = []
        for r in all_db:
            if r['is_folder']:
                flat.append((r['id'], True, None))
                if r['id'] not in self._collapsed_folders:
                    for cid in children_of.get(r['id'], []):
                        flat.append((cid, False, r['id']))
            elif not r['folder_id'] or r['folder_id'] not in folder_ids:
                flat.append((r['id'], False, None))

        moved_set = set(multi_ids)

        # Сохраняем относительный порядок перетаскиваемых элементов
        moved_in_order = [t[0] for t in flat if t[0] in moved_set]

        # flat без перетаскиваемых
        flat_no_moved = [t for t in flat if t[0] not in moved_set]

        # Корректируем insert_idx с учётом убранных строк
        # intended_row == -1 если drag завершился без dragMoveEvent → вставляем в конец
        if intended_row < 0:
            insert_idx = len(flat_no_moved)
        else:
            rows_before = sum(1 for i, t in enumerate(flat) if i < intended_row and t[0] in moved_set)
            insert_idx = max(0, min(intended_row - rows_before, len(flat_no_moved)))

        # Определяем новый folder_id из контекста вставки
        drop_context = getattr(cat_list, '_saved_drop_context', 'normal')
        prev_entry = flat_no_moved[insert_idx - 1] if insert_idx > 0 else None
        next_entry = flat_no_moved[insert_idx] if insert_idx < len(flat_no_moved) else None

        def _get_fid(entry):
            if entry is None: return None
            iid, isf, fid = entry
            return None if isf else fid

        if onto_folder_id is not None:
            # Drop прямо на папку — вставляем в самый конец детей этой папки
            new_folder_id = onto_folder_id
            last_child_idx = -1
            for fi, (iid, isf, fid) in enumerate(flat_no_moved):
                if iid == onto_folder_id or fid == onto_folder_id:
                    last_child_idx = fi
            insert_idx = last_child_idx + 1
        elif drop_context in ('above_folder_outside', 'after_last_child', 'top_of_free', 'end_of_list'):
            new_folder_id = None
        elif drop_context == 'top_of_child':
            new_folder_id = _get_fid(next_entry)
        elif drop_context == 'end_of_folder':
            new_folder_id = _get_fid(prev_entry)
        elif drop_context == 'between_children':
            new_folder_id = _get_fid(prev_entry)
        else:
            fp = _get_fid(prev_entry)
            fn = _get_fid(next_entry)
            if fp is not None:
                new_folder_id = fp
            elif fn is not None and prev_entry is not None and prev_entry[1]:
                new_folder_id = fn if fn == prev_entry[0] else None
            else:
                new_folder_id = None

        # Вставляем flat_no_moved + moved_in_order в нужное место
        final_flat = flat_no_moved[:insert_idx] + [(mid, False, new_folder_id) for mid in moved_in_order] + flat_no_moved[insert_idx:]

        # Назначаем позиции по индексу в final_flat — одним батчем
        c.executemany(
            'UPDATE categories SET position=?, folder_id=? WHERE id=?',
            [(float(pos_idx + 1), fid, iid) for pos_idx, (iid, isf, fid) in enumerate(final_flat)]
        )
        self.db.conn.commit()
        self.load_categories(select_ids=multi_ids)

    def _on_categories_dropped_single(self, moved_id):
        """Оригинальная логика перетаскивания одной категории/папки."""
        cat_list = self.categories_list
        if moved_id is None:
            self._restore_category_selection()
            return

        intended_row    = getattr(cat_list, '_saved_intended_drop_row', -1)
        onto_folder_id  = getattr(cat_list, '_drop_onto_folder_id', None)
        cat_list._drop_onto_folder_id = None

        c = self.db.conn.cursor()
        c.execute('SELECT is_folder, folder_id FROM categories WHERE id = ?', (moved_id,))
        moved_row_db = c.fetchone()
        if not moved_row_db:
            self._restore_category_selection()
            return
        is_folder      = bool(moved_row_db[0])
        old_folder_id  = moved_row_db[1]

        # Тихо игнорируем drop на папку, в которой категория уже находится
        if onto_folder_id is not None and not is_folder and old_folder_id == onto_folder_id:
            self.load_categories(reload_items=not self.all_categories_mode, skip_global_reload=True)
            return

        c.execute('SELECT id, name, is_folder, folder_id, position FROM categories ORDER BY position ASC')
        all_db = [dict(r) for r in c.fetchall()]

        folder_ids = {r['id'] for r in all_db if r['is_folder']}
        children_of = {}
        for r in all_db:
            if not r['is_folder'] and r['folder_id'] in folder_ids:
                children_of.setdefault(r['folder_id'], []).append(r['id'])

        flat = []  # [(id, is_folder, folder_id_or_None)]
        for r in all_db:
            if r['is_folder']:
                flat.append((r['id'], True, None))
                if r['id'] not in self._collapsed_folders:
                    for cid in children_of.get(r['id'], []):
                        flat.append((cid, False, r['id']))
            elif not r['folder_id'] or r['folder_id'] not in folder_ids:
                flat.append((r['id'], False, None))

        orig_flat_idx = next((i for i, t in enumerate(flat) if t[0] == moved_id), -1)
        if orig_flat_idx < 0:
            self.load_categories(reload_items=not self.all_categories_mode, skip_global_reload=True)
            return

        if onto_folder_id is not None and not is_folder:
            folder_flat_idx = next((i for i, t in enumerate(flat) if t[0] == onto_folder_id), -1)
            prev_id = onto_folder_id
            next_id = None
            if folder_flat_idx >= 0:
                j = folder_flat_idx + 1
                last_child_flat_id = None
                while j < len(flat) and flat[j][2] == onto_folder_id:
                    if flat[j][0] != moved_id:
                        last_child_flat_id = flat[j][0]
                    j += 1
                if last_child_flat_id is not None:
                    prev_id = last_child_flat_id
                while j < len(flat):
                    if flat[j][0] != moved_id:
                        next_id = flat[j][0]
                        break
                    j += 1
            self.db.update_category_folder(moved_id, onto_folder_id)
            self.db.reorder_position('categories', moved_id, prev_id, None)
            self.load_categories()
            return

        # intended_row — строка в визуальном списке ГДЕ должна появиться белая линия
        # (т.е. элемент вставляется ПЕРЕД этой строкой).
        # Нам нужно найти prev_id и next_id относительно flat, игнорируя
        # перемещаемый блок (папка + её дети).

        # Блок = сам moved_id + все его видимые дочерние (если папка)
        block_ids = {moved_id}
        if is_folder:
            for cid in children_of.get(moved_id, []):
                if moved_id not in self._collapsed_folders:
                    block_ids.add(cid)

        flat_no_block = [(iid, isf, fid) for (iid, isf, fid) in flat if iid not in block_ids]

        block_rows_before = sum(1 for i, t in enumerate(flat) if i < intended_row and t[0] in block_ids)

        insert_idx = max(0, intended_row - block_rows_before)
        insert_idx = min(insert_idx, len(flat_no_block))

        # Для папки: prev/next должны быть "якорями блоков" (сами папки, не дети)
        # Для категории: prev/next — прямые соседи
        if is_folder:
            block_anchors = []  # (anchor_id, start_flat_no_block_idx)
            j = 0
            while j < len(flat_no_block):
                iid, isf, fid = flat_no_block[j]
                if isf:
                    block_anchors.append((iid, j))
                    j += 1
                    while j < len(flat_no_block) and flat_no_block[j][2] == iid:
                        j += 1
                elif fid is None:
                    block_anchors.append((iid, j))
                    j += 1
                else:
                    j += 1  # дочерняя — пропускаем

            insert_before_anchor = len(block_anchors)
            for bi, (aid, aidx) in enumerate(block_anchors):
                if aidx >= insert_idx:
                    insert_before_anchor = bi
                    break

            prev_id = block_anchors[insert_before_anchor - 1][0] if insert_before_anchor > 0 else None
            next_id = block_anchors[insert_before_anchor][0] if insert_before_anchor < len(block_anchors) else None

            self.db.reorder_position('categories', moved_id, prev_id, next_id)

            c.execute('SELECT position FROM categories WHERE id=?', (moved_id,))
            fpos = float(c.fetchone()[0])
            if next_id:
                c.execute('SELECT position FROM categories WHERE id=?', (next_id,))
                npos = float(c.fetchone()[0])
            else:
                npos = fpos + 1.0
            real_children = children_of.get(moved_id, [])
            n = len(real_children)
            if real_children:
                step = (npos - fpos) / (n + 1)
                c.executemany(
                    'UPDATE categories SET position=? WHERE id=?',
                    [(fpos + step * (k + 1), cid) for k, cid in enumerate(real_children)]
                )
            self.db.conn.commit()

        else:
            drop_context = getattr(cat_list, '_saved_drop_context', 'normal')

            prev_entry = flat_no_block[insert_idx - 1] if insert_idx > 0 else None
            next_entry = flat_no_block[insert_idx] if insert_idx < len(flat_no_block) else None

            prev_id = prev_entry[0] if prev_entry else None
            next_id = next_entry[0] if next_entry else None

            def _get_folder_id(entry):
                if entry is None:
                    return None
                iid, isf, fid = entry
                if isf:
                    return None  # папка-заголовок → снаружи
                return fid

            if drop_context in ('above_folder_outside', 'after_last_child'):
                new_folder_id = None

            elif drop_context == 'top_of_child':
                new_folder_id = _get_folder_id(next_entry)  # next_entry = этот ребёнок

            elif drop_context == 'top_of_free':
                new_folder_id = None

            elif drop_context == 'end_of_folder':
                new_folder_id = _get_folder_id(prev_entry)  # prev = этот ребёнок

            elif drop_context == 'end_of_list':
                new_folder_id = None

            elif drop_context == 'between_children':
                folder_from_prev = _get_folder_id(prev_entry)
                new_folder_id = folder_from_prev  # prev — предыдущий ребёнок

            else:
                # 'normal' — стандартное определение по соседям
                folder_from_prev = _get_folder_id(prev_entry)
                folder_from_next = _get_folder_id(next_entry)

                if folder_from_prev is not None:
                    new_folder_id = folder_from_prev
                elif folder_from_next is not None and prev_entry is not None and prev_entry[1]:
                    # prev — папка-заголовок, next — её ребёнок → 1-й ребёнок этой папки
                    new_folder_id = folder_from_next if folder_from_next == prev_entry[0] else None
                else:
                    new_folder_id = None

            self.db.update_category_folder(moved_id, new_folder_id)
            self.db.reorder_position('categories', moved_id, prev_id, next_id)

        self.load_categories(reload_items=not self.all_categories_mode, skip_global_reload=True)

    def _on_item_dropped_to_category(self, source_widget):
        """Перенос элемента(ов) из items_list в выбранную категорию"""
        target_cat_item = self.categories_list._hovered_item
        if not target_cat_item:
            self._restore_category_selection()
            return
        if target_cat_item.data(Qt.UserRole + 2):
            self._restore_category_selection()
            return
        new_cat_id = target_cat_item.data(Qt.UserRole)

        # _dragged_multi_ids хранится на items_list, не на source_widget (categories_list)
        dragged_ids_raw = getattr(self.items_list, '_dragged_multi_ids', None)                        or getattr(source_widget, '_dragged_multi_ids', None)
        if not dragged_ids_raw:
            cur_id = self._current_item_id()
            dragged_ids_raw = [cur_id] if cur_id else []

        # Используем модель для построения id→row
        id_to_row = {self._item_model.item_id(i): i
                     for i in range(self._item_model.rowCount())
                     if self._item_model.item_id(i) is not None}
        dragged_ids = sorted(dragged_ids_raw, key=lambda iid: id_to_row.get(iid, 999999))

        cursor = self.db.conn.cursor()
        cursor.execute('SELECT MAX(custom_position) FROM items WHERE category_id = ?', (new_cat_id,))
        max_pos = cursor.fetchone()[0] or 0

        if not dragged_ids:
            self._restore_category_selection()
            return

        cursor.executemany(
            'UPDATE items SET category_id = ?, custom_position = ? WHERE id = ?',
            [(new_cat_id, max_pos + idx + 1, item_id) for idx, item_id in enumerate(dragged_ids)]
        )
        # Убираем фильмы из тирлистов их старых категорий
        if dragged_ids:
            placeholders = ','.join('?' * len(dragged_ids))
            cursor.execute(
                f'DELETE FROM tier_items WHERE item_id IN ({placeholders})',
                dragged_ids
            )
        self.db.conn.commit()

        rows_to_remove = sorted(
            [id_to_row[iid] for iid in dragged_ids if iid in id_to_row],
            reverse=True
        )
        # FIX: сохранить позицию скролла перед удалением строк
        scroll_val = self.items_list.verticalScrollBar().value()

        if self.all_categories_mode:
            # В режиме глобального поиска — элемент остаётся в списке,
            # только обновляем его данные (category_id изменился)
            for iid in dragged_ids:
                row = id_to_row.get(iid)
                if row is None:
                    continue
                store = getattr(self, '_items_store', None)
                if store is not None and 0 <= row < len(store):
                    # Обновляем category_id в хранимых данных
                    entry = store[row]
                    if entry and entry[0]:
                        entry[0] = dict(entry[0])
                        entry[0]['category_id'] = new_cat_id
                        if len(entry) > 6: entry[6] = None  # invalidate parts cache
                proxy_row = self._proxy_row_for_id(iid)
                if proxy_row >= 0:
                    idx = self._item_proxy.index(proxy_row, 0)
                    self.items_list.update(idx)
        else:
            removed_ids = set(dragged_ids)
            # Батчевое удаление через resetModel — гарантирует полную перерисовку
            # вместо поштучных beginRemoveRows, которые не перерисовывают сдвинувшиеся строки.
            model = self._item_model
            model.beginResetModel()
            # Удаляем из _ids и _store (текущий вид)
            new_ids   = [iid for iid in model._ids   if iid not in removed_ids]
            new_store = [e   for e   in model._store  if not (e and e[0] and e[0].get('id') in removed_ids)]
            model._ids   = new_ids
            model._store = new_store
            # Удаляем из _all_ids и _all_store (полный список)
            model._all_ids   = [iid for iid in model._all_ids   if iid not in removed_ids]
            model._all_store = [e   for e   in model._all_store  if not (e and e[0] and e[0].get('id') in removed_ids)]
            model.endResetModel()
            # Синхронизируем _items_store и _full_items_store
            self._items_store = model._store
            if hasattr(self, '_items_delegate') and self._items_delegate:
                self._items_delegate.item_store = self._items_store
            full_store = getattr(self, '_full_items_store', None)
            if full_store is not None:
                self._full_items_store = [
                    e for e in full_store
                    if not (e and e[0] and e[0].get('id') in removed_ids)
                ]
        # FIX: восстановить позицию скролла
        self.items_list.verticalScrollBar().setValue(scroll_val)

        # Форсируем полную перерисовку — после удаления нескольких строк Qt
        # не всегда перерисовывает строки, сдвинувшиеся вверх на их место.
        self.items_list.viewport().update()

        # В глобальном режиме элементы остаются видимыми — не сбрасываем detail panel
        if not self.all_categories_mode:
            self.detail_panel.clear_item()
        else:
            # Обновляем detail panel если выделен один из перемещённых элементов
            cur_id = self._current_item_id()
            if cur_id and cur_id in set(dragged_ids):
                self.on_item_selected_by_id(cur_id)
        # Re-apply active search filter if any (move operation resets model visibility)
        active_search = self.search_edit.text().strip()
        if active_search and not self.all_categories_mode:
            predicate = self._build_search_predicate(active_search)
            full_store = getattr(self, '_full_items_store', [])
            visible_indices = [i for i, entry in enumerate(full_store) if predicate(entry)]
            self._item_proxy.set_visibility(visible_indices, self.items_list)
            self._items_store = self._item_model._store
            if hasattr(self, '_items_delegate') and self._items_delegate:
                self._items_delegate.item_store = self._items_store
            self.stats_label.setText(
                self.translations.get('total_items', 'Total items: {}').format(len(visible_indices))
            )
        else:
            self.update_stats()
        self.categories_list._hovered_item = None
        self._restore_category_selection()

    def _on_items_dropped(self):
        """Сохранить позиции после DnD-сортировки (теперь через MediaItemModel)."""
        # Используем _all_ids — полный список включая скрытые при поиске
        all_ids = list(self._item_model._all_ids)
        if not all_ids:
            return

        # Сохраняем позиции в БД для всех элементов по новому порядку
        cursor = self.db.conn.cursor()
        cursor.executemany(
            'UPDATE items SET custom_position = ? WHERE id = ?',
            [(float(idx + 1), iid) for idx, iid in enumerate(all_ids)]
        )
        self.db.conn.commit()

        # Пересобрать _full_items_store по новому порядку _all_ids
        old_full = getattr(self, '_full_items_store', [])
        id_to_entry = {}
        for entry in old_full:
            item_data = entry[0] if entry else None
            if item_data:
                id_to_entry[item_data.get('id')] = entry
        # Также берём из текущего store на случай если full не синхронизирован
        for entry in getattr(self, '_items_store', []):
            item_data = entry[0] if entry else None
            if item_data and item_data.get('id') not in id_to_entry:
                id_to_entry[item_data.get('id')] = entry

        new_full_store = []
        for iid in all_ids:
            if iid in id_to_entry:
                new_full_store.append(id_to_entry[iid])
            else:
                new_full_store.append([None, [], [], None, None, None])

        self._full_items_store        = new_full_store
        self._item_model._all_ids     = list(all_ids)
        self._item_model._all_store   = new_full_store

        # Видимый store (_ids/_store) уже обновлён в dropEvent — синхронизируем делегат
        self._items_store = self._item_model._store
        self._item_model._store = self._items_store
        if hasattr(self, '_items_delegate'):
            self._items_delegate.item_store = self._items_store

        self._preserved_selection = set(getattr(self, '_preserved_selection', set()))
        self._selection_ids = set(self._preserved_selection)
        self.items_list.viewport().update()
    def _current_sort_by(self):
        sort_map = {0: 'title', 1: 'year', 2: 'watch_date', 3: 'rating', 4: 'shuffle', 5: 'manual'}
        return sort_map.get(self.sort_combo.currentIndex(), 'watch_date')

    def _update_items_drag_mode(self):
        """Переключить режим drag-drop items_list в зависимости от сортировки"""
        if self._current_sort_by() == 'manual' and not self.all_categories_mode and not self.favorites_only and not self._date_from:
            self.items_list.setDragDropMode(QListView.InternalMove)
            self.items_list.setAcceptDrops(True)
            self.items_list.setDropIndicatorShown(True)
            pass  # drag-drop handled via _on_items_dropped directly
        else:
            self.items_list.setDragDropMode(QListView.DragOnly)
            self.items_list.setAcceptDrops(False)
            self.items_list.setDropIndicatorShown(False)

    def _reload_item_widget(self, list_item):
        """Восстановить данные для строки после takeItem/insertItem (делегатный подход)."""
        item_id = list_item.data(ROLE_ITEM_ID)
        if not item_id:
            return
        item_data = self.db.get_item_by_id(item_id)
        if not item_data:
            return
        item_data = dict(item_data)   # sqlite3.Row → dict
        users   = self.db.get_item_users(item_id)
        cf_data = self._get_cf_data_for_item(item_id)
        row_h   = (MediaItemDelegate.COMPACT_HEIGHT if self.compact_view
                   else MediaItemDelegate.NORMAL_HEIGHT)

        list_item.setData(ROLE_ITEM_DATA,    item_data)
        list_item.setData(ROLE_USERS,        [dict(u) for u in users])
        list_item.setData(ROLE_CF_DATA,      cf_data)
        list_item.setData(ROLE_COVER_PIXMAP, None)
        list_item.setData(ROLE_LOADED,       True)
        list_item.setSizeHint(QSize(0, row_h))

        if not self.compact_view:
            cover_path = item_data.get('cover_path')
            if cover_path:
                row = self._source_row_for_id(list_item) if isinstance(list_item, int) else -1
                self._request_cover_for_row(row, item_id, cover_path)

        self._request_file_icons_for_cf(cf_data)


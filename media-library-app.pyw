    def set_item_tier(self, item_id, category_id, tier_key, position=None):
        """Place item into a tier."""
        cursor = self.conn.cursor()
        if position is None:
            cursor.execute(
                'SELECT MAX(position) FROM tier_items WHERE category_id=? AND tier_key=?',
                (category_id, tier_key)
            )
            mx = cursor.fetchone()[0]
            position = (mx or 0) + 1
        cursor.execute(
            'INSERT OR REPLACE INTO tier_items (item_id, category_id, tier_key, position) VALUES (?,?,?,?)',
            (item_id, category_id, tier_key, position)
        )
        self.commit()

    def remove_item_tier(self, item_id, category_id):
        """Remove item from any tier (back to pool)."""
        cursor = self.conn.cursor()
        cursor.execute(
            'DELETE FROM tier_items WHERE item_id=? AND category_id=?',
            (item_id, category_id)
        )
        self.commit()

    def reorder_tier(self, category_id, tier_key, visible_ids):
        """Reorder items within a tier preserving hidden (filtered-out) items.

        visible_ids — только те item_id, которые сейчас видны в UI (после фильтра).
        Элементы, скрытые фильтром, сохраняют свои относительные позиции и
        вставляются между видимыми так, чтобы не потерять их порядок.
        """
        cursor = self.conn.cursor()
        # Полный порядок из БД (все элементы тира, включая скрытые)
        cursor.execute(
            'SELECT item_id FROM tier_items WHERE category_id=? AND tier_key=? ORDER BY position ASC',
            (category_id, tier_key)
        )
        all_db_ids = [r[0] for r in cursor.fetchall()]
        visible_set = list(visible_ids)  # новый порядок видимых
        merged = _merge_tier_order(all_db_ids, visible_set)
        cursor.execute('BEGIN')
        cursor.executemany(
            'UPDATE tier_items SET position=? WHERE item_id=? AND category_id=? AND tier_key=?',
            [(pos, item_id, category_id, tier_key) for pos, item_id in enumerate(merged)]
        )
        self.conn.commit()

    def move_and_reorder_tier(self, item_id, category_id, new_tier_key, visible_ids):
        """Переместить элемент в тир и записать новый порядок видимых элементов.

        Скрытые фильтром элементы не трогаются — их позиции в БД остаются
        нетронутыми. Видимые получают позиции 0..N среди скрытых «слотов»
        через _merge_tier_order.
        """
        cursor = self.conn.cursor()

        # Читаем полный порядок тира ДО добавления нового элемента
        cursor.execute(
            'SELECT item_id FROM tier_items WHERE category_id=? AND tier_key=? ORDER BY position ASC',
            (category_id, new_tier_key)
        )
        old_db_ids = [r[0] for r in cursor.fetchall()]

        # Регистрируем элемент в тире
        cursor.execute('BEGIN')
        cursor.execute(
            'UPDATE tier_items SET tier_key=?, position=0 WHERE item_id=? AND category_id=?',
            (new_tier_key, item_id, category_id)
        )
        if cursor.rowcount == 0:
            cursor.execute(
                'INSERT INTO tier_items (item_id, category_id, tier_key, position) VALUES (?,?,?,0)',
                (item_id, category_id, new_tier_key)
            )
        self.conn.commit()

        # Мержим: видимые в новом порядке, скрытые не трогаем
        merged = _merge_tier_order(old_db_ids, list(visible_ids))

        cursor.execute('BEGIN')
        cursor.executemany(
            'UPDATE tier_items SET position=? WHERE item_id=? AND category_id=? AND tier_key=?',
            [(pos, iid, category_id, new_tier_key) for pos, iid in enumerate(merged)]
        )
        self.conn.commit()
        self.commit()


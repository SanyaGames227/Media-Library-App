                act.triggered.connect(_on_cf_action)
                menu.addAction(act)
        
        menu.addSeparator()

        delete_action = QAction(self.translations.get('delete', 'Delete'), self)
        delete_action.triggered.connect(self.delete_item)
        menu.addAction(delete_action)
        
        menu.exec_(self.items_list.mapToGlobal(position))
        
        self._restore_category_selection()
    
    def toggle_user_for_item(self, item_id, user_id, add):
        """Добавить/убрать пользователя для элемента"""
        current_users = [u['id'] for u in self.db.get_item_users(item_id)]
        
        if add and user_id not in current_users:
            current_users.append(user_id)
        elif not add and user_id in current_users:
            current_users.remove(user_id)
        
        self.db.update_item(item_id, user_ids=current_users)
        self.load_item(item_id)
        
        if self._current_item_id() == item_id:
            self.on_item_selected_by_id(item_id)
    
    def toggle_favorite(self, item_id):
        """Переключить избранное"""
        new_favorite = not dict(self.db.get_item_by_id(item_id) or {}).get("is_favorite", False)
        self.db.update_item(item_id, is_favorite=new_favorite)

        if self.favorites_only and not new_favorite:
            _sb = self.items_list.verticalScrollBar()
            _scroll_val = _sb.value()
            self._item_model.remove_row_by_id(item_id)
            src_row = self._source_row_for_id(item_id)
            if src_row < 0:  # уже удалён из модели — ищем в store
                src_row = next((i for i, e in enumerate(self._items_store)
                                if e[0] and e[0].get('id') == item_id), -1)
            if src_row >= 0 and src_row < len(self._items_store):
                self._items_store.pop(src_row)
            self.update_stats()
            self.detail_panel.clear_item()
            QTimer.singleShot(0, lambda _v=_scroll_val: self.items_list.verticalScrollBar().setValue(_v))
            return

        self.load_item(item_id)

        if self._current_item_id() == item_id:
            self.on_item_selected_by_id(item_id)
            
    def resizeEvent(self, event):
        super().resizeEvent(event)
        if getattr(self, '_tier_mode', False) and self.tier_list_widget:
            QTimer.singleShot(100, self.tier_list_widget._request_visible_covers)
        elif self._item_model.rowCount() > 0:
            QTimer.singleShot(50, self._fill_viewport)

            
_ROUNDED_PIX_CACHE: dict = {}

def rounded_pixmap(path, radius=20, target_w=None, target_h=None):
    """Load image at HiDPI physical resolution with rounded corners.
    target_w/h — logical pixel dimensions (defaults to DetailPanel.COVER_W/H).
    """
    sc = _get_dpr()
    lw = target_w or 200   # DetailPanel.COVER_W
    lh = target_h or 300   # DetailPanel.COVER_H
    key = (path, radius, lw, lh, sc)
    cached = _ROUNDED_PIX_CACHE.get(key)
    if cached is not None:
        return cached

    phys_w = round(lw * sc)
    phys_h = round(lh * sc)

    # Load and crop via Pillow at physical resolution
    try:
        img = Image.open(path)
        if img.mode not in ('RGB', 'RGBA'):
            img = img.convert('RGBA' if 'A' in img.getbands() else 'RGB')
        iw, ih = img.size
        # Crop to target aspect ratio
        if iw / ih > phys_w / phys_h:
            new_w = int(ih * phys_w / phys_h)
            left = (iw - new_w) // 2
            img = img.crop((left, 0, left + new_w, ih))
        else:
            new_h = int(iw * phys_h / phys_w)
            top = (ih - new_h) // 2
            img = img.crop((0, top, iw, top + new_h))
        img = img.resize((phys_w, phys_h), Image.LANCZOS)
        if img.mode == 'RGBA':
            data = img.tobytes('raw', 'RGBA')
            qimg = QImage(data, phys_w, phys_h, phys_w * 4, QImage.Format_RGBA8888)
        else:
            data = img.tobytes('raw', 'RGB')
            qimg = QImage(data, phys_w, phys_h, phys_w * 3, QImage.Format_RGB888)
        pixmap = QPixmap.fromImage(qimg)
    except Exception:
        pixmap = QPixmap(path)
        if not pixmap.isNull():
            pixmap = pixmap.scaled(phys_w, phys_h,
                Qt.KeepAspectRatioByExpanding, Qt.SmoothTransformation)

    pixmap.setDevicePixelRatio(sc)

    # Apply rounded corners mask at physical resolution
    mask = QPixmap(phys_w, phys_h)
    mask.fill(Qt.transparent)
    mask.setDevicePixelRatio(sc)
    mp = QPainter(mask)
    mp.setRenderHint(QPainter.Antialiasing)
    rpath = QPainterPath()
    # draw in logical coords (painter honours DPR)
    rpath.addRoundedRect(QRectF(0, 0, lw, lh), radius, radius)
    mp.fillPath(rpath, Qt.white)
    mp.end()
    pixmap.setMask(mask.createMaskFromColor(Qt.transparent, Qt.MaskInColor))

    if len(_ROUNDED_PIX_CACHE) > 200:
        _ROUNDED_PIX_CACHE.clear()
    _ROUNDED_PIX_CACHE[key] = pixmap
    return pixmap

class SplashScreen(QWidget):
    """Aurora-style splash: тёмный фон с живым свечением, прогресс-бар с градиентом."""

    W, H = 480, 240

    def __init__(self):
        super().__init__()
        self.setWindowFlags(Qt.SplashScreen | Qt.FramelessWindowHint)
        self.setFixedSize(self.W, self.H)
        self._progress = 0
        self._anim_offset = 0.0

        # Название из файла языка
        self._title = 'Media Library'
        try:
            _db = DATA_DIR / 'library.db'
            if _db.exists():
                _c = sqlite3.connect(str(_db))
                _r = _c.execute("SELECT value FROM settings WHERE key='language'").fetchone()
                _c.close()
                _lf = DATA_DIR / '.languages' / f'{(_r[0] if _r else "en")}.json'
                if _lf.exists():
                    self._title = json.loads(_lf.read_text(encoding='utf-8')).get('app_title', self._title)
        except Exception:
            pass

        # Таймер анимации ауроры
        self._anim_timer = QTimer(self)
        self._anim_timer.timeout.connect(self._tick)
        self._anim_timer.start(30)

        screen = QApplication.primaryScreen().geometry()
        self.move(screen.center().x() - self.W // 2, screen.center().y() - self.H // 2)

    def _tick(self):
        self._anim_offset += 0.018
        self.update()

    def paintEvent(self, _):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)

        W, H = self.W, self.H
        t = self._anim_offset

        # Фон
        p.fillRect(self.rect(), QColor('#0d0d12'))

        # Аурора — три перекрывающихся радиальных градиента, анимированных
        for cx_frac, cy_frac, r, col, phase in [
            (0.35 + 0.12 * math.sin(t),        -0.15 + 0.08 * math.cos(t * 0.7),  280, QColor(18, 55, 90,  160), 0),
            (0.60 + 0.10 * math.cos(t * 0.8),   0.20 + 0.10 * math.sin(t * 1.1),  220, QColor(12, 70, 55,  130), 1),
            (0.20 + 0.08 * math.sin(t * 1.3),   0.50 + 0.08 * math.cos(t * 0.9),  180, QColor(35, 22, 70,  110), 2),
        ]:
            cx = int(cx_frac * W)
            cy = int(cy_frac * H)
            grad = QRadialGradient(cx, cy, r)
            grad.setColorAt(0.0, col)
            col_transparent = QColor(col)
            col_transparent.setAlpha(0)
            grad.setColorAt(1.0, col_transparent)
            p.fillRect(self.rect(), QBrush(grad))

        # Слоган — мелкий текст над заголовком
        _slogans = [
            'Your personal media universe',
            'Keep track of what you love',
            'Everything you watch, in one place',
        ]
        if not hasattr(self, '_slogan'):
            self._slogan = random.choice(_slogans)
        slogan_font = QFont('Segoe UI', 8)
        p.setFont(slogan_font)
        p.setPen(QColor(130, 160, 180, 140))
        p.drawText(QRect(24, H - 74, W - 48, 16), Qt.AlignLeft | Qt.AlignVCenter, self._slogan)

        # Заголовок
        title_font = QFont('Segoe UI', 20)
        title_font.setWeight(QFont.Bold)
        p.setFont(title_font)
        p.setPen(QColor('#e8edf5'))
        p.drawText(QRect(24, H - 58, W - 48, 34), Qt.AlignLeft | Qt.AlignVCenter, 'Media Library')

        # Прогресс-бар — трек (с отступами 20px по бокам, под заголовком)
        bar_x = 24
        bar_w = W - 48
        bar_y = H - 14
        bar_h = 2
        p.fillRect(bar_x, bar_y, bar_w, bar_h, QColor(255, 255, 255, 35))

        # Прогресс-бар — заливка с градиентом
        if self._progress > 0:
            fill_w = int(bar_w * self._progress / 100)
            bar_grad = QLinearGradient(bar_x, 0, bar_x + bar_w, 0)
            bar_grad.setColorAt(0.0, QColor(42, 106, 90))
            bar_grad.setColorAt(0.5, QColor(74, 154, 170))
            bar_grad.setColorAt(1.0, QColor(106, 122, 255))
            p.fillRect(bar_x, bar_y, fill_w, bar_h, QBrush(bar_grad))



        p.end()

    def set_progress(self, value: int, status: str = ''):
        self._progress = value
        self.update()
        QApplication.processEvents()

    def finish(self, main_window):
        self._anim_timer.stop()
        self._progress = 100
        self.update()
        QApplication.processEvents()
        main_window.show()
        main_window.activateWindow()
        main_window.raise_()
        if sys.platform == 'win32':
            try:
                hwnd = int(main_window.winId())
                # Alt key trick to allow SetForegroundWindow from another process
                ctypes.windll.user32.keybd_event(0x12, 0, 0, 0)       # Alt down
                ctypes.windll.user32.SetForegroundWindow(hwnd)
                ctypes.windll.user32.keybd_event(0x12, 0, 0x0002, 0)  # Alt up
            except Exception:
                pass
        self.close()


def main():
    # ── Логирование в файл с момента последнего запуска ──────────────────────
    # DATA_DIR может ещё не существовать — создаём его
    try:
        DATA_DIR.mkdir(parents=True, exist_ok=True)
        _log_path = DATA_DIR / 'last_run.log'

        class _TeeStream:
            """Пишет одновременно в файл и в оригинальный поток (консоль)."""
            def __init__(self, original, file_handle):
                self._orig = original
                self._file = file_handle
            def write(self, msg):
                try:
                    self._file.write(msg)
                    self._file.flush()
                except Exception:
                    pass
                try:
                    if self._orig:
                        self._orig.write(msg)
                except Exception:
                    pass
            def flush(self):
                try: self._file.flush()
                except Exception: pass
                try:
                    if self._orig: self._orig.flush()
                except Exception: pass
            def fileno(self):
                # Нужно для subprocess и некоторых библиотек
                return self._orig.fileno() if self._orig else -1
            def isatty(self):
                return False

        _log_file = open(_log_path, 'w', encoding='utf-8', errors='replace')
        import datetime
        _now = datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        _log_file.write('=== Media Library started: ' + _now + ' ===\n')

        sys.stdout = _TeeStream(sys.__stdout__, _log_file)
        sys.stderr = _TeeStream(sys.__stderr__, _log_file)

        # Перехватываем необработанные исключения
        def _excepthook(exc_type, exc_value, exc_tb):
            import traceback
            msg = ''.join(traceback.format_exception(exc_type, exc_value, exc_tb))
            sys.stderr.write('\n=== UNHANDLED EXCEPTION ===\n' + msg + '\n')
            # Показываем простое окно с ошибкой если Qt уже запущен
            try:
                app = QApplication.instance()
                if app:
                    from PyQt5.QtWidgets import QMessageBox
                    mb = QMessageBox()
                    mb.setWindowTitle('Critical Error')
                    mb.setText('Unhandled exception:\n\n' + msg + '\nDetails saved to:\n' + str(_log_path))
                    mb.setIcon(QMessageBox.Critical)
                    mb.exec_()
            except Exception:
                pass
            sys.__excepthook__(exc_type, exc_value, exc_tb)
        sys.excepthook = _excepthook

    except Exception as _log_err:
        # Не падаем если логирование не удалось — просто продолжаем без него
        print(f'[LOG] Failed to set up logging: {_log_err}')

    # Убираем все ручные env-переменные масштаба — будем управлять сами
    os.environ.pop('QT_SCALE_FACTOR', None)
    os.environ.pop('QT_SCREEN_SCALE_FACTORS', None)
    os.environ.pop('QT_AUTO_SCREEN_SCALE_FACTOR', None)

    # Читаем настройку HiDPI из БД напрямую (QApplication ещё не создан)
    _hidpi_enabled = True  # по умолчанию включено
    try:
        import sqlite3 as _sqlite3
        _db_check = _sqlite3.connect(str(DB_PATH))
        _row = _db_check.execute(
            "SELECT value FROM settings WHERE key='hidpi_scaling'").fetchone()
        if _row is not None:
            _hidpi_enabled = _row[0] == '1'
        _db_check.close()
    except Exception:
        pass

    # Узнаём физическое разрешение экрана ДО создания QApplication.
    # Windows: ctypes.windll.user32
    # Linux:   xrandr / xdpyinfo / /sys/class/drm (без Qt)
    def _get_physical_screen_size():
        """Возвращает (width, height) в физических пикселях основного экрана."""
        # ── Windows ──────────────────────────────────────────────────────────
        if platform.system() == 'Windows':
            try:
                _u32 = ctypes.windll.user32
                _u32.SetProcessDPIAware()
                return _u32.GetSystemMetrics(0), _u32.GetSystemMetrics(1)
            except Exception:
                pass

        # ── Linux / BSD ───────────────────────────────────────────────────────
        # Способ 1: xrandr (наиболее надёжный, работает на X11 и XWayland)
        try:
            out = subprocess.check_output(
                ['xrandr', '--current'], stderr=subprocess.DEVNULL,
                timeout=2, text=True)
            # Ищем строку типа "   2560x1440+0+0" или "   3840x2160+0+0"
            # Берём первый connected экран с текущим режимом (помечен *)
            best_w = best_h = 0
            for line in out.splitlines():
                m = re.search(r'(\d+)x(\d+)\+\d+\+\d+', line)
                if m and '*' not in line:
                    # строка режима с координатами (connected line)
                    pass
                # Строка "connected primary WxH+X+Y" или режим с *
                m2 = re.search(r'connected.*?(\d+)x(\d+)\+', line)
                if m2:
                    w, h = int(m2.group(1)), int(m2.group(2))
                    if w * h > best_w * best_h:
                        best_w, best_h = w, h
                # Текущий активный режим (со звёздочкой)
                m3 = re.search(r'^\s+(\d+)x(\d+)\s+[\d.]+\*', line)
                if m3:
                    # используем последний найденный connected размер — он уже есть
                    pass
            if best_w and best_h:
                return best_w, best_h
        except Exception:
            pass

        # Способ 2: xdpyinfo
        try:
            out = subprocess.check_output(
                ['xdpyinfo'], stderr=subprocess.DEVNULL,
                timeout=2, text=True)
            m = re.search(r'dimensions:\s+(\d+)x(\d+)', out)
            if m:
                return int(m.group(1)), int(m.group(2))
        except Exception:
            pass

        # Способ 3: /sys/class/drm (работает даже без X11, Wayland-native)
        try:
            drm_base = Path('/sys/class/drm')
            best_w = best_h = 0
            for connector in sorted(drm_base.iterdir()):
                modes_file = connector / 'modes'
                status_file = connector / 'status'
                if not modes_file.exists():
                    continue
                try:
                    status = status_file.read_text().strip()
                    if status != 'connected':
                        continue
                except Exception:
                    pass
                for line in modes_file.read_text().splitlines():
                    m = re.match(r'(\d+)x(\d+)', line.strip())
                    if m:
                        w, h = int(m.group(1)), int(m.group(2))
                        if w * h > best_w * best_h:
                            best_w, best_h = w, h
                        break  # первая строка — наибольший режим
            if best_w and best_h:
                return best_w, best_h
        except Exception:
            pass

        return 1920, 1080  # fallback

    # Масштабируем только если разрешение ВЫШЕ 1080p (2K/4K) И настройка включена.
    try:
        _screen_w, _screen_h = _get_physical_screen_size()
        if _screen_h > 1080 and _hidpi_enabled:
            # Только для экранов выше FullHD — масштабируем под плотность 1080p
            _scale = round(_screen_h / 1080.0, 4)
            os.environ['QT_SCALE_FACTOR'] = str(_scale)
        else:
            _scale = 1.0
    except Exception:
        _scale = 1.0
        _screen_h = 1080
        _screen_w = 1920

    global _APP_SCALE
    _APP_SCALE = _scale

    QApplication.setAttribute(Qt.AA_EnableHighDpiScaling, False)
    QApplication.setAttribute(Qt.AA_UseHighDpiPixmaps, True)

    class _NoFocusStyle(QProxyStyle):
        def drawPrimitive(self, element, option, painter, widget=None):
            if element == QStyle.PE_FrameFocusRect:
                return
            if element == QStyle.PE_Frame and widget and isinstance(widget, QDialog):
                return
            super().drawPrimitive(element, option, painter, widget)

    # SVG-иконки для QMessageBox — чёткие на любом DPI
    _MSGBOX_ICONS_SVG = {
        'question': (
            '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">'
            '<circle cx="16" cy="16" r="15" fill="#1a6fb5" stroke="#4a9fd4" stroke-width="1.2"/>'
            '<text x="16" y="23" font-family="Arial,sans-serif" font-size="20" font-weight="bold" '
            'fill="white" text-anchor="middle">?</text></svg>'
        ),
        'information': (
            '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">'
            '<circle cx="16" cy="16" r="15" fill="#1a6fb5" stroke="#4a9fd4" stroke-width="1.2"/>'
            '<text x="16" y="23" font-family="Arial,sans-serif" font-size="20" font-weight="bold" '
            'fill="white" text-anchor="middle">i</text></svg>'
        ),
        'warning': (
            '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">'
            '<polygon points="16,2 30,28 2,28" fill="#c8860a" stroke="#e6a020" stroke-width="1.2" stroke-linejoin="round"/>'
            '<text x="16" y="26" font-family="Arial,sans-serif" font-size="18" font-weight="bold" '
            'fill="white" text-anchor="middle">!</text></svg>'
        ),
        'critical': (
            '<svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">'
            '<circle cx="16" cy="16" r="15" fill="#b52020" stroke="#d44a4a" stroke-width="1.2"/>'
            '<text x="16" y="23" font-family="Arial,sans-serif" font-size="20" font-weight="bold" '
            'fill="white" text-anchor="middle">&#x2715;</text></svg>'
        ),
    }

    def _svg_to_pixmap(svg_str: str, size: int) -> 'QPixmap':
        sc   = _get_dpr()
        phys = round(size * sc)
        renderer = QSvgRenderer(svg_str.encode('utf-8'))
        pix = QPixmap(phys, phys)
        pix.fill(Qt.transparent)
        p = QPainter(pix)
        renderer.render(p)
        p.end()
        pix.setDevicePixelRatio(sc)
        return pix

    def _universal_apply_scroll(dlg):
        """Универсальный скролл для любого QDialog без _AdaptiveHeightMixin."""
        if getattr(dlg, '_scroll_applied', False):
            return
        if isinstance(dlg, QMessageBox):
            return
        screen = QApplication.primaryScreen()
        if screen is None:
            return
        _MARGIN = 60
        avail_h = screen.availableGeometry().height()
        max_h   = avail_h - _MARGIN

        hint_h = getattr(dlg, '_content_hint_h', None)
        if hint_h is None:
            hint_h = max(dlg.sizeHint().height(), dlg.height())
        old_layout = dlg.layout()
        if old_layout is not None:
            hint_h = max(hint_h, old_layout.minimumSize().height())

        if hint_h <= max_h:
            return
        if old_layout is None:
            return

        cur_w = dlg.width() or dlg.sizeHint().width()

        dlg.setMinimumHeight(0)
        dlg.setMaximumHeight(16777215)

        # Снимаем SetFixedSize constraint — он запрещает изменение размера окна
        from PyQt5.QtWidgets import QLayout
        old_layout.setSizeConstraint(QLayout.SetDefaultConstraint)

        # Извлекаем строку кнопок (OK/Cancel и т.д.) — она должна быть всегда видна
        btn_item, btn_is_layout = _extract_button_row(old_layout)

        container = QWidget()
        container.setLayout(old_layout)

        scroll = QScrollArea()
        scroll.setWidget(container)
        scroll.setWidgetResizable(True)
        scroll.setFrameShape(QFrame.NoFrame)
        scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        scroll.setVerticalScrollBarPolicy(Qt.ScrollBarAsNeeded)

        sb_w = scroll.verticalScrollBar().sizeHint().width() + 4
        cont_w = max(container.sizeHint().width(), cur_w)
        scroll.setMinimumWidth(cont_w)

        new_layout = QVBoxLayout(dlg)
        new_layout.setContentsMargins(0, 0, 0, 0)
        new_layout.setSpacing(0)
        new_layout.addWidget(scroll)
        if btn_item is not None:
            new_layout.addSpacing(6)
            if btn_is_layout:
                new_layout.addLayout(btn_item)
            else:
                new_layout.addWidget(btn_item)
            new_layout.addSpacing(6)

        dlg.setMaximumHeight(max_h)
        dlg.setMinimumHeight(0)
        new_w = max(cur_w, cont_w + sb_w)
        dlg.resize(new_w, min(hint_h, max_h))
        dlg._scroll_applied = True

    class _DialogFilter(QObject):
        """Disables autoDefault on QPushButtons; replaces QMessageBox icons with crisp HiDPI SVG.
        Also applies universal scroll-wrapping for any QDialog that overflows the screen."""
        def eventFilter(self, obj, event):
            if event.type() == QEvent.Show and isinstance(obj, QDialog):
                for btn in obj.findChildren(QPushButton):
                    btn.setAutoDefault(False)
                    btn.setDefault(False)
                if isinstance(obj, QMessageBox):
                    icon_type = obj.icon()
                    svg_key = {
                        QMessageBox.Question:    'question',
                        QMessageBox.Information: 'information',
                        QMessageBox.Warning:     'warning',
                        QMessageBox.Critical:    'critical',
                    }.get(icon_type)
                    if svg_key:
                        pix = _svg_to_pixmap(_MSGBOX_ICONS_SVG[svg_key], 32)
                        obj.setIconPixmap(pix)
                else:
                    _universal_apply_scroll(obj)
            return False

    try:
        ctypes.windll.shell32.SetCurrentProcessExplicitAppUserModelID('MediaLibrary.Manager.1')
    except Exception:
        pass

    app = QApplication(sys.argv)
    app.setStyle(_NoFocusStyle('Fusion'))
    _dlg_filter = _DialogFilter()
    app.installEventFilter(_dlg_filter)

    # Обновляем глобальный DPR для корректного рендера pixmap'ов
    global _APP_DPR
    _screen_tmp = app.primaryScreen()
    _APP_DPR = _screen_tmp.devicePixelRatio() if _screen_tmp else 1.0
    app.setStyleSheet('QWidget { outline: 0; } QPushButton { outline: 0; } QCheckBox { outline: 0; } QRadioButton { outline: 0; } QComboBox { outline: 0; } QLineEdit { outline: 0; } QTextEdit { outline: 0; } QListWidget { outline: 0; } QToolButton { outline: 0; }')

    splash = SplashScreen()
    splash.show()
    QApplication.processEvents()

    # Прогрев emoji-шрифта — первый рендер QFont с emoji на Windows грузит
    # Segoe UI Emoji и занимает ~300ms.
    # Если в кеше есть хоть один PNG — грузим его (мгновенно), шрифт не нужен.
    # Если кеша нет — рендерим в невидимый пиксмап один раз, чтобы прогреть шрифт
    # до load_categories.
    _s = time.perf_counter()
    _warmup_pix = QPixmap(24, 24)
    _warmup_pix.fill(Qt.transparent)
    _warmup_p = QPainter(_warmup_pix)
    _warmup_f = QFont(); _warmup_f.setPointSize(12)
    _warmup_p.setFont(_warmup_f)
    _warmup_p.drawText(QRect(0, 0, 24, 24), Qt.AlignCenter, '🏷')
    _warmup_p.end()
    print(f"[DBG] emoji font warmup: {(time.perf_counter()-_s)*1000:.1f} ms")
    splash.set_progress(30)

    _orig_qdialog_exec = QDialog.exec_
    def _fixed_exec(self):
        # Убираем кнопку "?" глобально для всех диалогов.
        # isVisible() == False означает что нативный handle ещё не создан —
        # setWindowFlags безопасен и не вызовет пересоздания handle.
        if not self.isVisible():
            self.setWindowFlags(
                self.windowFlags() & ~Qt.WindowContextHelpButtonHint
            )
        # if CustomizeWindowHint was set (e.g. by _show_dialog) — restore it so
        # Windows does not re-add WS_DLGFRAME which draws the gray separator line
        if self.property('_custom_wflags'):
            self.setWindowFlags(Qt.WindowFlags(self.property('_custom_wflags')))
        return _orig_qdialog_exec(self)
    QDialog.exec_ = _fixed_exec
    
    palette = QPalette()

    palette.setColor(QPalette.Window, QColor(30, 30, 30))
    palette.setColor(QPalette.WindowText, QColor(255, 255, 255))

    palette.setColor(QPalette.Base, QColor(40, 40, 40))
    palette.setColor(QPalette.AlternateBase, QColor(55, 55, 55))

    palette.setColor(QPalette.ToolTipBase, QColor(255, 255, 255))
    palette.setColor(QPalette.ToolTipText, QColor(255, 255, 255))

    palette.setColor(QPalette.Text, QColor(255, 255, 255))
    palette.setColor(QPalette.Button, QColor(50, 50, 50))
    palette.setColor(QPalette.ButtonText, QColor(255, 255, 255))

    palette.setColor(QPalette.Mid, QColor(70, 70, 70))
    palette.setColor(QPalette.Dark, QColor(35, 35, 35))
    palette.setColor(QPalette.Light, QColor(90, 90, 90))
    palette.setColor(QPalette.Shadow, QColor(20, 20, 20))

    palette.setColor(QPalette.Highlight, QColor(85, 85, 85))
    palette.setColor(QPalette.HighlightedText, QColor(255, 255, 255))

    app.setPalette(palette)

    # Размер окна в логических пикселях — QT_SCALE_FACTOR масштабирует всё сам.
    # На разрешениях ниже 1080p окно делаем максимально большим с небольшим отступом,
    # а минимальный размер не фиксируем жёстко, чтобы UI не ломался.
    _screen      = app.primaryScreen()
    _avail       = _screen.availableGeometry()
    _avail_w     = _avail.width()
    _avail_h     = _avail.height()

    # Идеальный размер окна (1400x800), но не больше доступного экрана минус отступ
    _margin      = 20 if _avail_h < 800 else 40   # меньше отступ на маленьких экранах
    _win_w       = min(1400, _avail_w - _margin * 2)
    _win_h       = min(800,  _avail_h - _margin * 2)

    # Минимальный размер — не жёстко 1400x800, а пропорционально экрану.
    # Это позволяет корректно отображаться на 720p, 768p и других малых разрешениях.
    _min_w       = min(_win_w, _avail_w - _margin * 2)
    _min_h       = min(_win_h, _avail_h - _margin * 2)

    splash.set_progress(60)
    window = MainWindow()
    window.setMinimumSize(_min_w, _min_h)

    # ── Восстановление геометрии окна ─────────────────────────────────────────
    _geom_restored = False
    try:
        _saved_key  = window.db.get_setting('window_monitor_key', '')
        _saved_geom = window.db.get_setting('window_geometry',    '')
        _saved_max  = window.db.get_setting('window_maximized',   'false') == 'true'

        # Текущий ключ монитора
        _cur_ag  = _screen.availableGeometry()
        _cur_key = f'{_cur_ag.width()}x{_cur_ag.height()}@{_cur_ag.left()},{_cur_ag.top()}'

        if _saved_key == _cur_key and _saved_geom:
            _parts = [int(v) for v in _saved_geom.split(',')]
            if len(_parts) == 4:
                _sx, _sy, _sw, _sh = _parts
                # Проверяем что сохранённая геометрия хоть частично попадает в доступную область
                _visible_x = max(_cur_ag.left(), min(_sx, _cur_ag.right()  - 100))
                _visible_y = max(_cur_ag.top(),  min(_sy, _cur_ag.bottom() - 50))
                # Ограничиваем размер доступным экраном
                _sw = min(_sw, _cur_ag.width())
                _sh = min(_sh, _cur_ag.height())
                _sw = max(_sw, _min_w)
                _sh = max(_sh, _min_h)
                window.resize(_sw, _sh)
                window.move(_visible_x, _visible_y)
                if _saved_max:
                    window.showMaximized()
                _geom_restored = True
    except Exception:
        pass

    if not _geom_restored:
        window.resize(_win_w, _win_h)
        # Центрируем окно на экране
        window.move(
            _avail.left() + (_avail_w - _win_w) // 2,
            _avail.top()  + (_avail_h - _win_h) // 2,
        )
    # ──────────────────────────────────────────────────────────────────────────

    splash.set_progress(90)

    app_icon = window._make_app_icon()
    app.setWindowIcon(app_icon)
    window.setWindowIcon(app_icon)

    splash.finish(window)
    window._start_weekly_backup_check()

    # Сохраняем/восстанавливаем мульти-выделение категорий при открытии/закрытии любых диалогов.
    # Qt при деактивации главного окна снимает State_Selected — перехватываем на уровне приложения.
    class _CatSelectionFilter(QObject):
        def __init__(self):
            super().__init__()
            self._saved_ids = set()   # IDs выделенных элементов
            self._suppress = False    # True = не восстанавливать (после успешного экспорта)
            self._keep_timer = QTimer()
            self._keep_timer.setInterval(16)

        def suppress_restore(self):
            """Вызывается перед успешным экспортом — подавляет следующее восстановление."""
            self._suppress = True
            self._saved_ids = set()
            self._stop_keep()

        def _start_keep(self, saved_ids):
            cl = window.categories_list
            def _tick():
                if not self._keep_timer.isActive():
                    return
                needs = any(
                    not it.isSelected()
                    for i in range(cl.count())
                    for it in [cl.item(i)]
                    if it and it.data(Qt.UserRole) in saved_ids
                )
                if needs:
                    cl.blockSignals(True)
                    for i in range(cl.count()):
                        it = cl.item(i)
                        if it and it.data(Qt.UserRole) in saved_ids:
                            it.setSelected(True)
                    cl.blockSignals(False)
                    cl.viewport().repaint()
            self._keep_timer.timeout.connect(_tick)
            self._keep_timer.start()

        def _reapply_now(self, saved_ids):
            """Синхронно восстанавливаем выделение."""
            cl = window.categories_list
            cl.blockSignals(True)
            for i in range(cl.count()):
                it = cl.item(i)
                if it and it.data(Qt.UserRole) in saved_ids:
                    it.setSelected(True)
            cl.blockSignals(False)
            cl.viewport().repaint()

        def _stop_keep(self):
            self._keep_timer.stop()
            try:
                self._keep_timer.timeout.disconnect()
            except Exception:
                pass

        def eventFilter(self, obj, event):
            t = event.type()
            _is_show = t == QEvent.Show and (
                (isinstance(obj, QDialog) and obj.isModal()) or isinstance(obj, QMenu)
            )
            _is_hide = t == QEvent.Hide and (
                (isinstance(obj, QDialog) and obj.isModal()) or isinstance(obj, QMenu)
            )
            if _is_show:
                cl = window.categories_list
                ids = {cl.item(i).data(Qt.UserRole)
                       for i in range(cl.count())
                       if cl.item(i) and cl.item(i).isSelected()}
                if len(ids) > 1:
                    self._saved_ids = ids
                    self._stop_keep()
                    if isinstance(obj, QMenu):
                        # QMenu: таймер тикает нормально
                        self._start_keep(ids)
                    else:
                        # QDialog modal: восстанавливаем через singleShot(0)
                        # внутри exec_ loop — после того как Qt снял выделения
                        def _do_reapply(_ids=ids):
                            self._reapply_now(_ids)
                            # Qt может снять снова — повторим через 50мс
                            QTimer.singleShot(50, lambda: self._reapply_now(_ids))
                        QTimer.singleShot(0, _do_reapply)
            elif _is_hide:
                self._stop_keep()
                if self._suppress:
                    self._suppress = False
                elif self._saved_ids:
                    saved = self._saved_ids
                    self._saved_ids = set()
                    # Восстанавливаем синхронно
                    self._reapply_now(saved)
            # Сброс выделения при клике вне списка категорий
            if t == QEvent.MouseButtonPress:
                if event.button() != Qt.LeftButton:
                    return False
                if event.modifiers() & (Qt.ControlModifier | Qt.ShiftModifier):
                    return False
                if QApplication.activeModalWidget() is not None:
                    return False
                # Не сбрасываем если открыто контекстное меню
                if QApplication.activePopupWidget() is not None:
                    return False
                cl = window.categories_list
                if len(cl.selectedItems()) <= 1:
                    return False
                w = obj
                while w is not None:
                    if w is cl:
                        return False
                    w = w.parent() if hasattr(w, 'parent') else None
                self._saved_ids = set()
                self._stop_keep()
                cl.clearSelection()
                cur_id = window.current_category_id
                if cur_id is not None:
                    for i in range(cl.count()):
                        it = cl.item(i)
                        if it and it.data(Qt.UserRole) == cur_id:
                            it.setSelected(True)
                            break
            return False

    _cat_sel_filter = _CatSelectionFilter()
    app._cat_sel_filters = [_cat_sel_filter]
    app.installEventFilter(_cat_sel_filter)

    # Прогрев grab() — первый вызов медленный из-за инициализации compositor буфера.
    QTimer.singleShot(200, lambda: window.categories_list.viewport().grab())
    if not getattr(window, "_lazy_startup_pending", False):
        print(f"[DBG] ✓ Total startup: {(time.perf_counter()-window._startup_t0)*1000:.1f} ms")
    else:
        print(f"[DBG] ✓ Startup until show(): {(time.perf_counter()-window._startup_t0)*1000:.1f} ms (lazy load pending)")

    sys.exit(app.exec_())

if __name__ == '__main__':
    main()
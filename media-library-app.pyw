    DEFAULT_TIERS = [
        {'key': 'S', 'label': 'S', 'color': '#FF7F7F'},
        {'key': 'A', 'label': 'A', 'color': '#FBBC7D'},
        {'key': 'B', 'label': 'B', 'color': '#FFDF7F'},

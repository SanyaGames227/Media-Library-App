        {'key': 'D', 'label': 'D', 'color': '#BFFF7F'},
    ]

    def get_tier_config(self, category_id):
        """Return list of tier dicts for category. Creates default if missing."""
        cursor = self.conn.cursor()
        cursor.execute('SELECT config FROM tier_configs WHERE category_id=?', (category_id,))
        row = cursor.fetchone()
        if row:
            try:
                return json.loads(row['config'])
            except Exception:
                pass
        return [dict(t) for t in self.DEFAULT_TIERS]

    def set_tier_config(self, category_id, tiers):
        """Save tier config for category."""
        cursor = self.conn.cursor()
        cursor.execute(
            'INSERT OR REPLACE INTO tier_configs (category_id, config) VALUES (?, ?)',

    def _make_app_icon(self):
        """ML monogram icon — aurora gradient, multi-size aware."""
        def _draw_ml(size, show_ml=True):
            pix = QPixmap(size, size)
            pix.fill(Qt.transparent)
            p = QPainter(pix)
            p.setRenderHint(QPainter.Antialiasing)
            S = size

            # Background
            r = S * 0.20
            bg_path = QPainterPath()
            bg_path.addRoundedRect(QRectF(0, 0, S, S), r, r)
            bg_grad = QLinearGradient(0, 0, S, S)
            bg_grad.setColorAt(0.0, QColor(15, 26, 46))
            bg_grad.setColorAt(1.0, QColor(10, 16, 28))
            p.setPen(Qt.NoPen)
            p.setBrush(bg_grad)
            p.drawPath(bg_path)

            # Aurora text gradient: teal → cyan → blue
            txt_grad = QLinearGradient(0, S * 0.7, S, S * 0.2)
            txt_grad.setColorAt(0.0, QColor(42, 106, 90))
            txt_grad.setColorAt(0.5, QColor(74, 154, 170))
            txt_grad.setColorAt(1.0, QColor(106, 122, 255))

            if not show_ml:
                # 16px: only "M"
                font = QFont('Segoe UI', int(S * 0.58))
                font.setWeight(QFont.Bold)
                tp = QPainterPath()
                tp.addText(0, 0, font, 'M')
                br = tp.boundingRect()
                tp.translate((S - br.width()) / 2 - br.x(),
                              (S - br.height()) / 2 - br.y())
                p.setPen(Qt.NoPen)
                p.fillPath(tp, txt_grad)
            else:
                # 32px+: "ML" with underline accent
                font_size = int(S * 0.40) if S >= 64 else int(S * 0.42)
                font = QFont('Segoe UI', font_size)
                font.setWeight(QFont.Bold)
                tp = QPainterPath()
                tp.addText(0, 0, font, 'ML')
                br = tp.boundingRect()
                dx = (S - br.width()) / 2 - br.x()
                dy = (S - br.height()) / 2 - br.y()
                tp.translate(dx, dy)
                p.setPen(Qt.NoPen)
                p.fillPath(tp, txt_grad)

                # Underline accent bar (only 64px+)
                if S >= 64:
                    uw = S * 0.56
                    uh = max(1.5, S * 0.045)
                    uy = dy + br.height() + S * 0.06
                    bar_path = QPainterPath()
                    bar_path.addRoundedRect(QRectF((S - uw) / 2, uy, uw, uh), uh / 2, uh / 2)
                    p.fillPath(bar_path, txt_grad)

            # Border (32px+)
            if S >= 32:
                border_path = QPainterPath()
                border_path.addRoundedRect(QRectF(0.5, 0.5, S - 1, S - 1), r, r)
                p.setBrush(Qt.NoBrush)
                p.setPen(QPen(QColor(42, 106, 90, 80), 1.0))
                p.drawPath(border_path)

            p.end()
            return pix

        icon = QIcon()
        icon.addPixmap(_draw_ml(16,  show_ml=False))
        icon.addPixmap(_draw_ml(32,  show_ml=True))
        icon.addPixmap(_draw_ml(64,  show_ml=True))
        icon.addPixmap(_draw_ml(128, show_ml=True))
        icon.addPixmap(_draw_ml(256, show_ml=True))
        return icon


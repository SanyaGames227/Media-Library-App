    def _on_items_selection_changed(self, selected, deselected):
        """Обработка изменения выделения в items_list (QListView)."""
        if getattr(self, '_restoring_selection', False):
            return
        if getattr(self, '_selecting_all', False):
            return

        ctrl_held  = bool(QApplication.keyboardModifiers() & Qt.ControlModifier)
        shift_held = bool(QApplication.keyboardModifiers() & Qt.ShiftModifier)

        if not hasattr(self, '_selection_ids'):
            self._selection_ids = set()

        # Обычный клик без модификаторов — сбрасываем _selection_ids полностью,
        # чтобы скрытые поиском (но технически "выделенные") элементы не висели.
        if not ctrl_held and not shift_held and selected.indexes():
            self._selection_ids = set()

        for idx in selected.indexes():
            src_row = self._item_proxy.map_to_source_row(idx.row())
            item_id = self._item_model.item_id(src_row)
            if item_id is not None:
                self._selection_ids.add(item_id)
        for idx in deselected.indexes():
            src_row = self._item_proxy.map_to_source_row(idx.row())
            item_id = self._item_model.item_id(src_row)
            if item_id is not None:
                self._selection_ids.discard(item_id)

        self._preserved_selection = set(self._selection_ids)

        if ctrl_held:
            return
        sel_indexes = self.items_list.selectionModel().selectedIndexes()
        if len(sel_indexes) == 0:
            self.detail_panel.clear_item()
            return
        if len(sel_indexes) > 1:
            return
        proxy_idx = sel_indexes[0]
        src_row = self._item_proxy.map_to_source_row(proxy_idx.row())
        item_id = self._item_model.item_id(src_row)
        if item_id is not None:
            self.on_item_selected_by_id(item_id)

    def on_item_selected_by_id(self, item_id):
        """Обработка выбора элемента по ID."""
        item_data, users_data, cf_vals = self.db.get_item_full(item_id)
        if item_data:
            cf_fields = self.db.get_custom_fields_cached()
            cf_list = [(f, cf_vals[f['id']]) for f in cf_fields if f['id'] in cf_vals]
            self.detail_panel.show_item(item_data, users_data, cf_list if cf_list else None)

    def on_item_selected(self, list_item):
        """Обратная совместимость — принимает item_id напрямую или объект с .data()."""
        if list_item is None:
            return
        if isinstance(list_item, int):
            self.on_item_selected_by_id(list_item)
        else:
            item_id = list_item if isinstance(list_item, int) else None
            if item_id is None:
                try: item_id = list_item.data(Qt.UserRole)
                except Exception: return
            self.on_item_selected_by_id(item_id)

    def _current_item_id(self):
        """Вернуть item_id текущего (focused) элемента или None."""
        idx = self.items_list.currentIndex()
        if not idx.isValid():
            return None
        src_row = self._item_proxy.map_to_source_row(idx.row())
        return self._item_model.item_id(src_row)

    def _selected_item_ids(self):
        """Вернуть список item_id всех выделенных элементов."""
        ids = []
        for idx in self.items_list.selectionModel().selectedIndexes():
            src_row = self._item_proxy.map_to_source_row(idx.row())
            iid = self._item_model.item_id(src_row)
            if iid is not None:
                ids.append(iid)
        return ids

    def _selected_proxy_rows(self):
        """Вернуть список proxy-row для выделенных элементов."""
        return [idx.row() for idx in self.items_list.selectionModel().selectedIndexes()]

    def _source_row_for_id(self, item_id):
        """Вернуть source row по item_id."""
        return self._item_model.row_for_id(item_id)

    def _proxy_row_for_id(self, item_id):
        """Вернуть proxy row по item_id."""
        src = self._item_model.row_for_id(item_id)
        if src < 0:
            return -1
        return self._item_proxy.map_from_source_row(src)

    def _select_item_by_id(self, item_id):
        """Выделить элемент по item_id."""
        proxy_row = self._proxy_row_for_id(item_id)
        if proxy_row < 0:
            return
        idx = self._item_proxy.index(proxy_row, 0)
        self.items_list.setCurrentIndex(idx)
        self.items_list.scrollTo(idx)

    def _get_cf_data_for_item(self, item_id, cf_values_dict=None):
        """Вернуть [(field_dict, value), ...] для делегата/виджетов элемента"""
        result = []
        fields = self.db.get_custom_fields_cached()
        if not fields:
            return result
        if cf_values_dict is None:
            cf_values_dict = self.db.get_all_custom_field_values_for_item(item_id)
        for f in fields:
            val = cf_values_dict.get(f['id'])
            if val is not None:
                result.append((dict(f), val))
        return result
    

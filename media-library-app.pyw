        self.categories_list.delete_pressed.connect(_on_cat_delete)

        # Синхронизация выделения папки с детьми: если снята хотя бы одна дочерняя
        # категория — снимаем папку; если все дочерние выделены — выделяем папку.
        def _on_cat_selection_changed():
            cl = self.categories_list
            if cl.signalsBlocked():
                return
            if getattr(cl, '_suppress_restore_active', False):
                return
            # Синхронизируем выделение папок только при мульти-выделении (Ctrl зажат)
            # или когда уже выделено >1 элемент. При обычном одиночном клике — не трогаем папки.
            ctrl_held = bool(QApplication.keyboardModifiers() & Qt.ControlModifier)
            total_selected = len(cl.selectedItems())
            if not ctrl_held and total_selected <= 1:
                # Если снято всё — восстанавливаем активную категорию
                if total_selected == 0:
                    cl.blockSignals(True)
                    self._restore_active_cat_item(cl, self.current_category_id)
                    cl.blockSignals(False)
                return
            cl.blockSignals(True)
            for i in range(cl.count()):
                folder_item = cl.item(i)
                if not folder_item or not folder_item.data(Qt.UserRole + 2):
                    continue
                fid = folder_item.data(Qt.UserRole)
                children = [cl.item(j) for j in range(cl.count())
                            if cl.item(j) and not cl.item(j).data(Qt.UserRole + 2)
                            and cl.item(j).data(Qt.UserRole + 3) == fid]
                if not children:
                    continue
                all_selected = all(c.isSelected() for c in children)
                any_selected = any(c.isSelected() for c in children)
                if not any_selected and folder_item.isSelected():
                    folder_item.setSelected(False)
                elif not all_selected and folder_item.isSelected():
                    folder_item.setSelected(False)
            # Если после синхронизации ни одна обычная категория не выделена — восстанавливаем активную
            self._restore_active_cat_item(cl, self.current_category_id)
            cl.blockSignals(False)
        self.categories_list.itemSelectionChanged.connect(_on_cat_selection_changed)


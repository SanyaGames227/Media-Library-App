        def on_save():
            new_lang = lang_combo.currentData()
            lang_changed = new_lang != self.db.get_setting('language', self.current_language)
            hidpi_changed = _is_hidpi_screen and (hidpi_cb.isChecked() != _hidpi_initial)

            # Батчевое сохранение всего — одна транзакция
            with self.db.conn:
                if lang_changed:
                    self.db.conn.execute(
                        "INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)",
                        ('language', new_lang))
                val = jpg_slider.value()
                self.jpg_quality = val
                self.db.conn.execute(
                    "INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)",
                    ('jpg_quality', str(val)))
                self.db.conn.execute(
                    "INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)",
                    ('date_format', date_fmt_combo.currentData()))
                self.db.conn.execute(
                    "INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)",
                    ('per_category_sort', '1' if per_cat_cb.isChecked() else '0'))
                self.per_category_sort = per_cat_cb.isChecked()
                if _is_hidpi_screen:
                    self.db.conn.execute(
                        "INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)",
                        ('hidpi_scaling', '1' if hidpi_cb.isChecked() else '0'))
                for key, cb in _bk_checkboxes:
                    self.db.conn.execute(
                        "INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)",
                        (key, '1' if cb.isChecked() else '0'))

            self._reload_date_fmt()

            if lang_changed or hidpi_changed:
                # Строим список того что изменилось
                _changed_items = []
                if lang_changed:
                    _changed_items.append('• ' + self.translations.get('language', 'Language'))
                if hidpi_changed:
                    _changed_items.append('• ' + self.translations.get('setting_hidpi', 'HiDPI scaling'))
                _changed_list = '\n'.join(_changed_items)
                _msg = (
                    self.translations.get('restart_required_message',
                        'The following settings will take effect after restart:')
                    + '\n\n' + _changed_list + '\n\n'
                    + self.translations.get('restart_now_prompt', 'Restart now?')
                )
                if self._show_dialog_confirm(dialog, _msg):
                    dialog.accept()
                    self._restart_app()
                    return

            dialog.accept()
            # Обновляем после закрытия диалога — иначе viewport перекрыт
            def _refresh():
                # Сбрасываем кеш отрисовки (_cached_parts = entry[6]) во всех строках
                store = getattr(self, '_items_store', None)
                if store:
                    for entry in store:
                        if len(entry) > 6:
                            entry[6] = None
                if hasattr(self, 'items_list'):
                    self.items_list.viewport().update()
                if hasattr(self, 'detail_panel') and self.detail_panel.isVisible():
                    self.detail_panel.refresh()
            QTimer.singleShot(0, _refresh)


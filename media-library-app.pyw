class SortableListWidget(QListWidget):
    """
    QListWidget с красивым drag-пиксмапом и стандартным Qt InternalMove.
    Полоска drop-индикатора рисуется вручную — только пока drag активен,
    сбрасывается сразу при dragLeave или dropEvent.
    """
    dropped = pyqtSignal()
    external_drop = pyqtSignal(object)
    delete_pressed = pyqtSignal()

    def __init__(self, parent=None, translations=None):
        super().__init__(parent)
        self.translations = translations or {}
        self._label_func = lambda item: item.text() if item else ''
        self._external_sources = []
        self._hovered_item = None
        self._indicator_row = -1
        self._folder_hover_row = -1   # строка папки, на которую наведён курсор (синяя подсветка)
        self._deny_hover_row = -1     # строка папки с запретом (красная подсветка)
        self._last_dragged_item = None
        self._last_dragged_data = None
        self._is_folder_func = lambda item: False
        self._dragged_is_folder_func = lambda: False
        self._current_cat_func = lambda: None
        self._search_active_func = lambda: False
        self._all_categories_mode_func = lambda: False
        self._item_in_folder_func = lambda item: False
        self._get_item_folder_id_func = lambda item: None
        self._drag_scroll_timer = QTimer()
        self._drag_scroll_timer.setInterval(100)
        self._drag_scroll_timer.timeout.connect(self._do_drag_scroll)
        self._drag_scroll_speed = 0
        self._drag_scroll_interval = 100   # можно переопределить снаружи для медленного скролла
        self._dragging_folder = False   # True если сейчас тащим папку
        self._post_drag_callbacks = []   # функции, вызываемые после завершения drag
        self._intended_drop_row = -1     # строка куда хотим вставить при drag (internal)
        self._intended_folder_row = -1   # строка папки при "drop into folder"
        self._drop_context = 'normal'    # контекст дропа: normal/into_folder/above_folder_outside/after_last_child
        self._spacer_item = None         # временный пустой элемент внизу во время drag
        self._is_dragging = False        # True пока выполняется drag из этого списка
        self._keyboard_search_enabled = True  # можно отключить keyboard search снаружи

        self.setDragEnabled(True)
        self.setAcceptDrops(True)
        self.setDropIndicatorShown(False)
        self.setDragDropMode(QListWidget.InternalMove)
        self.setDefaultDropAction(Qt.MoveAction)
        self.viewport().installEventFilter(self)

    def eventFilter(self, obj, event):
        if obj is self.viewport() and event.type() in (QEvent.MouseButtonPress, QEvent.MouseButtonDblClick):
            if event.type() == QEvent.MouseButtonPress and event.button() == Qt.LeftButton:
                self._no_drag_press_pos = event.pos()
                self._no_drag_press_on_item = self.itemAt(event.pos()) is not None
                # Capture folder selection state BEFORE Qt changes it (itemPressed is too late)
                if getattr(self, '_is_categories_list', False):
                    _it = self.itemAt(event.pos())
                    if _it and _it.data(Qt.UserRole + 2):
                        self._folder_was_selected_before_click = _it.isSelected()
                    else:
                        self._folder_was_selected_before_click = None
            if getattr(self, '_keep_selection_on_empty_click', False) and not self.itemAt(event.pos()):
                return True  # клик по пустому месту — игнорируем, выделение не сбрасываем
        if obj is self.viewport() and event.type() == QEvent.MouseMove:
            if getattr(self, '_no_drag_select', False) and event.buttons() & Qt.LeftButton:
                # Пропускаем MouseMove только если нажатие было НА элементе —
                # в этом случае Qt запустит startDrag() (drag элемента).
                # Если нажатие было на пустом месте — блокируем: это rubber-band selection.
                press_pos = getattr(self, '_no_drag_press_pos', None)
                press_on_item = getattr(self, '_no_drag_press_on_item', False)
                if press_on_item:
                    return False  # нажали на элемент — разрешаем drag
                return True  # нажали на пустое место — блокируем rubber-band
        if obj is self.viewport() and event.type() == QEvent.Paint:
            super().viewportEvent(event)
            painter = QPainter(self.viewport())
            painter.setRenderHint(QPainter.Antialiasing)

            if self._folder_hover_row >= 0:
                it = self.item(self._folder_hover_row)
                if it:
                    r = self.visualItemRect(it)
                    painter.fillRect(r, QColor(70, 100, 150, 60))
                    painter.setPen(QColor(100, 150, 220, 180))
                    painter.drawRect(r.adjusted(1, 1, -1, -1))
            # Не рисуем линию если позиция находится внутри группы выделенных
            # Не рисуем линию если поиск активен (режим сортировки отключён)
            show_indicator = self._indicator_row >= 0
            if show_indicator and self._search_active_func():
                show_indicator = False
            if show_indicator and self._is_dragging:
                dragged_set = set(getattr(self, '_dragged_multi_ids', []) or [])
                if len(dragged_set) > 1:
                    selected_rows = set()
                    for i in range(self.count()):
                        it = self.item(i)
                        if it and it.data(Qt.UserRole) in dragged_set:
                            selected_rows.add(i)
                    # Позиция "между" элементами группы — строка N означает
                    # вставку перед элементом N, то есть после N-1.
                    # Если и N-1 и N — оба выделены, то позиция внутри группы.
                    row = self._indicator_row
                    prev_row = row - 1
                    if prev_row in selected_rows and row in selected_rows:
                        show_indicator = False
            if show_indicator:
                count = self.count()
                if count == 0:
                    y = 2
                elif self._indicator_row >= count:
                    rect = self.visualItemRect(self.item(count - 1))
                    y = rect.bottom()
                else:
                    rect = self.visualItemRect(self.item(self._indicator_row))
                    y = rect.top()
                painter.setPen(QColor(255, 255, 255))
                painter.drawLine(0, y, self.viewport().width(), y)
            painter.end()
            return True
        return False

    def wheelEvent(self, event):
        """Always scroll on wheel, even during drag."""
        sb = self.verticalScrollBar()
        delta = event.angleDelta().y()
        # Standard Qt scroll: 120 units = 1 notch = 3 lines, each line ~20px
        steps = delta / 120.0 * 3
        sb.setValue(sb.value() - int(steps * self.sizeHintForRow(0) if self.count() else steps * 20))
        event.accept()

    def keyPressEvent(self, event):
        if event.key() == Qt.Key_Delete:
            self.delete_pressed.emit()
            return
        super().keyPressEvent(event)

    def _set_indicator(self, row, folder_row=-1, deny_row=-1):
        if (self._indicator_row != row or self._folder_hover_row != folder_row
                or self._deny_hover_row != deny_row):
            self._indicator_row = row
            self._folder_hover_row = folder_row
            self._deny_hover_row = deny_row
            self.viewport().update()

    def set_label_func(self, func):
        self._label_func = func

    def add_external_source(self, widget):
        if widget not in self._external_sources:
            self._external_sources.append(widget)

    def _make_pixmap(self, label_text):
        font = self.font()
        font.setPointSize(10)
        font.setBold(True)
        fm = QFontMetrics(font)
        px, py = 14, 6
        rect = fm.boundingRect(label_text)
        w, h = rect.width() + px * 2, rect.height() + py * 2
        pix = QPixmap(w, h)
        pix.fill(Qt.transparent)
        painter = QPainter(pix)
        painter.setRenderHint(QPainter.Antialiasing)
        path = QPainterPath()
        path.addRoundedRect(QRectF(0, 0, w, h), 8, 8)
        painter.fillPath(path, QColor(70, 70, 70))
        painter.setFont(font)
        painter.setPen(QColor(255, 255, 255))
        painter.drawText(pix.rect().adjusted(px, 0, -px, 0),
                         Qt.AlignVCenter | Qt.AlignLeft, label_text)
        painter.end()
        return pix

    def _add_drag_spacer(self):
        """Добавить пустой элемент внизу только если нет свободного места."""
        if self._spacer_item is not None:
            return
        vp = self.viewport()
        last_item = self.item(self.count() - 1)
        if last_item is not None:
            last_rect = self.visualItemRect(last_item)
            free_space = vp.height() - last_rect.bottom()
            if free_space >= 40:
                return  # места достаточно — spacer не нужен
        spacer = QListWidgetItem('')
        spacer.setFlags(Qt.NoItemFlags)
        spacer.setSizeHint(QSize(0, 40))
        spacer.setData(Qt.UserRole, '__drag_spacer__')
        spacer.setBackground(QColor(0, 0, 0, 0))  # прозрачный
        spacer.setForeground(QColor(0, 0, 0, 0))
        self.addItem(spacer)
        self._spacer_item = spacer

    def _remove_drag_spacer(self):
        """Убрать временный пустой элемент (безопасно)."""
        if self._spacer_item is None:
            return
        # Ищем spacer по маркеру, не по указателю (Qt мог переместить объект)
        for i in range(self.count()):
            it = self.item(i)
            try:
                if it is not None and it.data(Qt.UserRole) == '__drag_spacer__':
                    self.takeItem(i)
                    break
            except RuntimeError:
                break
        self._spacer_item = None

    def startDrag(self, supported_actions):
        item = self.currentItem()
        if not item:
            return
        self._drag_was_performed = True  # drag начался — itemClicked должен его проигнорировать
        self._last_dragged_item = item
        self._last_dragged_data = item.data(Qt.UserRole)
        # Запомнить ДО drag — currentItem() может смениться в процессе
        self._dragging_folder = self._is_folder_func(item)
        self._is_dragging = True
        # Запомнить category_id перетаскиваемого элемента (для all_categories_mode)
        _dragged_row = self.row(item)
        _delegate = self.itemDelegate()
        _store = getattr(_delegate, 'item_store', None) if _delegate else None
        if _store and 0 <= _dragged_row < len(_store):
            _entry = _store[_dragged_row]
            _item_data = _entry[0] if isinstance(_entry, (list, tuple)) else _entry
            self._last_dragged_category_id = _item_data.get('category_id') if isinstance(_item_data, dict) else None
        else:
            self._last_dragged_category_id = None
        # Запомним все выделенные item_id для multi-drag
        selected_items = self.selectedItems()
        self._dragged_multi_ids = [it.data(Qt.UserRole) for it in selected_items
                                   if it.data(Qt.UserRole) != '__drag_spacer__']
        self._add_drag_spacer()
        for sel_it in selected_items:
            if self._is_folder_func(sel_it):
                sel_it.setBackground(QColor(60, 68, 84))
            else:
                sel_it.setBackground(QColor(75, 75, 75))
        if len(self._dragged_multi_ids) > 1:
            label_text = f"{len(self._dragged_multi_ids)} {self.translations.get('items', 'items')}"
        else:
            label_text = self._label_func(item)
        pix = self._make_pixmap(label_text)
        mime = self.model().mimeData(self.selectedIndexes())
        drag = QDrag(self)
        drag.setMimeData(mime)
        drag.setPixmap(pix)
        drag.setHotSpot(QPoint(-10, -10))
        drag.exec_(Qt.MoveAction)
        self._drag_scroll_timer.stop()
        self.viewport().unsetCursor()
        self._set_indicator(-1, folder_row=-1, deny_row=-1)
        self._dragging_folder = False
        self._is_dragging = False
        self._remove_drag_spacer()
        for dragged_id in getattr(self, '_dragged_multi_ids', [self._last_dragged_data]):
            for i in range(self.count()):
                it = self.item(i)
                try:
                    if it is not None and it.data(Qt.UserRole) == dragged_id:
                        if it.data(Qt.UserRole + 2):
                            it.setBackground(QColor(38, 44, 56))
                        else:
                            it.setBackground(QColor(0, 0, 0, 0))
                        break
                except RuntimeError:
                    break
        for cb in self._post_drag_callbacks:
            cb()
        self._post_drag_callbacks.clear()

    def dragEnterEvent(self, event):
        if event.source() in self._external_sources:
            self.viewport().unsetCursor()
            item_at = self.itemAt(event.pos())
            self.clearSelection()
            if item_at:
                item_at.setSelected(True)
            event.acceptProposedAction()
        else:
            # В all_categories_mode запрещаем drop внутри items_list — только на categories_list
            if self._all_categories_mode_func():
                self.viewport().setCursor(Qt.ForbiddenCursor)
                event.setDropAction(Qt.IgnoreAction)
                event.accept()
                return
            super().dragEnterEvent(event)

    def dragMoveEvent(self, event):
        if event.source() in self._external_sources:
            item_at = self.itemAt(event.pos())
            self.clearSelection()
            current_cat = self._current_cat_func()
            is_folder_target = item_at and self._is_folder_func(item_at)
            all_cats = self._all_categories_mode_func()
            if all_cats:
                # В режиме all_categories_mode current_category_id устарел.
                # Используем category_id, сохранённый в startDrag из _items_store.
                dragged_cat = getattr(event.source(), '_last_dragged_category_id', None)
                is_same_cat = (item_at and not is_folder_target
                               and dragged_cat is not None
                               and item_at.data(Qt.UserRole) == dragged_cat)
            else:
                is_same_cat = (item_at and not is_folder_target
                               and item_at.data(Qt.UserRole) == current_cat)
            if is_folder_target or is_same_cat:
                self._set_indicator(-1, folder_row=-1, deny_row=-1)
                self._hovered_item = None
                event.setDropAction(Qt.IgnoreAction)
                self.viewport().setCursor(Qt.ForbiddenCursor)
                event.accept()
            else:
                self._set_indicator(-1, folder_row=-1, deny_row=-1)
                self.viewport().unsetCursor()
                if item_at:
                    item_at.setSelected(True)
                    self._hovered_item = item_at
                else:
                    self._hovered_item = None
                event.acceptProposedAction()
        else:
            pos = event.pos()
            item_at = self.itemAt(pos)
            if item_at is not None and item_at.data(Qt.UserRole) == '__drag_spacer__':
                item_at = None
            dragging_folder = self._dragged_is_folder_func()

            # В all_categories_mode блокируем сортировку только для items_list, не categories_list
            if self._all_categories_mode_func() and not getattr(self, '_is_categories_list', False):
                self._set_indicator(-1, folder_row=-1, deny_row=-1)
                self.viewport().setCursor(Qt.ForbiddenCursor)
                event.setDropAction(Qt.IgnoreAction)
                event.accept()
                return

            # Если поиск активен — не показываем индикатор сортировки,
            # но не блокируем drag (он нужен для переноса в другую категорию)
            if self._search_active_func():
                self._set_indicator(-1, folder_row=-1, deny_row=-1)
                # В режиме глобального поиска блокируем drop на элемент той же категории
                dragged_item = self._last_dragged_item
                dragged_data = dragged_item.data(ROLE_ITEM_DATA) if dragged_item else None
                dragged_cat = dragged_data.get('category_id') if isinstance(dragged_data, dict) else None
                target_item = self.itemAt(pos)
                target_data = target_item.data(ROLE_ITEM_DATA) if target_item else None
                target_cat  = target_data.get('category_id') if isinstance(target_data, dict) else None
                if dragged_cat and target_cat and dragged_cat == target_cat:
                    self.viewport().setCursor(Qt.ForbiddenCursor)
                    event.setDropAction(Qt.IgnoreAction)
                    event.accept()
                else:
                    self.viewport().unsetCursor()
                    event.acceptProposedAction()
                return

            margin = 40
            y = pos.y()
            h = self.viewport().height()
            if y < margin:
                self._drag_scroll_speed = -1
                self._drag_scroll_timer.setInterval(self._drag_scroll_interval)
                self._drag_scroll_timer.start()
            elif y > h - margin:
                self._drag_scroll_speed = 1
                self._drag_scroll_timer.setInterval(self._drag_scroll_interval)
                self._drag_scroll_timer.start()
            else:
                self._drag_scroll_speed = 0
                self._drag_scroll_timer.stop()

            if item_at is not None and self._is_folder_func(item_at):
                rect = self.visualItemRect(item_at)
                folder_row_idx = self.row(item_at)
                folder_id_val  = item_at.data(Qt.UserRole)

                last_child_row = folder_row_idx  # строка последнего ребёнка (или сама папка если 0)
                j = folder_row_idx + 1
                while j < self.count():
                    ni = self.item(j)
                    if self._is_folder_func(ni):
                        break
                    if self._item_in_folder_func(ni):
                        last_child_row = j
                        j += 1
                    else:
                        break
                has_visible_children = last_child_row > folder_row_idx

                top_threshold    = rect.top() + rect.height() // 4
                bottom_threshold = rect.top() + (rect.height() * 3 // 4)

                if pos.y() <= top_threshold:
                    if dragging_folder:
                        self._intended_drop_row = folder_row_idx
                        self._drop_context = 'normal'
                        self.viewport().unsetCursor()
                        self._set_indicator(folder_row_idx, folder_row=-1, deny_row=-1)
                    else:
                        self._intended_drop_row = folder_row_idx
                        self._drop_context = 'above_folder_outside'  # явно снаружи
                        self.viewport().unsetCursor()
                        self._set_indicator(folder_row_idx, folder_row=-1, deny_row=-1)
                elif pos.y() <= bottom_threshold:
                    if dragging_folder:
                        self._intended_drop_row = -1
                        self._drop_context = 'deny'
                        self._set_indicator(-1, folder_row=-1, deny_row=-1)
                        self.viewport().setCursor(Qt.ForbiddenCursor)
                        event.ignore()
                        return
                    else:
                        self._intended_drop_row = -2  # в конец папки
                        self._drop_context = 'into_folder'
                        self._intended_folder_row = folder_row_idx
                        self.viewport().unsetCursor()
                        self._set_indicator(-1, folder_row=folder_row_idx, deny_row=-1)
                else:
                    if dragging_folder:
                        if has_visible_children:
                            self._intended_drop_row = -1
                            self._drop_context = 'deny'
                            self._set_indicator(-1, folder_row=-1, deny_row=-1)
                            self.viewport().setCursor(Qt.ForbiddenCursor)
                            event.ignore()
                            return
                        else:
                            target_row = folder_row_idx + 1
                            self._intended_drop_row = target_row
                            self._drop_context = 'normal'
                            self.viewport().unsetCursor()
                            self._set_indicator(target_row, folder_row=-1, deny_row=-1)
                    else:
                        if has_visible_children:
                            target_row = folder_row_idx + 1
                            self._drop_context = 'top_of_child'   # первый ребёнок = в папку
                        else:
                            target_row = folder_row_idx + 1
                            self._drop_context = 'normal'
                        self._intended_drop_row = target_row
                        self.viewport().unsetCursor()
                        self._set_indicator(target_row, folder_row=-1, deny_row=-1)
            elif item_at is None:
                real_count = self.count() - (1 if self._spacer_item is not None else 0)
                self._intended_drop_row = real_count
                self._drop_context = 'end_of_list'
                self.viewport().unsetCursor()
                self._set_indicator(real_count, folder_row=-1, deny_row=-1)
            else:
                if dragging_folder and self._item_in_folder_func(item_at):
                    self._intended_drop_row = -1
                    self._drop_context = 'deny'
                    self._set_indicator(-1, folder_row=-1, deny_row=-1)
                    self.viewport().setCursor(Qt.ForbiddenCursor)
                    event.ignore()
                    return
                row = self.row(item_at)
                rect = self.visualItemRect(item_at)
                is_child = self._item_in_folder_func(item_at)
                in_bottom_half = pos.y() > rect.top() + rect.height() // 2
                if in_bottom_half:
                    row += 1
                self._intended_drop_row = row
                # Явный контекст: где именно курсор относительно папки
                if is_child and not in_bottom_half:
                    self._drop_context = 'top_of_child'    # верхняя часть ребёнка → в папку
                elif is_child and in_bottom_half:
                    # Проверяем: следующий элемент тоже ребёнок той же папки?
                    next_i = self.item(row)  # row уже +1
                    next_is_same_child = (
                        next_i is not None
                        and not self._is_folder_func(next_i)
                        and self._item_in_folder_func(next_i)
                    )
                    if next_is_same_child:
                        self._drop_context = 'between_children'   # между детьми папки
                    else:
                        self._drop_context = 'end_of_folder'      # конец папки → внутрь
                else:
                    # Свободный элемент: верхняя ½ → снаружи, нижняя ½ → normal
                    if not in_bottom_half:
                        self._drop_context = 'top_of_free'
                    else:
                        self._drop_context = 'normal'
                self.viewport().unsetCursor()
                self._set_indicator(row, folder_row=-1, deny_row=-1)

            event.acceptProposedAction()

    def dragLeaveEvent(self, event):
        self._set_indicator(-1, folder_row=-1, deny_row=-1)
        self.viewport().unsetCursor()
        self._drag_scroll_timer.stop()
        # Не вызываем super().dragLeaveEvent — он сбрасывает selection во время drag
        if not self._is_dragging:
            super().dragLeaveEvent(event)
        
    def _do_drag_scroll(self):
        bar = self.verticalScrollBar()
        if self._drag_scroll_speed > 0:
            bar.triggerAction(bar.SliderSingleStepAdd)
        else:
            bar.triggerAction(bar.SliderSingleStepSub)

    def dropEvent(self, event):
        self._drag_scroll_timer.stop()
        self.viewport().unsetCursor()
        if self._deny_hover_row >= 0:
            self._set_indicator(-1, folder_row=-1, deny_row=-1)
            event.ignore()
            return
        if self._folder_hover_row >= 0:
            folder_item = self.item(self._folder_hover_row)
            self._drop_onto_folder_id = folder_item.data(Qt.UserRole) if folder_item else None
        else:
            self._drop_onto_folder_id = None
        self._saved_intended_drop_row = self._intended_drop_row
        self._saved_intended_folder_row = getattr(self, '_intended_folder_row', -1)
        self._saved_drop_context = getattr(self, '_drop_context', 'normal')
        self._intended_drop_row = -1
        self._drop_context = 'normal' 
        self._set_indicator(-1, folder_row=-1, deny_row=-1)
        if event.source() in self._external_sources:
            self.viewport().unsetCursor()
            self._set_indicator(-1, folder_row=-1, deny_row=-1)
            if event.dropAction() == Qt.IgnoreAction:
                event.ignore()
                return
            self.external_drop.emit(event.source())
            event.acceptProposedAction()
        else:
            if self._all_categories_mode_func() and not getattr(self, '_is_categories_list', False):
                self._set_indicator(-1, folder_row=-1, deny_row=-1)
                event.ignore()
                return
            if self._search_active_func():
                self._set_indicator(-1, folder_row=-1, deny_row=-1)
                event.ignore()
                return
            # Блокируем drop только если он не даст реального перемещения.
            # Qt при InternalMove ломает виджет под курсором даже без реального сдвига.
            target_item = self.itemAt(event.pos())
            if target_item is not None and target_item.data(Qt.UserRole) != '__drag_spacer__':
                target_row = self.row(target_item)
                sel_rows = {idx.row() for idx in self.selectedIndexes()}
                rect = self.visualItemRect(target_item)
                in_bottom_half = event.pos().y() > rect.top() + rect.height() // 2
                # insert_row — строка ПЕРЕД которой Qt вставит блок
                insert_row = target_row + (1 if in_bottom_half else 0)
                sel_sorted = sorted(sel_rows)
                if sel_sorted:
                    # Бессмысленна вставка если insert_row находится между
                    # двумя подряд идущими выделенными строками — элементы уже там.
                    # Пример: sel=[2,3,4], insert_row=3 или 4 → ничего не изменится.
                    # НО: sel=[0,1490], insert_row=0 → нужно разрешить (перемещаем 1490 наверх)
                    # Алгоритм: после виртуального удаления sel_rows и вставки перед insert_row,
                    # проверяем изменился бы порядок. Упрощённо:
                    # блокируем если insert_row строго внутри непрерывного блока sel_sorted
                    # И insert_row-1 тоже в sel_sorted (т.е. это не граница блока).
                    would_be_noop = (
                        insert_row in sel_rows
                        and (insert_row - 1) in sel_rows
                    )
                    if would_be_noop:
                        event.ignore()
                        return
            # Запоминаем item_id до drop — Qt при InternalMove иногда дублирует
            dragged_id = self._last_dragged_data
            super().dropEvent(event)

            # После super().dropEvent при multi-drag Qt может оставить:
            # 1) Дубликаты перемещённых элементов
            # 2) Пустые строки (без UserRole / без виджета) — визуальный мусор
            # Сначала находим все дубли итерацией вперёд (первое вхождение = старая позиция)
            seen_ids = set()
            rows_to_delete = []
            for i in range(self.count()):
                it = self.item(i)
                if it is None:
                    rows_to_delete.append(i)
                    continue
                uid = it.data(Qt.UserRole)
                if uid is None or uid == '' or uid == '__drag_spacer__':
                    rows_to_delete.append(i)
                    continue
                if uid in seen_ids:
                    rows_to_delete.append(i)  # это первое (старое) вхождение
                    continue
                seen_ids.add(uid)

            for i in sorted(rows_to_delete, reverse=True):
                self.takeItem(i)

            self.dropped.emit()
            
    def keyboardSearch(self, search):
        if self._keyboard_search_enabled:
            super().keyboardSearch(search)

    def wheelEvent(self, event):
        super().wheelEvent(event)


def _resolve_display_value(db, fd: dict, val) -> str:
    """Конвертирует ID(ы) значения в читаемую строку для select/marks."""
    if not val:
        return None
    ftype = fd.get('field_type', '')
    fid = fd.get('id')
    if ftype == 'select':
        return db.resolve_option_labels(fid, val, 'select') if fid else None
    elif ftype == 'marks':
        resolved = db.resolve_option_labels(fid, val, 'marks') if fid else None
        if resolved:
            try:
                labels = json.loads(resolved)
                return ', '.join(labels) if labels else None
            except Exception:
                pass
        return None
    return str(val)


def _smooth_scale_pixmap(path: str, size: int) -> 'QPixmap':
    """Загрузка иконки через Qt с учётом _APP_SCALE для чёткости."""
    sc = _get_dpr()
    phys = round(size * sc)
    pix = QPixmap(path)
    if pix.isNull():
        return pix
    result = pix.scaled(phys, phys, Qt.KeepAspectRatio, Qt.SmoothTransformation)
    result.setDevicePixelRatio(sc)
    return result

_ICON_PIXMAP_CACHE: dict = {}
_TEXT_WIDTH_CACHE:  dict = {}   # (font_key, text) -> int pixel width


def _is_plain_symbol(icon_str: str) -> bool:
    """Возвращает True если icon_str — обычная буква/символ (не эмодзи, не file:).
    Логика совпадает с отображением в списке кастомных полей: len == 1 и ord < 0x2000."""
    if not icon_str or icon_str.startswith("file:"):
        return False
    return len(icon_str) == 1 and ord(icon_str) < 0x2000


def _is_colored_emoji(ch: str) -> bool:
    """True если символ — цветное эмодзи (не типографский символ вроде ✓ → ★)."""
    if not ch:
        return False
    cp = ord(ch[0])
    if cp > 0xFFFF:
        return True   # Supplementary plane — всегда эмодзи
    if len(ch) > 1:
        return True   # ZWJ sequence, флаг и т.д.
    # Misc Technical U+2300-U+23FF: часть — эмодзи (⌚⌛⏰⏱⏲⏳ и др.)
    if cp in {0x231A, 0x231B, 0x23E9, 0x23EA, 0x23EB, 0x23EC, 0x23ED, 0x23EE,
              0x23EF, 0x23F0, 0x23F1, 0x23F2, 0x23F3, 0x23F8, 0x23F9, 0x23FA}:
        return True
    # Enclosed Alphanumerics U+2460-U+24FF (①②③ и т.д.) — эмодзи
    if 0x2460 <= cp <= 0x24FF:
        return True
    # Misc Symbols U+2600-U+26FF (☀☁☂☃☄ и т.д.) — эмодзи
    if 0x2600 <= cp <= 0x26FF:
        return True
    # Из Dingbats U+2700-U+27BF исключаем типографские:
    # ✓✗✘ (2713-2718), →← стрелки — НЕ эмодзи
    if 0x2700 <= cp <= 0x27BF:
        EMOJI_DINGBATS = {0x2702, 0x2705, 0x2708, 0x2709, 0x270A, 0x270B,
                          0x270C, 0x270D, 0x270F, 0x2712, 0x2714, 0x2716,
                          0x271D, 0x2721, 0x2728, 0x2733, 0x2734, 0x2744,
                          0x2747, 0x274C, 0x274E, 0x2753, 0x2754, 0x2755,
                          0x2757, 0x2763, 0x2764}
        return cp in EMOJI_DINGBATS
    # Misc Symbols and Arrows U+2B00-U+2BFF
    if 0x2B00 <= cp <= 0x2BFF:
        return True
    if 0xFE00 <= cp <= 0xFE0F:
        return True   # Variation selectors
    return False


def _has_real_text(s: str) -> bool:
    """Возвращает True если строка содержит хотя бы один не-эмодзи символ."""
    if not s:
        return False
    for cluster in _GRAPHEME_RE.findall(s):
        if not _is_colored_emoji(cluster):
            cp = ord(cluster[0]) if cluster else 0
            if cp > 0x20:
                return True
    return False


ROLE_ITEM_ID      = Qt.UserRole          # int  — item id in DB
ROLE_LOADED       = Qt.UserRole + 1      # bool — data has been fetched
ROLE_ITEM_DATA    = Qt.UserRole + 2      # dict — item row from DB
ROLE_USERS        = Qt.UserRole + 3      # list — users for this item
ROLE_CF_DATA      = Qt.UserRole + 4      # list — [(field_row, value), ...]
ROLE_COVER_PIXMAP = Qt.UserRole + 5      # QPixmap|None — loaded cover
ROLE_MIN_WIDTH    = Qt.UserRole + 6      # int|None — minimum content width

# UserRole slots for CategoryListDelegate items
# Qt.UserRole      = category/folder id  (int)
# Qt.UserRole + 1  = icon string         (str)  e.g. '📁', 'file:/path', '🎬'
# Qt.UserRole + 2  = is_folder           (bool)
# Qt.UserRole + 3  = folder_id           (int|None)
# Qt.UserRole + 4  = is_collapsed        (bool)  only meaningful for folders


def _draw_separator(painter, rect, row):
    """Draw a 1px separator at the bottom of every row."""
    pen = QPen(QColor(0x3c, 0x3c, 0x3c))
    pen.setWidthF(1.0)
    pen.setCosmetic(True)
    painter.save()
    painter.setClipping(False)
    painter.setPen(pen)
    painter.translate(rect.bottomLeft())
    painter.drawLine(QPointF(0, 0.5), QPointF(rect.width(), 0.5))
    painter.restore()


class SimpleListDelegate(QStyledItemDelegate):
    """Reusable delegate for plain text lists (Users, Tiers, etc).

    Features:
    - Consistent hover / selected background
    - 1px #3c3c3c separator between rows
    - Respects item foreground color (for colored tier labels)
    - Optional left padding
    """
    PAD_LEFT  = 8
    ROW_H     = 26
    C_HOVER   = QColor(255, 255, 255, 18)
    C_SEP     = QColor(0x3c, 0x3c, 0x3c)
    C_DEFAULT_FG = QColor(255, 255, 255)

    def sizeHint(self, option, index):
        sh = super().sizeHint(option, index)
        return QSize(sh.width(), max(sh.height(), self.ROW_H))

    def paint(self, painter, option, index):
        painter.save()
        painter.setRenderHint(QPainter.Antialiasing)
        painter.setClipRect(option.rect)

        rect = option.rect
        is_sel   = bool(option.state & QStyle.State_Selected)
        is_hover = bool(option.state & QStyle.State_MouseOver)

        # background
        if is_sel:
            painter.fillRect(rect, option.palette.color(option.palette.Highlight))
        elif is_hover:
            painter.fillRect(rect, self.C_HOVER)

        # text — honour item foreground if set (e.g. coloured tier rows)
        fg = index.data(Qt.ForegroundRole)
        if fg is not None:
            if hasattr(fg, 'color'):   # QBrush
                text_color = fg.color()
            elif isinstance(fg, QColor):
                text_color = fg
            else:
                text_color = self.C_DEFAULT_FG
        elif is_sel:
            text_color = option.palette.color(option.palette.HighlightedText)
        else:
            text_color = self.C_DEFAULT_FG

        label = index.data(Qt.DisplayRole) or ''
        painter.setPen(text_color)
        painter.drawText(
            QRect(rect.left() + self.PAD_LEFT, rect.top(),
                  rect.width() - self.PAD_LEFT - 4, rect.height()),
            Qt.AlignVCenter | Qt.AlignLeft | Qt.TextSingleLine,
            label
        )

        # separator
        _draw_separator(painter, rect, index.row())

        painter.restore()


class CategoryListDelegate(QStyledItemDelegate):
    """Pure-QPainter delegate for the categories QListWidget.

    Renders every row itself so that emoji/icon scaling is always correct
    on every DPI / QT_SCALE_FACTOR combination.  The QListWidgetItems carry
    only data (no QIcon / no setText tricks) — the delegate does all drawing.

    Row layout
    ----------
    Folder  (height 28 logical px):
        [4px gap][icon 20×20][4px gap][label … right-truncated][8px][arrow 10px][4px]

    Child category  (height 24 logical px, 20px left indent):
        [24px indent][icon 20×20][4px gap][label …][4px]

    Free category  (height 24 logical px, no indent):
        [4px gap][icon 20×20][4px gap][label …][4px]
    """

    # ── visual constants (logical pixels) ────────────────────────────────────
    HEIGHT_FOLDER   = 28
    HEIGHT_CAT      = 26
    ICON_SIZE       = 18      # square box for emoji / file icon
    ICON_FONT_PT    = 12      # emoji point-size  (logical, no ×sc)
    ARROW_FONT_PT   = 8
    INDENT          = 32      # extra left offset for child categories
    PAD_LEFT        = 12      # gap before icon for folders / free cats
    PAD_MID         = 7       # gap between icon and label
    PAD_RIGHT       = 4

    # ── colours ──────────────────────────────────────────────────────────────
    C_CAT_FG        = QColor(255, 255, 255)
    C_CHILD_BG      = QColor(0x1A, 0x1A, 0x1A)   # background for categories inside folders
    C_HOVER_BG      = QColor(255, 255, 255, 18)
    C_ARROW         = QColor(180, 180, 180)
    C_ICON_TEXT     = QColor(255, 255, 255)
    C_SEPARATOR     = QColor(0x3c, 0x3c, 0x3c)    # 1px row divider

    def __init__(self, parent=None):
        super().__init__(parent)
        self._pix_cache: dict = {}   # (icon_str, size_px_physical) -> QPixmap

    # ------------------------------------------------------------------
    # helpers
    # ------------------------------------------------------------------
    def _row_height(self, is_folder: bool) -> int:
        return self.HEIGHT_FOLDER if is_folder else self.HEIGHT_CAT

    def _get_emoji_pixmap(self, emoji: str, logical_size: int) -> QPixmap:
        """Render an emoji string into a crisp HiDPI pixmap."""
        sc = _get_dpr()
        phys = round(logical_size * sc)
        key = (emoji, phys, sc)
        cached = self._pix_cache.get(key)
        if cached is not None:
            return cached
        pix = QPixmap(phys, phys)
        pix.fill(Qt.transparent)
        pix.setDevicePixelRatio(sc)
        p = QPainter(pix)
        f = QFont()
        f.setPointSizeF(self.ICON_FONT_PT)
        p.setFont(f)
        p.setPen(self.C_ICON_TEXT)
        # draw in logical coords  (painter honours DPR automatically)
        p.drawText(QRect(0, 0, logical_size, logical_size), Qt.AlignCenter, emoji)
        p.end()
        self._pix_cache[key] = pix
        return pix

    def _get_file_pixmap(self, path: str, logical_size: int) -> QPixmap:
        sc = _get_dpr()
        phys = round(logical_size * sc)
        key = ('file', path, phys, sc)
        cached = self._pix_cache.get(key)
        if cached is not None:
            return cached
        pix = _smooth_scale_pixmap(path, logical_size)   # already returns physical-size pix
        self._pix_cache[key] = pix
        return pix

    def invalidate_cache(self):
        self._pix_cache.clear()

    # ------------------------------------------------------------------
    # QStyledItemDelegate interface
    # ------------------------------------------------------------------
    def sizeHint(self, option, index):
        is_folder = bool(index.data(Qt.UserRole + 2))
        h = self._row_height(is_folder)
        # respect animated collapse: item's SizeHint may be overridden externally
        stored = index.data(Qt.SizeHintRole)
        if stored is not None:
            ext_h = stored.height() if isinstance(stored, QSize) else int(stored)
            if ext_h != h:          # animation in progress
                return QSize(option.rect.width() or 200, ext_h)
        return QSize(option.rect.width() or 200, h)

    def paint(self, painter, option, index):
        is_folder   = bool(index.data(Qt.UserRole + 2))
        folder_id   = index.data(Qt.UserRole + 3)
        is_indent   = (not is_folder) and (folder_id is not None)
        is_collapsed = bool(index.data(Qt.UserRole + 4)) if is_folder else False
        icon_str    = index.data(Qt.UserRole + 1) or ''
        label       = index.data(Qt.DisplayRole) or ''

        rect = option.rect
        h    = rect.height()
        if h <= 0:
            return   # collapsed / animating to 0 — skip drawing

        painter.save()
        painter.setRenderHint(QPainter.Antialiasing)
        painter.setClipRect(rect)

        # ── background ────────────────────────────────────────────────
        # Принудительно выставляем State_Active чтобы Qt не убирал State_Selected
        # когда главное окно теряет фокус (открыт модальный диалог).
        option.state |= QStyle.State_Active

        is_selected = bool(option.state & QStyle.State_Selected)
        if not is_selected and option.widget:
            try:
                is_selected = option.widget.selectionModel().isSelected(option.index)
            except Exception:
                pass
        is_hover    = bool(option.state & QStyle.State_MouseOver)

        if is_selected:
            pal_color = option.palette.color(option.palette.Highlight)
            painter.fillRect(rect, pal_color)
        elif is_hover:
            painter.fillRect(rect, self.C_HOVER_BG)

        # ── decide x-start of icon ────────────────────────────────────
        if is_indent:
            icon_x = rect.left() + self.INDENT
        else:
            icon_x = rect.left() + self.PAD_LEFT

        icon_y = rect.center().y() - self.ICON_SIZE // 2

        # ── draw icon ─────────────────────────────────────────────────
        if icon_str.startswith('file:'):
            path = to_absolute_path(icon_str[5:])
            src  = self._get_file_pixmap(path, self.ICON_SIZE)
            if not src.isNull():
                lw = round(src.width()  / (src.devicePixelRatioF() or 1))
                lh = round(src.height() / (src.devicePixelRatioF() or 1))
                dx = (self.ICON_SIZE - lw) // 2
                dy = (self.ICON_SIZE - lh) // 2
                painter.drawPixmap(icon_x + dx, icon_y + dy, lw, lh, src)
        elif icon_str:
            pix = self._get_emoji_pixmap(icon_str, self.ICON_SIZE)
            painter.drawPixmap(QRect(icon_x, icon_y, self.ICON_SIZE, self.ICON_SIZE), pix)

        # ── label ──────────────────────────────────────────────────────
        label_x = icon_x + self.ICON_SIZE + self.PAD_MID
        # reserve space for arrow in folders
        arrow_w = 18 if is_folder else 0
        label_w = rect.right() - label_x - self.PAD_RIGHT - arrow_w
        label_rect = QRect(label_x, rect.center().y() - h // 2, label_w, h)

        if is_folder:
            f = QFont()
            f.setBold(not is_collapsed)
            painter.setFont(f)
            painter.setPen(self.C_CAT_FG if not is_selected else
                           option.palette.color(option.palette.HighlightedText))
        else:
            painter.setFont(QFont())
            painter.setPen(self.C_CAT_FG if not is_selected else
                           option.palette.color(option.palette.HighlightedText))

        painter.drawText(label_rect,
                         Qt.AlignVCenter | Qt.AlignLeft | Qt.TextSingleLine,
                         label)

        # ── arrow for folder ──────────────────────────────────────────
        if is_folder:
            painter.setRenderHint(QPainter.Antialiasing)
            painter.setPen(Qt.NoPen)
            painter.setBrush(self.C_ARROW)
            cx = rect.right() - arrow_w // 2 - self.PAD_RIGHT + 1
            cy = rect.center().y() + 1
            path = QPainterPath()
            if is_collapsed:
                # right-pointing triangle
                s = 3.5
                path.moveTo(cx - s * 0.6, cy - s)
                path.lineTo(cx + s * 0.8, cy)
                path.lineTo(cx - s * 0.6, cy + s)
            else:
                # down-pointing triangle (same as before but drawn, not text)
                s = 3.5
                path.moveTo(cx - s, cy - s * 0.6)
                path.lineTo(cx,     cy + s * 0.8)
                path.lineTo(cx + s, cy - s * 0.6)
            path.closeSubpath()
            painter.drawPath(path)

        # ── separator ─────────────────────────────────────────────────
        _draw_separator(painter, rect, index.row())

        painter.restore()



class SearchWorker(QThread):
    """Фильтрация в фоновом потоке — не блокирует UI при 50k+ записей."""
    # Передаём только индексы видимых строк — не весь список булевых
    result_ready = pyqtSignal(object, int, str)  # set(visible_indices), count, text

    def __init__(self, parent=None):
        super().__init__(parent)
        self._store     = []
        self._predicate = None
        self._text      = ''
        self._cancel_event = threading.Event()

    def start_search(self, store, predicate, text):
        # Отменяем предыдущий прогон — НЕ ждём его (нет wait())
        self._cancel_event.set()
        self._store     = store
        self._predicate = predicate
        self._text      = text
        self._cancel_event.clear()
        if not self.isRunning():
            self.start()

    def run(self):
        while True:
            store     = self._store
            predicate = self._predicate
            text      = self._text
            self._cancel_event.clear()

            visible_ids = []
            count = 0
            cancelled = False
            for i, entry in enumerate(store):
                if self._cancel_event.is_set():
                    cancelled = True
                    break
                if predicate(entry):
                    visible_ids.append(i)
                    count += 1

            if not cancelled:
                self.result_ready.emit(visible_ids, count, text)
                # Ждём следующего задания
                self._cancel_event.wait()
                if not self._store:
                    break


class MediaItemListView(QListView):
    """QListView для списка фильмов с кастомным drop-indicator (белая линия)
    и правильным поведением drag&drop — только AboveItem/BelowItem, не OnItem."""

    dropped = pyqtSignal()  # сигнал после успешного внутреннего drop

    def __init__(self, parent=None):
        super().__init__(parent)
        self._indicator_y    = -1   # y-координата белой линии, -1 = скрыта
        self._is_dragging    = False
        self._search_active_func        = lambda: False
        self._all_categories_mode_func  = lambda: False
        self._drag_scroll_dir  = 0   # -1 вверх, 0 стоп, 1 вниз
        self._drag_scroll_timer = QTimer(self)
        self._drag_scroll_timer.setInterval(60)
        self._drag_scroll_timer.timeout.connect(self._do_drag_scroll)
        self._bg_pixmap        = None
        self._bg_overlay       = 0.65
        self._bg_cache         = None
        self._bg_cache_size    = None
        self._bg_cache_offset  = (0, 0)

    @staticmethod
    def _screen_cap():
        screen = QApplication.primaryScreen()
        if screen:
            dpr  = screen.devicePixelRatio()
            size = screen.size()
            return int(size.width() * dpr), int(size.height() * dpr)
        return 1920, 1080

    def _rebuild_bg_cache(self):
        if not self._bg_pixmap:
            self._bg_cache      = None
            self._bg_cache_size = None
            return
        dpr    = _get_dpr()
        full_w = self.frameRect().width()
        full_h = self.frameRect().height()
        phys_w = round(full_w * dpr)
        phys_h = round(full_h * dpr)
        if phys_w <= 0 or phys_h <= 0:
            return
        scaled = self._bg_pixmap.scaled(
            phys_w, phys_h,
            Qt.KeepAspectRatioByExpanding,
            Qt.SmoothTransformation)
        scaled.setDevicePixelRatio(dpr)
        # Вычисляем смещение для центрирования (scaled может быть шире/выше viewport)
        lw = scaled.width()  / dpr
        lh = scaled.height() / dpr
        ox = int((full_w - lw) / 2)
        oy = int((full_h - lh) / 2)
        if self._bg_overlay > 0:
            p = QPainter(scaled)
            p.fillRect(scaled.rect(), QColor(0, 0, 0, int(self._bg_overlay * 255)))
            p.end()
        self._bg_cache         = scaled
        self._bg_cache_size    = QSize(full_w, full_h)
        self._bg_cache_offset  = (ox, oy)

    def set_category_bg(self, abs_path, overlay):
        self._bg_overlay    = max(0.0, min(1.0, overlay))
        self._bg_cache      = None
        self._bg_cache_size = None
        if abs_path and os.path.exists(abs_path):
            raw = QPixmap(abs_path)
            if raw.isNull():
                self._bg_pixmap = None
            else:
                cap_w, cap_h = self._screen_cap()
                if raw.width() > cap_w or raw.height() > cap_h:
                    self._bg_pixmap = raw.scaled(
                        cap_w, cap_h,
                        Qt.KeepAspectRatioByExpanding,
                        Qt.SmoothTransformation)
                else:
                    self._bg_pixmap = raw
        else:
            self._bg_pixmap = None
        self._rebuild_bg_cache()
        self.viewport().update()

    def clear_category_bg(self):
        self._bg_pixmap     = None
        self._bg_cache      = None
        self._bg_cache_size = None
        self.viewport().update()

    def resizeEvent(self, event):
        super().resizeEvent(event)
        if self._bg_pixmap:
            new_size = QSize(self.frameRect().width(), self.frameRect().height())
            if new_size != self._bg_cache_size:
                self._rebuild_bg_cache()

    # ── auto scroll ───────────────────────────────────────────────────────

    def _do_drag_scroll(self):
        sb = self.verticalScrollBar()
        if self._drag_scroll_dir < 0:
            sb.setValue(sb.value() - 1)
        elif self._drag_scroll_dir > 0:
            sb.setValue(sb.value() + 1)
        else:
            self._drag_scroll_timer.stop()

    # ── drop indicator painting ────────────────────────────────────────────

    def _set_indicator(self, y: int):
        if y != self._indicator_y:
            self._indicator_y = y
            self.viewport().update()

    def paintEvent(self, event):
        if self._bg_cache:
            p = QPainter(self.viewport())
            ox, oy = self._bg_cache_offset
            p.drawPixmap(ox, oy, self._bg_cache)
            p.end()
        super().paintEvent(event)
        if self._indicator_y < 0:
            return
        painter = QPainter(self.viewport())
        painter.setPen(QPen(QColor(255, 255, 255), 1))
        painter.drawLine(0, self._indicator_y, self.viewport().width(), self._indicator_y)
        painter.end()

    # ── drag & drop ────────────────────────────────────────────────────────

    def _indicator_y_for_pos(self, pos):
        """Вернуть y линии и proxy_row куда вставим — AboveItem или BelowItem."""
        idx = self.indexAt(pos)
        if idx.isValid():
            rect = self.visualRect(idx)
            if pos.y() < rect.top() + rect.height() // 2:
                return rect.top(), idx.row()        # вставка ДО этого элемента
            else:
                return rect.bottom(), idx.row() + 1 # вставка ПОСЛЕ этого элемента
        # Ниже всех элементов
        model = self.model()
        if model and model.rowCount() > 0:
            last_rect = self.visualRect(model.index(model.rowCount() - 1, 0))
            return last_rect.bottom(), model.rowCount()
        return -1, 0

    def dragEnterEvent(self, event):
        if event.source() is self:
            self._is_dragging = True
            event.acceptProposedAction()
        else:
            super().dragEnterEvent(event)

    def dragMoveEvent(self, event):
        if event.source() is self:
            if self._all_categories_mode_func():
                self._set_indicator(-1)
                event.ignore()
                return
            y, _ = self._indicator_y_for_pos(event.pos())
            self._set_indicator(y)
            # Автоскролл по таймеру
            pos_y  = event.pos().y()
            vp_h   = self.viewport().height()
            margin = 40
            if pos_y < margin:
                self._drag_scroll_dir = -1
                if not self._drag_scroll_timer.isActive():
                    self._drag_scroll_timer.start()
            elif pos_y > vp_h - margin:
                self._drag_scroll_dir = 1
                if not self._drag_scroll_timer.isActive():
                    self._drag_scroll_timer.start()
            else:
                self._drag_scroll_dir = 0
                self._drag_scroll_timer.stop()
            event.acceptProposedAction()
        else:
            super().dragMoveEvent(event)

    def dragLeaveEvent(self, event):
        self._set_indicator(-1)
        self._is_dragging = False
        self._drag_scroll_dir = 0
        self._drag_scroll_timer.stop()
        super().dragLeaveEvent(event)

    def dropEvent(self, event):
        self._set_indicator(-1)
        self._is_dragging = False
        self._drag_scroll_dir = 0
        self._drag_scroll_timer.stop()

        if self._all_categories_mode_func():
            event.ignore()
            return

        if event.source() is not self:
            super().dropEvent(event)
            return

        _, insert_proxy_row = self._indicator_y_for_pos(event.pos())
        proxy     = self.model()
        src_model = proxy.sourceModel() if hasattr(proxy, 'sourceModel') else proxy

        # Собираем перетаскиваемые proxy rows → ids
        sel_proxy_rows = sorted(set(i.row() for i in self.selectionModel().selectedIndexes()))
        dragged_ids = []
        for pr in sel_proxy_rows:
            src_idx = proxy.mapToSource(proxy.index(pr, 0)) if hasattr(proxy, 'mapToSource') else proxy.index(pr, 0)
            iid = src_model._ids[src_idx.row()] if src_idx.isValid() and src_idx.row() < len(src_model._ids) else None
            if iid is not None:
                dragged_ids.append(iid)

        if not dragged_ids:
            event.ignore()
            return

        # Определяем соседей в видимом списке — между ними вставляем в полном _all_ids
        # Элемент ПЕРЕД которым вставляем (в proxy)
        if insert_proxy_row < proxy.rowCount():
            ins_src = proxy.mapToSource(proxy.index(insert_proxy_row, 0)) if hasattr(proxy, 'mapToSource') else proxy.index(insert_proxy_row, 0)
            anchor_id_after = src_model._ids[ins_src.row()] if ins_src.isValid() and ins_src.row() < len(src_model._ids) else None
        else:
            anchor_id_after = None  # вставка в конец видимого списка

        # Проверяем no-op: элемент уже на нужной позиции
        dragged_set = set(dragged_ids)
        ids = src_model._ids
        insert_idx = ids.index(anchor_id_after) if anchor_id_after and anchor_id_after in ids else len(ids)
        positions = [ids.index(iid) for iid in dragged_ids if iid in ids]
        # Если anchor — один из перетаскиваемых, ищем следующий не-dragged
        if anchor_id_after in dragged_set:
            try:
                anchor_pos = ids.index(anchor_id_after)
            except ValueError:
                anchor_pos = len(ids)
            anchor_id_after = None
            for iid in ids[anchor_pos + 1:]:
                if iid not in dragged_set:
                    anchor_id_after = iid
                    break

        # Работаем с _all_ids и _all_store (полный список)
        all_ids   = src_model._all_ids
        all_store = src_model._all_store

        # Удаляем перетаскиваемые из all_ids
        dragged_set = set(dragged_ids)
        dragged_entries = []
        for iid in dragged_ids:
            try:
                idx = all_ids.index(iid)
                dragged_entries.append((iid, all_store[idx] if idx < len(all_store) else None))
            except ValueError:
                dragged_entries.append((iid, None))

        for iid in dragged_ids:
            try:
                idx = all_ids.index(iid)
                all_ids.pop(idx)
                if idx < len(all_store):
                    all_store.pop(idx)
            except ValueError:
                pass

        # Находим позицию вставки в all_ids по anchor_id_after
        if anchor_id_after is not None and anchor_id_after not in dragged_set:
            try:
                insert_all_row = all_ids.index(anchor_id_after)
            except ValueError:
                insert_all_row = len(all_ids)
        else:
            insert_all_row = len(all_ids)

        # Вставляем в all_ids/_all_store
        for i, (iid, entry) in enumerate(dragged_entries):
            all_ids.insert(insert_all_row + i, iid)
            if entry is not None:
                all_store.insert(insert_all_row + i, entry)

        # Пересобираем _ids/_store (видимые) из обновлённого _all_ids
        if proxy._visible:
            # Поиск активен — пересобираем видимые сохраняя порядок из all_ids
            visible_set = set(src_model._ids) | dragged_set
            src_model.beginResetModel()
            src_model._ids   = [iid for iid in all_ids if iid in visible_set]
            src_model._store = [all_store[all_ids.index(iid)] for iid in src_model._ids]
            src_model.endResetModel()
        else:
            # Без поиска — видимые == все
            src_model.beginResetModel()
            src_model._ids   = list(all_ids)
            src_model._store = list(all_store)
            src_model.endResetModel()

        # Восстанавливаем выделение
        sel_model = self.selectionModel()
        sel_model.clearSelection()
        for iid in dragged_ids:
            try:
                src_row = src_model._ids.index(iid)
                pidx = proxy.mapFromSource(src_model.index(src_row, 0)) if hasattr(proxy, 'mapFromSource') else src_model.index(src_row, 0)
                if pidx.isValid():
                    sel_model.select(pidx, sel_model.Select)
            except ValueError:
                pass

        event.acceptProposedAction()
        self.dropped.emit()


class MediaItemModel(QAbstractListModel):
    """Модель списка фильмов. Хранит item_ids и ссылку на _items_store.
    Делегат читает данные из item_store[row] — O(1), без QListWidgetItem."""

    def __init__(self, parent=None):
        super().__init__(parent)
        self._ids:      list = []   # текущий (возможно отфильтрованный) список item_id
        self._store:    list = []   # текущий (возможно отфильтрованный) store
        self._all_ids:  list = []   # полный список item_id (не меняется при фильтрации)
        self._all_store: list = []  # полный store (не меняется при фильтрации)
        self._row_h: int  = MediaItemDelegate.NORMAL_HEIGHT

    # ── базовые методы QAbstractListModel ──────────────────────────────────

    def rowCount(self, parent=QModelIndex()):
        return 0 if parent.isValid() else len(self._ids)

    def data(self, index, role=Qt.DisplayRole):
        if not index.isValid():
            return None
        row = index.row()
        if row < 0 or row >= len(self._ids):
            return None
        if role == ROLE_ITEM_ID:
            return self._ids[row]
        if role == Qt.SizeHintRole:
            return QSize(0, self._row_h)
        # Делегат читает из item_store напрямую — не через data()
        # Но оставляем fallback для совместимости
        if self._store and row < len(self._store):
            entry = self._store[row]
            if role == ROLE_ITEM_DATA:    return entry[0] if entry else None
            if role == ROLE_USERS:        return entry[1] if entry else []
            if role == ROLE_CF_DATA:      return entry[2] if entry else []
            if role == ROLE_COVER_PIXMAP: return entry[3] if entry else None
        return None

    def flags(self, index):
        if not index.isValid():
            return Qt.ItemIsDropEnabled
        return (Qt.ItemIsEnabled | Qt.ItemIsSelectable |
                Qt.ItemIsDragEnabled | Qt.ItemIsDropEnabled)

    # ── drag & drop ────────────────────────────────────────────────────────

    def supportedDropActions(self):
        return Qt.MoveAction | Qt.CopyAction

    def mimeTypes(self):
        return ['application/x-mediaitem-rows']

    def mimeData(self, indexes):
        mime = QMimeData()
        rows = sorted(set(i.row() for i in indexes if i.isValid()))
        data = ','.join(str(r) for r in rows)
        mime.setData('application/x-mediaitem-rows', data.encode())
        return mime

    def dropMimeData(self, mime, action, row, col, parent):
        if not mime.hasFormat('application/x-mediaitem-rows'):
            return False
        src_rows = [int(x) for x in mime.data('application/x-mediaitem-rows').data().decode().split(',') if x]
        if not src_rows:
            return False
        dest = row if row >= 0 else self.rowCount()
        # Move rows in _ids and _store
        entries = [(self._ids[r], self._store[r] if r < len(self._store) else None) for r in src_rows]
        # Remove from bottom to top
        for r in sorted(src_rows, reverse=True):
            self._ids.pop(r)
            if r < len(self._store):
                self._store.pop(r)
            if r < dest:
                dest -= 1
        self.beginResetModel()
        for i, (iid, entry) in enumerate(entries):
            self._ids.insert(dest + i, iid)
            if entry is not None:
                self._store.insert(dest + i, entry)
        self.endResetModel()
        return True

    # ── публичный API ──────────────────────────────────────────────────────

    def reset_data(self, ids: list, store: list, row_h: int):
        """Полная замена данных (аналог clear + addItems)."""
        self.beginResetModel()
        self._ids      = list(ids)
        self._store    = store
        self._all_ids  = list(ids)    # полный список — не меняется при фильтрации
        self._all_store = store       # ссылка на полный store
        self._row_h    = row_h
        self.endResetModel()

    def set_row_height(self, h: int):
        if h != self._row_h:
            self._row_h = h
            if self._ids:
                self.dataChanged.emit(
                    self.index(0), self.index(len(self._ids) - 1), [Qt.SizeHintRole])

    def item_id(self, row: int):
        return self._ids[row] if 0 <= row < len(self._ids) else None

    def row_for_id(self, item_id) -> int:
        try:
            return self._ids.index(item_id)
        except ValueError:
            return -1

    def remove_row_by_id(self, item_id) -> bool:
        row = self.row_for_id(item_id)
        if row < 0:
            return False
        self.beginRemoveRows(QModelIndex(), row, row)
        self._ids.pop(row)
        if row < len(self._store):
            self._store.pop(row)
        # Также удаляем из полных списков
        try:
            all_row = self._all_ids.index(item_id)
            self._all_ids.pop(all_row)
            if all_row < len(self._all_store):
                self._all_store.pop(all_row)
        except ValueError:
            pass
        self.endRemoveRows()
        return True

    def append_id(self, item_id, entry, row_h=None):
        r = len(self._ids)
        self.beginInsertRows(QModelIndex(), r, r)
        self._ids.append(item_id)
        self._store.append(entry)
        self._all_ids.append(item_id)
        if entry not in self._all_store:
            self._all_store.append(entry)
        if row_h is not None:
            self._row_h = row_h
        self.endInsertRows()


class MediaItemProxyModel(QSortFilterProxyModel):
    """Proxy-модель для мгновенной фильтрации поиском.
    Хранит bitarray видимости — filterAcceptsRow за O(1)."""

    def __init__(self, parent=None):
        super().__init__(parent)
        self._visible: list = []   # list[bool], индексируется по source row
        self.setDynamicSortFilter(False)

    def set_visibility(self, visible_indices, view=None):
        """Меняем _ids модели — только видимые строки по их индексам.
        None = показать все, [] = нет результатов, [1,2,...] = видимые индексы."""
        src = self.sourceModel()
        src.beginResetModel()
        if visible_indices is None:
            # Сброс поиска — показать всё
            src._ids   = src._all_ids
            src._store = src._all_store
        else:
            # Фильтр активен — показываем только matching (может быть 0)
            all_ids   = src._all_ids
            all_store = src._all_store
            src._ids   = [all_ids[i]   for i in visible_indices]
            src._store = [all_store[i] for i in visible_indices]
        src.endResetModel()
        self._visible = visible_indices

    def filterAcceptsRow(self, source_row, source_parent):
        return True  # фильтрация через _ids — proxy пропускает всё

    def map_to_source_row(self, proxy_row: int) -> int:
        # Без proxy — proxy_row == source_row
        return proxy_row

    def map_from_source_row(self, source_row: int) -> int:
        return source_row



class MediaItemDelegate(QStyledItemDelegate):
    """Делегат що рендерить рядки через реальні QWidget (ItemWidget/CompactItemWidget).

    Замість QPainter.drawText використовується widget.render() — завдяки цьому
    шрифти виглядають ідентично оригіналу (той самий subpixel hinting що і QLabel).

    Віджети НЕ додаються в layout і НЕ є дочірніми QListWidget — вони існують
    лише як offscreen буфери. Один екземпляр на рядок НЕ створюється — натомість
    використовується LRU-кеш з фіксованою кількістю слотів.
    """

    NORMAL_HEIGHT  = 85
    COMPACT_HEIGHT = 28
    COVER_W = 50
    COVER_H = 75

    COLOR_BG_HOVER    = QColor(0x3c, 0x3c, 0x3c)
    COLOR_BG_SELECTED = QColor(0x55, 0x55, 0x55)
    COLOR_BORDER      = QColor(0x3c, 0x3c, 0x3c)
    COLOR_TEXT        = QColor(0xff, 0xff, 0xff)
    COLOR_DETAIL      = QColor(0xaa, 0xaa, 0xaa)
    COLOR_COVER_BG    = QColor(0x3c, 0x3c, 0x3c)
    COLOR_COVER_BORDER= QColor(0x55, 0x55, 0x55)

    _FONT_TITLE:          QFont = None
    _FONT_DETAILS:        QFont = None
    _FONT_COMPACT_TITLE:  QFont = None
    _FONT_COMPACT_DETAILS:QFont = None

    def __init__(self, parent=None, compact=False, translations=None, db=None, item_store=None, main_window=None):
        super().__init__(parent)
        self.compact      = compact
        self.translations = translations or {}
        self.db           = db
        self.item_store   = item_store
        self.main_window  = main_window
        self._cat_icon_cache = {}
        self.has_bg       = False  # True когда у категории есть фоновое изображение
        self._build_fonts()

    def _get_cat_info(self, category_id):
        """Вернуть (name, icon_str) для категории по ID. Кэшируется."""
        if not self.db or not category_id:
            return None, None
        if not hasattr(self, '_cat_info_cache'):
            self._cat_info_cache = {}
        if category_id not in self._cat_info_cache:
            c = self.db.conn.cursor()
            c.execute('SELECT name, icon FROM categories WHERE id = ?', (category_id,))
            row = c.fetchone()
            if row:
                self._cat_info_cache[category_id] = (row[0], row[1])
            else:
                self._cat_info_cache[category_id] = (None, None)
        return self._cat_info_cache[category_id]

    def invalidate_cat_cache(self):
        """Сбросить кэш категорий (при переключении режима или смене категорий)."""
        self._cat_info_cache = {}
        self._cat_icon_cache = {}

    def _render_cat_icon(self, icon_str, size=14):
        """Рендерить иконку категории в QPixmap. Кэшируется по icon_str+size."""
        key = (icon_str, size)
        if key in self._cat_icon_cache:
            return self._cat_icon_cache[key]
        pix = None
        if icon_str and icon_str.startswith('file:'):
            abs_p = to_absolute_path(icon_str[5:])
            src = QPixmap(abs_p)
            if not src.isNull():
                sc   = _get_dpr()
                phys = round(size * sc)
                pix  = src.scaled(phys, phys, Qt.KeepAspectRatio, Qt.SmoothTransformation)
                pix.setDevicePixelRatio(sc)
        if pix is None:
            _fsize = max(6, (max(9, size - 2) * 72) // 96)
            pix = render_emoji_pixmap(icon_str or '🏷', size, _fsize)
        self._cat_icon_cache[key] = pix
        return pix

    @classmethod
    def _build_fonts(cls):
        cls._FONT_TITLE = QFont("Segoe UI")
        cls._FONT_TITLE.setPixelSize(14)
        cls._FONT_TITLE.setBold(True)
        cls._FONT_DETAILS = QFont()
        cls._FONT_DETAILS.setPixelSize(11)
        cls._FONT_COMPACT_TITLE = QFont()
        cls._FONT_COMPACT_TITLE.setPixelSize(12)
        cls._FONT_COMPACT_TITLE.setBold(True)
        cls._FONT_COMPACT_DETAILS = QFont()
        cls._FONT_COMPACT_DETAILS.setPixelSize(11)

    _FM_TITLE:   'QFontMetrics' = None
    _FMF_TITLE:  'QFontMetricsF' = None
    _FM_DETAILS: 'QFontMetrics' = None
    _FMF_DETAILS:'QFontMetricsF' = None

    @classmethod
    def _ensure_fm(cls):
        if cls._FM_TITLE is None:
            if cls._FONT_TITLE is None:
                cls._build_fonts()
            cls._FM_TITLE    = QFontMetrics(cls._FONT_TITLE)
            cls._FM_DETAILS  = QFontMetrics(cls._FONT_DETAILS)
            cls._FMF_TITLE   = QFontMetricsF(cls._FONT_TITLE)
            cls._FMF_DETAILS = QFontMetricsF(cls._FONT_DETAILS)

    @classmethod
    def estimate_row_width(cls, item_data, users, cf_data, db=None):
        """Быстрый расчёт ширины строки. Шрифты/FM кэшированы — создаются один раз."""
        cls._ensure_fm()
        font_title  = cls._FONT_TITLE
        font_details = cls._FONT_DETAILS
        fm_t = cls._FM_TITLE
        fm_d = cls._FM_DETAILS

        def _sw(fm, text):
            return fm.horizontalAdvance(text)

        SPACING = 6
        LEFT    = 5 + 50 + 8
        RIGHT   = 5

        title_raw = str(item_data.get('title', ''))
        title = _display_title(title_raw)

        title_w = _sw(fm_t, title)
        if item_data.get('year') and item_data['year'] != 0:
            title_w += 3 + _sw(fm_d, f"({item_data['year']})")
        if item_data.get('is_favorite'):
            title_w += 3 + _sw(fm_d, "🩷")

        parts = []

        if item_data.get('watch_date'):
            parts.append(_sw(fm_d, f"📅 {_fmt_date(item_data['watch_date'], _DATE_FMT)}"))
        if item_data.get('rating'):
            # Ширина пиксмапа звёзд: 5 звёзд × 12px + 4 зазора × 2px
            parts.append(5 * 11 + 4 * 0)
        view_count = item_data.get('view_count', 1)
        if view_count and view_count > 1:
            parts.append(_sw(fm_d, f"♻️ {view_count}"))
        if item_data.get('time_spent') and item_data['time_spent'] > 0:
            parts.append(_sw(fm_d, f"🕒 {item_data['time_spent']}h"))
        if users:
            users_text = ", ".join(u.get('name','') if isinstance(u, dict) else str(u) for u in users)
            parts.append(_sw(fm_d, '  '))  # невеликий відступ
            parts.append(_sw(fm_d, users_text))

        for fd, val in cf_data:
            fd = dict(fd) if not isinstance(fd, dict) else fd
            if not fd.get('show_in_list') or val is None:
                continue
            ftype = fd.get('field_type', 'string')
            if ftype == 'boolean' and val != '1':
                continue
            if ftype in ('integer', 'slider'):
                try:
                    if int(val) == 0:
                        continue
                except Exception:
                    pass
            use_name = bool(fd.get('show_name_in_list'))
            icon_str = fd.get('icon') or '🧩'
            is_file_icon = icon_str.startswith('file:')
            if use_name:
                if ftype == 'boolean':
                    display = '✓'
                elif ftype in ('marks', 'select'):
                    display = _resolve_display_value(db, fd, val) if db else str(val)
                    if not display:
                        continue
                else:
                    display = str(val)
                parts.append(_sw(fm_d, fd.get('name','') + ':') + 3 + _sw(fm_d, display))
            else:
                if is_file_icon:
                    parts.append(14 + 3)
                    if ftype == 'boolean':
                        parts.append(_sw(fm_d, '✓'))
                    elif ftype in ('marks', 'select'):
                        display = _resolve_display_value(db, fd, val) if db else str(val)
                        if not display:
                            continue
                        parts.append(_sw(fm_d, display))
                    else:
                        parts.append(_sw(fm_d, str(val)))
                else:
                    is_plain = _is_plain_symbol(icon_str)
                    if ftype == 'boolean':
                        text_val = '✓'
                    elif ftype in ('marks', 'select'):
                        text_val = _resolve_display_value(db, fd, val) if db else str(val)
                        if not text_val:
                            continue
                    else:
                        text_val = str(val)
                    if is_plain and icon_str:
                        parts.append(_sw(fm_d, icon_str) + 3 + _sw(fm_d, text_val))
                    else:
                        combined = (icon_str + ' ' + text_val) if icon_str else text_val
                        parts.append(_sw(fm_d, combined))

        details_w = sum(parts) + SPACING * max(len(parts) - 1, 0)
        w = LEFT + max(title_w, details_w) + RIGHT + 4
        return w


    def sizeHint(self, option, index):
        h = self.COMPACT_HEIGHT if self.compact else self.NORMAL_HEIGHT
        if self.compact:
            return QSize(1, h)
        # proxy == source (фильтрация через _ids, не через proxy mapping)
        row = index.row()
        store = self.item_store
        if store is None or row < 0 or row >= len(store):
            return QSize(0, h)
        entry = store[row]
        cached_w = entry[4] if len(entry) > 4 else None
        if cached_w:
            return QSize(cached_w, h)
        item_data = entry[0]
        if not item_data:
            return QSize(0, h)

        w = self.estimate_row_width(item_data, entry[1], entry[2], self.db)
        while len(entry) < 6:
            entry.append(None)
        entry[4] = w
        return QSize(w, h)

    @staticmethod
    def _draw_text(painter, rect, text, font, color, flags=Qt.AlignLeft | Qt.AlignVCenter, elide=True, has_bg=False, shadow=False):
        """Малює текст. При has_bg=True додає обводку або тінь для читабельності на фото."""
        if not text:
            return
        painter.save()
        painter.setFont(font)
        if elide:
            fm = (MediaItemDelegate._FM_TITLE
                  if font is MediaItemDelegate._FONT_TITLE
                  else MediaItemDelegate._FM_DETAILS)
            if fm is None:
                fm = QFontMetrics(font)
            text = fm.elidedText(text, Qt.ElideRight, rect.width())
        if has_bg and _has_real_text(text):
            # Мягкая тень для читабельности на фото
            painter.setPen(QColor(0, 0, 0, 160))
            painter.drawText(rect.translated(1, 1), flags, text)
        painter.setPen(color)
        painter.drawText(rect, flags, text)
        painter.restore()



    def _build_right_parts(self, item_data, users, cf_data):
        """Собрать список строк для правой части (рейтинг, просмотры, время, дата, CF).
        Порядок и эмодзи совпадают с детальным видом: дата → рейтинг → просмотры → время → юзеры."""
        parts = []
        wd = item_data.get('watch_date')
        if wd:
            parts.append(f'📅 {_fmt_date(wd, _DATE_FMT)}')
        rating = item_data.get('rating')
        if rating:
            try:
                parts.append(f'__star_rating__\x00{int(rating)}')
            except (ValueError, TypeError):
                pass
        vc = item_data.get('view_count', 1)
        if vc and vc > 1:
            parts.append(f'__refresh_icon__\x00{vc}')
        ts = item_data.get('time_spent')
        if ts and isinstance(ts, (int, float)) and ts > 0:
            parts.append(f"🕒 {ts}{self.translations.get('hours', 'h')}")
        for fd, val in cf_data:
            fd = dict(fd)
            show_key = 'show_in_list_compact' if self.compact else 'show_in_list'
            if not fd.get(show_key) or val is None:
                continue
            ftype = fd.get('field_type', 'string')
            if ftype == 'boolean' and val != '1':
                continue
            if ftype in ('integer', 'slider'):
                try:
                    if int(val) == 0:
                        continue
                except Exception:
                    pass
            icon_str = fd.get('icon') or '🧩'
            is_file  = icon_str.startswith('file:')
            use_name = bool(fd.get('show_name_in_list')) and not self.compact
            if ftype in ('marks', 'select'):
                dv = _resolve_display_value(self.db, fd, val) if self.db else str(val)
                if not dv:
                    continue
                display_text = dv
            elif ftype == 'boolean':
                display_text = '__check__'
            else:
                _raw = str(val).split('\n')[0]
                _max_ch = 10 if self.compact else 20
                display_text = (_raw[:_max_ch] + '…') if len(_raw) > _max_ch else _raw

            if use_name:
                parts.append(f"{fd.get('name', '')}: {display_text}")
            elif is_file:
                abs_p = to_absolute_path(icon_str[5:])
                parts.append(f'__file_icon__\x00{abs_p}\x00{display_text}')
            else:
                if display_text == '__check__':
                    parts.append(f'__check__\x00{icon_str}')
                elif icon_str:
                    parts.append(f'{icon_str} {display_text}')
                else:
                    parts.append(display_text)
        return parts


    def paint(self, painter, option, index):
        painter.save()
        painter.setRenderHint(QPainter.TextAntialiasing, True)
        if not self.compact:
            # Normal mode needs these for cover images and rounded shapes
            painter.setRenderHint(QPainter.Antialiasing,          True)
            painter.setRenderHint(QPainter.SmoothPixmapTransform, True)
        try:
            self._paint_impl(painter, option, index)
        finally:
            painter.restore()

    def _paint_impl(self, painter, option, index):
        rect = option.rect

        is_selected = bool(option.state & QStyle.State_Selected)
        is_hovered  = bool(option.state & QStyle.State_MouseOver)

        if is_selected:
            color = QColor(255, 255, 255, 60) if self.has_bg else self.COLOR_BG_SELECTED
            painter.fillRect(rect, color)
        elif is_hovered:
            color = QColor(255, 255, 255, 30) if self.has_bg else self.COLOR_BG_HOVER
            painter.fillRect(rect, color)

        painter.save()
        painter.setRenderHint(QPainter.Antialiasing, False)
        sep_color = QColor(255, 255, 255, 25) if self.has_bg else self.COLOR_BORDER
        pen = QPen(sep_color, 1)
        pen.setCosmetic(True)
        painter.setPen(pen)
        y = rect.bottom()
        painter.drawLine(rect.left(), y, rect.right(), y)
        painter.restore()

        # proxy == source (фильтрация через _ids, не через proxy mapping)
        row = index.row()
        store = self.item_store
        if store is not None and 0 <= row < len(store):
            entry = store[row]
            item_data = entry[0]
            users     = entry[1]
            cf_data   = entry[2]
            cover_pix = entry[3]   # QPixmap | None
        else:
            item_data = index.data(ROLE_ITEM_DATA)
            users     = index.data(ROLE_USERS)   or []
            cf_data   = index.data(ROLE_CF_DATA) or []
            cover_pix = index.data(ROLE_COVER_PIXMAP)

        if not item_data:
            return

        # Cache _build_right_parts in entry[6] to avoid recomputing every paint
        if store is not None and 0 <= row < len(store):
            entry = store[row]
            while len(entry) < 7:
                entry.append(None)
            if entry[6] is None:
                entry[6] = self._build_right_parts(item_data, users, cf_data)
            _cached_parts = entry[6]
        else:
            _cached_parts = None
        if self.compact:
            self._paint_compact(painter, rect, item_data, users, cf_data, is_selected, _cached_parts)
        else:
            self._paint_normal(painter, rect, item_data, users, cf_data, is_selected, index, cover_pix, _cached_parts)


    def _paint_normal(self, painter, rect, item_data, users, cf_data, is_selected, index, cover_pix=None, _cached_parts=None):
        """Точное воспроизведение дизайна ItemWidget через QPainter."""
        M        = 5
        SPACING  = 6
        COVER_W  = 50
        COVER_H  = 75
        ICON_SZ  = 14

        x0 = rect.left() + M
        y0 = rect.top()
        h  = rect.height()

        self._ensure_fm()
        fm_title   = self._FM_TITLE
        fm_details = self._FM_DETAILS
        title_h    = fm_title.height()
        detail_h   = fm_details.height()

        if cover_pix is None:
            cover_pix = index.data(ROLE_COVER_PIXMAP)
        cy = y0 + (h - COVER_H) // 2
        cover_rect = QRect(x0, cy, COVER_W, COVER_H)

        painter.save()
        if cover_pix and not cover_pix.isNull():
            sc    = _get_dpr()
            row   = index.row()
            store = self.item_store
            cropped = None
            if store is not None and 0 <= row < len(store):
                entry = store[row]
                while len(entry) < 6:
                    entry.append(None)
                cropped = entry[5]
                # Invalidate cache if DPR changed (e.g. moved between monitors)
                if cropped is not None and not cropped.isNull():
                    if abs(cropped.devicePixelRatio() - sc) > 0.01:
                        cropped = None
                        store[row][5] = None
                    elif cropped.width() != round(COVER_W * sc) or cropped.height() != round(COVER_H * sc):
                        cropped = None
                        store[row][5] = None
            if cropped is None or cropped.isNull():
                # cover_pix уже phys_w×phys_h с DPR=sc — просто используем как cropped
                cropped = cover_pix
                if store is not None and 0 <= row < len(store):
                    store[row][5] = cropped
            # Draw pixmap, then sharp 1px border on top
            cover_rectf = QRectF(cover_rect)
            painter.setRenderHint(QPainter.SmoothPixmapTransform, False)
            painter.drawPixmap(cover_rect, cropped)
            painter.setRenderHint(QPainter.Antialiasing, False)
            pen = QPen(QColor(0x55, 0x55, 0x55))
            pen.setCosmetic(True)
            pen.setWidthF(1.0)
            painter.setBrush(Qt.NoBrush)
            painter.setPen(pen)
            painter.drawRect(QRectF(cover_rect.x() + 0.5, cover_rect.y() + 0.5,
                                    cover_rect.width() - 1, cover_rect.height() - 1))
        else:
            painter.setRenderHint(QPainter.Antialiasing, False)
            painter.setBrush(QColor(0x3c, 0x3c, 0x3c))
            pen = QPen(QColor(0x55, 0x55, 0x55))
            pen.setCosmetic(True)
            pen.setWidthF(1.0)
            painter.setPen(pen)
            painter.drawRect(QRectF(cover_rect.x() + 0.5, cover_rect.y() + 0.5,
                                    cover_rect.width() - 1, cover_rect.height() - 1))
        painter.restore()

        x_info = x0 + COVER_W + 8
        info_w = rect.right() - x_info - M

        title_y  = y0 + M + 8
        detail_y = y0 + h - M - detail_h - 8

        title_raw = str(item_data.get('title', '—'))
        title = _display_title(title_raw)

        def _w(fm, text):
            """Реальная ширина текста — boundingRect корректно считает эмодзи."""
            return fm.boundingRect(text).width()

        pfm_title   = self._FMF_TITLE
        pfm_details = self._FMF_DETAILS

        dx = x_info
        self._draw_text(painter, QRect(dx, title_y, info_w, title_h),
                        title, self._FONT_TITLE, QColor('#ffffff'), elide=True, has_bg=self.has_bg, shadow=True)
        dx += int(pfm_title.horizontalAdvance(title)) + 3

        year = item_data.get('year')
        if year and year != 0:
            year_str = f'({year})'
            self._draw_text(painter, QRect(dx, title_y, info_w, title_h),
                            year_str, self._FONT_DETAILS, QColor('#999999'), elide=False, has_bg=self.has_bg)
            dx += int(pfm_details.horizontalAdvance(year_str)) + 1

        if item_data.get('is_favorite'):
            self._draw_text(painter, QRect(dx, title_y, 24, title_h),
                            '🩷', self._FONT_DETAILS, QColor('#ffffff'), elide=False, has_bg=self.has_bg)
            dx += int(pfm_details.horizontalAdvance('🩷')) + 3

        # Показываем категорию в режиме глобального поиска — на второй строке под названием
        mw = self.main_window
        if mw and getattr(mw, 'all_categories_mode', False):
            cat_id = item_data.get('category_id')
            cat_name, cat_icon_str = self._get_cat_info(cat_id)
            if cat_name:
                CAT_ICON_SZ = 12
                cat_y = title_y + title_h + 2
                cdx = x_info
                cat_pix = self._render_cat_icon(cat_icon_str or '🏷', CAT_ICON_SZ)
                if cat_pix and not cat_pix.isNull():
                    iy = cat_y + (detail_h - CAT_ICON_SZ) // 2
                    painter.drawPixmap(QRect(cdx, iy, CAT_ICON_SZ, CAT_ICON_SZ), cat_pix)
                    cdx += CAT_ICON_SZ + 4
                avail = max(1, rect.right() - cdx - M)
                self._draw_text(painter, QRect(cdx, cat_y, avail, detail_h),
                                cat_name, self._FONT_DETAILS, QColor('#aaaaaa'), elide=True, has_bg=self.has_bg)

        frags = []  # (text|None, QColor|None, pixmap|None, tight_after, is_star, star_val, is_person, is_refresh, no_stroke)

        def _frag(text, color='#aaaaaa', tight=False, no_stroke=False):
            # Если строка смешанная (эмодзи + текст), разбиваем на части,
            # чтобы обводка не применялась к эмодзи внутри текста.
            if no_stroke or not text:
                frags.append((text, QColor(color), None, tight, False, None, False, False, True))
                return
            clusters = _GRAPHEME_RE.findall(text)
            # Проверяем: есть ли одновременно эмодзи И не-эмодзи символы
            has_emoji = any(_is_colored_emoji(c) for c in clusters)
            has_text  = any(not _is_colored_emoji(c) and ord(c[0]) > 0x20 for c in clusters)
            if not (has_emoji and has_text):
                # Однородная строка — добавляем как раньше
                _no_stroke = not has_text
                frags.append((text, QColor(color), None, tight, False, None, False, False, _no_stroke))
                return
            # Смешанная строка — группируем последовательные кластеры одного типа
            parts = []   # (chunk_str, is_emoji)
            cur_chunks = []
            cur_is_emoji = _is_colored_emoji(clusters[0])
            for c in clusters:
                c_is_emoji = _is_colored_emoji(c)
                if c_is_emoji == cur_is_emoji:
                    cur_chunks.append(c)
                else:
                    parts.append((''.join(cur_chunks), cur_is_emoji))
                    cur_chunks = [c]
                    cur_is_emoji = c_is_emoji
            parts.append((''.join(cur_chunks), cur_is_emoji))
            for i, (chunk, is_emoji) in enumerate(parts):
                # tight=True для всех частей кроме последней, чтобы не было лишних пробелов
                chunk_tight = tight if i == len(parts) - 1 else True
                frags.append((chunk, QColor(color), None, chunk_tight, False, None, False, False, is_emoji))
        def _frag_pix(pix, is_star=False):
            frags.append((None, None, pix, False, is_star, None, False, False, True))
        def _frag_star(rating_val):
            frags.append((None, None, None, False, True, rating_val, False, False, True))
        def _frag_person():
            frags.append((None, None, None, False, False, None, True, False, True))
        def _frag_refresh():
            frags.append((None, None, None, False, False, None, False, True, True))
        def _frag_check():
            frags.append(('__check__', QColor('#aaaaaa'), None, False, False, None, False, False, True))

        def _frag_emoji_text(emoji, text, text_color='#aaaaaa'):
            """Эмодзи отдельно (без обводки) + текст отдельно (с обводкой если надо).
            Текстовая часть прогоняется через _frag, чтобы смешанные строки
            тоже корректно разбивались на эмодзи/текст-фрагменты."""
            if emoji:
                frags.append((emoji, QColor('#ffffff'), None, True, False, None, False, False, True))
            if text:
                _frag(text, color=text_color)

        if item_data.get('watch_date'):
            _frag_emoji_text('📅', _fmt_date(item_data['watch_date'], _DATE_FMT))
        if item_data.get('rating'):
            try:
                _frag_star(int(item_data['rating']))
            except Exception:
                pass
        vc = item_data.get('view_count', 1)
        if vc and vc > 1:
            _frag_refresh()
            _frag(str(vc))
        ts = item_data.get('time_spent')
        if ts and ts > 0:
            _frag_emoji_text('🕒', f"{ts}{self.translations.get('hours', 'h')}")
        if users:
            _frag_person()
            _frag(', '.join(
                u['name'] if isinstance(u, dict) else u.get('name', '') for u in users))

        for fd, val in cf_data:
            fd = dict(fd)
            if not fd.get('show_in_list') or val is None:
                continue
            ftype = fd.get('field_type', 'string')
            if ftype == 'boolean' and val != '1':
                continue
            if ftype in ('integer', 'slider'):
                try:
                    if int(val) == 0:
                        continue
                except Exception:
                    pass
            icon_str   = fd.get('icon') or '🧩'
            use_name   = bool(fd.get('show_name_in_list'))
            name_color = fd.get('name_color') or '#ffffff'
            is_file    = icon_str.startswith('file:')
            is_plain   = _is_plain_symbol(icon_str)

            if ftype in ('marks', 'select'):
                display_val = _resolve_display_value(self.db, fd, val) if self.db else val
                if not display_val:
                    continue
            elif ftype == 'boolean':
                display_val = '__check__'
            else:
                # Только первая строка, без переносов, с обрезкой
                _raw_val = str(val).split('\n')[0]
                _max_ch = 10 if self.compact else 20
                display_val = (_raw_val[:_max_ch] + '…') if len(_raw_val) > _max_ch else _raw_val

            if use_name:
                _frag(f"{fd['name']}:", name_color, tight=True)
                if display_val == '__check__': _frag_check()
                else: _frag(display_val)
            elif is_file:
                cached_icon = _ICON_PIXMAP_CACHE.get(to_absolute_path(icon_str[5:]))
                if cached_icon:
                    _frag_pix(cached_icon)
                if display_val == '__check__': _frag_check()
                else: _frag(display_val)
            elif is_plain:
                _frag(icon_str, '#ffffff', tight=True)
                if display_val == '__check__': _frag_check()
                else: _frag(display_val)
            else:
                if display_val == '__check__':
                    if icon_str and not icon_str.startswith('file:'):
                        frags.append((icon_str, QColor('#ffffff'), None, True, False, None, False, False, True))
                    _frag_check()
                elif icon_str and not icon_str.startswith('file:'):
                    _frag_emoji_text(icon_str, display_val)
                else:
                    _frag(display_val)

        dx = x_info
        painter.save()
        painter.setFont(self._FONT_DETAILS)
        pfm = self._FMF_DETAILS
        right_edge = x_info + info_w  # правая граница доступного пространства
        _detail_baseline = detail_y + (detail_h - fm_details.height()) // 2 + fm_details.ascent()
        for text, color, pix, tight, is_star, star_val, is_person, is_refresh, no_stroke in frags:
            if star_val is not None:
                # Рисуем звёзды напрямую с baseline — идеальное выравнивание с текстом
                _star_sz = fm_details.ascent() + fm_details.descent()
                star_w = draw_star_rating(painter, int(dx), 0, star_val, _star_sz,
                                          baseline=_detail_baseline,
                                          cap_height=fm_details.capHeight())
                dx += star_w + SPACING
                continue
            if is_person:
                # Малюємо іконку людини напряму — чітко на будь-якому DPI
                draw_person_icon(painter, dx, detail_y, detail_h, QColor('#CDCDCD'))
                dx += detail_h + 3
                continue
            if is_refresh:
                _rsz = 13
                draw_refresh_icon(painter, dx, detail_y + (detail_h - _rsz) // 2, _rsz, QColor('#CDCDCD'))
                dx += _rsz + 3
                continue
            if text == '__check__':
                _csz = fm_details.ascent() + fm_details.descent() - 2
                draw_check_icon(painter, dx, detail_y + (detail_h - _csz) // 2 + 1, _csz, QColor('#CDCDCD'))
                dx += _csz + SPACING
                continue
            if pix is not None:
                iy = detail_y + (detail_h - ICON_SZ) // 2 + 1
                painter.drawPixmap(QRect(int(dx), iy, ICON_SZ, ICON_SZ), pix)
                dx += ICON_SZ + 3
                continue
            if not text:
                continue
            avail_w = max(1, int(right_edge - dx))
            used = painter.drawText(
                QRect(int(dx), detail_y, avail_w, detail_h),
                Qt.AlignLeft | Qt.AlignVCenter | Qt.TextDontPrint, text
            )
            tw = used.width() if used.width() > 0 else max(
                int(pfm.horizontalAdvance(text)),
                self._FM_DETAILS.boundingRect(text).width()
            )
            if self.has_bg and not no_stroke:
                # Тень для текста
                painter.setPen(QColor(0, 0, 0, 160))
                painter.drawText(QRect(int(dx) + 1, detail_y + 1, avail_w, detail_h),
                                 Qt.AlignLeft | Qt.AlignVCenter, text)
            painter.setPen(color)
            painter.drawText(QRect(int(dx), detail_y, avail_w, detail_h),
                             Qt.AlignLeft | Qt.AlignVCenter, text)
            dx += tw + (3 if tight else SPACING)
        painter.restore()


    def _paint_compact(self, painter, rect, item_data, users, cf_data, is_selected, _cached_parts=None):
        """Compact mode: uses painter.boundingRect for all measurements."""
        M_H = 6; M_V = 2
        ICON_SZ = 14
        SEP  = 5
        RGAP = 8

        x0 = rect.left() + M_H
        y0 = rect.top()  + M_V
        h  = rect.height() - M_V * 2
        x1 = rect.right() - M_H
        row_w = x1 - x0

        FD = self._FONT_COMPACT_DETAILS
        FT = self._FONT_COMPACT_TITLE

        # _split_mixed_cached — модульная функция с lru_cache(512),
        # логика идентична прежней локальной _split_mixed.

        def _chunk_widths(font, text):
            """Ширины кусков через boundingRect — единый источник для measure и draw_at.
            save/setFont/restore вынесены наружу цикла."""
            if not text:
                return []
            painter.save()
            painter.setFont(font)
            result = [
                painter.boundingRect(QRect(0, 0, 9999, h), Qt.AlignLeft | Qt.AlignVCenter, chunk).width()
                for chunk, _ in _split_mixed_cached(text)
            ]
            painter.restore()
            return result

        def measure(font, text):
            """Ширина для layout — через тот же boundingRect что и draw_at."""
            return sum(_chunk_widths(font, text))

        def draw_at(px, font, color, text, shadow=False):
            """Рисует текст начиная с px, возвращает ширину.
            Ширины берутся из _chunk_widths — идентичны тому что measure считает."""
            if not text:
                return 0
            chunks = list(_split_mixed_cached(text))
            widths = _chunk_widths(font, text)
            total_w = 0
            painter.save()
            painter.setFont(font)
            for (chunk, is_emoji), w in zip(chunks, widths):
                if self.has_bg and not is_emoji:
                    # Тень для текста
                    painter.setPen(QColor(0, 0, 0, 160))
                    painter.drawText(QRect(px + total_w + 1, y0 + 1, w, h), Qt.AlignLeft | Qt.AlignVCenter, chunk)
                painter.setPen(color)
                painter.drawText(QRect(px + total_w, y0, w, h), Qt.AlignLeft | Qt.AlignVCenter, chunk)
                total_w += w
            painter.restore()
            return total_w

        title_raw  = str(item_data.get('title', '—'))
        title_text = _display_title(title_raw)
        year       = item_data.get('year')
        year_str   = f'({year})' if year and year != 0 else ''
        fav        = item_data.get('is_favorite')

        year_w  = (3 + measure(FD, year_str)) if year_str else 0
        heart_w = (3 + measure(FD, '🩷'))      if fav      else 0

        mw = self.main_window
        _cat_name = None; _cat_icon_pix = None; _cat_icon_w = 0; _cat_text_w = 0
        if mw and getattr(mw, 'all_categories_mode', False):
            cat_id = item_data.get('category_id')
            cat_name, cat_icon_str = self._get_cat_info(cat_id)
            if cat_name:
                _cat_name     = cat_name
                _cat_icon_pix = self._render_cat_icon(cat_icon_str or '🏷', ICON_SZ)
                _cat_icon_w   = (ICON_SZ + 3) if (_cat_icon_pix and not _cat_icon_pix.isNull()) else 0
                _cat_text_w   = measure(FD, cat_name)

        cat_w       = (SEP + _cat_icon_w + _cat_text_w) if _cat_name else 0
        fixed_after = year_w + heart_w + cat_w

        parts = _cached_parts if _cached_parts is not None else self._build_right_parts(item_data, users, cf_data)

        # Один QFontMetrics на весь вызов — не пересоздавать в каждой ветке part_w
        _fm_d = QFontMetrics(FD)

        def part_w(part):
            if part.startswith('__file_icon__\x00'):
                _, abs_p, text = part.split('\x00', 2)
                if text == '__check__':
                    _csz = _fm_d.ascent() + _fm_d.descent() - 2
                    return ICON_SZ + 3 + _csz
                return ICON_SZ + 3 + measure(FD, text)
            if part.startswith('__star_rating__\x00'):
                sz = _fm_d.ascent() + _fm_d.descent()
                return 5 * sz
            if part.startswith('__refresh_icon__\x00'):
                return (ICON_SZ - 2) + 3 + measure(FD, part.split('\x00', 1)[1])
            if part.startswith('__check__'):
                _csz = _fm_d.ascent() + _fm_d.descent() - 2
                icon_part = part.split('\x00', 1)[1] if '\x00' in part else ''
                icon_w = measure(FD, icon_part) + 3 if icon_part else 0
                return icon_w + _csz
            return measure(FD, part)

        MIN_GAP_BETWEEN = 50
        # Строка делится пополам: левые 50% — название, правые 50% — поля
        half = int(row_w * 0.45)
        fields_start = int(row_w * 0.50)
        max_right_w = (x1 - x0) - fields_start - RGAP
        fitting = []; right_w = 0
        for part in parts:
            pw   = part_w(part)
            need = pw + (RGAP if fitting else 0)
            if right_w + need > max_right_w:
                break
            fitting.append(part)
            right_w += need

        # Название обрезается чтобы не заходить в правую половину
        title_avail = max(1, half - fixed_after - MIN_GAP_BETWEEN)
        elided = QFontMetrics(FT).elidedText(title_text, Qt.ElideRight, title_avail)

        dx = x0
        dx += draw_at(dx, FT, QColor('#ffffff'), elided, shadow=True)

        if year_str:
            dx += 3
            dx += draw_at(dx, FD, QColor('#999999'), year_str)

        if fav:
            dx += 1
            dx += draw_at(dx, FD, QColor('#ffffff'), '🩷')

        if _cat_name:
            dx += SEP
            if _cat_icon_pix and not _cat_icon_pix.isNull():
                iy = y0 + (h - ICON_SZ) // 2
                painter.drawPixmap(QRect(dx, iy, ICON_SZ, ICON_SZ), _cat_icon_pix)
                dx += _cat_icon_w
            dx += draw_at(dx, FD, QColor('#aaaaaa'), _cat_name)

        if fitting:
            dx = x1 - right_w
            first = True
            for part in fitting:
                if not first:
                    dx += RGAP
                first = False
                if part.startswith('__file_icon__\x00'):
                    _, abs_p, text = part.split('\x00', 2)
                    cached_icon = _ICON_PIXMAP_CACHE.get(abs_p)
                    if cached_icon:
                        iy = y0 + (h - ICON_SZ) // 2 + 1
                        painter.drawPixmap(QRect(dx, iy, ICON_SZ, ICON_SZ), cached_icon)
                        dx += ICON_SZ + 3
                    if text == '__check__':
                        _csz = _fm_d.ascent() + _fm_d.descent() - 2
                        draw_check_icon(painter, dx, y0 + (h - _csz) // 2 + 2, _csz, QColor('#CDCDCD'))
                        dx += _csz
                    else:
                        dx += draw_at(dx, FD, QColor('#aaaaaa'), text)
                elif part.startswith('__star_rating__\x00'):
                    rating_val = int(part.split('\x00', 1)[1])
                    star_sz = _fm_d.ascent() + _fm_d.descent()
                    # baseline текста при AlignVCenter: y0 + (h - fm.height())//2 + fm.ascent()
                    _bl = y0 + (h - _fm_d.height()) // 2 + _fm_d.ascent() + 1
                    star_w = draw_star_rating(painter, dx, 0, rating_val, star_sz, baseline=_bl, cap_height=_fm_d.capHeight())
                    dx += star_w
                elif part.startswith('__refresh_icon__\x00'):
                    vc_text = part.split('\x00', 1)[1]
                    _rsz = ICON_SZ - 2
                    iy = y0 + (h - _rsz) // 2 + 1
                    draw_refresh_icon(painter, dx, iy, _rsz, QColor('#CDCDCD'))
                    dx += _rsz + 3
                    dx += draw_at(dx, FD, QColor('#aaaaaa'), vc_text)
                elif part.startswith('__check__'):
                    icon_part = part.split('\x00', 1)[1] if '\x00' in part else ''
                    if icon_part and not icon_part.startswith('file:') and not _is_plain_symbol(icon_part):
                        dx += draw_at(dx, FD, QColor('#ffffff'), icon_part)
                        dx += 3
                    elif icon_part and _is_plain_symbol(icon_part):
                        dx += draw_at(dx, FD, QColor('#ffffff'), icon_part)
                        dx += 3
                    _csz = _fm_d.ascent() + _fm_d.descent() - 2
                    draw_check_icon(painter, dx, y0 + (h - _csz) // 2 + 2, _csz, QColor('#CDCDCD'))
                    dx += _csz
                else:
                    dx += draw_at(dx, FD, QColor('#aaaaaa'), part)





    def resolve_option_labels(self, field_id, value, field_type):
        """Конвертирует ID(ы) обратно в текстовые метки для отображения."""
        if not value:
            return None
        # Кеш options по field_id — SQL только при первом обращении к полю
        if not hasattr(self, '_options_cache'):
            self._options_cache = {}
        if field_id not in self._options_cache:
            cursor = self.conn.cursor()
            cursor.execute('SELECT id, label FROM custom_field_options WHERE field_id=? ORDER BY position ASC', (field_id,))
            self._options_cache[field_id] = {str(row['id']): row['label'] for row in cursor.fetchall()}
        id_to_label = self._options_cache[field_id]
        if field_type == 'select':
            return id_to_label.get(str(value))
        elif field_type == 'marks':
            try:
                ids = json.loads(value)
                if not isinstance(ids, list): ids = []
            except Exception:
                ids = []
            order = list(id_to_label.keys())
            ids_str = [str(i) for i in ids]  # normalize to str for lookup
            ids_sorted = sorted(ids_str, key=lambda x: order.index(x) if x in order else 9999)
            labels = [id_to_label[i] for i in ids_sorted if i in id_to_label]
            return json.dumps(labels) if labels else None
        return None

    def invalidate_options_cache(self, field_id=None):
        """Сбросить кеш опций (вызывать при изменении custom_field_options)."""
        if not hasattr(self, '_options_cache'):
            return
        if field_id is None:
            self._options_cache.clear()
        else:
            self._options_cache.pop(field_id, None)


    def _on_scrollbar_range_changed(self, min_val, max_val):
        """Меняем ширину элементов в зависимости от наличия скроллбара"""
        self._update_items_width()

    def _update_items_width(self):
        sb = self._sa.verticalScrollBar()
        has_scroll = sb.maximum() > sb.minimum()
        w = self.COVER_W - 6 if has_scroll else self.COVER_W
        for i in range(self._vbox.count()):
            widget = self._vbox.itemAt(i).widget()
            if widget:
                widget.setFixedWidth(w)

    def _lbl(self, text, color="#ffffff", bold=False, wrap=False, radii=(4,4,4,4)):
        # radii = (top-left, top-right, bottom-right, bottom-left)
        cover_w = self.COVER_W
        fg      = color
        is_bold = bold
        _radii  = radii

        class _PlainLabel(QWidget):
            PAD_H, PAD_V = 7, 4

            def __init__(self2):
                super().__init__()
                self2.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Minimum)

            def _line_h(self2):
                f = self2.font()
                if is_bold:
                    f.setBold(True)
                return QFontMetrics(f).height()

            def _num_lines(self2, w):
                if not wrap:
                    return 1
                inner_w = w - 2 * self2.PAD_H
                if inner_w <= 0:
                    return 1
                f = self2.font()
                if is_bold:
                    f.setBold(True)
                fm = QFontMetrics(f)
                rect = fm.boundingRect(
                    QRect(0, 0, inner_w, 9999),
                    Qt.TextWordWrap | Qt.TextExpandTabs,
                    text
                )
                lh = self2._line_h()
                return max(1, round(rect.height() / lh)) if lh else 1

            def heightForWidth(self2, w):
                return self2._num_lines(w) * self2._line_h() + 2 * self2.PAD_V

            def hasHeightForWidth(self2):
                return True

            def sizeHint(self2):
                w = self2.width() if self2.width() > 0 else cover_w
                return QSize(w, self2.heightForWidth(w))

            def resizeEvent(self2, event):
                self2.setFixedHeight(self2.heightForWidth(event.size().width()))
                super().resizeEvent(event)

            def paintEvent(self2, event):
                p = QPainter(self2)
                p.setRenderHint(QPainter.Antialiasing)
                r = QRectF(self2.rect())
                tl, tr_, br, bl = _radii
                path = QPainterPath()
                path.moveTo(r.left() + tl, r.top())
                path.lineTo(r.right() - tr_, r.top())
                path.quadTo(r.right(), r.top(), r.right(), r.top() + tr_)
                path.lineTo(r.right(), r.bottom() - br)
                path.quadTo(r.right(), r.bottom(), r.right() - br, r.bottom())
                path.lineTo(r.left() + bl, r.bottom())
                path.quadTo(r.left(), r.bottom(), r.left(), r.bottom() - bl)
                path.lineTo(r.left(), r.top() + tl)
                path.quadTo(r.left(), r.top(), r.left() + tl, r.top())
                path.closeSubpath()
                p.fillPath(path, QColor(0x2e, 0x2e, 0x2e))
                f = self2.font()
                if is_bold:
                    f.setBold(True)
                p.setFont(f)
                p.setPen(QColor(fg))
                flags = (Qt.TextWordWrap | Qt.AlignTop | Qt.AlignLeft) if wrap else (Qt.AlignVCenter | Qt.AlignLeft)
                p.drawText(
                    QRect(self2.PAD_H, self2.PAD_V,
                          self2.width() - 2 * self2.PAD_H,
                          self2.height() - 2 * self2.PAD_V),
                    flags,
                    text
                )
                p.end()

        return _PlainLabel()

    def _rating_widget(self, rating, fav_text='', label_text='Rating'):
        """Виджет который рисует 'Оценка: ★★★☆☆ (🩷)' в одном paintEvent —
        высота автоматически совпадает с текстом т.к. всё рисуется одним шрифтом."""
        _rating = rating
        _fav = fav_text
        _label = label_text
        _cover_w = self.COVER_W

        class _RatingWidget(QWidget):
            def sizeHint(self):
                fm = QFontMetrics(self.font())
                h = fm.height() + 8  # padding как у _lbl (4+4)
                return QSize(_cover_w, h)

            def paintEvent(self, event):
                painter = QPainter(self)
                painter.setRenderHint(QPainter.Antialiasing, True)
                # Фон как у _lbl
                painter.setPen(Qt.NoPen)
                painter.setBrush(QColor(0x2e, 0x2e, 0x2e))
                painter.drawRoundedRect(self.rect(), 4, 4)

                fm = QFontMetrics(self.font())
                star_sz = fm.ascent() + fm.descent()
                y_text = (self.height() - fm.height()) // 2  # верх текстовой строки
                baseline = y_text + fm.ascent()

                painter.setFont(self.font())

                # Префикс "Оценка: "
                prefix = f"{_label}: "
                painter.setPen(QColor(0xff, 0xff, 0xff))
                painter.drawText(7, baseline, prefix)
                x = 7 + fm.horizontalAdvance(prefix)

                # Звёзды — передаём baseline, звёзды выровняются автоматически
                star_w = draw_star_rating(painter, x, 0, _rating, star_sz, baseline=baseline, cap_height=fm.capHeight())
                x += star_w + 3

                # Фаворит
                if _fav:
                    painter.setPen(QColor(0xff, 0xff, 0xff))
                    painter.drawText(x, baseline, _fav)

                painter.end()

        w = _RatingWidget(self)
        w.setFixedWidth(_cover_w)
        w.setStyleSheet("")  # paintEvent рисует сам
        return w



    def _lbl_token_wrap(self, prefix, tokens, color="#ffffff"):
        """Label где токены переносятся целиком, высота точно совпадает с _lbl.
        Использует QFontMetrics для расчёта — без лишнего line spacing QTextDocument."""
        def protect(t):
            return t.replace(' ', '\u00a0')
        joined = ', '.join(protect(t) for t in tokens)
        text = f"{prefix}: {joined}"
        fg = color
        cover_w = self.COVER_W

        class _TokenLabel(QWidget):
            PAD_H, PAD_V = 7, 4

            def __init__(self2):
                super().__init__()
                self2.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Minimum)

            def _line_h(self2):
                return QFontMetrics(self2.font()).height()

            def _num_lines(self2, w):
                """Считаем количество строк через QFontMetrics.boundingRect — точно как Qt."""
                inner_w = w - 2 * self2.PAD_H
                if inner_w <= 0:
                    return 1
                fm = QFontMetrics(self2.font())
                rect = fm.boundingRect(
                    QRect(0, 0, inner_w, 9999),
                    Qt.TextWordWrap | Qt.TextExpandTabs,
                    text
                )
                lh = self2._line_h()
                return max(1, round(rect.height() / lh)) if lh else 1

            def heightForWidth(self2, w):
                return self2._num_lines(w) * self2._line_h() + 2 * self2.PAD_V

            def hasHeightForWidth(self2):
                return True

            def sizeHint(self2):
                w = self2.width() if self2.width() > 0 else cover_w
                return QSize(w, self2.heightForWidth(w))

            def resizeEvent(self2, event):
                self2.setFixedHeight(self2.heightForWidth(event.size().width()))
                super().resizeEvent(event)

            def paintEvent(self2, event):
                p = QPainter(self2)
                p.setRenderHint(QPainter.Antialiasing)
                path = QPainterPath()
                path.addRoundedRect(QRectF(self2.rect()), 4, 4)
                p.fillPath(path, QColor(0x2e, 0x2e, 0x2e))
                p.setPen(QColor(fg))
                p.setFont(self2.font())
                p.drawText(
                    QRect(self2.PAD_H, self2.PAD_V,
                          self2.width() - 2 * self2.PAD_H,
                          self2.height() - 2 * self2.PAD_V),
                    Qt.TextWordWrap | Qt.AlignTop | Qt.AlignLeft,
                    text
                )
                p.end()

        return _TokenLabel()

    def show_item(self, item_data, users_data, custom_fields_data=None):

    def _make_cat_list_item(self, row, indent=False):
        """Создать QListWidgetItem для категории или папки из строки БД.
        Все данные сохраняются в UserRole-слотах; рендеринг выполняет
        CategoryListDelegate — без QIcon / пиксмапов здесь."""
        row = dict(row)
        is_folder = bool(row.get('is_folder', 0))
        row_id    = row['id']
        raw_icon  = row['icon'] or None
        name      = row['name']

        if is_folder:
            collapsed = row_id in self._collapsed_folders
            if raw_icon is None or raw_icon in self._FOLDER_DEFAULT_ICONS:
                icon_val = '📁' if collapsed else '📂'
            else:
                icon_val = raw_icon
        else:
            icon_val = raw_icon or '🏷'

        item = QListWidgetItem(name)

        # All visual data for CategoryListDelegate
        item.setData(Qt.UserRole,     row_id)
        item.setData(Qt.UserRole + 1, icon_val)
        item.setData(Qt.UserRole + 2, bool(is_folder))
        item.setData(Qt.UserRole + 3, row.get('folder_id'))
        item.setData(Qt.UserRole + 4, (row_id in self._collapsed_folders) if is_folder else False)

        h = CategoryListDelegate.HEIGHT_FOLDER if is_folder else CategoryListDelegate.HEIGHT_CAT
        item.setSizeHint(QSize(0, h))
        return item
    def _cat_is_in_folder(self, cat_id):
        """True если категория cat_id принадлежит какой-либо папке."""
        if cat_id is None:
            return False
        c = self.db.conn.cursor()
        c.execute('SELECT folder_id FROM categories WHERE id = ?', (cat_id,))
        row = c.fetchone()
        return bool(row and row[0])

    def _cat_get_folder_id(self, cat_id):
        """Вернуть folder_id категории cat_id, или None если не в папке."""
        if cat_id is None:
            return None
        c = self.db.conn.cursor()
        c.execute('SELECT folder_id FROM categories WHERE id = ?', (cat_id,))
        row = c.fetchone()
        return row[0] if row else None

    def _toggle_folder_collapsed(self, folder_id):
        """Свернуть/развернуть папку — блок едет как единое целое."""
        # Блокируем любой клик пока идёт любая анимация
        if getattr(self, '_folder_anim_obj', None) is not None:
            return
        if getattr(self, '_folder_anim_active', None) == folder_id:
            return

        collapsing = folder_id not in self._collapsed_folders

        folder_row_idx = -1
        for i in range(self.categories_list.count()):
            it = self.categories_list.item(i)
            if it and it.data(Qt.UserRole + 2) and it.data(Qt.UserRole) == folder_id:
                folder_row_idx = i
                break
        if folder_row_idx < 0:
            if collapsing:
                self._collapsed_folders.add(folder_id)
            else:
                self._collapsed_folders.discard(folder_id)
            self.db.set_setting('collapsed_folders', ','.join(str(x) for x in self._collapsed_folders))
            self.load_categories(reload_items=not self.all_categories_mode)
            return

        ITEM_H      = CategoryListDelegate.HEIGHT_CAT
        n_items     = 0  # определим ниже
        BASE_DUR    = 150
        PER_ITEM    = 12
        MAX_DUR     = 400
        vp     = self.categories_list.viewport()
        item_w = vp.width()
        dpr    = vp.devicePixelRatioF()  # коэффициент масштабирования экрана

        def _render_block(items_list):
            if not items_list:
                return QPixmap(1, 1)
            first_rect = self.categories_list.visualItemRect(items_list[0])
            last_rect  = self.categories_list.visualItemRect(items_list[-1])
            block_rect = QRect(0, first_rect.top(),
                               vp.width(),
                               last_rect.bottom() + 1 - first_rect.top())
            pix = vp.grab(block_rect)
            return pix

        # Overlay который рисует блок с клиппингом ниже папки
        class _SlideOverlay(QWidget):
            def __init__(self2, parent, pix, folder_bottom_y):
                super().__init__(parent)
                self2.setAttribute(Qt.WA_TransparentForMouseEvents)
                self2._pix    = pix
                self2._clip_y = folder_bottom_y  # логические пиксели
                self2._y      = float(folder_bottom_y)
                self2.setGeometry(0, 0, parent.width(), parent.height())

            def set_y(self2, y):
                self2._y = y
                self2.update()

            def paintEvent(self2, event):
                p   = QPainter(self2)
                _dpr = self2._pix.devicePixelRatioF()
                # Высота pixmap в логических пикселях
                pix_h_log   = self2._pix.height() / _dpr if _dpr > 0 else self2._pix.height()
                pix_w_log   = self2._pix.width()  / _dpr if _dpr > 0 else self2._pix.width()
                visible_top = max(0.0, self2._clip_y - self2._y)
                draw_h      = pix_h_log - visible_top
                if draw_h <= 0:
                    p.end()
                    return
                # dst — логические координаты на экране
                dst_rect = QRectF(0, self2._clip_y, pix_w_log, draw_h)
                # src — физические координаты внутри pixmap
                src_rect = QRectF(0, visible_top * _dpr, pix_w_log * _dpr, draw_h * _dpr)
                p.drawPixmap(dst_rect, self2._pix, src_rect)
                p.end()

        if collapsing:
            # ── СВОРАЧИВАЕМ ───────────────────────────────────────────────────
            children = []
            for j in range(self.categories_list.count()):
                it = self.categories_list.item(j)
                if it is None or it.data(Qt.UserRole + 2):
                    continue
                if it.data(Qt.UserRole + 3) == folder_id:
                    children.append((j, it))
            if not children:
                self._collapsed_folders.add(folder_id)
                self.db.set_setting('collapsed_folders', ','.join(str(x) for x in self._collapsed_folders))
                self._update_folder_item_icon(folder_row_idx, folder_id, collapsed=True)
                return

            n_items  = len(children)
            duration = min(BASE_DUR + n_items * PER_ITEM, MAX_DUR)

            self._update_folder_item_icon(folder_row_idx, folder_id, collapsed=True)
            self._folder_anim_active = folder_id

            # Рисуем блок пока строки ещё видимы
            block_pix = _render_block([it for _, it in children])
            block_h   = ITEM_H * len(children)  # логические пиксели

            folder_item   = self.categories_list.item(folder_row_idx)
            folder_bottom = self.categories_list.visualItemRect(folder_item).bottom() + 1

            # Скрываем реальные строки
            for _, it in children:
                self.categories_list.setRowHidden(self.categories_list.row(it), True)

            # Spacer: невидимая строка с высотой block_h — соседи плавно поднимутся
            spacer = QListWidgetItem()
            spacer.setFlags(Qt.NoItemFlags)
            spacer.setSizeHint(QSize(0, block_h))
            self.categories_list.insertItem(children[-1][0] + 1, spacer)
            spacer_row = children[-1][0] + 1

            overlay = _SlideOverlay(vp, block_pix, folder_bottom)
            overlay._y = float(folder_bottom)
            overlay.show()
            overlay.raise_()

            sb = self.categories_list.verticalScrollBar()
            _scroll_before = sb.value()
            sb.setEnabled(False)

            anim = QVariantAnimation(self)
            anim.setStartValue(float(block_h))
            anim.setEndValue(0.0)
            anim.setDuration(duration)
            anim.setEasingCurve(QEasingCurve.InOutQuad)

            def _on_value(val):
                h = int(val)
                spacer.setSizeHint(QSize(0, h))
                overlay.set_y(folder_bottom - (block_h - h))
                # Держим scroll на месте пока анимация идёт
                sb.setValue(_scroll_before)

            def _on_finished():
                overlay.hide()
                overlay.setParent(None)
                overlay.deleteLater()
                self.categories_list.takeItem(spacer_row)
                for idx, _ in reversed(children):
                    self.categories_list.takeItem(idx)
                self._collapsed_folders.add(folder_id)
                self.db.set_setting('collapsed_folders',
                                    ','.join(str(x) for x in self._collapsed_folders))
                self._update_folder_item_icon(folder_row_idx, folder_id, collapsed=True)
                self._folder_anim_active = None
                self._folder_anim_obj    = None
                # Если текущая категория была внутри свёрнутой папки — выбираем первую доступную
                if self.current_category_id is not None:
                    c2 = self.db.conn.cursor()
                    c2.execute('SELECT folder_id FROM categories WHERE id=?', (self.current_category_id,))
                    row2 = c2.fetchone()
                    if row2 and row2['folder_id'] == folder_id:
                        # Ищем первую видимую категорию (не папку, не скрытую в закрытой папке)
                        first_item = None
                        for i in range(self.categories_list.count()):
                            it = self.categories_list.item(i)
                            if it and not it.data(Qt.UserRole + 2):
                                first_item = it
                                break
                        if first_item is not None:
                            self.categories_list.blockSignals(True)
                            self.categories_list.clearSelection()
                            first_item.setSelected(True)
                            self.categories_list.blockSignals(False)
                            self.on_category_selected(first_item)
                        else:
                            self.current_category_id = None
                            self.db.set_setting('last_category', '')
                            self._update_category_buttons()
                            self._update_cat_bg(None)
                            self._item_model.beginResetModel()
                            self._item_model._ids.clear()
                            self._item_model._store = []
                            self._item_model.endResetModel()
                            self._item_proxy.set_visibility(None, self.items_list)
                            self._items_store = []
                            self._full_items_store = []
                            if hasattr(self, '_items_delegate'):
                                self._items_delegate.item_store = self._items_store
                            self.detail_panel.clear_item()
                            self.update_stats()
                # Клампим в новый maximum и перерисовываем
                def _fix_scroll():
                    new_max = sb.maximum()
                    sb.setValue(min(_scroll_before, new_max))
                    sb.setEnabled(True)
                    self.categories_list.viewport().update()
                QTimer.singleShot(0, _fix_scroll)

            anim.valueChanged.connect(_on_value)
            anim.finished.connect(_on_finished)
            self._folder_anim_obj = (anim, overlay)
            anim.start()

        else:
            # ── РАЗВОРАЧИВАЕМ ────────────────────────────────────────────────
            self._collapsed_folders.discard(folder_id)
            self.db.set_setting('collapsed_folders', ','.join(str(x) for x in self._collapsed_folders))

            c = self.db.conn.cursor()
            c.execute('SELECT * FROM categories WHERE folder_id=? AND is_folder=0 ORDER BY position ASC',
                      (folder_id,))
            child_rows_db = [dict(r) for r in c.fetchall()]
            if not child_rows_db:
                self._update_folder_item_icon(folder_row_idx, folder_id, collapsed=False)
                return

            n_items  = len(child_rows_db)
            duration = min(BASE_DUR + n_items * PER_ITEM, MAX_DUR)

            # Вставляем строки скрытыми
            inserted = []
            for k, cr in enumerate(child_rows_db):
                new_item = self._make_cat_list_item(cr, indent=True)
                new_item.setSizeHint(QSize(0, ITEM_H))
                self.categories_list.insertItem(folder_row_idx + 1 + k, new_item)
                self.categories_list.setRowHidden(folder_row_idx + 1 + k, True)
                inserted.append(new_item)

            block_h = ITEM_H * n_items

            # Spacer начинает с 0
            spacer = QListWidgetItem()
            spacer.setFlags(Qt.NoItemFlags)
            spacer.setSizeHint(QSize(0, 0))
            spacer_row = folder_row_idx + 1 + n_items
            self.categories_list.insertItem(spacer_row, spacer)

            self._update_folder_item_icon(folder_row_idx, folder_id, collapsed=False)
            self._folder_anim_active = folder_id

            folder_item   = self.categories_list.item(folder_row_idx)
            folder_bottom = self.categories_list.visualItemRect(folder_item).bottom() + 1

            # Overlay с фоновым цветом — закрывает область до готовности grab
            _bg_pix = QPixmap(round(item_w * dpr), round(block_h * dpr))
            _bg_pix.setDevicePixelRatio(dpr)
            _bg_pix.fill(QColor(30, 30, 30))
            overlay = _SlideOverlay(vp, _bg_pix, folder_bottom)
            overlay._y = float(folder_bottom - block_h)
            overlay.show()
            overlay.raise_()

            sb = self.categories_list.verticalScrollBar()
            _scroll_before = sb.value()
            sb.setEnabled(False)

            def _start_anim():
                # Grab под overlay — overlay уже закрывает область, мелькания нет
                for k in range(n_items):
                    self.categories_list.setRowHidden(folder_row_idx + 1 + k, False)
                block_pix = _render_block(inserted)
                for k in range(n_items):
                    self.categories_list.setRowHidden(folder_row_idx + 1 + k, True)
                overlay._pix    = block_pix
                overlay._clip_y = folder_bottom
                overlay.update()

                anim = QVariantAnimation(self)
                anim.setStartValue(0.0)
                anim.setEndValue(float(block_h))
                anim.setDuration(duration)
                anim.setEasingCurve(QEasingCurve.InOutQuad)

                def _on_value(val):
                    h = int(val)
                    spacer.setSizeHint(QSize(0, h))
                    overlay.set_y(folder_bottom - block_h + h)
                    sb.setValue(_scroll_before)

                def _on_finished():
                    overlay.hide()
                    overlay.setParent(None)
                    overlay.deleteLater()
                    self.categories_list.takeItem(spacer_row)
                    for k in range(n_items):
                        self.categories_list.setRowHidden(folder_row_idx + 1 + k, False)
                    self._folder_anim_active = None
                    self._folder_anim_obj    = None
                    def _fix_scroll():
                        new_max = sb.maximum()
                        sb.setValue(min(_scroll_before, new_max))
                        sb.setEnabled(True)
                        self.categories_list.viewport().update()
                        self._restore_category_selection()
                    QTimer.singleShot(0, _fix_scroll)

                anim.valueChanged.connect(_on_value)
                anim.finished.connect(_on_finished)
                self._folder_anim_obj = (anim, overlay)
                anim.start()

            _start_anim()
    def _update_folder_item_icon(self, folder_row_idx, folder_id, collapsed):
        """Обновить данные иконки папки без перезагрузки всего списка.
        CategoryListDelegate сам перерисует строку при следующем paint()."""
        it = self.categories_list.item(folder_row_idx)
        if not it:
            return
        c = self.db.conn.cursor()
        c.execute('SELECT * FROM categories WHERE id = ?', (folder_id,))
        row = c.fetchone()
        if not row:
            return
        row = dict(row)
        raw_icon = row['icon'] or None
        if raw_icon is None or raw_icon in self._FOLDER_DEFAULT_ICONS:
            icon_val = '📁' if collapsed else '📂'
        else:
            icon_val = raw_icon

        it.setData(Qt.UserRole + 1, icon_val)
        it.setData(Qt.UserRole + 4, collapsed)
        # Trigger repaint
        self.categories_list.update(self.categories_list.indexFromItem(it))


    def load_categories(self, reload_items=True, select_ids=None, skip_global_reload=False):
        """Загрузка категорий с поддержкой папок.
        reload_items=False: не вызывать load_items при восстановлении выделения.
        select_ids: если задан — выделить эти категории вместо last_category."""
        with _t("load_categories (total)"):
         with _t("categories_list.clear"):
          _scroll_val = self.categories_list.verticalScrollBar().value()
          self.categories_list.clear()
          if hasattr(self, '_cat_delegate'):
              self._cat_delegate.invalidate_cache()

         with _t("db.get_categories"):
          all_rows = self.db.get_categories()  # ORDER BY position ASC

         with _t("dict conversion"):
          all_rows = [dict(r) for r in all_rows]

         with _t(f"build folder/cat structure ({len(all_rows)} rows)"):
          folders = [r for r in all_rows if r.get('is_folder')]
          folder_map = {r['id']: r for r in folders}

          cats_by_folder = {}   # folder_id -> [cat_row]
          free_cats = []        # категории без папки
          for r in all_rows:
            if r.get('is_folder'):
                continue
            fid = r.get('folder_id')
            if fid and fid in folder_map:
                cats_by_folder.setdefault(fid, []).append(r)
            else:
                free_cats.append(r)

          display_rows = []
          added_folder_ids = set()
          for r in all_rows:
            if r.get('is_folder'):
                display_rows.append(('folder', r))
                added_folder_ids.add(r['id'])
            else:
                fid = r.get('folder_id')
                if not fid or fid not in folder_map:
                    display_rows.append(('cat', r))

          rendered = []
          for kind, r in display_rows:
            if kind == 'folder':
                rendered.append(('folder', r, False))
                fid = r['id']
                if fid not in self._collapsed_folders:
                    for cr in cats_by_folder.get(fid, []):
                        rendered.append(('cat', cr, True))  # True = indent
            else:
                rendered.append(('cat', r, False))

         with _t(f"addItem to categories_list ({len(rendered)} items)"):
          _t_make = 0.0
          _t_add  = 0.0
          for kind, r, indent in rendered:
            _s = time.perf_counter()
            item = self._make_cat_list_item(r, indent=indent)
            _t_make += time.perf_counter() - _s
            _s = time.perf_counter()
            self.categories_list.addItem(item)
            _t_add += time.perf_counter() - _s
          print(f"[DBG]     _make_cat_list_item total: {_t_make*1000:.1f} ms")
          print(f"[DBG]     categories_list.addItem total: {_t_add*1000:.1f} ms")

         with _t("restore last_category selection"):
          last_category = self.db.get_setting('last_category')
        found = False
        if last_category is not None:
            for i in range(self.categories_list.count()):
                it = self.categories_list.item(i)
                if not it.data(Qt.UserRole + 2) and str(it.data(Qt.UserRole)) == str(last_category):
                    self.categories_list.setCurrentRow(i)
                    if reload_items and not self.all_categories_mode:
                        self.on_category_selected(it)
                    elif not self.all_categories_mode:
                        self._restore_category_selection()
                        if self.current_category_id:
                            self._update_cat_bg(it.data(Qt.UserRole))
                    found = True
                    break

        if not found:
            for i in range(self.categories_list.count()):
                it = self.categories_list.item(i)
                if not it.data(Qt.UserRole + 2):
                    self.categories_list.blockSignals(True)
                    self.categories_list.setCurrentRow(i)
                    self.categories_list.blockSignals(False)
                    if reload_items and not self.all_categories_mode:
                        self.on_category_selected(it)
                    elif not self.all_categories_mode:
                        self._restore_category_selection()
                        if self.current_category_id:
                            self._update_cat_bg(it.data(Qt.UserRole))
                    found = True
                    break

        if self.categories_list.count() == 0 or not found:
            self.current_category_id = None
            self._update_cat_bg(None)
            self._update_category_buttons()
            if not found:
                self._item_model.beginResetModel()
                self._item_model._ids.clear()
                self._item_model._store = []
                self._item_model.endResetModel()
                self._item_proxy.set_visibility(None, self.items_list)
                self._items_store = []
                self._full_items_store = []
                if hasattr(self, '_items_delegate'):
                    self._items_delegate.item_store = self._items_store
                self.detail_panel.clear_item()
                self.update_stats()

        # Восстанавливаем скролл отложенно — после того как Qt завершит layout
        QTimer.singleShot(0, lambda: self.categories_list.verticalScrollBar().setValue(_scroll_val))

        # Если передан явный список id для выделения — применяем после всех событий
        if select_ids:
            _ids = list(select_ids)
            def _apply_select():
                self.categories_list.clearSelection()
                id_set = set(_ids)
                for i in range(self.categories_list.count()):
                    it = self.categories_list.item(i)
                    if it and it.data(Qt.UserRole) in id_set:
                        it.setSelected(True)
            QTimer.singleShot(0, _apply_select)

        # Восстановить режим глобального поиска — лениво, после показа окна
        if not skip_global_reload and self.db.get_setting('all_categories_mode') == '1':
            self._enter_global_mode()
            self._lazy_startup_pending = True
            QTimer.singleShot(50, self._lazy_restore_global_mode)
        elif not skip_global_reload and reload_items and getattr(self, '_tier_mode', False) and self.current_category_id:
            # Проверяем что категория ещё существует
            _cur = self.db.conn.cursor()
            _cur.execute('SELECT id FROM categories WHERE id=? AND is_folder=0', (self.current_category_id,))
            if _cur.fetchone():
                self._enter_tier_mode()
                self._restore_date_filter(self.current_category_id)
                self.tier_list_widget.load_category(self.current_category_id, **self._tier_load_params())
                self.update_stats()
            else:
                # Категория удалена — сбрасываем tier_mode
                self._tier_mode = False
                self.db.set_setting('tier_mode', 'false')
                self.current_category_id = None
                self._update_cat_bg(None)
    
    def _enter_global_mode(self):
        """Применить все UI-изменения для режима глобального поиска.

        Вызывается как при восстановлении состояния после старта, так и при
        переключении режима вручную.  Скрывает кнопку «+», прячет tier-кнопки,
        убирает Import из меню экспорта и т.д.
        """
        self.all_cats_btn.setChecked(True)
        self.all_categories_mode = True
        self.categories_list.clearSelection()
        self._update_items_drag_mode()
        # Убираем фон категории в глобальном режиме
        self.items_list.clear_category_bg()
        if hasattr(self, '_items_delegate'):
            self._items_delegate.has_bg = False
        # Скрыть tier_btn и сепаратор
        self.tier_config_btn.hide()
        if hasattr(self, '_tier_sets_btn'):
            self._tier_sets_btn.hide()
        self._update_category_buttons()
        # В глобальном режиме Import недоступен, ручная сортировка тоже
        self._set_exp_btn_menu(global_mode=True)
        self._set_manual_sort_enabled(False)
        # Скрыть кнопку добавления — в глобальном режиме она бессмысленна
        if hasattr(self, 'add_item_btn'):
            self.add_item_btn.hide()
        self._item_model.beginResetModel()
        self._item_model._ids.clear()
        self._item_model._store = []
        self._item_model.endResetModel()
        self._item_proxy.set_visibility([], self.items_list)
        self._items_store = []
        if hasattr(self, '_items_delegate'):
            self._items_delegate.item_store = self._items_store
        self.stats_label.setText(self.translations.get('loading', 'Loading...'))

    def _set_manual_sort_enabled(self, enabled: bool):
        """Включить или заблокировать пункт «Ручной» в sort_combo.

        Вызывается при входе/выходе из тир-режима и из режима глобального поиска,
        где ручная сортировка недоступна.  Также при необходимости сбрасывает
        текущий индекс на «По дате» (2), если выбран «Ручной» (4).
        """
        manual_item = self.sort_combo.model().item(5)
        if not manual_item:
            return
        if enabled:
            manual_item.setEnabled(True)
            manual_item.setForeground(QColor(255, 255, 255))
        else:
            manual_item.setEnabled(False)
            manual_item.setForeground(QColor(80, 80, 80))
            # Если сейчас выбран «Ручной» — автоматически переключаем на «По дате»
            if self.sort_combo.currentIndex() == 5:
                self.sort_combo.blockSignals(True)
                self.sort_combo.setCurrentIndex(2)
                self.sort_combo.blockSignals(False)
                self.sort_order_btn.setVisible(True)

    def _set_exp_btn_menu(self, global_mode: bool):
        """Настроить меню кнопки Export в зависимости от режима.

        В глобальном режиме Import недоступен — кнопка работает как одиночная.
        В режиме категории — показывает выпадающее меню с пунктом Import.
        """
        if not hasattr(self, '_exp_btn'):
            return
        if global_mode:
            self._exp_btn.setPopupMode(QToolButton.DelayedPopup)
            self._exp_btn.setMenu(None)
        else:
            _m = QMenu(self._exp_btn)
            _a = _m.addAction(self.translations.get('import', 'Import'))
            _a.triggered.connect(lambda: self.export_category(_open_import_tab=True))
            self._exp_btn.setMenu(_m)
            self._exp_btn.setPopupMode(QToolButton.MenuButtonPopup)

    def _enter_tier_mode(self):
        """Применить все UI-изменения для входа в тир-режим.

        Вызывается как из toggle_tier_view() при ручном включении, так и из
        load_categories() при восстановлении состояния после старта.
        Загрузку данных (tier_list_widget.load_category) вызывающий код делает
        сам — здесь только UI.
        """
        self.tier_btn.setActive(True)
        self.tier_config_btn.setVisible(True)
        if hasattr(self, '_tier_sets_btn'):
            self._tier_sets_btn.setVisible(True)
        self.view_btn.setVisible(False)
        self._set_manual_sort_enabled(False)
        self.items_list.hide()
        self.detail_panel.hide()
        self._tier_frame.show()

    def _lazy_restore_global_mode(self):
        """Загрузить все элементы глобального режима после показа окна."""
        QApplication.processEvents()
        self.load_items()
        self._lazy_startup_pending = False
        print(f"[DBG] ✓ Total startup (incl. lazy load): {(time.perf_counter()-self._startup_t0)*1000:.1f} ms")



    def _save_cat_sort(self, cat_id):
        """Сохранить текущую сортировку/фильтр для категории."""
        if not self.per_category_sort or not cat_id:
            return
        raw = self.db.get_setting('per_cat_sort_data', '{}')
        try: data = json.loads(raw)
        except Exception: data = {}
        _tier_set_id = None
        _is_tier = getattr(self, '_tier_mode', False)
        if self.tier_list_widget and _is_tier:
            _tier_set_id = self.tier_list_widget._active_set_id
        # Use separate key for tier mode so sort/filter don't bleed between modes
        _key = f'{cat_id}_tier' if _is_tier else str(cat_id)
        data[_key] = {
            'sort_by':     self._current_sort_by(),
            'ascending':   self.sort_ascending,
            'fav':         self.favorites_only,
            'tier_mode':   _is_tier,
            'tier_set_id': _tier_set_id,
        }
        # Always record whether tier was active in the normal key too,
        # so _restore_cat_sort can decide which mode to switch to on category change
        _normal_key = str(cat_id)
        _existing = data.get(_normal_key, {})
        _existing['tier_mode'] = _is_tier
        data[_normal_key] = _existing
        self.db.set_setting('per_cat_sort_data', json.dumps(data))

    def _restore_cat_sort(self, cat_id):
        """Восстановить сортировку/фильтр для категории (или глобальные если нет записи)."""
        if not self.per_category_sort:
            return
        raw = self.db.get_setting('per_cat_sort_data', '{}')
        try: data = json.loads(raw)
        except Exception: data = {}

        # First, peek at the normal key to know whether tier mode should be on,
        # then read the actual sort params from the matching key.
        _normal_key = 'global' if cat_id is None else str(cat_id)
        _tier_key   = f'{cat_id}_tier' if cat_id is not None else 'global_tier'

        _normal_data = data.get(_normal_key, {})
        _tier_data   = data.get(_tier_key,   {})

        _startup = getattr(self, '_startup_restore_in_progress', False)
        _skip_tier_toggle = getattr(self, '_restore_sort_only', False)

        if _skip_tier_toggle or _startup:
            # Called from toggle_tier_view or startup — tier state already set, just load matching block
            _will_be_tier = getattr(self, '_tier_mode', False)
        else:
            # Called from category change — read saved tier_mode for this category
            _will_be_tier = bool(_normal_data.get('tier_mode', False))

        # Pick the settings block for the mode we're about to show
        s = _tier_data if _will_be_tier and _tier_data else _normal_data
        if not s:
            s = {'sort_by': 'watch_date', 'ascending': False, 'fav': False,
                 'tier_mode': _will_be_tier}

        sort_by     = s.get('sort_by', 'watch_date')
        ascending   = s.get('ascending', False)
        fav         = s.get('fav', False)
        tier_mode   = _will_be_tier
        tier_set_id = s.get('tier_set_id', None)

        sort_map_inv = {'title': 0, 'year': 1, 'watch_date': 2, 'rating': 3, 'shuffle': 4, 'manual': 5}
        idx = sort_map_inv.get(sort_by, 2)
        self.sort_combo.blockSignals(True)
        self.sort_combo.setCurrentIndex(idx)
        self.sort_combo.blockSignals(False)
        is_manual  = (sort_by == 'manual')
        is_shuffle = (sort_by == 'shuffle')
        self.sort_order_btn.setVisible(not is_manual and not is_shuffle)
        self._update_items_drag_mode()
        if ascending != self.sort_ascending:
            self.sort_ascending = ascending
            if ascending:
                self.sort_order_btn.setText(self.translations.get('descending', 'Descending'))
            else:
                self.sort_order_btn.setText(self.translations.get('ascending', 'Ascending'))
        if fav != self.favorites_only:
            self.favorites_only = fav
            self.favorites_btn.setActive(fav)
        _skip_tier_toggle2 = getattr(self, '_restore_sort_only', False)
        if not _startup and not _skip_tier_toggle2:
            current_tier = getattr(self, '_tier_mode', False)
            if tier_mode and not current_tier:
                self._tier_mode = True
                self.db.set_setting('tier_mode', 'true')
                self._enter_tier_mode()
            elif not tier_mode and current_tier:
                self._tier_mode = False
                self.db.set_setting('tier_mode', 'false')
                self.tier_btn.setActive(False)
                self.tier_config_btn.setVisible(False)
                if hasattr(self, '_tier_sets_btn'):
                    self._tier_sets_btn.setVisible(False)
                self.view_btn.setVisible(True)
                self._set_manual_sort_enabled(True)
                self._tier_frame.hide()
                self.items_list.show()
                self.detail_panel.show()
        if self.tier_list_widget and tier_mode and cat_id is not None:
            saved_sid = tier_set_id
            if saved_sid is not None:
                existing_ids = {s2['id'] for s2 in self.db.get_tier_list_sets(cat_id)}
                if saved_sid not in existing_ids:
                    saved_sid = None
            self.tier_list_widget._active_set_id = saved_sid
            if hasattr(self, '_tier_sets_btn'):
                if saved_sid is None:
                    lbl = self.translations.get('tier_set_main', 'Main')
                else:
                    sets_map = {s2['id']: s2['name'] for s2 in self.db.get_tier_list_sets(cat_id)}
                    lbl = sets_map.get(saved_sid, self.translations.get('tier_set_main', 'Main'))
                self._tier_sets_btn.setText(lbl)

    @staticmethod
    def _restore_active_cat_item(categories_list, current_category_id):
        """Восстанавливает выделение активной категории если ни один элемент не выделен."""
        if current_category_id is None:
            return
        selected = [categories_list.item(i) for i in range(categories_list.count())
                    if categories_list.item(i) and categories_list.item(i).isSelected()
                    and not categories_list.item(i).data(Qt.UserRole + 2)]
        if not selected:
            for i in range(categories_list.count()):
                it = categories_list.item(i)
                if it and not it.data(Qt.UserRole + 2) and it.data(Qt.UserRole) == current_category_id:
                    it.setSelected(True)
                    break

    def on_category_selected(self, item):
        """Обработка выбора категории или клика по папке"""
        # Если только что был drag — itemClicked всё равно срабатывает, игнорируем
        if getattr(self.categories_list, '_drag_was_performed', False):
            self.categories_list._drag_was_performed = False
            return
        _t0 = time.perf_counter()
        if not item:
            return
        ctrl_held = bool(QApplication.keyboardModifiers() & Qt.ControlModifier)
        is_folder = item.data(Qt.UserRole + 2)
        if is_folder:
            folder_id = item.data(Qt.UserRole)
            if ctrl_held:
                pre_click_selected = getattr(self.categories_list,
                                             '_folder_was_selected_before_click', None)
                if pre_click_selected is None:
                    pre_click_selected = not item.isSelected()
                if not pre_click_selected and not item.isSelected():
                    children = [self.categories_list.item(i)
                                for i in range(self.categories_list.count())
                                if self.categories_list.item(i)
                                and not self.categories_list.item(i).data(Qt.UserRole + 2)
                                and self.categories_list.item(i).data(Qt.UserRole + 3) == folder_id]
                    non_active = [c for c in children
                                  if c.data(Qt.UserRole) != self.current_category_id]
                    all_ch = all(c.isSelected() for c in children)
                    all_na = bool(non_active and all(c.isSelected() for c in non_active))
                    if non_active and all_na and all_ch:
                        self.categories_list.blockSignals(True)
                        item.setSelected(True)
                        self.categories_list.blockSignals(False)
                        return
                if folder_id in self._collapsed_folders:
                    # Раскрываем папку без сброса выделения —
                    # сохраняем все выделенные IDs до перезагрузки
                    _sel_ids_before = {
                        self.categories_list.item(i).data(Qt.UserRole)
                        for i in range(self.categories_list.count())
                        if self.categories_list.item(i) and self.categories_list.item(i).isSelected()
                    }
                    self._collapsed_folders.discard(folder_id)
                    self.db.set_setting('collapsed_folders', ','.join(str(x) for x in self._collapsed_folders))
                    self.load_categories(reload_items=False)
                    # Восстанавливаем выделение после перезагрузки
                    self.categories_list.blockSignals(True)
                    for i in range(self.categories_list.count()):
                        it = self.categories_list.item(i)
                        if it and it.data(Qt.UserRole) in _sel_ids_before:
                            it.setSelected(True)
                    self.categories_list.blockSignals(False)
                    # После reload ищем item заново
                    for i in range(self.categories_list.count()):
                        it = self.categories_list.item(i)
                        if it and it.data(Qt.UserRole + 2) and it.data(Qt.UserRole) == folder_id:
                            item = it
                            break
                    pre_click_selected = False  # папка только что раскрыта — была не выделена
                if pre_click_selected:
                    # Повторный Ctrl+click — снимаем папку и всех детей,
                    # но активную категорию оставляем выделенной
                    self.categories_list._suppress_restore_active = True
                    self.categories_list.blockSignals(True)
                    item.setSelected(False)
                    for i in range(self.categories_list.count()):
                        it = self.categories_list.item(i)
                        if it and not it.data(Qt.UserRole + 2) and it.data(Qt.UserRole + 3) == folder_id:
                            it.setSelected(False)
                    # Восстанавливаем выделение активной категории если она стала невыделенной
                    self._restore_active_cat_item(self.categories_list, self.current_category_id)
                    self.categories_list.blockSignals(False)
                    self.categories_list._suppress_restore_active = False
                else:
                    # Выделяем папку и всех детей
                    self.categories_list.blockSignals(True)
                    item.setSelected(True)
                    for i in range(self.categories_list.count()):
                        it = self.categories_list.item(i)
                        if it and not it.data(Qt.UserRole + 2) and it.data(Qt.UserRole + 3) == folder_id:
                            it.setSelected(True)
                    self.categories_list.blockSignals(False)
                return
            # Обычный клик по папке — toggle collapse как раньше
            self._toggle_folder_collapsed(folder_id)
            self._restore_category_selection()
            return
        # При Ctrl — только выделяем, не переключаем категорию
        if ctrl_held:
            return
        new_cat_id = item.data(Qt.UserRole)
        if self.all_categories_mode:
            self.all_categories_mode = False
            self.all_cats_btn.setChecked(False)
            self.db.set_setting('all_categories_mode', '0')
            # Сохраняем глобальный дата-фильтр
            _s_df = QSettings('MediaLibrary', 'DateFilter')
            _s_df.setValue('date_from_global', self._date_from or '')
            _s_df.setValue('date_to_global',   self._date_to   or '')
            _lbl_now = self._date_filter_btn.text()
            _all_lbl_now = self.translations.get('all_time', 'All time')
            _s_df.setValue('label_global', '' if _lbl_now == _all_lbl_now else _lbl_now)
            self._save_cat_sort(None)  # сохранить global состояние
            self._set_manual_sort_enabled(True)
            # Restore add button and export menu
            if hasattr(self, 'add_item_btn'):
                self.add_item_btn.show()
            self._set_exp_btn_menu(global_mode=False)
            self.current_category_id = new_cat_id
            self.db.set_setting('last_category', self.current_category_id)
            self._update_category_buttons()
            self._update_cat_bg(new_cat_id)
            # Восстанавливаем сортировку и дата-фильтр для категории
            self._restore_cat_sort(new_cat_id)  # восстановит в т.ч. tier_set_id
            self._restore_date_filter(new_cat_id)
            # Восстанавливаем тир-режим напрямую
            _was_tier = getattr(self, '_tier_mode_before_global', False)
            if _was_tier and not getattr(self, '_tier_mode', False):
                self._tier_mode = True
                self.db.set_setting('tier_mode', 'true')
                self._enter_tier_mode()
            self.items_list.verticalScrollBar().setValue(0)
            self.search_edit.blockSignals(True)
            self.search_edit.clear()
            self.search_edit.blockSignals(False)
            self._preserved_selection = set()
            self._selection_ids = set()
            self.items_list.selectionModel().blockSignals(True)
            self.items_list.clearSelection()
            self.items_list.selectionModel().blockSignals(False)
            if getattr(self, '_tier_mode', False):
                self._restore_date_filter(self.current_category_id)
                self.tier_list_widget.load_category(self.current_category_id, **self._tier_load_params())
                self.tier_list_widget.restore_pool_state()
                self.update_stats()
            else:
                self.load_items()
            self.detail_panel.clear_item()
            QTimer.singleShot(0, self.items_list.setFocus)
            return
        if new_cat_id == self.current_category_id and self.current_category_id is not None:
            return
        self._save_cat_sort(self.current_category_id)  # сохранить старую
        self._save_date_filter(self.current_category_id)  # сохранить дата-фильтр
        self.current_category_id = new_cat_id
        self.db.set_setting('last_category', self.current_category_id)
        self._restore_cat_sort(new_cat_id)  # восстановить новую (в т.ч. tier_set_id)
        self._update_category_buttons()
        self._update_cat_bg(new_cat_id)
        self.search_edit.blockSignals(True)
        self.search_edit.clear()
        self.search_edit.blockSignals(False)
        self._preserved_selection = set()
        self._selection_ids = set()
        self.items_list.selectionModel().blockSignals(True)
        self.items_list.clearSelection()
        self.items_list.selectionModel().blockSignals(False)
        self.items_list.verticalScrollBar().setValue(0)
        if getattr(self, '_tier_mode', False):
            self._restore_date_filter(self.current_category_id)
            self.tier_list_widget.load_category(self.current_category_id, **self._tier_load_params())
            self.update_stats()
        else:
            self._restore_date_filter(self.current_category_id)
            self.load_items()
        self.detail_panel.clear_item()
        QTimer.singleShot(0, self.items_list.setFocus)
    

    def _restore_category_selection(self):
        self.categories_list.clearSelection()
        if not self.current_category_id or self.all_categories_mode:
            return
        for i in range(self.categories_list.count()):
            item = self.categories_list.item(i)
            if not item.data(Qt.UserRole + 2) and item.data(Qt.UserRole) == self.current_category_id:
                item.setSelected(True)
                break

    def toggle_all_categories_mode(self):
        """Переключить режим отображения всех категорий"""
        _t0 = time.perf_counter()
        self.all_categories_mode = self.all_cats_btn.isChecked()
        self.db.set_setting('all_categories_mode', '1' if self.all_categories_mode else '0')
        if self.all_categories_mode:
            # Сохраняем состояние категории ДО выключения тир-режима
            self._save_cat_sort(self.current_category_id)
            # Сохраняем дата-фильтр текущей категории
            if self.current_category_id:
                _s = QSettings('MediaLibrary', 'DateFilter')
                _ck = str(self.current_category_id)
                _s.setValue(f'date_from_{_ck}', self._date_from or '')
                _s.setValue(f'date_to_{_ck}',   self._date_to   or '')
                _lbl = self._date_filter_btn.text()
                _all_lbl = self.translations.get('all_time', 'All time')
                _s.setValue(f'label_{_ck}', '' if _lbl == _all_lbl else _lbl)
            # Запоминаем тир-режим отдельно — независимо от per_category_sort
            self._tier_mode_before_global = getattr(self, '_tier_mode', False)
            # Убираем фон категории при входе в глобальный режим
            self.items_list.clear_category_bg()
            if hasattr(self, '_items_delegate'):
                self._items_delegate.has_bg = False
            # Exit tier mode if active
            if getattr(self, '_tier_mode', False):
                self._tier_mode = False
                self.db.set_setting('tier_mode', 'false')
                self.tier_btn.setActive(False)
                self._tier_frame.hide()
                self.items_list.show()
                self.detail_panel.show()
            # Hide tier buttons in global search
            self.tier_config_btn.hide()
            if hasattr(self, '_tier_sets_btn'):
                self._tier_sets_btn.hide()
            self._update_category_buttons()
            self._restore_cat_sort(None)    # восстановить global
            self._restore_date_filter(None)  # восстановить global дата-фильтр
        else:
            self._save_cat_sort(None)  # сохранить global состояние
            # Сохраняем глобальный дата-фильтр
            _s = QSettings('MediaLibrary', 'DateFilter')
            _s.setValue('date_from_global', self._date_from or '')
            _s.setValue('date_to_global',   self._date_to   or '')
            _lbl = self._date_filter_btn.text()
            _all_lbl = self.translations.get('all_time', 'All time')
            _s.setValue('label_global', '' if _lbl == _all_lbl else _lbl)
        # В глобальном режиме — кнопка без выпадающего меню (только Export)
        self._set_exp_btn_menu(global_mode=self.all_categories_mode)
        # Сбросить кэш категорий в делегате
        if hasattr(self, '_items_delegate'):
            self._items_delegate.invalidate_cat_cache()
        self._preserved_selection = set()
        self._selection_ids = set()
        self.items_list.selectionModel().blockSignals(True)
        self.items_list.clearSelection()
        self.items_list.selectionModel().blockSignals(False)
        self.detail_panel.clear_item()
        self.items_list.verticalScrollBar().setValue(0)  # сброс скролла
        if self.all_categories_mode:
            # Скрыть кнопку «+» — в глобальном режиме добавление недоступно
            if hasattr(self, 'add_item_btn'):
                self.add_item_btn.hide()
            self.categories_list.clearSelection()
            self._set_manual_sort_enabled(False)
            self.load_items()
        else:
            # Показать кнопку «+» — вернулись в режим конкретной категории
            if hasattr(self, 'add_item_btn'):
                self.add_item_btn.show()
            self._set_manual_sort_enabled(True)
            # Restore tier buttons
            self._update_category_buttons()
            # Восстановить фон категории
            self._update_cat_bg(self.current_category_id)
            # Восстанавливаем сортировку и дата-фильтр ПОСЛЕ UI-кнопок
            self._restore_cat_sort(self.current_category_id)
            self._restore_date_filter(self.current_category_id)
            # Восстанавливаем тир-режим напрямую — независимо от per_category_sort
            _was_tier = getattr(self, '_tier_mode_before_global', False)
            if _was_tier and not getattr(self, '_tier_mode', False):
                self._tier_mode = True
                self.db.set_setting('tier_mode', 'true')
                self._enter_tier_mode()
            # Грузим данные: если тир активен — загружаем тирлист, иначе обычный список
            if getattr(self, '_tier_mode', False) and self.current_category_id:
                self._restore_date_filter(self.current_category_id)
                self.tier_list_widget.load_category(self.current_category_id, **self._tier_load_params())
                self.tier_list_widget.restore_pool_state()
                self.update_stats()
            else:
                self.load_items()
            self._restore_category_selection()
        print(f"[DBG] ◀ toggle_all_categories_mode: {(time.perf_counter()-_t0)*1000:.1f} ms  mode={self.all_categories_mode}")
    
    def _reload_after_cat_change(self, cat_was_deleted=False):
        """Перезагрузить категории и, если активен глобальный режим, список фильмов.

        cat_was_deleted=True передаётся когда снаружи уже известно, что активная
        категория была удалена (и current_category_id уже сброшен до None).
        """
        # Проверяем что текущая категория ещё существует
        _was_current = self.current_category_id
        if self.current_category_id:
            cur = self.db.conn.cursor()
            cur.execute('SELECT id FROM categories WHERE id = ?', (self.current_category_id,))
            if not cur.fetchone():
                self.current_category_id = None
                self._update_cat_bg(None)
        # Текущая категория удалена: либо только что обнулилась в БД-проверке выше,
        # либо была сброшена снаружи до вызова метода (cat_was_deleted=True).
        _cat_deleted = (_was_current and self.current_category_id is None) or cat_was_deleted
        if _cat_deleted and getattr(self, '_tier_mode', False):
            # Выходим из тир-режима визуально
            self._tier_mode = False
            self.db.set_setting('tier_mode', 'false')
            self.tier_btn.setActive(False)
            self.tier_config_btn.setVisible(False)
            if hasattr(self, '_tier_sets_btn'):
                self._tier_sets_btn.setVisible(False)
            self.view_btn.setVisible(True)
            self._set_manual_sort_enabled(True)
            self._tier_frame.hide()
            self.items_list.show()
            self.detail_panel.show()
        self.load_categories(reload_items=False)
        if self.all_categories_mode:
            self.load_items()
        elif _cat_deleted:
            # Категория удалена — загружаем пустой список и обновляем счётчик
            self.load_items()
        self.update_stats()

    def update_stats(self):
        """Обновить счётчик элементов"""
        _t0 = time.perf_counter()
        if not self.current_category_id and not self.all_categories_mode:
            self.stats_label.setText('')
            return

        # Тир-режим: считаем элементы напрямую из store'ов, а не из БД.
        # БД не знает о текстовом поиске (он работает через setRowHidden),
        # поэтому db.get_items_count вернул бы неверное число при активном поиске.
        if getattr(self, '_tier_mode', False) and self.tier_list_widget:
            tlw = self.tier_list_widget
            # Элементы в тирах — все учитываются (поиск не скрывает тиры)
            tier_total = sum(len(s) for s in tlw._tier_store.values())
            # Элементы в пуле — только видимые (не скрытые текстовым поиском)
            pool_lw = tlw._pool
            pool_visible = sum(
                1 for r in range(pool_lw.count())
                if not pool_lw.isRowHidden(r)
            )
            total = tier_total + pool_visible
            self.stats_label.setText(
                self.translations.get('total_items', 'Total items: {}').format(total)
            )
            print(f"[DBG] ◀ update_stats (tier): {(time.perf_counter()-_t0)*1000:.1f} ms  tiers={tier_total} pool_visible={pool_visible}")
            return

        query_cat_id = None if self.all_categories_mode else self.current_category_id
        total = self.db.get_items_count(
            query_cat_id,
            self.search_edit.text(),
            self.favorites_only,
            date_from=self._date_from,
            date_to=self._date_to,
        )
        self.stats_label.setText(
            self.translations.get('total_items', 'Total items: {}').format(total)
        )
        print(f"[DBG] ◀ update_stats: {(time.perf_counter()-_t0)*1000:.1f} ms  total={total}")
    

    def load_item(self, item_id):
        item_data, users, cf_values_dict = self.db.get_item_full(item_id)
        if not item_data:
            return None
        cf_data = self._get_cf_data_for_item(item_id, cf_values_dict)
        row_h   = (MediaItemDelegate.COMPACT_HEIGHT if self.compact_view
                   else MediaItemDelegate.NORMAL_HEIGHT)

        store = getattr(self, '_items_store', None)
        src_row = self._source_row_for_id(item_id)
        if src_row >= 0:
            i = src_row
            if store is not None and i < len(store):
                old_cover_pix  = store[i][3]
                new_cover_path = item_data.get('cover_path')
                old_item_data  = store[i][0] or {}
                old_cover_path = old_item_data.get('cover_path')
                keep_cover = (old_cover_pix is not None and not old_cover_pix.isNull()
                              and new_cover_path == old_cover_path)
                store[i][0] = item_data
                store[i][1] = users
                store[i][2] = cf_data
                if not keep_cover:
                    store[i][3] = None
                    while len(store[i]) < 6: store[i].append(None)
                    store[i][5] = None
                while len(store[i]) < 6: store[i].append(None)
                store[i][4] = None
                if len(store[i]) > 6: store[i][6] = None
            if not self.compact_view and not keep_cover and item_data.get('cover_path'):
                self._request_cover_for_row(i, item_id, item_data['cover_path'])
            self._request_file_icons_for_cf(cf_data)
            proxy_row = self._proxy_row_for_id(item_id)
            if proxy_row >= 0:
                idx = self._item_proxy.index(proxy_row, 0)
                self.items_list.update(idx)
            return (item_data, users, cf_values_dict)

        # Новый элемент — добавляем в конец модели и store
        new_entry = [item_data, users, cf_data, None, None, None]
        new_row = len(self._item_model._ids)
        self._item_model.append_id(item_id, new_entry, row_h)
        if store is not None:
            store.append(new_entry)
            # Синхронизируем _full_items_store — он используется SearchWorker'ом.
            # Без этого при активном поиске len(_all_ids) != len(_full_items_store)
            # и следующий поиск вызывает load_items(), обложка теряется.
            full_store = getattr(self, '_full_items_store', None)
            if full_store is not None:
                full_store.append(new_entry)
            cover_path = item_data.get('cover_path')
            if not self.compact_view and cover_path:
                # append_id добавил item_id в конец _ids (и _all_ids).
                # Используем позицию в _ids — она совпадает с позицией в _store
                # (= _items_store при активном поиске), поэтому _on_cover_ready
                # запишет pixmap в правильную ячейку и item_id(row) вернёт верный id.
                src_row = len(self._item_model._ids) - 1
                self._request_cover_for_row(src_row, item_id, cover_path)


    def load_items(self):
        """Мгновенная загрузка всех данных в Python-список.
        QListWidgetItem создаются пустыми (только ID) — Qt не тратит время на setData.
        Делегат читает данные из self._items_store[row] — O(1) без сигналов."""
        with _t("load_items (total)"):
         if not hasattr(self, '_selection_ids'):
            self._selection_ids = set()

         with _t("collect selection + cover cache"):
          # Берём _selection_ids только если _preserved_selection не был явно сброшен
          _preserved_selection = set(getattr(self, '_preserved_selection', None) or getattr(self, '_selection_ids', set()))

          _cover_cache = {}
          old_store = getattr(self, '_items_store', [])
          for i, entry in enumerate(old_store):
            pix = entry[3]
            if pix and not pix.isNull():
                iid = self._item_model.item_id(i)
                if iid is not None:
                    _cover_cache[iid] = pix

         with _t("cancel covers + clear list"):
          CoverLoaderThread.instance().cancel_all()
          if hasattr(self, '_cover_cb_map'):
            self._cover_cb_map.clear()
          self._restoring_selection = True
          self._item_model.beginResetModel()
          self._item_model._ids.clear()
          self._item_model._store = []
          self._item_model.endResetModel()
          self._restoring_selection = False
          self._item_proxy.set_visibility([], self.items_list)
          self._items_store = []
          if hasattr(self, '_items_delegate'):
            self._items_delegate.item_store = self._items_store

         if not self.current_category_id and not self.all_categories_mode:
            return

         sort_map = {0: 'title', 1: 'year', 2: 'watch_date', 3: 'rating', 4: 'shuffle', 5: 'manual'}
         sort_by = sort_map.get(self.sort_combo.currentIndex(), 'watch_date')

         if self.all_categories_mode and sort_by == 'manual':
            self.sort_combo.blockSignals(True)
            self.sort_combo.setCurrentIndex(2)
            self.sort_combo.blockSignals(False)
            sort_by = 'watch_date'
            self.sort_order_btn.setVisible(True)

         self._update_items_drag_mode()
         query_cat_id = None if self.all_categories_mode else self.current_category_id

         with _t("db.get_items"):
          all_items = self.db.get_items(
            query_cat_id, '', sort_by,
            self.sort_ascending, self.favorites_only,
            date_from=self._date_from,
            date_to=self._date_to,
          )
         total = len(all_items)
         self.stats_label.setText(
            self.translations.get('total_items', 'Total items: {}').format(total)
         )
         if total == 0:
            self._preserved_selection = _preserved_selection
            return

         with _t(f"db.get_users_for_items ({total} items)"):
          all_ids    = [r['id'] for r in all_items]
          users_map  = self.db.get_users_for_items(all_ids)
         with _t(f"db.get_custom_fields_for_items_batch ({total} items)"):
          cf_map     = self.db.get_custom_fields_for_items_batch(all_ids)
         with _t("db.get_custom_fields"):
          cf_fields  = self.db.get_custom_fields()

         with _t(f"build _items_store ({total} items)"):
          # Предвычисляем cf_fields один раз — не пересоздаём список внутри цикла
          _no_cover = None
          _empty_list = []
          store = [
            [
              item_row,
              users_map.get(item_row['id'], _empty_list),
              [(f, _cf[f['id']]) for f in cf_fields if f['id'] in _cf]
                if (_cf := cf_map.get(item_row['id'])) else _empty_list,
              _cover_cache.get(item_row['id'], _no_cover),
              None,
              None,
            ]
            for item_row in all_items
          ]

          self._items_store = store
          self._full_items_store = list(store)  # полная копия без фильтра поиска
          if hasattr(self, '_items_delegate'):
            self._items_delegate.item_store = store

         row_h = (MediaItemDelegate.COMPACT_HEIGHT if self.compact_view
                  else MediaItemDelegate.NORMAL_HEIGHT)

         with _t(f"reset MediaItemModel ({total} rows)"):
          self._item_model.reset_data(all_ids, store, row_h)
          self._item_proxy.set_visibility(None, self.items_list)  # показать все
          # Восстановить выделение
          sel_model = self.items_list.selectionModel()
          sel_model.clearSelection()
          for iid in _preserved_selection:
            proxy_row = self._proxy_row_for_id(iid)
            if proxy_row >= 0:
                idx = self._item_proxy.index(proxy_row, 0)
                sel_model.select(idx, sel_model.Select)

        self._preserved_selection = _preserved_selection
        self._selection_ids = set(_preserved_selection)

        _t_sc = time.perf_counter()
        if not hasattr(self, '_scroll_connected'):
            self.items_list.verticalScrollBar().valueChanged.connect(self._on_scroll)
            self._scroll_connected = True
            self._scroll_connected = True
        print(f"[DBG]   scroll_connected: {(time.perf_counter()-_t_sc)*1000:.1f} ms")

        # Если поисковая строка не пустая — применить фильтр сразу после загрузки
        active_search = self.search_edit.text().strip()
        if active_search:
            predicate = self._build_search_predicate(active_search)
            visible_indices = [i for i, entry in enumerate(self._full_items_store) if predicate(entry)]
            self._item_proxy.set_visibility(visible_indices, self.items_list)
            self._items_store = self._item_model._store
            if hasattr(self, '_items_delegate') and self._items_delegate:
                self._items_delegate.item_store = self._items_store
            self.stats_label.setText(
                self.translations.get('total_items', 'Total items: {}').format(len(visible_indices))
            )

        _t_cov = time.perf_counter()
        QTimer.singleShot(0, self._request_visible_covers)
        self._request_file_icons_batch(cf_fields)
        print(f"[DBG]   request_covers + file_icons queued: {(time.perf_counter()-_t_cov)*1000:.1f} ms")

        _t_sel = time.perf_counter()
        sel = self._selected_item_ids()
        if len(sel) == 1:
            self.on_item_selected(sel[0])
            _scroll_id_li = sel[0]
            def _scroll_after_load(_sid=_scroll_id_li):
                proxy_row = self._proxy_row_for_id(_sid)
                if proxy_row >= 0:
                    idx = self._item_proxy.index(proxy_row, 0)
                    self.items_list.scrollTo(idx, QListView.PositionAtCenter)
            QTimer.singleShot(0, _scroll_after_load)
        print(f"[DBG]   on_item_selected: {(time.perf_counter()-_t_sel)*1000:.1f} ms")

    def _get_visible_range(self, buf=20):
        """Вернуть (top_source_row, bottom_source_row) видимой зоны + буфер."""
        rect       = self.items_list.viewport().rect()
        top_pidx   = self.items_list.indexAt(rect.topLeft())
        bot_pidx   = self.items_list.indexAt(rect.bottomLeft())
        top_p  = top_pidx.row()  if top_pidx.isValid()  else 0
        bot_p  = bot_pidx.row()  if bot_pidx.isValid()  else min(top_p + 30, self._item_proxy.rowCount() - 1)
        # конвертируем proxy → source
        top_s  = self._item_proxy.map_to_source_row(top_p)  if top_p  >= 0 else 0
        bot_s  = self._item_proxy.map_to_source_row(bot_p)  if bot_p  >= 0 else min(top_s + 30, len(self._items_store) - 1)
        if top_s < 0: top_s = 0
        if bot_s < 0: bot_s = min(top_s + 30, len(self._items_store) - 1)
        total = len(self._items_store)
        return (max(0, top_s - buf), min(total - 1, bot_s + buf))

    def _fill_viewport(self):
        """Совместимость — данные уже в item_store, только обложки."""
        self._request_visible_covers()

    def _request_visible_covers(self):
        """Запросить обложки только для видимых + буферных строк."""
        _t0 = time.perf_counter()
        if self.compact_view:
            return
        store = getattr(self, '_items_store', [])
        if not store:
            return
        top, bottom = self._get_visible_range(buf=20)
        queued = 0
        for row in range(top, bottom + 1):
            if row >= len(store):
                break
            entry = store[row]
            if entry[3] is not None:
                continue   # обложка уже есть
            item_data = entry[0]
            if not item_data:
                continue
            cover_path = item_data.get('cover_path')
            if cover_path:
                item_id = self._item_model.item_id(row)
                if item_id is not None:
                    self._request_cover_for_row(row, item_id, cover_path)
                    queued += 1
        print(f"[DBG] ◀ _request_visible_covers: {(time.perf_counter()-_t0)*1000:.1f} ms  queued={queued}  range={top}-{bottom}")

    def _request_file_icons_batch(self, cf_fields=None):
        """Загрузить file-иконки для всех кастомных полей одним батчем."""
        if cf_fields is None:
            cf_fields = self.db.get_custom_fields()
        self._ensure_loader()
        for f in cf_fields:
            icon_str = (f.get('icon') if isinstance(f, dict) else dict(f).get('icon')) or ''
            if not icon_str.startswith('file:'):
                continue
            abs_p = to_absolute_path(icon_str[5:])
            if abs_p in _ICON_PIXMAP_CACHE:
                continue
            cb_id = self._next_cb_id()
            self._cover_cb_map[cb_id] = ('icon', None, None)
            CoverLoaderThread.instance().put_task(abs_p, cb_id, 'icon')



    def _on_scroll(self, value):
        """При скролле — запрашиваем обложки для новой видимой зоны."""
        if not hasattr(self, '_scroll_debounce_timer'):
            self._scroll_debounce_timer = QTimer(self)
            self._scroll_debounce_timer.setSingleShot(True)
            self._scroll_debounce_timer.timeout.connect(self._request_visible_covers)
        self._scroll_debounce_timer.start(40)


    def _ensure_loader(self):
        if not hasattr(self, '_cover_cb_counter'):
            self._cover_cb_counter = 0
            self._cover_cb_map = {}
            CoverLoaderThread.instance().cover_ready.connect(self._on_cover_ready)
            # Батчинг обновлений обложек — накапливаем и применяем раз в 50ms
            self._cover_update_pending = []   # [(row, pixmap, item_id, cb_id)]
            self._icon_update_pending = False
            self._cover_batch_timer = QTimer()
            self._cover_batch_timer.setInterval(30)
            self._cover_batch_timer.timeout.connect(self._flush_cover_updates)
            self._cover_batch_timer.start()

    def _next_cb_id(self) -> int:
        self._cover_cb_counter += 1
        return self._cover_cb_counter

    def _request_cover_for_row(self, row: int, item_id: int, cover_path: str):
        """Поставить задачу на загрузку обложки. Результат пишется в item_store[row][3]."""
        self._ensure_loader()
        cb_id = self._next_cb_id()

        # Отменить предыдущий запрос для этой строки если есть
        old_cb = self._cover_cb_map.get(('pending', row))
        if old_cb is not None:
            CoverLoaderThread.instance().cancel(old_cb)
            self._cover_cb_map.pop(old_cb, None)
        self._cover_cb_map[('pending', row)] = cb_id
        self._cover_cb_map[cb_id] = ('cover', row, item_id)
        CoverLoaderThread.instance().put_task(cover_path, cb_id, 'cover')

    def _request_file_icons_for_cf(self, cf_data):
        """Загрузить в кеш file-иконки кастомных полей (если ещё не загружены)."""
        self._ensure_loader()
        for fd, val in cf_data:
            fd = dict(fd)
            icon_str = fd.get('icon') or ''
            if not icon_str.startswith('file:'):
                continue
            abs_p = to_absolute_path(icon_str[5:])
            if abs_p in _ICON_PIXMAP_CACHE:
                continue
            cb_id = self._next_cb_id()
            self._cover_cb_map[cb_id] = ('icon', None, None)
            CoverLoaderThread.instance().put_task(abs_p, cb_id, 'icon')



    def _on_cover_ready(self, cb_id: int, pixmap: QPixmap):
        """Слот главного потока: накапливаем обновления, применяем батчем."""
        entry = self._cover_cb_map.pop(cb_id, None)
        if entry is None:
            return
        task_type = entry[0]

        if task_type == 'cover':
            _, row, item_id = entry
            # Проверяем что строка всё ещё актуальна
            current_id = self._item_model.item_id(row)
            if current_id == item_id:
                self._cover_cb_map.pop(('pending', row), None)
                store = getattr(self, '_items_store', None)
                if store is not None and 0 <= row < len(store):
                    store[row][3] = pixmap
                    while len(store[row]) < 6: store[row].append(None)
                    store[row][5] = None
                self._cover_update_pending.append(row)

        elif task_type == 'icon':
            # Накапливаем — один viewport().update() на весь батч
            self._icon_update_pending = True

        elif task_type == 'cover_widget':
            _, _, widget = entry
            try:
                if widget._cover_cb_id == cb_id:
                    widget.set_cover(pixmap)
            except RuntimeError:
                pass

        elif task_type == 'icon_widget':
            _, _, widget = entry
            try:
                widget.refresh_file_icons()
            except RuntimeError:
                pass

    def _flush_cover_updates(self):
        """Применить накопленные обновления обложек одним батчем."""
        rows = self._cover_update_pending
        icon_upd = self._icon_update_pending
        if not rows and not icon_upd:
            return
        self._cover_update_pending = []
        self._icon_update_pending = False

        if rows:
            for row in set(rows):
                proxy_row = self._item_proxy.map_from_source_row(row)
                if proxy_row >= 0:
                    idx = self._item_proxy.index(proxy_row, 0)
                    self.items_list.update(idx)

        if icon_upd:
            self.items_list.viewport().update()
    
    def _select_all_items(self):
        """Ctrl+A — выделить все элементы с учётом lazy-загрузки."""
        if not hasattr(self, '_selection_ids'):
            self._selection_ids = set()
        all_ids = set()
        all_ids = {self._item_model.item_id(i)
                   for i in range(self._item_model.rowCount())
                   if self._item_model.item_id(i) is not None}
        self._selection_ids = all_ids
        self._preserved_selection = set(all_ids)
        self._selecting_all = True
        self._restoring_selection = True
        self.items_list.selectAll()
        self._restoring_selection = False
        self._selecting_all = False

    def filter_items(self):
        """Запуск фильтрации: мгновенно для сброса, в потоке для поиска."""
        # Тир-лист — синхронно, данных мало
        if getattr(self, '_tier_mode', False):
            text = self.search_edit.text()
            self.tier_list_widget._pool_search = text
            predicate = self._build_search_predicate(text) if text.strip() else None
            self.tier_list_widget._apply_pool_search(text, predicate)
            # Обновляем счётчик после применения поиска — он должен отражать
            # кол-во видимых элементов в пуле + всех элементов в тирах.
            self.update_stats()
            # Два вызова: первый — сразу после применения фильтра (покрывает быстрый путь),
            # второй — после того как Qt перерисует скрытые/видимые строки и
            # indexAt вернёт корректные значения для нового состояния пула.
            QTimer.singleShot(0,   self.tier_list_widget._request_visible_covers)
            QTimer.singleShot(150, self.tier_list_widget._request_visible_covers)
            return

        text = self.search_edit.text().strip()

        if not hasattr(self, '_full_items_store') or not self._full_items_store:
            self.load_items()
            return

        if not text:
            # Сброс — проверяем синхронизацию модели с _full_items_store.
            # При удалении с активным поиском модель может содержать "зомби"-строки.
            _model_ids  = set(self._item_model._ids)
            _full_ids   = {e[0].get('id') for e in self._full_items_store}
            if _model_ids != _full_ids:
                # Рассинхрон — перезагружаем из БД (единственный надёжный вариант)
                self.load_items()
                return
            # Запоминаем активный элемент ДО сброса модели (beginResetModel сбрасывает currentIndex)
            _sel_before = self._selected_item_ids()
            _scroll_id = _sel_before[0] if len(_sel_before) == 1 else None
            if _scroll_id is None:
                _scroll_id = self._current_item_id()
            # Сброс — мгновенно, без потока
            self._item_proxy.set_visibility(None, self.items_list)
            self._items_store = self._item_model._store
            if hasattr(self, '_items_delegate'):
                self._items_delegate.item_store = self._items_store
            # Восстанавливаем выделение
            preserved = getattr(self, '_preserved_selection', set())
            if preserved:
                self._restoring_selection = True
                sel_model = self.items_list.selectionModel()
                sel_model.clearSelection()
                for iid in preserved:
                    proxy_row = self._proxy_row_for_id(iid)
                    if proxy_row >= 0:
                        idx = self._item_proxy.index(proxy_row, 0)
                        sel_model.select(idx, sel_model.Select)
                self._restoring_selection = False
            if _scroll_id is not None:
                def _scroll_to_selected_after_clear(_sid=_scroll_id):
                    proxy_row = self._proxy_row_for_id(_sid)
                    if proxy_row >= 0:
                        idx = self._item_proxy.index(proxy_row, 0)
                        self.items_list.scrollTo(idx, QListView.PositionAtCenter)
                QTimer.singleShot(0, _scroll_to_selected_after_clear)
            else:
                self.items_list.verticalScrollBar().setValue(0)
            self.update_stats()
            QTimer.singleShot(0, self._request_visible_covers)
            return

        if len(self._item_model._all_ids) != len(self._full_items_store):
            self.load_items()
            return

        # Предикат — кэшируем, пересоздаём только при смене текста
        if getattr(self, '_last_predicate_text', None) != text:
            self._last_predicate = self._build_search_predicate(text)
            self._last_predicate_text = text

        # Запускаем тяжёлый цикл в фоновом потоке
        if not hasattr(self, '_search_worker'):
            self._search_worker = SearchWorker(self)
            self._search_worker.result_ready.connect(self._on_search_result)

        self._search_worker.start_search(
            self._full_items_store, self._last_predicate, text)

    def _on_search_result(self, visible_indices, count, text):
        """Вызывается из main thread когда SearchWorker закончил."""
        if text != self.search_edit.text().strip():
            return
        _t0 = time.perf_counter()
        self._item_proxy.set_visibility(visible_indices, self.items_list)
        self._items_store = self._item_model._store
        if hasattr(self, '_items_delegate'):
            self._items_delegate.item_store = self._items_store
        # Восстанавливаем выделение после beginResetModel (он сбрасывает selection)
        preserved = getattr(self, '_preserved_selection', set())
        if preserved:
            self._restoring_selection = True
            sel_model = self.items_list.selectionModel()
            sel_model.clearSelection()
            for iid in preserved:
                proxy_row = self._proxy_row_for_id(iid)
                if proxy_row >= 0:
                    idx = self._item_proxy.index(proxy_row, 0)
                    sel_model.select(idx, sel_model.Select)
            self._restoring_selection = False
        self.items_list.verticalScrollBar().setValue(0)
        self.stats_label.setText(
            self.translations.get('total_items', 'Total items: {}').format(count)
        )
        QTimer.singleShot(0, self._request_visible_covers)
        print(f"[DBG] ◀ _on_search_result: {(time.perf_counter()-_t0)*1000:.1f} ms  visible={count}")

    def _build_search_predicate(self, search_text):
        """Строит Python-функцию predicate(entry) -> bool для мгновенной фильтрации.

        entry = [item_data, users, cf_data, cover_pix, ...]
          item_data : dict  — поля из таблицы items
          users     : list[dict]  — [{id, name}, ...]
          cf_data   : list[(field_dict, value)]

        Синтаксис:
          слово / "фраза"     — AND по title
          a | b               — OR
          !слово              — NOT по title
          (a | b) c           — группировка
          y:2007              — год выхода (release year)
          yw:2007             — год просмотра (watch year)
          y:>=2010            — операторы >=, <=, >, < для числовых/дата полей
          yw:>=2010           — операторы >=, <=, >, < для года просмотра
          !y:2007             — отрицание любого префикса
          n:слово             — заметки
          u:имя               — пользователь
          r:8                 — рейтинг (точное или через оператор r:>=7)
          prefix:val          — кастомные поля
        """
        search_text = search_text.strip()
        if not search_text:
            return lambda entry: True

        # Карта кастомных префиксов
        cf_prefix_map = {}
        cf_field_info = {}
        try:
            for f in self.db.get_custom_fields():
                fd = dict(f)
                sf = fd.get('search_filter')
                if sf:
                    fid = fd['id']
                    cf_prefix_map[sf.lower()] = fid
                    ftype = fd.get('field_type', 'string')
                    options = {}
                    if ftype in ('select', 'marks'):
                        try:
                            c = self.db.conn.cursor()
                            c.execute('SELECT id, label FROM custom_field_options WHERE field_id=? ORDER BY position', (fid,))
                            for orow in c.fetchall():
                                options[str(orow['id'])] = orow['label'].lower()
                        except Exception:
                            pass
                    cf_field_info[fid] = {'type': ftype, 'options': options}
        except Exception:
            pass

        # ── Вспомогательные ─────────────────────────────────────────────────

        def ilike(pattern, text):
            if text is None:
                return False
            return pattern.lower() in str(text).lower()

        CMP_OPS = ('>=', '<=', '>', '<')

        def _cmp_match(op, operand_str, actual_val):
            if actual_val is None:
                return False
            actual_s  = str(actual_val).strip()
            operand_s = str(operand_str).strip()
            if not actual_s or not operand_s:
                return False
            try:
                a = float(actual_s)
                b = float(operand_s)
                if op == '>=': return a >= b
                if op == '<=': return a <= b
                if op == '>':  return a >  b
                if op == '<':  return a <  b
            except ValueError:
                pass
            # лексикографическое (работает для дат YYYY-MM-DD)
            if op == '>=': return actual_s >= operand_s
            if op == '<=': return actual_s <= operand_s
            if op == '>':  return actual_s >  operand_s
            if op == '<':  return actual_s <  operand_s
            return False

        # ── Токенизатор ──────────────────────────────────────────────────────
        def tokenize(text):
            token_re = re.compile(
                r'!"([^"]+)"|"([^"]+)"|(\()|(\))|(\|)|!([^\s()|]+)|([^\s()|]+)'
            )
            tokens = []
            for m in token_re.finditer(text):
                neg_phrase, phrase, lparen, rparen, pipe, neg_word, word = m.groups()
                if neg_phrase is not None:   tokens.append(('NEG_PHRASE', neg_phrase))
                elif phrase is not None:     tokens.append(('PHRASE', phrase))
                elif lparen is not None:     tokens.append(('LPAREN', '('))
                elif rparen is not None:     tokens.append(('RPAREN', ')'))
                elif pipe is not None:       tokens.append(('PIPE', '|'))
                elif neg_word is not None:   tokens.append(('NEG', neg_word))
                elif word is not None:       tokens.append(('WORD', word))
            return tokens

        # ── Рекурсивный парсер выражений ─────────────────────────────────────
        def make_atom(kind, val, field_getter):
            if kind in ('PHRASE', 'WORD'):
                return lambda d: ilike(val, field_getter(d))
            return lambda d: True

        def parse_or(tokens, pos, field_getter):
            left, pos = parse_and(tokens, pos, field_getter)
            while pos < len(tokens) and tokens[pos][0] == 'PIPE':
                pos += 1
                right, pos = parse_and(tokens, pos, field_getter)
                l, r = left, right
                left = lambda d, _l=l, _r=r: _l(d) or _r(d)
            return left, pos

        def parse_and(tokens, pos, field_getter):
            first, pos = parse_atom_fn(tokens, pos, field_getter)
            parts = [first]
            while pos < len(tokens) and tokens[pos][0] not in ('PIPE', 'RPAREN'):
                fn, pos = parse_atom_fn(tokens, pos, field_getter)
                parts.append(fn)
            if len(parts) == 1:
                return parts[0], pos
            def combined(d, _parts=parts): return all(f(d) for f in _parts)
            return combined, pos

        def parse_atom_fn(tokens, pos, field_getter):
            if pos >= len(tokens):
                return (lambda d: True), pos
            kind, val = tokens[pos]
            if kind == 'LPAREN':
                pos += 1
                fn, pos = parse_or(tokens, pos, field_getter)
                if pos < len(tokens) and tokens[pos][0] == 'RPAREN':
                    pos += 1
                return fn, pos
            pos += 1
            return make_atom(kind, val, field_getter), pos

        # ── Парсинг префиксных токенов ────────────────────────────────────────
        # Формат: [!]prefix:"quoted value"  или  [!]prefix:value
        # Операторы сравнения (>=, <=, >, <) идут ПОСЛЕ двоеточия, как часть value:
        #   y:>=2010   r:<=5   !y:>2000
        all_prefixes_sorted = sorted(
            ['y', 'yw', 'n', 'u', 'r'] + list(cf_prefix_map.keys()),
            key=lambda p: -len(p)
        )
        _pfx_pat = '|'.join(re.escape(p) for p in all_prefixes_sorted)
        # с кавычками:  (!)(prefix):"value"
        # без кавычек:  (!)(prefix):value
        _prefixed_re = re.compile(
            rf'(!?)({_pfx_pat}):"([^"]*)"'           # quoted: пустые "" допустимы
            rf'|(!?)({_pfx_pat}):(\S+)'              # plain: есть значение
            rf'|(!?)({_pfx_pat}):(?=\s|$)',          # bare: n: без значения
            re.IGNORECASE
        )

        def _parse_cmp(val):
            """Вернуть (op, operand) — op=None если нет оператора сравнения."""
            for op in CMP_OPS:
                if val.startswith(op):
                    return op, val[len(op):]
            return None, val

        note_terms        = []  # (negate, val)
        year_terms        = []  # (negate, op|None, val)  — y: release year
        watch_year_terms  = []  # (negate, op|None, val)  — yw: watch year
        rating_terms      = []  # (negate, op|None, val)
        user_terms        = []  # (negate, val)
        cf_terms          = {}  # prefix -> [(negate, op|None, val)]

        consumed_spans = []
        for m in _prefixed_re.finditer(search_text):
            # g[0..2]  = quoted branch: bang, pfx, val
            # g[3..5]  = plain  branch: bang, pfx, val
            # g[6..7]  = bare   branch: bang, pfx  (val = '')
            g = m.groups()
            if g[2] is not None:         # quoted branch
                negate = g[0] == '!'
                prefix = g[1].lower()
                val    = g[2]            # может быть '' (n:"")
                op     = None
            elif g[5] is not None:       # plain branch
                negate = g[3] == '!'
                prefix = g[4].lower()
                op, val = _parse_cmp(g[5])
            else:                        # bare branch: n: без значения
                negate = g[6] == '!'
                prefix = g[7].lower()
                op, val = None, ''
            consumed_spans.append((m.start(), m.end()))
            if prefix == 'n':
                note_terms.append((negate, val))
            elif prefix == 'yw':
                watch_year_terms.append((negate, op, val))
            elif prefix == 'y':
                year_terms.append((negate, op, val))
            elif prefix == 'r':
                rating_terms.append((negate, op, val))
            elif prefix == 'u':
                user_terms.append((negate, val))
            elif prefix in cf_prefix_map:
                cf_terms.setdefault(prefix, []).append((negate, op, val))

        # Остаток строки (без префиксных токенов)
        remainder = list(search_text)
        for start, end in sorted(consumed_spans, reverse=True):
            remainder[start:end] = [' '] * (end - start)
        remainder = ''.join(remainder).strip()

        # ── Предикаты ────────────────────────────────────────────────────────
        predicates = []

        # free text / title
        if remainder:
            tokens = tokenize(remainder)
            not_vals = []
            filtered = []
            i = 0
            while i < len(tokens):
                kind, val = tokens[i]
                if kind in ('NEG_PHRASE', 'NEG'):
                    not_vals.append(val)
                    had_left_pipe = bool(filtered) and filtered[-1][0] == 'PIPE'
                    if had_left_pipe:
                        filtered.pop()
                    if i + 1 < len(tokens) and tokens[i+1][0] == 'PIPE':
                        if had_left_pipe:
                            i += 1
                else:
                    filtered.append((kind, val))
                i += 1
            while filtered and filtered[0][0] == 'PIPE':  filtered.pop(0)
            while filtered and filtered[-1][0] == 'PIPE': filtered.pop()
            deduped = []
            for tok in filtered:
                if tok[0] == 'PIPE' and deduped and deduped[-1][0] == 'PIPE':
                    continue
                deduped.append(tok)
            filtered = deduped

            _global_mode = getattr(self, 'all_categories_mode', False)
            if _global_mode:
                _cat_cache = {}
                try:
                    c = self.db.conn.cursor()
                    c.execute('SELECT id, name FROM categories')
                    for row in c.fetchall():
                        _cat_cache[row['id']] = row['name']
                except Exception:
                    pass
                def _cat_name_getter(entry, _cache=_cat_cache):
                    return _cache.get(entry[0].get('category_id'), '')
                def _title_or_cat(entry):
                    raw = entry[0].get('title', '') or ''
                    return ' '.join(_search_titles(raw)) + '\n' + _cat_name_getter(entry)
                title_getter = _title_or_cat
            else:
                title_getter = lambda entry: ' '.join(_search_titles(entry[0].get('title', '') or ''))

            if filtered:
                pos_fn, _ = parse_or(filtered, 0, title_getter)
                predicates.append(lambda entry, _fn=pos_fn: _fn(entry))
            for nval in not_vals:
                v = nval
                predicates.append(lambda entry, _v=v, _tg=title_getter: not ilike(_v, _tg(entry)))

        # notes  n:
        for (negate, val) in note_terms:
            if val == '':
                predicates.append(lambda entry, _neg=negate:
                    bool(str(entry[0].get('notes') or '').strip()) != _neg)
                continue
            toks = tokenize(val)
            note_getter = lambda entry: entry[0].get('notes', '')
            fn, _ = parse_or(toks, 0, note_getter)
            if negate:
                predicates.append(lambda entry, _fn=fn: not _fn(entry))
            else:
                predicates.append(lambda entry, _fn=fn: _fn(entry))

        # release year  y:  (только поле year)
        for (negate, op, val) in year_terms:
            val = val.strip()
            if val == '' and not op:
                predicates.append(lambda entry, _neg=negate:
                    bool(entry[0].get('year') not in (None, 0, '', '0')) != _neg)
                continue
            if not val:
                continue
            if op:
                def _year_cmp(entry, _op=op, _val=val, _neg=negate):
                    yr = str(entry[0].get('year', '') or '')
                    matched = _cmp_match(_op, _val, yr)
                    return not matched if _neg else matched
                predicates.append(_year_cmp)
            else:
                def _year_exact(entry, _t=val, _neg=negate):
                    yr = str(entry[0].get('year', '') or '')
                    try:
                        matched = float(yr) == float(_t)
                    except (ValueError, TypeError):
                        matched = yr == _t
                    return not matched if _neg else matched
                predicates.append(_year_exact)

        # watch year  yw:  (только поле watch_date, с нормализацией форматов)
        for (negate, op, val) in watch_year_terms:
            val = val.strip()
            if val == '' and not op:
                predicates.append(lambda entry, _neg=negate:
                    bool(str(entry[0].get('watch_date') or '').strip()) != _neg)
                continue
            if not val:
                continue
            # Нормализуем значение в ISO для корректного сравнения
            _iso_val = _normalise_yw(val) or val
            _iso_len = len(_iso_val)
            if op:
                def _watch_year_cmp(entry, _op=op, _iso=_iso_val, _iso_l=_iso_len, _neg=negate):
                    wd = str(entry[0].get('watch_date', '') or '')
                    # Сравниваем только столько символов, сколько задал пользователь
                    wd_prefix = wd[:_iso_l] if len(wd) >= _iso_l else wd
                    matched = _cmp_match(_op, _iso, wd_prefix)
                    return not matched if _neg else matched
                predicates.append(_watch_year_cmp)
            else:
                def _watch_year_exact(entry, _iso=_iso_val, _iso_l=_iso_len, _neg=negate):
                    wd = str(entry[0].get('watch_date', '') or '')
                    # watch_date начинается с ISO-фрагмента
                    matched = wd[:_iso_l] == _iso
                    return not matched if _neg else matched
                predicates.append(_watch_year_exact)

        # rating  r:
        for (negate, op, val) in rating_terms:
            val = val.strip()
            if val == '' and not op:
                predicates.append(lambda entry, _neg=negate:
                    bool(entry[0].get('rating') not in (None, 0)) != _neg)
                continue
            if not val:
                continue
            if op:
                def _rating_cmp(entry, _op=op, _val=val, _neg=negate):
                    r = entry[0].get('rating')
                    matched = _cmp_match(_op, _val, r)
                    return not matched if _neg else matched
                predicates.append(_rating_cmp)
            else:
                def _rating_exact(entry, _t=val, _neg=negate):
                    r = entry[0].get('rating')
                    if r is None:
                        return _neg  # нет рейтинга — не совпадает
                    try:
                        matched = float(r) == float(_t)
                    except (ValueError, TypeError):
                        matched = str(r) == str(_t)
                    return not matched if _neg else matched
                predicates.append(_rating_exact)

        # users  u:
        for (negate, val) in user_terms:
            if val == '':
                predicates.append(lambda entry, _neg=negate:
                    bool(entry[1]) != _neg)
                continue
            parts = [p for p in val.split('|') if p.strip()] if '|' in val else [val]
            def user_pred(entry, _parts=parts, _neg=negate):
                users = entry[1]
                user_names = [u.get('name', '').lower() for u in users]
                matched = any(
                    any(p.lower() in uname for uname in user_names)
                    for p in _parts
                )
                return not matched if _neg else matched
            predicates.append(user_pred)

        # custom fields
        for prefix, term_list in cf_terms.items():
            fid = cf_prefix_map.get(prefix)
            if fid is None:
                continue
            info  = cf_field_info.get(fid, {})
            ftype   = info.get('type', 'string')
            options = info.get('options', {})
            _numeric_cf = ftype in ('number', 'integer', 'float', 'date')

            for (negate, op, val) in term_list:
                v = val.strip()
                if v == '' and not op:
                    # empty sentinel: prefix: = поле заполнено
                    def _cf_empty_pred(entry, _fid=fid, _neg=negate,
                                       _ftype=ftype, _options=options):
                        raw_val = None
                        for fd_pair in entry[2]:
                            if fd_pair[0].get('id') == _fid:
                                raw_val = fd_pair[1]
                                break
                        if _ftype in ('select', 'marks'):
                            if _ftype == 'select':
                                filled = raw_val not in (None, '', '0', 0)
                            else:
                                try:
                                    ids = json.loads(raw_val) if isinstance(raw_val, str) else []
                                except Exception:
                                    ids = []
                                filled = bool(ids)
                        else:
                            filled = raw_val not in (None, '', '0', 0) and str(raw_val).strip() not in ('', '0')
                        return not filled if _neg else filled
                    predicates.append(_cf_empty_pred)
                    continue
                if not v:
                    continue
                parts = [p for p in v.split('|') if p.strip()] if '|' in v else [v]

                def cf_pred(entry, _fid=fid, _parts=parts, _neg=negate,
                            _ftype=ftype, _options=options, _op=op, _num=_numeric_cf):
                    raw_val = None
                    for fd_pair in entry[2]:
                        if fd_pair[0].get('id') == _fid:
                            raw_val = fd_pair[1]
                            break
                    if raw_val is None:
                        return _neg

                    # Числовые / дата — операторы сравнения
                    if _op and _num:
                        matched = _cmp_match(_op, _parts[0], raw_val)
                        return not matched if _neg else matched

                    if _ftype in ('select', 'marks'):
                        if _ftype == 'select':
                            label = _options.get(str(raw_val), '').lower()
                            matched = any(p.lower() in label for p in _parts)
                        else:
                            try:
                                ids = json.loads(raw_val) if isinstance(raw_val, str) else []
                            except Exception:
                                ids = []
                            labels = [_options.get(str(i), '').lower() for i in ids]
                            matched = any(
                                any(p.lower() in lbl for lbl in labels)
                                for p in _parts
                            )
                    else:
                        # string/text/number — contains или cmp
                        if _op:
                            matched = _cmp_match(_op, _parts[0], raw_val)
                        else:
                            matched = any(p.lower() in str(raw_val).lower() for p in _parts)
                    return not matched if _neg else matched

                predicates.append(cf_pred)

        if not predicates:
            return lambda entry: True

        def final_predicate(entry, _preds=predicates):
            return all(p(entry) for p in _preds)

        return final_predicate
    
    def show_search_help(self):
        dialog = QDialog(self)
        dialog.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        dialog.setWindowTitle(self.translations.get('search_help_title', 'Search Help'))
        dialog.setMinimumWidth(460)
        layout = QVBoxLayout()

        text = QLabel(self.translations.get('search_help_text', (
            "Combine multiple filters in one query:\n\n"
            "· Text — search by title\n"
            "  Example: inception\n\n"
            "· y:year — filter by release year\n"
            "  Examples: y:2007   y:>=2010   y:<2000\n\n"
            "· yw:date — filter by watch year/date (multiple formats supported)\n"
            "  Examples: yw:2024   yw:>=2020   yw:02/2026   yw:20.02.2026\n\n"
            "· r:rating — filter by rating\n"
            "  Examples: r:8   r:>=7   r:<5\n\n"
            "· n:word or n:\"phrase\" — search in notes\n"
            "  Example: n:\"french dub\"\n\n"
            "· u:name or u:\"name1 name2\" — filter by user\n"
            "  Example: u:\"Alex James\"\n\n"
            "· !prefix:value — negate any filter\n"
            "  Examples: !y:2020   !yw:2024   !u:Alex   !r:<=5\n\n"
            "· prefix: or prefix:\"\" — field is not empty\n"
            "  !prefix: or !prefix:\"\" — field is empty\n"
            "  Examples: n:   !n:   r:   !yw:   !u:\n\n"
            "· !word — exclude from title results\n"
            "  Example: !horror\n\n"
            "· word1|word2 — match either\n"
            "  Example: comedy|drama\n\n"
            "· Comparison operators: >=  <=  >  <\n"
            "  Work for y:, yw:, r:, and numeric/date custom fields\n\n"
            "· Combine freely:\n"
            "  n:\"french dub\" inception y:>=2010 r:>=7 !boring"
        )))
        text.setWordWrap(True)
        text.setTextFormat(Qt.PlainText)
        text.setStyleSheet("padding: 10px; color: #ffffff;")
        layout.addWidget(text)

        cf_fields_with_filter = [dict(f) for f in self.db.get_custom_fields() if dict(f).get('search_filter')]
        if cf_fields_with_filter:
            cf_header = QLabel(self.translations.get('search_help_custom_vars', '* Custom filters'))
            cf_header.setStyleSheet("padding: 0 10px; font-weight: bold; color: #ffffff;")
            layout.addWidget(cf_header)

            cf_container = QWidget()
            cf_vbox = QVBoxLayout(cf_container)
            cf_vbox.setContentsMargins(0, 0, 0, 0)
            cf_vbox.setSpacing(2)
            for fd in cf_fields_with_filter:
                cf_line = QLabel(f"  {fd['search_filter']}: — {fd['name']}")
                cf_line.setTextFormat(Qt.PlainText)
                cf_line.setStyleSheet("padding: 0 10px; color: #ffffff;")
                cf_vbox.addWidget(cf_line)

            cf_scroll = QScrollArea()
            cf_scroll.setWidget(cf_container)
            cf_scroll.setWidgetResizable(True)
            cf_scroll.setFrameShape(QScrollArea.NoFrame)
            cf_scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
            cf_scroll.setMaximumHeight(min(len(cf_fields_with_filter) * 22 + 8, 160))
            layout.addWidget(cf_scroll)

        layout.addLayout(self._make_ok_only(dialog))
        dialog.setLayout(layout)
        dialog.exec_()
    
    def _on_sort_activated(self, index):
        """Повторное нажатие на shuffle — перемешать снова."""
        sort_map = {0: 'title', 1: 'year', 2: 'watch_date', 3: 'rating', 4: 'shuffle', 5: 'manual'}
        if sort_map.get(index) == 'shuffle':
            self.sort_items()

    def sort_items(self):
        """Сортировка элементов"""
        _t0 = time.perf_counter()
        sort_map = {0: 'title', 1: 'year', 2: 'watch_date', 3: 'rating', 4: 'shuffle', 5: 'manual'}
        sort_by = sort_map.get(self.sort_combo.currentIndex(), 'watch_date')
        if (self.all_categories_mode or getattr(self, '_tier_mode', False)) and sort_by == 'manual':
            self.sort_combo.blockSignals(True)
            self.sort_combo.setCurrentIndex(2)
            self.sort_combo.blockSignals(False)
            sort_by = 'watch_date'
        self.db.set_setting('sort_by', sort_by)
        is_manual = (sort_by == 'manual')
        is_shuffle = (sort_by == 'shuffle')
        self.sort_order_btn.setVisible(not is_manual and not is_shuffle)
        self._update_items_drag_mode()
        self._save_cat_sort(self.current_category_id if not self.all_categories_mode else None)
        if getattr(self, '_tier_mode', False):
            self.tier_list_widget.reload_pool(**self._tier_load_params())
        else:
            _sel = getattr(self, '_selection_ids', set())
            _scroll_to_id = next(iter(_sel)) if len(_sel) == 1 else None
            self.load_items()
            if _scroll_to_id is not None:
                _row = self._proxy_row_for_id(_scroll_to_id)
                if _row >= 0:
                    self.items_list.scrollTo(self._item_proxy.index(_row, 0), QListView.PositionAtCenter)
            else:
                self.items_list.verticalScrollBar().setValue(0)
        QTimer.singleShot(0, self.items_list.setFocus)
        print(f"[DBG] ◀ sort_items: {(time.perf_counter()-_t0)*1000:.1f} ms  sort={sort_by}")
    

    def _select_all_categories(self):
        """Выделить все категории и папки (CTRL+A для списка категорий)."""
        if self._collapsed_folders:
            self._collapsed_folders.clear()
            self.db.set_setting('collapsed_folders', '')
            self.load_categories(reload_items=False)
        self.categories_list.blockSignals(True)
        self.categories_list.clearSelection()
        for i in range(self.categories_list.count()):
            it = self.categories_list.item(i)
            if it:
                it.setSelected(True)
        self.categories_list.blockSignals(False)

    def _categories_list_key_press(self, event):
        """KeyPress для списка категорий: Delete, Enter. Стрелки и Ctrl+A отключены."""
        key = event.key()
        mods = event.modifiers()
        # Ctrl+A — выделяем все категории и папки
        if key == Qt.Key_A and (mods & Qt.ControlModifier):
            self._select_all_categories()
            return
        # Стрелки — запрещаем навигацию
        if key in (Qt.Key_Up, Qt.Key_Down, Qt.Key_Left, Qt.Key_Right,
                   Qt.Key_PageUp, Qt.Key_PageDown, Qt.Key_Home, Qt.Key_End):
            return
        if key in (Qt.Key_Return, Qt.Key_Enter):
            selected = self.categories_list.selectedItems()
            if len(selected) == 1:
                self.edit_category(selected[0])
            return
        if key == Qt.Key_Delete:
            selected = self.categories_list.selectedItems()
            if not selected:
                return
            cats    = [i for i in selected if not i.data(Qt.UserRole + 2)]
            folders = [i for i in selected if i.data(Qt.UserRole + 2)]
            if len(selected) == 1 and not folders:
                self.delete_category(cats[0])
            elif selected:
                self.delete_categories_batch(cats, folders)
            return
        QListWidget.keyPressEvent(self.categories_list, event)

    def duplicate_categories_batch(self, items):
        """Дублировать несколько категорий — дубликаты идут в самый низ вне папок."""
        if not items:
            return
        names = ', '.join(i.text().split('\n')[0] for i in items[:3])
        if len(items) > 3:
            names += f' и ещё {len(items)-3}'
        dup_dialog = QDialog(self)
        dup_dialog.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        dup_dialog.setWindowTitle(self.translations.get('duplicate', 'Duplicate'))
        dup_dialog.setMinimumWidth(340)
        dup_layout = QVBoxLayout()
        dup_layout.addWidget(QLabel(
            self.translations.get('duplicate_items_confirm', 'Duplicate {} items?').format(len(items))
        ))
        copy_suffix_cb = QCheckBox(self.translations.get('add_copy_suffix', 'Add "-copy" to title'))
        copy_suffix_cb.setChecked(True)
        dup_layout.addWidget(copy_suffix_cb)
        dup_layout.addLayout(self._make_ok_cancel(dup_dialog, dup_dialog.accept, dup_dialog.reject))
        dup_dialog.setLayout(dup_layout)
        if dup_dialog.exec_() != QDialog.Accepted:
            return

        add_suffix = copy_suffix_cb.isChecked()
        cursor = self.db.conn.cursor()

        cursor.execute(
            'SELECT MAX(position) FROM categories WHERE (folder_id IS NULL OR folder_id = 0)'
        )
        max_pos = float(cursor.fetchone()[0] or 0)

        for item in items:
            cat_id = item.data(Qt.UserRole)
            cursor.execute('SELECT * FROM categories WHERE id = ?', (cat_id,))
            cat_data = cursor.fetchone()
            if not cat_data:
                continue

            _copy_sfx = self.translations.get('copy_suffix', '-copy')
            new_name = cat_data['name'] + (' ' + _copy_sfx if add_suffix else '')
            base_name = new_name
            suffix = 1
            while True:
                cursor.execute('SELECT id FROM categories WHERE name = ?', (new_name,))
                if not cursor.fetchone():
                    break
                new_name = f"{base_name} ({suffix})"
                suffix += 1

            dup_icon = cat_data['icon'] or '📁'
            if dup_icon.startswith('file:'):
                orig_path = to_absolute_path(dup_icon[5:])
                if os.path.exists(orig_path):
                    ext = os.path.splitext(orig_path)[1].lower()
                    new_abs = str(ICONS_DIR / f"icon_{uuid.uuid4().hex}{ext}")
                    try:
                        shutil.copy2(orig_path, new_abs)
                        dup_icon = f'file:{to_relative_path(new_abs)}'
                    except Exception:
                        dup_icon = '📁'
                else:
                    dup_icon = '📁'

            max_pos += 1.0
            cursor.execute(
                'INSERT INTO categories (name, icon, position, folder_id) VALUES (?, ?, ?, NULL)',
                (new_name, dup_icon, max_pos)
            )
            new_cat_id = cursor.lastrowid

            cursor.execute('SELECT * FROM items WHERE category_id = ?', (cat_id,))
            orig_items = list(cursor.fetchall())
            item_id_map = {}
            for orig in orig_items:
                new_cover_path = None
                old_cover = to_absolute_path(orig['cover_path'])
                if old_cover and os.path.exists(old_cover):
                    dup_fn = f"cover_{uuid.uuid4().hex}.jpg"
                    dup_abs = str(COVERS_DIR / dup_fn)
                    try:
                        dup_img = Image.open(old_cover)
                        if dup_img.mode != 'RGB':
                            dup_img = dup_img.convert('RGB')
                        dup_img.save(dup_abs, 'JPEG', quality=self.jpg_quality)
                        new_cover_path = to_relative_path(dup_abs)
                    except Exception:
                        pass
                cursor.execute(
                    'INSERT INTO items (category_id, title, year, cover_path, watch_date,'
                    ' notes, rating, is_favorite, time_spent, view_count, custom_position)'
                    ' VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)',
                    (new_cat_id, orig['title'], orig['year'], new_cover_path,
                     orig['watch_date'], orig['notes'], orig['rating'],
                     orig['is_favorite'], orig['time_spent'], orig['view_count'],
                     orig['custom_position'])
                )
                new_item_id = cursor.lastrowid
                item_id_map[orig['id']] = new_item_id
                cursor.execute('SELECT user_id FROM item_users WHERE item_id = ?', (orig['id'],))
                for ur in cursor.fetchall():
                    cursor.execute(
                        'INSERT INTO item_users (item_id, user_id) VALUES (?, ?)',
                        (new_item_id, ur['user_id'])
                    )
                cursor.execute(
                    'SELECT field_id, value FROM custom_field_values WHERE item_id = ?', (orig['id'],)
                )
                for cfr in cursor.fetchall():
                    cursor.execute(
                        'INSERT INTO custom_field_values (item_id, field_id, value) VALUES (?, ?, ?)',
                        (new_item_id, cfr['field_id'], cfr['value'])
                    )

            # ── Дублирование тирлистов ────────────────────────────────────────
            # 1. Конфигурация тиров
            cursor.execute('SELECT config FROM tier_configs WHERE category_id = ?', (cat_id,))
            _tc_row = cursor.fetchone()
            if _tc_row:
                cursor.execute(
                    'INSERT OR REPLACE INTO tier_configs (category_id, config) VALUES (?, ?)',
                    (new_cat_id, _tc_row['config'])
                )

            # 2. Дефолтный тирлист (tier_items)
            cursor.execute(
                'SELECT item_id, tier_key, position FROM tier_items WHERE category_id = ? ORDER BY tier_key, position ASC',
                (cat_id,)
            )
            for _ti in cursor.fetchall():
                _new_iid = item_id_map.get(_ti['item_id'])
                if _new_iid is not None:
                    cursor.execute(
                        'INSERT OR REPLACE INTO tier_items (item_id, category_id, tier_key, position) VALUES (?, ?, ?, ?)',
                        (_new_iid, new_cat_id, _ti['tier_key'], _ti['position'])
                    )

            # 3. Именованные тирлисты (tier_list_sets + tier_list_set_placements)
            cursor.execute(
                'SELECT id, name, order_idx FROM tier_list_sets WHERE category_id = ? ORDER BY order_idx ASC, id ASC',
                (cat_id,)
            )
            for _tls in cursor.fetchall():
                cursor.execute(
                    'INSERT INTO tier_list_sets (category_id, name, order_idx) VALUES (?, ?, ?)',
                    (new_cat_id, _tls['name'], _tls['order_idx'])
                )
                new_set_id = cursor.lastrowid
                cursor.execute(
                    'SELECT item_id, tier_key, position FROM tier_list_set_placements WHERE set_id = ? ORDER BY tier_key, position ASC',
                    (_tls['id'],)
                )
                for _pl in cursor.fetchall():
                    _new_iid = item_id_map.get(_pl['item_id'])
                    if _new_iid is not None:
                        cursor.execute(
                            'INSERT OR REPLACE INTO tier_list_set_placements (set_id, item_id, tier_key, position) VALUES (?, ?, ?, ?)',
                            (new_set_id, _new_iid, _pl['tier_key'], _pl['position'])
                        )

        self.db.commit()
        self.load_categories()
        QTimer.singleShot(0, self._restore_category_selection)

    def delete_categories_batch(self, cats, folders):
        """Удалить несколько категорий и/или папок с подтверждением."""
        if not cats and not folders:
            return
        tr = self.translations.get
        parts = []
        if cats:
            parts.append(f"{len(cats)} {tr('categories_word', 'categories')}")
        if folders:
            parts.append(f"{len(folders)} {tr('folders_word', 'folders')}")
        msg1 = tr('delete_confirm_multi',
                  'Delete {} items?').format(' + '.join(parts))
        if not self._show_dialog_confirm(self, msg1):
            return
        if cats:
            total_items = 0
            c = self.db.conn.cursor()
            for item in cats:
                cid = item.data(Qt.UserRole)
                c.execute('SELECT COUNT(*) FROM items WHERE category_id = ?', (cid,))
                total_items += c.fetchone()[0]
            msg2 = tr(
                'delete_categories_double_confirm',
                'Warning: {} categories contain {} items total. All will be permanently deleted. Continue?'
            ).format(len(cats), total_items)
            if not self._show_dialog_confirm(self, msg2):
                return
        self._do_backup('delete_category')
        for item in folders:
            fid = item.data(Qt.UserRole)
            self.db.delete_folder(fid)
        deleted_cat_ids = []
        for item in cats:
            cid = item.data(Qt.UserRole)
            self.db.delete_category(cid)
            deleted_cat_ids.append(cid)
        # Чистим сохранённые настройки для удалённых категорий
        if deleted_cat_ids:
            _raw = self.db.get_setting('per_cat_sort_data', '{}')
            try:
                _sort_data = json.loads(_raw)
                changed = False
                for _cid in deleted_cat_ids:
                    if str(_cid) in _sort_data:
                        del _sort_data[str(_cid)]
                        changed = True
                if changed:
                    self.db.set_setting('per_cat_sort_data', json.dumps(_sort_data))
            except Exception:
                pass
            _last = self.db.get_setting('last_category', '')
            if _last and int(_last) in deleted_cat_ids:
                self.db.set_setting('last_category', '')
            # Если текущая категория среди удалённых — сбрасываем её явно,
            # чтобы _reload_after_cat_change корректно определил _cat_deleted
            _active_deleted = self.current_category_id in deleted_cat_ids
            if _active_deleted:
                self.current_category_id = None
                self._update_cat_bg(None)
        else:
            _active_deleted = False
        self._reload_after_cat_change(cat_was_deleted=_active_deleted)

    def show_category_context_menu(self, position):
        """Показ контекстного меню для категории или папки"""
        item = self.categories_list.itemAt(position)
        if not item:
            return

        selected = self.categories_list.selectedItems()
        is_folder_click = item.data(Qt.UserRole + 2)

        if is_folder_click:
            # ПКМ по папке: если уже есть мульти-выделение (>1) — используем его,
            # иначе показываем одиночное меню папки
            if len(selected) <= 1 or item not in selected:
                selected = [item]
        elif item not in selected:
            # ПКМ по невыделенной категории — переключаемся на неё
            self.categories_list.clearSelection()
            item.setSelected(True)
            selected = [item]

        multi = len(selected) > 1
        # Папки в выборке
        selected_folders = [i for i in selected if i.data(Qt.UserRole + 2)]
        selected_cats = [i for i in selected if not i.data(Qt.UserRole + 2)]

        menu = QMenu()

        if not multi:
            is_folder = item.data(Qt.UserRole + 2)
            edit_action = QAction(self.translations.get('edit', 'Edit'), self)
            edit_action.triggered.connect(lambda: self.edit_category(item))
            menu.addAction(edit_action)

            if not is_folder:
                duplicate_action = QAction(self.translations.get('duplicate', 'Duplicate'), self)
                duplicate_action.triggered.connect(lambda: self.duplicate_category(item))
                menu.addAction(duplicate_action)

            # Export: одиночная категория или папка
            if not is_folder:
                exp_action = QAction(self.translations.get('export', 'Export'), self)
                _exp_id = item.data(Qt.UserRole)
                exp_action.triggered.connect(lambda checked=False, _id=_exp_id:
                    self.export_category(export_only=True, category_ids=[_id]))
                menu.addAction(exp_action)
            else:
                # Папка — экспортируем все категории внутри
                _folder_id = item.data(Qt.UserRole)
                _folder_cats = []
                for i in range(self.categories_list.count()):
                    it = self.categories_list.item(i)
                    if it and not it.data(Qt.UserRole + 2) and it.data(Qt.UserRole + 3) == _folder_id:
                        _folder_cats.append(it.data(Qt.UserRole))
                if _folder_cats:
                    _folder_name = item.text().strip()
                    exp_folder_action = QAction(self.translations.get('export', 'Export'), self)
                    def _do_export_folder(checked=False, _ids=_folder_cats, _fname=_folder_name):
                        self._export_is_folder = _fname  # имя папки вместо True
                        self.export_category(export_only=True, category_ids=_ids)
                    exp_folder_action.triggered.connect(_do_export_folder)
                    menu.addAction(exp_folder_action)

            menu.addSeparator()

            if is_folder:
                delete_action = QAction(self.translations.get('delete', 'Delete'), self)
                delete_action.triggered.connect(lambda: self.delete_folder_ui(item))
                menu.addAction(delete_action)
            else:
                delete_action = QAction(self.translations.get('delete', 'Delete'), self)
                delete_action.triggered.connect(lambda: self.delete_category(item))
                menu.addAction(delete_action)
        else:
            # Мульти-выборка: Export + Delete (без Duplicate)
            # Собираем все cat IDs: явно выделенные категории + дочерние из выделенных папок
            _sel_cat_ids = [it.data(Qt.UserRole) for it in selected_cats]
            _sel_cat_ids_set = set(_sel_cat_ids)
            for folder_item in selected_folders:
                fid = folder_item.data(Qt.UserRole)
                for i in range(self.categories_list.count()):
                    it = self.categories_list.item(i)
                    if it and not it.data(Qt.UserRole + 2) and it.data(Qt.UserRole + 3) == fid:
                        cid = it.data(Qt.UserRole)
                        if cid not in _sel_cat_ids_set:
                            _sel_cat_ids.append(cid)
                            _sel_cat_ids_set.add(cid)
            if _sel_cat_ids:
                exp_multi_action = QAction(self.translations.get('export', 'Export'), self)
                # Если выделена ровно одна папка (и возможно её дочерние) — передаём folder_name
                _folder_name_for_export = None
                if len(selected_folders) == 1 and not selected_cats:
                    _folder_name_for_export = selected_folders[0].text().strip()
                # Build folder info per category for multi-folder export.
                # Categories that belong to a selected folder header get folder structure.
                # Categories NOT in any selected folder export flat.
                _selected_folder_ids = {_fi.data(Qt.UserRole) for _fi in selected_folders}
                _folder_info_map = {}
                for _fi in selected_folders:
                    _fid   = _fi.data(Qt.UserRole)
                    _fname = _fi.text().strip()
                    _ficon = _fi.data(Qt.UserRole + 1) or '📁'
                    for i in range(self.categories_list.count()):
                        _it = self.categories_list.item(i)
                        if _it and not _it.data(Qt.UserRole + 2) and _it.data(Qt.UserRole + 3) == _fid:
                            _folder_info_map[_it.data(Qt.UserRole)] = {'name': _fname, 'icon': _ficon}
                def _do_multi_export(checked=False, _ids=_sel_cat_ids, _fname=_folder_name_for_export,
                                     _fmap=_folder_info_map):
                    if _fname:
                        self._export_is_folder = _fname
                    self._pending_folder_info_by_cat = _fmap if not _fname else {}
                    self.export_category(export_only=True, category_ids=_ids)
                exp_multi_action.triggered.connect(_do_multi_export)
                menu.addAction(exp_multi_action)
            menu.addSeparator()
            delete_action = QAction(self.translations.get('delete', 'Delete'), self)
            delete_action.triggered.connect(lambda: self.delete_categories_batch(selected_cats, selected_folders))
            menu.addAction(delete_action)

        # Запоминаем все выделенные IDs (категории и папки) до открытия меню
        _selected_ids_before = {
            it.data(Qt.UserRole) for it in self.categories_list.selectedItems()
        }
        menu.exec_(self.categories_list.mapToGlobal(position))
        # После закрытия меню восстанавливаем выделение — включая мульти-выделение и папки.
        # Но не восстанавливаем если экспорт специально его сбросил.
        if getattr(self, '_export_cleared_multiselection', False):
            self._export_cleared_multiselection = False
        else:
            self.categories_list.blockSignals(True)
            self.categories_list.clearSelection()
            for i in range(self.categories_list.count()):
                it = self.categories_list.item(i)
                if it and it.data(Qt.UserRole) in _selected_ids_before:
                    it.setSelected(True)
            self.categories_list.blockSignals(False)
    
    def _make_icon_row(self, dialog, layout, current_icon='📁', default_icon=None):
        """Создать строку выбора иконки: превью слева, поле+кнопки впритык справа."""
        if default_icon is None:
            default_icon = '📁'
        layout.addWidget(QLabel(self.translations.get('icon', 'Icon')))

        if current_icon and current_icon.startswith('file:'):
            _file_icon = [to_absolute_path(current_icon[5:])]
        else:
            _file_icon = [None]

        outer_row = QHBoxLayout()
        outer_row.setSpacing(6)
        outer_row.setContentsMargins(0, 0, 0, 0)

        icon_preview = QLabel()
        icon_preview.setFixedSize(48, 48)
        icon_preview.setAlignment(Qt.AlignCenter)

        def _set_preview_from_file(path):
            pix = _smooth_scale_pixmap(path, 48)
            if not pix.isNull():
                icon_preview.setPixmap(pix)
            else:
                icon_preview.clear()

        def _set_preview_from_emoji(emoji):
            pix = render_emoji_pixmap(emoji, 48, 26)
            icon_preview.setPixmap(pix)

        if _file_icon[0] and os.path.exists(_file_icon[0]):
            _set_preview_from_file(_file_icon[0])
        elif current_icon and not current_icon.startswith('file:'):
            _set_preview_from_emoji(current_icon)
        else:
            _set_preview_from_emoji(default_icon)

        outer_row.addWidget(icon_preview)

        right_row = QHBoxLayout()
        right_row.setSpacing(0)
        right_row.setContentsMargins(0, 0, 0, 0)

        icon_edit = QLineEdit()
        if _file_icon[0]:
            icon_edit.setPlaceholderText(self.translations.get('file_selected', 'File selected'))
            icon_edit.setEnabled(False)
        else:
            if current_icon and not current_icon.startswith('file:'):
                icon_edit.setText(current_icon)
            icon_edit.setPlaceholderText(default_icon)

        right_row.addWidget(icon_edit)

        pick_btn = QPushButton('📂')
        pick_btn.setFixedSize(32, icon_edit.sizeHint().height())
        right_row.addWidget(pick_btn)

        remove_btn = QPushButton()
        remove_btn.setFixedSize(26, icon_edit.sizeHint().height())
        remove_btn.setIcon(_make_close_icon())
        remove_btn.setIconSize(QSize(14, 14))
        _btn_h = icon_edit.sizeHint().height()
        remove_btn.setFixedSize(0, 0) if not _file_icon[0] else remove_btn.setFixedSize(26, _btn_h)
        right_row.addWidget(remove_btn)

        outer_row.addLayout(right_row)
        layout.addLayout(outer_row)

        def _on_text_changed(text):
            if not _file_icon[0]:
                if text and _count_graphemes(text) > 1:
                    icon_edit.blockSignals(True)
                    icon_edit.setText(_first_grapheme(text))
                    icon_edit.blockSignals(False)
                    _set_preview_from_emoji(_first_grapheme(text))
                    return
                _set_preview_from_emoji(text or default_icon)
        icon_edit.textChanged.connect(_on_text_changed)

        def _refresh_state():
            has_file = bool(_file_icon[0])
            icon_edit.setEnabled(not has_file)
            if has_file:
                icon_edit.setPlaceholderText(self.translations.get('file_selected', 'File selected'))
                icon_edit.clear()
                _set_preview_from_file(_file_icon[0])
            else:
                icon_edit.setPlaceholderText(default_icon)
                _set_preview_from_emoji(icon_edit.text() or default_icon)
            remove_btn.setFixedSize(0, 0) if not has_file else remove_btn.setFixedSize(26, _btn_h)

        # Файлы для удаления после OK — не удаляем сразу (пользователь может отменить)
        _original_file = [_file_icon[0]]
        _pending_delete = []   # список путей в ICONS_DIR, которые удалить после OK

        def _on_pick():
            path, _ = QFileDialog.getOpenFileName(dialog, '', '', 'Images (*.ico *.png)')
            if not path:
                return
            dest = str(ICONS_DIR / f"icon_{uuid.uuid4().hex}.png")
            try:
                src_img = Image.open(path)
                if hasattr(src_img, 'n_frames') or getattr(src_img, 'format', '') == 'ICO':
                    try:
                        sizes = src_img.ico.sizes() if hasattr(src_img, 'ico') else []
                        if sizes:
                            src_img = src_img.ico.getimage(max(sizes))
                    except Exception:
                        pass
                if src_img.mode not in ('RGBA', 'RGB'):
                    src_img = src_img.convert('RGBA')
                w, h = src_img.size
                if h > 64:
                    target_h = 64
                    target_w = max(1, int(w * target_h / h))
                    while h > target_h * 2:
                        h = h // 2
                        w = w // 2
                        src_img = src_img.resize((w, h), Image.LANCZOS)
                    src_img = src_img.resize((target_w, target_h), Image.LANCZOS)

                # Откладываем удаление старого файла — только если это наш временный файл
                old_path = _file_icon[0]
                if old_path and str(ICONS_DIR) in old_path and old_path != _original_file[0]:
                    _pending_delete.append(old_path)

                src_img.save(dest, 'PNG')
                _file_icon[0] = dest
                _refresh_state()
            except Exception as e:
                self._show_dialog_warning(dialog, str(e))

        def _on_remove():
            if _file_icon[0] and str(ICONS_DIR) in _file_icon[0] and _file_icon[0] != _original_file[0]:
                _pending_delete.append(_file_icon[0])
            _file_icon[0] = None
            icon_edit.setText('')
            _refresh_state()

        pick_btn.clicked.connect(_on_pick)
        remove_btn.clicked.connect(_on_remove)

        def get_icon():
            """Возвращает (icon_value, paths_to_delete).
            paths_to_delete — только промежуточные временные файлы (не оригинал и не финальный).
            Оригинал удаляется самим update_category/update_custom_field после записи в БД.
            """
            to_delete = list(_pending_delete)
            if _file_icon[0]:
                return f'file:{to_relative_path(_file_icon[0])}', to_delete
            return icon_edit.text().strip(), to_delete

        def set_default_icon(new_default):
            """Змінює дефолтну іконку (placeholder і превью якщо поле порожнє)."""
            nonlocal default_icon
            default_icon = new_default
            if not _file_icon[0]:
                icon_edit.setPlaceholderText(new_default)
                if not icon_edit.text().strip():
                    _set_preview_from_emoji(new_default)

        return icon_edit, get_icon, _set_preview_from_emoji, set_default_icon, _file_icon, _original_file

    def edit_category(self, item=None, from_double_click=False):
        """Редактирование категории или папки"""
        if not item:
            item = self.categories_list.currentItem()
        if not item:
            return

        category_id = item.data(Qt.UserRole)
        is_folder = item.data(Qt.UserRole + 2)

        # Двойной клик по папке — только сворачивает/разворачивает, не открывает редактор
        if is_folder and from_double_click:
            return

        cursor = self.db.conn.cursor()
        cursor.execute('SELECT * FROM categories WHERE id = ?', (category_id,))
        category_data = cursor.fetchone()
        if not category_data:
            return

        dialog = QDialog(self)
        dialog.setWindowFlags(
            Qt.Dialog | Qt.WindowTitleHint | Qt.WindowCloseButtonHint
            | Qt.CustomizeWindowHint | Qt.MSWindowsFixedSizeDialogHint
        )
        
        if is_folder:
            title = self.translations.get('edit_folder', 'Edit Folder')
        else:
            title = self.translations.get('edit_category', 'Edit Category')
        dialog.setWindowTitle(title)
        
        layout = QVBoxLayout(dialog)

        layout.addWidget(QLabel(self.translations.get('name', 'Name')))
        name_edit = QLineEdit()
        name_edit.setMinimumWidth(280)
        name_edit.setText(category_data['name'])
        layout.addWidget(name_edit)

        default_icon = '📂' if is_folder else '🏷'
        _, get_icon, _, _, _file_icon, _original_file = self._make_icon_row(dialog, layout, current_icon=category_data['icon'] or '', default_icon=default_icon)

        # ── Фон категории (только для категорий, не папок) ────────────
        _bg_path    = [category_data['bg_path']    if category_data['bg_path']    else None]
        _bg_overlay = [category_data['bg_overlay'] if category_data['bg_overlay'] is not None else 0.65]
        _bg_pending_delete = [None]

        if not is_folder:
            from PyQt5.QtWidgets import QSlider

            # ── QGroupBox «Background image» ───────────────────────────
            bg_group = QGroupBox(self.translations.get('category_bg', 'Background image'))
            bg_group.setStyleSheet('QGroupBox { padding-top: 14px; margin-top: 4px; }')
            bg_group_layout = QVBoxLayout(bg_group)
            bg_group_layout.setContentsMargins(8, 4, 8, 8)
            bg_group_layout.setSpacing(4)

            # Галочка «Enabled»
            bg_cb = QCheckBox(self.translations.get('bg_enabled', 'Enabled'))
            bg_cb.setChecked(bool(_bg_path[0]))
            bg_group_layout.addWidget(bg_cb)

            # Контейнер с полями — схлопывается/разворачивается по галочке
            bg_container = QWidget()
            bg_cont_layout = QVBoxLayout(bg_container)
            bg_cont_layout.setContentsMargins(0, 2, 0, 0)
            bg_cont_layout.setSpacing(6)

            # Строка выбора файла
            bg_file_row = QHBoxLayout()
            bg_file_row.setSpacing(0)
            bg_file_row.setContentsMargins(0, 0, 0, 0)
            bg_edit = QLineEdit()
            bg_edit.setReadOnly(True)
            bg_edit.setFocusPolicy(Qt.NoFocus)
            bg_edit.setEnabled(False)
            bg_edit.setPlaceholderText(
                self.translations.get('bg_file_selected', 'Background image selected')
                if _bg_path[0] else
                self.translations.get('no_file_selected', 'No file selected'))
            bg_file_row.addWidget(bg_edit)
            bg_pick_btn = QPushButton('📂')
            bg_pick_btn.setFixedSize(32, bg_edit.sizeHint().height())
            bg_file_row.addWidget(bg_pick_btn)
            bg_remove_btn = QPushButton()
            _bg_btn_h = bg_edit.sizeHint().height()
            bg_remove_btn.setFixedSize(26, _bg_btn_h)
            bg_remove_btn.setIcon(_make_close_icon())
            bg_remove_btn.setIconSize(QSize(14, 14))
            bg_remove_btn.setFixedSize(0, 0) if not _bg_path[0] else bg_remove_btn.setFixedSize(26, _bg_btn_h)
            bg_file_row.addWidget(bg_remove_btn)
            bg_cont_layout.addLayout(bg_file_row)

            # Слайдер затемнения
            overlay_row = QHBoxLayout()
            overlay_lbl = QLabel(self.translations.get('bg_overlay', 'Dim:'))
            overlay_slider = QSlider(Qt.Horizontal)
            overlay_slider.setRange(0, 100)
            overlay_slider.setValue(int(_bg_overlay[0] * 100))
            overlay_val_lbl = QLabel(f"{int(_bg_overlay[0] * 100)}%")
            overlay_val_lbl.setFixedWidth(36)
            overlay_row.addWidget(overlay_lbl)
            overlay_row.addWidget(overlay_slider)
            overlay_row.addWidget(overlay_val_lbl)
            bg_cont_layout.addLayout(overlay_row)
            bg_group_layout.addWidget(bg_container)
            layout.addWidget(bg_group)

            overlay_slider.valueChanged.connect(
                lambda v: (_bg_overlay.__setitem__(0, v / 100), overlay_val_lbl.setText(f"{v}%")))

            def _bg_refresh_state():
                has_file = bool(_bg_path[0])
                bg_edit.setPlaceholderText(
                    self.translations.get('bg_file_selected', 'Background image selected')
                    if has_file else
                    self.translations.get('no_file_selected', 'No file selected'))
                bg_remove_btn.setFixedSize(0, 0) if not has_file else bg_remove_btn.setFixedSize(26, _bg_btn_h)

            def _on_bg_cb_toggled(checked):
                bg_container.setMaximumHeight(0 if not checked else 16777215)
                dialog.setMinimumHeight(0)
                dialog.setMaximumHeight(16777215)
                QTimer.singleShot(0, dialog.adjustSize)
            bg_cb.toggled.connect(_on_bg_cb_toggled)
            # Инициализируем начальное состояние
            bg_container.setMaximumHeight(0 if not _bg_path[0] else 16777215)

            def _on_bg_pick():
                path, _ = QFileDialog.getOpenFileName(dialog, '', '', 'Images (*.jpg *.jpeg *.png *.webp *.bmp)')
                if not path:
                    return
                try:
                    new_path = _process_category_bg(path)
                    if _bg_path[0] and _bg_path[0] != new_path:
                        _bg_pending_delete[0] = _bg_path[0]
                    _bg_path[0] = new_path
                    bg_cb.setChecked(True)
                    _bg_refresh_state()
                except Exception as ex:
                    _show_dialog_error(dialog, self.translations.get('image_process_error', 'Failed to process image: {}').format(ex), self.translations)

            def _on_bg_remove():
                if _bg_path[0]:
                    _bg_pending_delete[0] = _bg_path[0]
                _bg_path[0] = None
                _bg_refresh_state()

            bg_pick_btn.clicked.connect(_on_bg_pick)
            bg_remove_btn.clicked.connect(_on_bg_remove)

        def _on_edit_accept():
            if not name_edit.text().strip():
                self._show_dialog_warning(dialog, self.translations.get('name_required', 'Name is required'))
                return
            dialog.accept()
        layout.addLayout(self._make_ok_cancel(dialog, _on_edit_accept))
        _original_bg = [category_data['bg_path'] if category_data['bg_path'] else None]
        if dialog.exec_() == QDialog.Accepted:
            name = name_edit.text().strip()
            icon, icon_to_delete = get_icon()
            for _p in (icon_to_delete or []):
                _safe_delete_file(_p, self.db.conn)
            if name:
                # Определяем финальные значения bg
                if not is_folder:
                    use_bg    = bg_cb.isChecked() and _bg_path[0]
                    final_bg  = _bg_path[0] if use_bg else None
                    final_ov  = _bg_overlay[0]
                    # Удаляем старый файл если заменили или сняли галочку
                    if _bg_pending_delete[0]:
                        try: os.remove(_bg_pending_delete[0])
                        except Exception: pass
                    if not use_bg and _bg_path[0] and _bg_path[0] == category_data['bg_path']:
                        # Сняли галочку без замены — удаляем старый файл
                        try: os.remove(to_absolute_path(final_bg) if final_bg else '')
                        except Exception: pass
                        final_bg = None
                else:
                    final_bg = None
                    final_ov = 0.65
                try:
                    self.db.update_category(category_id, name, icon,
                                            bg_path=to_relative_path(final_bg) if final_bg else None,
                                            bg_overlay=final_ov)
                    # Обновляем overlay если это текущая категория
                    if category_id == self.current_category_id:
                        self._update_cat_bg(category_id)
                    self.load_categories(reload_items=False)
                except Exception as _e:
                    self._show_dialog_warning(self, str(_e))
        else:
            # Отмена — удаляем текущий временный файл + промежуточные
            if _file_icon[0] and _file_icon[0] != _original_file[0]:
                _safe_delete_file(_file_icon[0], self.db.conn)
            _, _icon_tmp_files = get_icon()
            for _p in (_icon_tmp_files or []):
                _safe_delete_file(_p, self.db.conn)
            # Удаляем новый bg если он был загружен и отличается от оригинального
            if not is_folder and _bg_path[0] and to_relative_path(_bg_path[0]) != _original_bg[0]:
                try: os.remove(_bg_path[0])
                except Exception: pass
    
    def duplicate_category(self, item):
        """Дублирование категории"""
        if not item:
            return

        category_id = item.data(Qt.UserRole)
        cursor = self.db.conn.cursor()
        cursor.execute('SELECT * FROM categories WHERE id = ?', (category_id,))
        cat_data = cursor.fetchone()
        if not cat_data:
            return

        dup_dialog = QDialog(self)
        dup_dialog.setWindowFlag(Qt.MSWindowsFixedSizeDialogHint)
        dup_dialog.setWindowTitle(self.translations.get('duplicate', 'Duplicate'))
        dup_dialog.setMinimumWidth(320)
        dup_layout = QVBoxLayout()
        dup_layout.addWidget(QLabel(self.translations.get('duplicate_item', 'Duplicate item:') + f" {cat_data['name']}"))
        copy_suffix_cb = QCheckBox(self.translations.get('add_copy_suffix', 'Add "-copy" to title'))
        copy_suffix_cb.setChecked(True)
        dup_layout.addWidget(copy_suffix_cb)
        dup_layout.addLayout(self._make_ok_cancel(dup_dialog, dup_dialog.accept, dup_dialog.reject))
        dup_dialog.setLayout(dup_layout)

        if dup_dialog.exec_() != QDialog.Accepted:
            return

        new_name = cat_data['name']
        if copy_suffix_cb.isChecked():
            _copy_sfx = self.translations.get('copy_suffix', '-copy')
            new_name = new_name + ' ' + _copy_sfx

        # Имена категорий не обязаны быть уникальными — уникален id

        cursor.execute('SELECT COUNT(*) FROM categories WHERE position != 0')
        if cursor.fetchone()[0] == 0:
            cursor.execute('SELECT id FROM categories ORDER BY id ASC')
            ids = [r[0] for r in cursor.fetchall()]
            cursor.executemany('UPDATE categories SET position = ? WHERE id = ?',
                               [(float(i + 1), iid) for i, iid in enumerate(ids)])

        cursor.execute('SELECT position FROM categories WHERE id = ?', (category_id,))
        orig_pos_row = cursor.fetchone()
        orig_pos = float(orig_pos_row[0]) if orig_pos_row else 0.0

        cursor.execute(
            'SELECT id, position FROM categories WHERE position > ? AND id != ? ORDER BY position ASC LIMIT 1',
            (orig_pos, category_id)
        )
        next_row = cursor.fetchone()
        if next_row:
            new_pos = (orig_pos + float(next_row[1])) / 2.0
        else:
            new_pos = orig_pos + 1.0

        dup_icon = cat_data['icon'] or '📁'
        if dup_icon.startswith('file:'):
            orig_icon_path = to_absolute_path(dup_icon[5:])
            if os.path.exists(orig_icon_path):
                ext = os.path.splitext(orig_icon_path)[1].lower()
                _new_icon_abs = str(ICONS_DIR / f"icon_{uuid.uuid4().hex}{ext}")
                try:
                    shutil.copy2(orig_icon_path, _new_icon_abs)
                    dup_icon = f'file:{to_relative_path(_new_icon_abs)}'
                except Exception:
                    dup_icon = '📁'
            else:
                dup_icon = '📁'

        orig_folder_id = cat_data['folder_id'] if 'folder_id' in cat_data.keys() else None
        cursor.execute(
            'INSERT INTO categories (name, icon, position, folder_id) VALUES (?, ?, ?, ?)',
            (new_name, dup_icon, new_pos, orig_folder_id)
        )
        new_cat_id = cursor.lastrowid

        cursor.execute('SELECT * FROM items WHERE category_id = ?', (category_id,))
        orig_items = cursor.fetchall()

        item_id_map = {}
        for orig in orig_items:
            new_cover_path = None
            old_cover = to_absolute_path(orig['cover_path'])
            if old_cover and os.path.exists(old_cover):
                _dup_filename = f"cover_{uuid.uuid4().hex}.jpg"
                _dup_abs = str(COVERS_DIR / _dup_filename)
                try:
                    dup_img = Image.open(old_cover)
                    if dup_img.mode != 'RGB':
                        dup_img = dup_img.convert('RGB')
                    dup_img.save(_dup_abs, 'JPEG', quality=self.jpg_quality)
                    new_cover_path = to_relative_path(_dup_abs)
                except Exception:
                    new_cover_path = None

            cursor.execute('''
                INSERT INTO items (category_id, title, year, cover_path, watch_date, notes,
                                   rating, is_favorite, time_spent, view_count, custom_position)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            ''', (new_cat_id, orig['title'], orig['year'], new_cover_path,
                  orig['watch_date'], orig['notes'], orig['rating'],
                  orig['is_favorite'], orig['time_spent'], orig['view_count'],
                  orig['custom_position']))
            new_item_id = cursor.lastrowid

            cursor.execute('SELECT user_id FROM item_users WHERE item_id = ?', (orig['id'],))
            _user_ids = [r['user_id'] for r in cursor.fetchall()]
            if _user_ids:
                cursor.executemany(
                    'INSERT INTO item_users (item_id, user_id) VALUES (?, ?)',
                    [(new_item_id, uid) for uid in _user_ids]
                )

            cursor.execute('SELECT field_id, value FROM custom_field_values WHERE item_id = ?', (orig['id'],))
            _cf_rows = cursor.fetchall()
            if _cf_rows:
                cursor.executemany(
                    'INSERT INTO custom_field_values (item_id, field_id, value) VALUES (?, ?, ?)',
                    [(new_item_id, r['field_id'], r['value']) for r in _cf_rows]
                )
            item_id_map[orig['id']] = new_item_id

        # ── Дублирование тирлистов ────────────────────────────────────────
        # 1. Конфигурация тиров (названия/цвета тиров)
        cursor.execute('SELECT config FROM tier_configs WHERE category_id = ?', (category_id,))
        _tc_row = cursor.fetchone()
        if _tc_row:
            cursor.execute(
                'INSERT OR REPLACE INTO tier_configs (category_id, config) VALUES (?, ?)',
                (new_cat_id, _tc_row['config'])
            )

        # 2. Дефолтный тирлист (tier_items)
        cursor.execute(
            'SELECT item_id, tier_key, position FROM tier_items WHERE category_id = ? ORDER BY tier_key, position ASC',
            (category_id,)
        )
        for _ti in cursor.fetchall():
            _new_iid = item_id_map.get(_ti['item_id'])
            if _new_iid is not None:
                cursor.execute(
                    'INSERT OR REPLACE INTO tier_items (item_id, category_id, tier_key, position) VALUES (?, ?, ?, ?)',
                    (_new_iid, new_cat_id, _ti['tier_key'], _ti['position'])
                )

        # 3. Именованные тирлисты (tier_list_sets + tier_list_set_placements)
        cursor.execute(
            'SELECT id, name, order_idx FROM tier_list_sets WHERE category_id = ? ORDER BY order_idx ASC, id ASC',
            (category_id,)
        )
        for _tls in cursor.fetchall():
            cursor.execute(
                'INSERT INTO tier_list_sets (category_id, name, order_idx) VALUES (?, ?, ?)',
                (new_cat_id, _tls['name'], _tls['order_idx'])
            )
            new_set_id = cursor.lastrowid
            cursor.execute(
                'SELECT item_id, tier_key, position FROM tier_list_set_placements WHERE set_id = ? ORDER BY tier_key, position ASC',
                (_tls['id'],)
            )
            for _pl in cursor.fetchall():
                _new_iid = item_id_map.get(_pl['item_id'])
                if _new_iid is not None:
                    cursor.execute(
                        'INSERT OR REPLACE INTO tier_list_set_placements (set_id, item_id, tier_key, position) VALUES (?, ?, ?, ?)',
                        (new_set_id, _new_iid, _pl['tier_key'], _pl['position'])
                    )

        self.db.commit()
        self._reload_after_cat_change()

    def delete_category(self, item):
        """Удаление категории"""
        if not item:
            return
        
        tr = self.translations.get
        if not self._show_dialog_confirm(self, tr('delete_category_confirm', 'Delete this category? All items inside will be deleted too.')):
            return
        category_id = item.data(Qt.UserRole)
        c = self.db.conn.cursor()
        c.execute('SELECT COUNT(*) FROM items WHERE category_id = ?', (category_id,))
        item_count = c.fetchone()[0]
        msg2 = tr('delete_category_double_confirm',
            'Warning: This category contains {} items. All will be permanently deleted. Continue?'
        ).format(item_count)
        if not self._show_dialog_confirm(self, msg2):
            return
        self._do_backup('delete_category')
        self.db.delete_category(category_id)
        _raw = self.db.get_setting('per_cat_sort_data', '{}')
        try:
            _sort_data = json.loads(_raw)
            if str(category_id) in _sort_data:
                del _sort_data[str(category_id)]
                self.db.set_setting('per_cat_sort_data', json.dumps(_sort_data))
        except Exception:
            pass
        # Если удалённая категория была последней выбранной — сбрасываем
        if str(self.db.get_setting('last_category', '')) == str(category_id):
            self.db.set_setting('last_category', '')
        _active_deleted = self.current_category_id == category_id
        if _active_deleted:
            self.current_category_id = None
            self._update_cat_bg(None)
        self._reload_after_cat_change(cat_was_deleted=_active_deleted)
    
    def delete_folder_ui(self, item):
        """Удалить папку с опцией удаления категорий внутри"""
        if not item:
            return
        folder_id = item.data(Qt.UserRole)
        folder_name = item.text().strip()
        cursor = self.db.conn.cursor()
        cursor.execute('SELECT id FROM categories WHERE folder_id = ?', (folder_id,))
        child_ids = [r[0] for r in cursor.fetchall()]
        child_count = len(child_ids)
        tr = self.translations.get

        # Диалог с чекбоксом
        dlg = QDialog(self)
        dlg.setWindowFlags(dlg.windowFlags() & ~Qt.WindowContextHelpButtonHint)
        dlg.setWindowTitle(tr('delete_folder', 'Delete folder'))
        dlg.setMinimumWidth(340)
        vbox = QVBoxLayout(dlg)
        vbox.setSpacing(10)

        msg_lbl = QLabel(tr('delete_folder_confirm',
            'Delete this folder? All categories inside will be moved out of it.'))
        msg_lbl.setWordWrap(True)
        vbox.addWidget(msg_lbl)

        also_delete_cb = None
        if child_count > 0:
            also_delete_cb = QCheckBox(tr('delete_folder_also_categories',
                'Also delete all {} categories inside (and their items)').format(child_count))
            also_delete_cb.setStyleSheet('')

            vbox.addWidget(also_delete_cb)

        btn_row = QHBoxLayout()
        btn_row.addStretch()
        ok_btn = QPushButton(tr('delete', 'Delete'))
        cancel_btn = QPushButton(tr('cancel', 'Cancel'))
        ok_btn.setDefault(True)
        ok_btn.clicked.connect(dlg.accept)
        cancel_btn.clicked.connect(dlg.reject)
        btn_row.addWidget(ok_btn)
        btn_row.addWidget(cancel_btn)
        vbox.addLayout(btn_row)

        if dlg.exec_() != QDialog.Accepted:
            return

        also_delete = also_delete_cb is not None and also_delete_cb.isChecked()

        if also_delete and child_ids:
            # Двойное подтверждение — считаем items
            total_items = 0
            for cid in child_ids:
                cursor.execute('SELECT COUNT(*) FROM items WHERE category_id = ?', (cid,))
                total_items += cursor.fetchone()[0]
            msg2 = tr('delete_categories_double_confirm',
                'Warning: {} categories contain {} items total. All will be permanently deleted. Continue?'
            ).format(child_count, total_items)
            if not self._show_dialog_confirm(self, msg2):
                return
            self._do_backup('delete_category')
            for cid in child_ids:
                self.db.delete_category(cid)
        else:
            self._do_backup('delete_category')

        self.db.delete_folder(folder_id)
        # Сбрасываем текущую категорию только если она была в удалённой папке
        # или если она сама была удалена (also_delete)

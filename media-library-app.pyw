class _CancelledError(Exception):
    """Internal sentinel for cooperative cancellation in worker threads."""


class HtmlExportWorker(QThread):
    """Фоновый экспорт HTML с прогрессом."""
    progress  = pyqtSignal(int, str)
    finished  = pyqtSignal()
    cancelled = pyqtSignal()
    error     = pyqtSignal(str)

    def __init__(self, category_id, file_path, img_mode,
                 sort_by, ascending, translations, app_icon_b64=None,
                 fallback_img_mode=None, date_fmt='ISO'):
        super().__init__()
        self._cancel_event    = threading.Event()
        self.category_id      = category_id
        self.file_path        = file_path
        self.img_mode         = img_mode
        self.fallback_img_mode = fallback_img_mode  # если >1000 обложек — переключить на этот
        self.sort_by          = sort_by
        self.ascending        = ascending
        self.translations     = translations
        self.app_icon_b64     = app_icon_b64
        self.date_fmt         = date_fmt

    def cancel(self):
        self._cancel_event.set()

    def run(self):
        self.setTerminationEnabled(False)  # не убивать поток принудительно
        try:
            _db = Database()

            self.progress.emit(5, self.translations.get('progress_preparing', 'Preparing...'))

            template = _get_export_template()

            lang_data = {
                'rating':      self.translations.get('rating', 'Rating'),
                'not_rated':   self.translations.get('not_rated', 'Not rated'),
                'watch_date':  self.translations.get('watch_date', 'Watch Date'),
                'view_count':  self.translations.get('view_count', 'View Count'),
                'time_spent':  self.translations.get('time_spent', 'Time Spent'),
                'hours':       self.translations.get('hours', 'h'),
                'watched_with':self.translations.get('watched_with', 'Watched with'),
                'notes':       self.translations.get('notes', 'Notes'),
                'no_notes':    self.translations.get('no_notes', 'No notes'),
                'search_placeholder': self.translations.get('search_placeholder', 'Search (Ctrl+F)...'),
                'sort_label':         self.translations.get('sort', 'Sort:'),
                'sort_title':         self.translations.get('sort_title', 'By Title'),
                'sort_year':          self.translations.get('sort_year', 'By Year'),
                'sort_watch_date':    self.translations.get('sort_watch_date', 'By Watch Date'),
                'sort_rating':        self.translations.get('sort_rating', 'By Rating'),
                'sort_manual':        self.translations.get('sort_manual', 'Manual'),
                'sort_asc':           self.translations.get('ascending', 'Ascending'),
                'sort_desc':          self.translations.get('descending', 'Descending'),
                'favorites_only':     self.translations.get('favorites_only', 'Favorites only'),
                'all_time':           self.translations.get('all_time', 'All time'),
                'select_an_item':     self.translations.get('select_an_item', 'Select an item'),
            }

            base_name = os.path.splitext(os.path.basename(self.file_path))[0]

            self.progress.emit(10, self.translations.get('progress_loading_data', 'Loading data...'))
            category_name_row = _db.conn.cursor().execute(
                'SELECT name FROM categories WHERE id=?', (self.category_id,)
            ).fetchone()
            category_name = category_name_row['name'] if category_name_row else ''

            items = _db.get_items(self.category_id, sort_by=self.sort_by, ascending=self.ascending)
            _all_ids   = [dict(r)['id'] for r in items]
            _users_map = _db.get_users_for_items(_all_ids)
            _cf_map    = _db.get_custom_fields_for_items_batch(_all_ids)
            cf_fields  = [dict(f) for f in _db.get_custom_fields()]

            # Если base64 выбран но обложек > 1000 — тихо переключаем на fallback
            if self.img_mode == 'base64' and self.fallback_img_mode:
                _cover_cnt = _db.conn.cursor().execute(
                    'SELECT COUNT(*) FROM items WHERE category_id=?'
                    ' AND cover_path IS NOT NULL AND cover_path != ""',
                    (self.category_id,)
                ).fetchone()[0]
                if _cover_cnt > 1000:
                    self.img_mode = self.fallback_img_mode

            # Создаём папки ПОСЛЕ возможного переключения img_mode
            covers_dir    = None
            icons_dir_out = None
            if self.img_mode == 'folder':
                covers_dir    = os.path.join(os.path.dirname(self.file_path), base_name + '_covers')
                icons_dir_out = os.path.join(os.path.dirname(self.file_path), base_name + '_icons')
                os.makedirs(covers_dir,    exist_ok=True)
                os.makedirs(icons_dir_out, exist_ok=True)

            if self._cancel_event.is_set():
                self.cancelled.emit(); return

            # ── Батчевое чтение обложек параллельно (как в CSV) ──────────────────
            # Собираем пути обложек для всех элементов заранее
            _cover_paths = {}  # iid → abs_path
            for row in items:
                item = dict(row)
                cp = to_absolute_path(item.get('cover_path'))
                if cp and os.path.exists(cp):
                    _cover_paths[item['id']] = cp

            # base64: читаем все файлы параллельно через ThreadPoolExecutor
            _cover_b64 = {}   # iid → data-uri
            _cover_fname = {} # iid → filename (для folder mode)
            if self.img_mode == 'base64' and _cover_paths:
                def _read_b64(iid_path):
                    iid, path = iid_path
                    try:
                        with open(path, 'rb') as f:
                            raw = f.read()
                        ext  = os.path.splitext(path)[1].lower().lstrip('.')
                        mime = 'jpeg' if ext in ('jpg', 'jpeg') else ext
                        return iid, f"data:image/{mime};base64,{base64.b64encode(raw).decode()}"
                    except Exception:
                        return iid, None
                with ThreadPoolExecutor(max_workers=8) as pool:
                    futures = {pool.submit(_read_b64, (iid, p)): iid
                               for iid, p in _cover_paths.items()}
                    done = 0
                    total_covers = len(futures)
                    for fut in as_completed(futures):
                        if self._cancel_event.is_set():
                            self.cancelled.emit(); return
                        iid, uri = fut.result()
                        if uri:
                            _cover_b64[iid] = uri
                        done += 1
                        pct = 15 + int(done / max(total_covers, 1) * 40)
                        self.progress.emit(pct, self.translations.get('progress_loading_covers', 'Loading covers') + f' {done}/{total_covers}...')

            elif self.img_mode == 'folder' and _cover_paths:
                # folder: копируем параллельно
                def _copy_cover(iid_title_path):
                    iid, title, path = iid_title_path
                    try:
                        safe = ''.join(
                            c for c in (title or 'cover') if c.isalnum() or c in ' _-'
                        ).strip()[:50] or 'cover'
                        ext   = os.path.splitext(path)[1]
                        fname = f"{iid}_{safe}{ext}"
                        shutil.copy2(path, os.path.join(covers_dir, fname))
                        return iid, fname
                    except Exception:
                        return iid, None
                _items_dict = {dict(r)['id']: dict(r) for r in items}
                tasks = [(iid, (_items_dict[iid].get('title') or ''), p)
                         for iid, p in _cover_paths.items()]
                with ThreadPoolExecutor(max_workers=8) as pool:
                    futures = {pool.submit(_copy_cover, t): t[0] for t in tasks}
                    done = 0
                    total_covers = len(futures)
                    for fut in as_completed(futures):
                        if self._cancel_event.is_set():
                            self.cancelled.emit(); return
                        iid, fname = fut.result()
                        if fname:
                            _cover_fname[iid] = fname
                        done += 1
                        pct = 15 + int(done / max(total_covers, 1) * 40)
                        self.progress.emit(pct, self.translations.get('progress_copying_covers', 'Copying covers') + f' {done}/{total_covers}...')

            if self._cancel_event.is_set():
                self.cancelled.emit(); return

            # icon b64 cache (иконки кастомных полей — их мало, без параллелизма)
            _icon_b64_cache = {}
            def _icon_to_b64(icon_str):
                if not icon_str or not icon_str.startswith('file:'):
                    return None
                if icon_str in _icon_b64_cache:
                    return _icon_b64_cache[icon_str]
                try:
                    abs_p = to_absolute_path(icon_str[5:])
                    if abs_p and os.path.exists(abs_p):
                        with open(abs_p, 'rb') as fh:
                            raw = fh.read()
                        ext  = os.path.splitext(abs_p)[1].lower().lstrip('.')
                        mime = 'png' if ext == 'png' else 'jpeg'
                        uri  = f"data:image/{mime};base64,{base64.b64encode(raw).decode()}"
                        _icon_b64_cache[icon_str] = uri
                        return uri
                except Exception:
                    pass
                _icon_b64_cache[icon_str] = None
                return None

            def _icon_to_folder(icon_str):
                if not icon_str or not icon_str.startswith('file:'):
                    return None
                try:
                    abs_p = to_absolute_path(icon_str[5:])
                    if abs_p and os.path.exists(abs_p):
                        fname = os.path.basename(abs_p)
                        dest  = os.path.join(icons_dir_out, fname)
                        if not os.path.exists(dest):
                            shutil.copy2(abs_p, dest)
                        return f"{base_name}_icons/{fname}"
                except Exception:
                    pass
                return None

            cf_def = []
            for fd in cf_fields:
                icon_str = fd.get('icon') or ''
                emoji = icon_str if (icon_str and not icon_str.startswith('file:')) else '🧩'
                cf_def.append({'id': fd['id'], 'variable': fd['variable'],
                               'name': fd['name'], 'icon_emoji': emoji})

            total = len(items)
            items_data = []

            self.progress.emit(58, self.translations.get('progress_processing', 'Processing') + '...')
            for i, row in enumerate(items):
                if self._cancel_event.is_set():
                    self.cancelled.emit(); return

                item    = dict(row)
                iid     = item['id']
                users   = _users_map.get(iid, [])
                cf_vals = _cf_map.get(iid, {})

                # cover — берём из уже подготовленного кэша
                cover_src = None
                thumb_src = None
                if self.img_mode == 'base64':
                    uri = _cover_b64.get(iid)
                    if uri:
                        cover_src = thumb_src = uri
                elif self.img_mode == 'folder':
                    fname = _cover_fname.get(iid)
                    if fname:
                        cover_src = thumb_src = f"{base_name}_covers/{fname}"

                # custom fields
                cf_list   = []
                cf_detail = []
                for fd in cf_fields:
                    fid   = fd['id']
                    ftype = fd.get('field_type', 'string')
                    val   = cf_vals.get(fid)
                    if val is None:
                        continue
                    if ftype == 'boolean':
                        dv = '✓' if val == '1' else None
                    elif ftype in ('integer', 'slider'):
                        try:   dv = None if int(val) == 0 else str(val)
                        except: dv = val
                    elif ftype in ('marks', 'select'):
                        dv = _resolve_display_value(_db, fd, val)
                    else:
                        dv = str(val)
                    if not dv:
                        continue

                    icon_str     = fd.get('icon') or ''
                    is_file_icon = icon_str.startswith('file:')
                    if self.img_mode == 'none' or not is_file_icon:
                        icon_b64   = None
                        icon_emoji = icon_str if (icon_str and not is_file_icon) else '🧩'
                    elif self.img_mode == 'base64':
                        icon_b64   = _icon_to_b64(icon_str)
                        icon_emoji = '🧩'
                    else:
                        icon_b64   = _icon_to_folder(icon_str)
                        icon_emoji = '🧩'

                    if fd.get('show_in_list'):
                        cf_list.append({'icon': icon_emoji, 'icon_b64': icon_b64, 'val': dv})
                    if fd.get('show_in_detail', 1):
                        cf_detail.append({'name': fd['name'], 'val': dv})

                items_data.append({
                    'id':          iid,
                    'title':       item.get('title') or '',
                    'year':        item.get('year'),
                    'rating':      item.get('rating') or 0,
                    'is_favorite': bool(item.get('is_favorite')),
                    'watch_date':  item.get('watch_date') or '',
                    'notes':       item.get('notes') or '',
                    'time_spent':  item.get('time_spent') or 0,
                    'view_count':  item.get('view_count') or 1,
                    'users':       [u['name'] for u in users],
                    'cover_src':   cover_src,
                    'thumb_src':   thumb_src,
                    'cf_list':     cf_list,
                    'cf_detail':   cf_detail,
                })

            self.progress.emit(92, self.translations.get('progress_writing_html', 'Writing HTML...'))
            if self._cancel_event.is_set():
                self.cancelled.emit(); return

            # HTML экспорт всегда открывается по дате, по возрастанию
            _default_sort = 'watch_date'

            favicon_tag = ''
            if self.app_icon_b64:
                favicon_tag = (f'<link rel="icon" type="image/png" '
                               f'href="data:image/png;base64,{self.app_icon_b64}">')

            # ── Tier data ─────────────────────────────────────────────
            tier_config = _db.get_tier_config(self.category_id)
            tier_items  = _db.get_tier_items(self.category_id)
            # build id→item lookup for quick access
            _id_map = {d['id']: d for d in items_data}

            def _build_tier_data(items_by_key):
                result = []
                for t in tier_config:
                    key   = t['key']
                    ids   = items_by_key.get(key, [])
                    cells = [_id_map[i] for i in ids if i in _id_map]
                    result.append({
                        'key':   key,
                        'label': t.get('label', key),
                        'color': t.get('color', '#888'),
                        'items': cells,
                    })
                return result

            tier_data = _build_tier_data(tier_items)

            # Build tier sets data (named lists)
            raw_sets = _db.get_tier_list_sets(self.category_id)
            tier_sets_data = []
            for s in raw_sets:
                # get_tier_set_items already returns {tier_key: [item_id,...]}
                items_by_key = _db.get_tier_set_items(s['id'])
                tier_sets_data.append({
                    'id':    s['id'],
                    'name':  s['name'],
                    'tiers': _build_tier_data(items_by_key),
                })

            html = template.replace('{{category_name}}', category_name)
            html = html.replace('{{items_json}}',      json.dumps(items_data,      ensure_ascii=False))
            html = html.replace('{{lang_json}}',       json.dumps(lang_data,       ensure_ascii=False))
            html = html.replace('{{cf_def_json}}',     json.dumps(cf_def,          ensure_ascii=False))
            html = html.replace('{{tier_json}}',       json.dumps(tier_data,       ensure_ascii=False))
            html = html.replace('{{tier_sets_json}}',  json.dumps(tier_sets_data,  ensure_ascii=False))
            html = html.replace('{{default_sort}}',    json.dumps(_default_sort))
            html = html.replace('{{favicon}}',         favicon_tag)
            html = html.replace('{{date_fmt}}',        self.date_fmt)

            with open(self.file_path, 'w', encoding='utf-8') as f:
                f.write(html)

            self.finished.emit()

        except Exception as e:
            self.error.emit(str(e))


class MultiHtmlExportWorker(QThread):
    """Мульти HTML экспорт — все категории последовательно, один диалог прогресса."""
    progress  = pyqtSignal(int, str)
    finished  = pyqtSignal()
    cancelled = pyqtSignal()
    error     = pyqtSignal(str)

    def __init__(self, category_ids, tmp_dir, img_mode, sort_by, ascending,
                 translations, app_icon_b64, db_getter, date_fmt='ISO'):
        super().__init__()
        self._cancel_event  = threading.Event()
        self.category_ids   = category_ids
        self.tmp_dir        = tmp_dir
        self.img_mode       = img_mode
        self.sort_by        = sort_by
        self.ascending      = ascending
        self.translations   = translations
        self.app_icon_b64   = app_icon_b64
        self.db_getter      = db_getter   # callable → Database()
        self.html_files     = []          # [(arcname, path)] после успеха
        self.date_fmt       = date_fmt

    def cancel(self):
        self._cancel_event.set()

    def run(self):
        self.setTerminationEnabled(False)  # не убивать поток принудительно
        try:
            _db = self.db_getter()
            total = len(self.category_ids)
            fallback = 'folder' if self.img_mode == 'base64' else None

            for i, cid in enumerate(self.category_ids):
                if self._cancel_event.is_set():
                    self.cancelled.emit(); return

                row = _db.conn.cursor().execute(
                    'SELECT name FROM categories WHERE id=?', (cid,)
                ).fetchone()
                cname = row['name'] if row else str(cid)
                safe  = ''.join(c for c in cname if c.isalnum() or c in ' _-').strip()[:60] or str(cid)
                html_path = os.path.join(self.tmp_dir, safe + '.html')

                base_pct = int(i / total * 95)
                cat_label = f'{cname} ({i+1}/{total})'
                self.progress.emit(base_pct, cat_label)

                # Вложенный воркер запускаем синхронно (мы уже в отдельном потоке)
                hw = HtmlExportWorker(
                    category_id=cid, file_path=html_path,
                    img_mode=self.img_mode, sort_by=self.sort_by,
                    ascending=self.ascending, translations=self.translations,
                    app_icon_b64=self.app_icon_b64, fallback_img_mode=fallback,
                    date_fmt=self.date_fmt)
                hw._cancel_event = self._cancel_event  # общий cancel

                # Прогресс воркера → масштабируем в [base_pct, base_pct + 95/total]
                _slice = 95 / total
                def _on_sub_progress(pct, msg, _base=base_pct, _slice=_slice):
                    self.progress.emit(int(_base + pct / 100 * _slice), msg)
                hw.progress.connect(_on_sub_progress)

                hw.run()  # синхронно — мы в QThread

                if self._cancel_event.is_set():
                    self.cancelled.emit(); return

                if os.path.exists(html_path):
                    self.html_files.append((safe + '.html', html_path))

            self.progress.emit(98, self.translations.get('progress_writing_html', 'Writing HTML...'))
            self.finished.emit()
        except Exception as e:
            self.error.emit(str(e))


class ExportWorker(QThread):
    """Фоновый экспорт CSV/ZIP с прогрессом."""
    progress     = pyqtSignal(int, str)   # (percent, message)
    finished     = pyqtSignal()
    cancelled    = pyqtSignal()
    error        = pyqtSignal(str)

    def __init__(self, db, category_id, file_path, export_images,
                 export_custom_fields, icon_mode, jpg_quality,
                 as_zip=False, sort_by='watch_date', ascending=False,
                 include_category_info=True, translations=None):
        super().__init__()
        self._cancel_event         = threading.Event()
        self.db_path               = str(DB_PATH)
        self.category_id           = category_id
        self.file_path             = file_path
        self.export_images         = export_images
        self.export_custom_fields  = export_custom_fields
        self.icon_mode             = icon_mode
        self.jpg_quality           = jpg_quality
        self.as_zip                = as_zip
        self.sort_by               = sort_by
        self.ascending             = ascending
        self.include_category_info = include_category_info
        self.translations          = translations or {}

    def cancel(self):
        self._cancel_event.set()

    def run(self):
        self.setTerminationEnabled(False)  # не убивать поток принудительно
        try:
            _db = Database()
            base_name = os.path.splitext(os.path.basename(self.file_path))[0]

            self.progress.emit(5, self.translations.get('progress_building_csv', 'Building CSV...'))

            if self.as_zip:
                tmp_dir = tempfile.mkdtemp()
                try:
                    csv_path   = os.path.join(tmp_dir, base_name + '.csv')
                    images_dir = os.path.join(tmp_dir, base_name + '_covers') if self.export_images else None
                    icons_dir  = os.path.join(tmp_dir, base_name + '_icons') \
                                 if (self.export_custom_fields and self.icon_mode == 'folder') else None
                    bg_dir     = os.path.join(tmp_dir, base_name + '_bg') \
                                 if self.include_category_info else None
                    if images_dir: os.makedirs(images_dir, exist_ok=True)
                    if icons_dir:  os.makedirs(icons_dir,  exist_ok=True)
                    if bg_dir:     os.makedirs(bg_dir,     exist_ok=True)

                    self.progress.emit(10, self.translations.get('progress_exporting_data', 'Exporting data...'))
                    if self._cancel_event.is_set():
                        self.cancelled.emit(); return

                    def _csv_cover_progress_zip(done, total, msg):
                        if self._cancel_event.is_set():
                            raise _CancelledError()
                        # обложки занимают диапазон 10..45%
                        pct = 10 + int(done / max(total, 1) * 35)
                        self.progress.emit(pct, msg)
                    lines, warnings = _db.export_csv_build(
                        category_id=self.category_id,
                        include_items=True,
                        include_custom_fields=self.export_custom_fields,
                        include_users=True,
                        icon_mode=self.icon_mode,
                        icons_dir=icons_dir,
                        export_images=self.export_images,
                        images_dir=images_dir,
                        bg_dir=bg_dir,
                        sort_by=self.sort_by,
                        ascending=self.ascending,
                        include_category_info=self.include_category_info,
                        progress_callback=_csv_cover_progress_zip if self.export_images else None,
                        translations=self.translations,
                    )
                    if self._cancel_event.is_set():
                        self.cancelled.emit(); return

                    _db.export_csv_write(csv_path, lines)
                    self.progress.emit(47, self.translations.get('progress_packing_zip', 'Packing ZIP...'))

                    all_files = [csv_path]
                    if images_dir and os.path.isdir(images_dir):
                        for f in os.listdir(images_dir):
                            all_files.append(os.path.join(images_dir, f))
                    if icons_dir and os.path.isdir(icons_dir):
                        for f in os.listdir(icons_dir):
                            all_files.append(os.path.join(icons_dir, f))
                    if bg_dir and os.path.isdir(bg_dir) and os.listdir(bg_dir):
                        for f in os.listdir(bg_dir):
                            all_files.append(os.path.join(bg_dir, f))

                    total = len(all_files)
                    with zipfile.ZipFile(self.file_path, 'w', zipfile.ZIP_STORED) as zf:
                        for i, fpath in enumerate(all_files):
                            if self._cancel_event.is_set():
                                raise _CancelledError()
                            arcname = os.path.relpath(fpath, tmp_dir)
                            zf.write(fpath, arcname)
                            pct = 50 + int((i + 1) / total * 48)
                            self.progress.emit(pct, self.translations.get('progress_compressing', 'Compressing...'))
                except _CancelledError:
                    # ZIP was being written — delete the incomplete output file
                    shutil.rmtree(tmp_dir, ignore_errors=True)
                    if os.path.exists(self.file_path):
                        try: os.remove(self.file_path)
                        except Exception: pass
                    self.cancelled.emit()
                    return
                finally:
                    shutil.rmtree(tmp_dir, ignore_errors=True)
            else:
                file_dir   = os.path.dirname(self.file_path)
                images_dir = os.path.join(file_dir, base_name + '_covers') if self.export_images else None
                icons_dir  = os.path.join(file_dir, base_name + '_icons') \
                             if (self.export_custom_fields and self.icon_mode == 'folder') else None
                created_images_dir = False
                created_icons_dir  = False
                if images_dir:
                    os.makedirs(images_dir, exist_ok=True)
                    created_images_dir = True
                if icons_dir:
                    os.makedirs(icons_dir, exist_ok=True)
                    created_icons_dir = True

                self.progress.emit(20, self.translations.get('progress_exporting_data', 'Exporting data...'))
                if self._cancel_event.is_set():
                    # Clean up empty dirs we just created
                    if created_images_dir and os.path.isdir(images_dir) and not os.listdir(images_dir):
                        shutil.rmtree(images_dir, ignore_errors=True)
                    if created_icons_dir and os.path.isdir(icons_dir) and not os.listdir(icons_dir):
                        shutil.rmtree(icons_dir, ignore_errors=True)
                    self.cancelled.emit(); return

                def _csv_cover_progress(done, total, msg):
                    if self._cancel_event.is_set():
                        raise _CancelledError()
                    # обложки занимают диапазон 20..75%
                    pct = 20 + int(done / max(total, 1) * 55)
                    self.progress.emit(pct, msg)
                lines, warnings = _db.export_csv_build(
                    category_id=self.category_id,
                    include_items=True,
                    include_custom_fields=self.export_custom_fields,
                    include_users=True,
                    icon_mode=self.icon_mode,
                    icons_dir=icons_dir,
                    export_images=self.export_images,
                    images_dir=images_dir,
                    sort_by=self.sort_by,
                    ascending=self.ascending,
                    include_category_info=self.include_category_info,
                    progress_callback=_csv_cover_progress if self.export_images else None,
                    translations=self.translations,
                )
                if self._cancel_event.is_set():
                    # CSV not written yet — delete partial images/icons dirs
                    if created_images_dir and os.path.isdir(images_dir):
                        shutil.rmtree(images_dir, ignore_errors=True)
                    if created_icons_dir and os.path.isdir(icons_dir):
                        shutil.rmtree(icons_dir, ignore_errors=True)
                    self.cancelled.emit(); return

                self.progress.emit(80, self.translations.get('progress_writing_csv', 'Writing CSV...'))
                _db.export_csv_write(self.file_path, lines)

            self.finished.emit()
        except _CancelledError:
            self.cancelled.emit()
        except Exception as e:
            # Удаляем незаконченный выходной файл при ошибке
            if self.as_zip and hasattr(self, 'file_path') and os.path.exists(self.file_path):
                try: os.remove(self.file_path)
                except Exception: pass
            self.error.emit(str(e))




class MultiExportWorker(QThread):
    """Фоновый экспорт нескольких категорий в один ZIP."""
    progress  = pyqtSignal(int, str)   # (percent, message)
    finished  = pyqtSignal()
    cancelled = pyqtSignal()
    error     = pyqtSignal(str)

    def __init__(self, db, category_ids, file_path,
                 export_images, export_custom_fields, icon_mode, jpg_quality,
                 sort_by='watch_date', ascending=False, folder_name=None, translations=None,
                 folder_info_by_cat=None):
        super().__init__()
        self._cancel_event       = threading.Event()
        self.db_path             = str(DB_PATH)
        self.category_ids        = category_ids
        self.file_path           = file_path
        self.export_images       = export_images
        self.export_custom_fields= export_custom_fields
        self.icon_mode           = icon_mode
        self.jpg_quality         = jpg_quality
        self.sort_by             = sort_by
        self.ascending           = ascending
        self.folder_name         = folder_name
        self.translations        = translations or {}
        # dict: cat_id -> {'name': str, 'icon': str}  — used for multi-folder export
        self.folder_info_by_cat  = folder_info_by_cat or {}

    def cancel(self):
        self._cancel_event.set()

    def run(self):
        self.setTerminationEnabled(False)  # не убивать поток принудительно
        try:
            _db = Database()

            total = len(self.category_ids)
            tmp_dir = tempfile.mkdtemp()

            try:
                all_zip_files = []
                _cat_id_to_safe_name = {}  # for folder grouping in Case B

                for idx, cat_id in enumerate(self.category_ids):
                    if self._cancel_event.is_set():
                        self.cancelled.emit(); return

                    # Получаем имя категории
                    cursor = _db.conn.cursor()
                    cursor.execute('SELECT name FROM categories WHERE id = ?', (cat_id,))
                    row = cursor.fetchone()
                    cat_name = row[0] if row else f'category_{cat_id}'

                    # Безопасное имя для файловой системы
                    safe_name = "".join(
                        c for c in cat_name if c.isalnum() or c in ' _-'
                    ).strip()[:50].strip() or f'category_{cat_id}'
                    # Append cat_id to guarantee uniqueness even if two categories
                    # produce the same safe_name (identical or similar titles).
                    safe_name = f'{safe_name}_{cat_id}'
                    _cat_id_to_safe_name[cat_id] = safe_name

                    pct_start = int(idx / total * 90)
                    pct_end   = int((idx + 1) / total * 90)
                    self.progress.emit(pct_start, f"{self.translations.get('progress_exporting', 'Exporting')}: {cat_name}")

                    cat_dir    = os.path.join(tmp_dir, safe_name)
                    os.makedirs(cat_dir, exist_ok=True)
                    csv_path   = os.path.join(cat_dir, safe_name + '.csv')
                    images_dir = os.path.join(cat_dir, safe_name + '_covers') if self.export_images else None
                    icons_dir  = os.path.join(cat_dir, safe_name + '_icons') \
                                 if (self.export_custom_fields and self.icon_mode == 'folder') else None
                    bg_dir     = os.path.join(cat_dir, safe_name + '_bg')
                    if images_dir: os.makedirs(images_dir, exist_ok=True)
                    if icons_dir:  os.makedirs(icons_dir,  exist_ok=True)
                    os.makedirs(bg_dir, exist_ok=True)

                    def _multi_cover_progress(done, total_covers, msg,
                                              _ps=pct_start, _pe=pct_end):
                        if self._cancel_event.is_set():
                            raise _CancelledError()
                        pct = _ps + int(done / max(total_covers, 1) * (_pe - _ps))
                        _msg = self.translations.get('progress_copying_covers', 'Copying covers') + f' {done}/{total_covers}...'
                        self.progress.emit(pct, _msg)

                    lines, _ = _db.export_csv_build(
                        category_id=cat_id,
                        include_items=True,
                        include_custom_fields=self.export_custom_fields,
                        include_users=True,
                        icon_mode=self.icon_mode,
                        icons_dir=icons_dir,
                        export_images=self.export_images,
                        images_dir=images_dir,
                        bg_dir=bg_dir,
                        sort_by=self.sort_by,
                        ascending=self.ascending,
                        include_category_info=True,
                        progress_callback=_multi_cover_progress if self.export_images else None,
                    )

                    if self._cancel_event.is_set():
                        self.cancelled.emit(); return

                    _db.export_csv_write(csv_path, lines)
                    all_zip_files.append((csv_path, os.path.join(safe_name, safe_name + '.csv')))

                    if images_dir and os.path.isdir(images_dir):
                        for f in os.listdir(images_dir):
                            src = os.path.join(images_dir, f)
                            all_zip_files.append((src, os.path.join(safe_name, safe_name + '_covers', f)))
                    if icons_dir and os.path.isdir(icons_dir):
                        for f in os.listdir(icons_dir):
                            src = os.path.join(icons_dir, f)
                            all_zip_files.append((src, os.path.join(safe_name, safe_name + '_icons', f)))
                    if bg_dir and os.path.isdir(bg_dir):
                        for f in os.listdir(bg_dir):
                            src = os.path.join(bg_dir, f)
                            all_zip_files.append((src, os.path.join(safe_name, safe_name + '_bg', f)))

                    self.progress.emit(pct_end, f"{self.translations.get('progress_done', 'Done')}: {cat_name}")

                if self._cancel_event.is_set():
                    self.cancelled.emit(); return

                # ── Folder structure handling ──────────────────────────────
                # Case A: single-folder export (legacy path, folder_name set)
                if self.folder_name and not self.folder_info_by_cat:
                    _folder_icon = ''
                    try:
                        _fc = _db.conn.cursor()
                        _fc.execute(
                            'SELECT icon FROM categories WHERE is_folder=1 AND name=? LIMIT 1',
                            (self.folder_name,))
                        _fr = _fc.fetchone()
                        if _fr:
                            _folder_icon = _fr[0] or '📁'
                    except Exception:
                        _folder_icon = '📁'
                    _folder_csv_path = os.path.join(tmp_dir, '_folder.csv')
                    with open(_folder_csv_path, 'w', encoding='utf-8', newline='') as _f:
                        _w = csv.writer(_f)
                        _w.writerow(['#FOLDER'])
                        _w.writerow(['name', 'icon'])
                        _w.writerow([self.folder_name, _folder_icon])
                    all_zip_files.insert(0, (_folder_csv_path, '_folder.csv'))

                # Case B: multi-folder export — group categories by folder,
                # wrap each folder group into its own inner ZIP with a _folder.csv.
                # Categories without a folder stay as plain CSV entries in the outer ZIP.
                elif self.folder_info_by_cat:
                    # Collect unique folders present in this export
                    _folder_keys = {}  # folder_name -> folder_icon
                    for _cid, _finfo in self.folder_info_by_cat.items():
                        _fn = _finfo['name']
                        if _fn not in _folder_keys:
                            _folder_keys[_fn] = _finfo['icon']

                    # Group all_zip_files by folder using the direct cat_id->safe_name map
                    _folder_arc_files = {_fn: [] for _fn in _folder_keys}
                    _no_folder_arc_files = []

                    # Build reverse: safe_name -> cat_id
                    _safe_name_to_cat = {v: k for k, v in _cat_id_to_safe_name.items()}

                    for _src, _arc in all_zip_files:
                        # Normalize separators — on Windows os.path.join uses backslash
                        _arc_norm = _arc.replace('\\', '/')
                        _arc_prefix = _arc_norm.split('/')[0]
                        _arc_cat_id = _safe_name_to_cat.get(_arc_prefix)
                        _finfo = self.folder_info_by_cat.get(_arc_cat_id) if _arc_cat_id is not None else None
                        if _finfo:
                            _folder_arc_files[_finfo['name']].append((_src, _arc))
                        else:
                            _no_folder_arc_files.append((_src, _arc))

                    # Create one inner ZIP per folder group
                    _inner_zip_entries = []  # (inner_zip_path, arcname_in_outer)
                    for _fn, _ficon in _folder_keys.items():
                        _fan = _folder_arc_files.get(_fn, [])
                        if not _fan:
                            continue
                        _safe_fn = "".join(c for c in _fn if c.isalnum() or c in ' _-').strip()[:40] or 'folder'
                        _inner_zip_path = os.path.join(tmp_dir, f'_folder_{_safe_fn}.zip')
                        # Write _folder.csv inside the inner ZIP
                        _inner_folder_csv = os.path.join(tmp_dir, f'_folder_{_safe_fn}.csv')
                        with open(_inner_folder_csv, 'w', encoding='utf-8', newline='') as _if:
                            _iw = csv.writer(_if)
                            _iw.writerow(['#FOLDER'])
                            _iw.writerow(['name', 'icon'])
                            _iw.writerow([_fn, _ficon or '📁'])
                        with zipfile.ZipFile(_inner_zip_path, 'w', zipfile.ZIP_STORED) as _izf:
                            _izf.write(_inner_folder_csv, '_folder.csv')
                            for _src, _arc in _fan:
                                _izf.write(_src, _arc)
                        _inner_zip_entries.append((_inner_zip_path, f'{_safe_fn}_folder.zip'))

                    # Rebuild all_zip_files: inner ZIPs + loose (no-folder) entries
                    all_zip_files = _inner_zip_entries + _no_folder_arc_files

                self.progress.emit(90, self.translations.get('progress_packing_zip', 'Packing ZIP...'))
                with zipfile.ZipFile(self.file_path, 'w', zipfile.ZIP_STORED) as zf:
                    for i, (src, arcname) in enumerate(all_zip_files):
                        if self._cancel_event.is_set():
                            raise _CancelledError()
                        zf.write(src, arcname)
                        pct = 90 + int((i + 1) / max(len(all_zip_files), 1) * 9)
                        self.progress.emit(pct, self.translations.get('progress_compressing', 'Compressing...'))

            except _CancelledError:
                shutil.rmtree(tmp_dir, ignore_errors=True)
                if os.path.exists(self.file_path):
                    try: os.remove(self.file_path)
                    except Exception: pass
                self.cancelled.emit()
                return
            finally:
                shutil.rmtree(tmp_dir, ignore_errors=True)

            self.finished.emit()
        except _CancelledError:
            self.cancelled.emit()
        except Exception as e:
            self.error.emit(str(e))

class ImportWorker(QThread):
    """Фоновый импорт CSV (из файла или ZIP) с прогрессом."""
    progress  = pyqtSignal(int, str)
    finished  = pyqtSignal(int)   # imported_count
    cancelled = pyqtSignal()
    error     = pyqtSignal(str)

    def __init__(self, db, file_path, category_id,
                 import_images, jpg_quality,
                 parsed, diff,
                 apply_new_fields, apply_changed_fields,
                 apply_new_options, apply_changed_options,
                 apply_new_users,
                 images_dir, icons_dir, zip_src_path=None, covers_prefix=None, icons_prefix=None, apply_bg=False, translations=None):
        super().__init__()
        self._cancel_event       = threading.Event()
        self.db_path             = str(DB_PATH)
        self.file_path           = file_path
        self.category_id         = category_id
        self.import_images       = import_images
        self.jpg_quality         = jpg_quality
        self.parsed              = parsed
        self.diff                = diff
        self.apply_new_fields    = apply_new_fields
        self.apply_changed_fields= apply_changed_fields
        self.apply_new_options   = apply_new_options
        self.apply_changed_options=apply_changed_options
        self.apply_new_users     = apply_new_users
        self.images_dir          = images_dir
        self.icons_dir           = icons_dir
        self.zip_src_path        = zip_src_path  # original ZIP for lazy cover extraction
        self.covers_prefix       = covers_prefix  # ZIP path prefix for this category's covers
        self.icons_prefix        = icons_prefix   # ZIP path prefix for this category's icons
        self._imported_ids       = []   # track inserted item ids for rollback
        self.translations        = translations or {}
        self.apply_bg            = apply_bg  # применять ли фон категории при импорте

    def cancel(self):
        self._cancel_event.set()

    def run(self):
        self.setTerminationEnabled(False)  # не убивать поток принудительно
        try:
            self.progress.emit(5, self.translations.get('progress_starting_import', 'Starting import...'))
            _db = Database()

            # Extract covers directly from ZIP into COVERS_DIR with uuid names.
            # No tmp dir, no rename — just write straight to destination.
            if self.import_images and self.zip_src_path and not self.images_dir:
                self.progress.emit(8, self.translations.get('progress_extracting_covers', 'Extracting covers...'))
                try:
                    name_remap = {}
                    with zipfile.ZipFile(self.zip_src_path, 'r') as zf:
                        for member in zf.namelist():
                            ml = member.lower()
                            if '_covers/' not in ml or member.endswith('/'):
                                continue
                            # If covers_prefix set, only extract covers for this category
                            if self.covers_prefix and not ml.startswith(self.covers_prefix):
                                continue
                            if self._cancel_event.is_set():
                                raise _CancelledError()
                            orig = os.path.basename(member)
                            ext  = os.path.splitext(orig)[1] or '.jpg'
                            uuid_name = f'cover_{uuid.uuid4().hex}{ext}'
                            dest = str(COVERS_DIR / uuid_name)
                            with zf.open(member) as src_f, open(dest, 'wb') as dst_f:
                                dst_f.write(src_f.read())
                            name_remap[orig] = uuid_name
                    for item_row in (self.parsed.get('items') or []):
                        orig = item_row.get('cover', '').strip()
                        if orig in name_remap:
                            item_row['cover'] = name_remap[orig]
                    self.images_dir = str(COVERS_DIR)
                except _CancelledError:
                    # Удаляем уже извлечённые обложки при отмене
                    for _uuid_name in name_remap.values():
                        _orphan = str(COVERS_DIR / _uuid_name)
                        try:
                            if os.path.exists(_orphan): os.remove(_orphan)
                        except Exception: pass
                    raise
                except Exception:
                    pass

            # Применяем фон категории если нужно
            if self.apply_bg and self.zip_src_path:
                _cat_rows = (self.parsed or {}).get('category', [])
                if _cat_rows:
                    _bg_fname = _cat_rows[0].get('bg_path', '').strip()
                    _bg_overlay_str = _cat_rows[0].get('bg_overlay', '0.65')
                    if _bg_fname:
                        try:
                            _bg_overlay_val = float(_bg_overlay_str) if _bg_overlay_str else 0.65
                        except (ValueError, TypeError):
                            _bg_overlay_val = 0.65
                        try:
                            # Ищем файл фона в ZIP: safe_name/_bg/filename или просто _bg/filename
                            with zipfile.ZipFile(self.zip_src_path, 'r') as _zf:
                                _bg_members = [m for m in _zf.namelist()
                                               if '_bg/' in m.lower() and os.path.basename(m) == _bg_fname
                                               and not m.endswith('/')]
                                if _bg_members:
                                    _bg_member = _bg_members[0]
                                    _bg_ext    = os.path.splitext(_bg_fname)[1] or '.jpg'
                                    _bg_uuid   = f'bg_{uuid.uuid4().hex}{_bg_ext}'
                                    _bg_dest   = str(CATEGORY_BG_DIR / _bg_uuid)
                                    with _zf.open(_bg_member) as _src_f:
                                        with open(_bg_dest, 'wb') as _dst_f:
                                            _dst_f.write(_src_f.read())
                                    _db.update_category_bg(
                                        self.category_id,
                                        to_relative_path(_bg_dest),
                                        _bg_overlay_val
                                    )
                        except Exception:
                            pass  # фон не критичен — молча пропускаем

            def _progress_cb(pct, msg):
                if self._cancel_event.is_set():
                    raise _CancelledError()
                self.progress.emit(pct, msg)
            count = _db.import_csv_apply(
                parsed=self.parsed,
                diff=self.diff,
                category_id=self.category_id,
                apply_new_fields=self.apply_new_fields,
                apply_changed_fields=self.apply_changed_fields,
                apply_new_options=self.apply_new_options,
                apply_changed_options=self.apply_changed_options,
                apply_new_users=self.apply_new_users,
                import_images=self.import_images,
                images_dir=self.images_dir if self.import_images else None,
                icons_dir=self.icons_dir,
                zip_src=self.zip_src_path,
                icons_prefix=self.icons_prefix,
                jpg_quality=self.jpg_quality,
                progress_cb=_progress_cb,
                translations=self.translations,
            )
            self.finished.emit(count or 0)
        except _CancelledError:
            self.cancelled.emit()
        except Exception as e:
            self.error.emit(str(e))


# ── Unused-images list (virtual model + lazy-thumbnail delegate) ─────────────

class UnusedImagesModel(QAbstractListModel):
    """Stores only file paths and check state. Thumbnails loaded on demand by delegate."""
    PathRole  = Qt.UserRole
    CheckRole = Qt.UserRole + 1

    def __init__(self, parent=None):
        super().__init__(parent)
        self._paths   = []   # str
        self._checked = []   # bool

    def append(self, fpath):
        row = len(self._paths)
        self.beginInsertRows(QModelIndex(), row, row)
        self._paths.append(fpath)
        self._checked.append(True)
        self.endInsertRows()

    def set_all(self, paths):
        """Bulk-load all paths at once — much faster than append() in a loop."""
        self.beginResetModel()
        self._paths   = list(paths)
        self._checked = [True] * len(self._paths)
        self.endResetModel()

    def clear(self):
        self.beginResetModel()
        self._paths.clear()
        self._checked.clear()
        self.endResetModel()

    def rowCount(self, parent=QModelIndex()):
        return len(self._paths)

    def data(self, index, role=Qt.DisplayRole):
        if not index.isValid() or not (0 <= index.row() < len(self._paths)):
            return None
        fpath = self._paths[index.row()]
        if role == Qt.DisplayRole:      return os.path.basename(fpath)
        if role == self.PathRole:       return fpath
        if role == self.CheckRole:      return self._checked[index.row()]
        if role == Qt.CheckStateRole:   return Qt.Checked if self._checked[index.row()] else Qt.Unchecked
        return None

    def setData(self, index, value, role=Qt.EditRole):
        if not index.isValid():
            return False
        if role == Qt.CheckStateRole:
            self._checked[index.row()] = (value == Qt.Checked)
            self.dataChanged.emit(index, index, [Qt.CheckStateRole])
            return True
        return False

    def flags(self, index):
        return Qt.ItemIsEnabled | Qt.ItemIsSelectable | Qt.ItemIsUserCheckable

    def checked_paths(self):
        return [p for p, c in zip(self._paths, self._checked) if c]

    def remove_rows_by_paths(self, paths_set):
        to_remove = [i for i, p in enumerate(self._paths) if p in paths_set]
        for i in sorted(to_remove, reverse=True):
            self.beginRemoveRows(QModelIndex(), i, i)
            self._paths.pop(i)
            self._checked.pop(i)
            self.endRemoveRows()

    def total(self):
        return len(self._paths)


class UnusedImagesDelegate(QStyledItemDelegate):
    """Renders thumbnail loaded on-demand from disk; LRU cache inside delegate."""
    THUMB_W  = 60
    THUMB_H  = 90
    PAD      = 6
    CB_SIZE  = 16
    CACHE_MAX = 600   # max pixmaps kept; ~600 × 21KB ≈ 12MB

    def __init__(self, parent=None):
        super().__init__(parent)
        self._cache = {}   # fpath → QPixmap
        self._lru   = []   # fpath, insertion order

    def _get_thumb(self, fpath):
        if fpath in self._cache:
            # bump to end
            self._lru.remove(fpath)
            self._lru.append(fpath)
            return self._cache[fpath]
        pix = QPixmap(fpath)
        if pix.isNull():
            return None
        thumb = pix.scaled(self.THUMB_W, self.THUMB_H,
                            Qt.KeepAspectRatio, Qt.SmoothTransformation)
        if len(self._lru) >= self.CACHE_MAX:
            evict = self._lru.pop(0)
            self._cache.pop(evict, None)
        self._cache[fpath] = thumb
        self._lru.append(fpath)
        return thumb

    def sizeHint(self, option, index):
        return QSize(self.THUMB_W + self.CB_SIZE + self.PAD * 3 + 160,
                     self.THUMB_H + self.PAD * 2)

    def paint(self, painter, option, index):
        painter.save()
        rect = option.rect

        if option.state & QStyle.State_Selected:
            painter.fillRect(rect, option.palette.highlight())

        x = rect.left() + self.PAD
        y = rect.top() + self.PAD

        # checkbox
        cb_rect = QRect(x, rect.top() + (rect.height() - self.CB_SIZE) // 2,
                        self.CB_SIZE, self.CB_SIZE)
        checked = index.data(UnusedImagesModel.CheckRole)
        cb_opt = QStyleOptionButton()
        cb_opt.rect = cb_rect
        cb_opt.state = QStyle.State_Enabled
        cb_opt.state |= QStyle.State_On if checked else QStyle.State_Off
        QApplication.style().drawControl(QStyle.CE_CheckBox, cb_opt, painter)
        x += self.CB_SIZE + self.PAD

        # thumbnail — loaded from disk only when this row is painted
        fpath = index.data(UnusedImagesModel.PathRole) or ''
        thumb_rect = QRect(x, y, self.THUMB_W, self.THUMB_H)
        thumb = self._get_thumb(fpath) if fpath else None
        if thumb:
            px = x + (self.THUMB_W - thumb.width())  // 2
            py = y + (self.THUMB_H - thumb.height()) // 2
            painter.drawPixmap(px, py, thumb)
        else:
            painter.setPen(QColor('#444'))
            painter.drawRect(thumb_rect)
            painter.setPen(QColor('#666'))
            painter.drawText(thumb_rect, Qt.AlignCenter, '?')
        x += self.THUMB_W + self.PAD

        # filename + path
        fname = index.data(Qt.DisplayRole) or ''
        text_rect = QRect(x, y, rect.right() - x - self.PAD, self.THUMB_H)
        painter.setPen(option.palette.color(
            option.palette.HighlightedText if (option.state & QStyle.State_Selected)
            else option.palette.Text))
        fm = painter.fontMetrics()
        painter.drawText(text_rect.adjusted(0, 4, 0, 0),
                         Qt.AlignTop | Qt.TextWordWrap,
                         fm.elidedText(fname, Qt.ElideMiddle, text_rect.width()))
        painter.setPen(QColor('#888'))
        small = painter.font()
        small.setPointSize(max(7, small.pointSize() - 2))
        painter.setFont(small)
        painter.drawText(text_rect.adjusted(0, fm.height() + 8, 0, 0),
                         Qt.AlignTop | Qt.TextWordWrap,
                         fm.elidedText(fpath, Qt.ElideLeft, text_rect.width()))

        painter.setPen(QColor('#333'))
        painter.drawLine(rect.left(), rect.bottom(), rect.right(), rect.bottom())
        painter.restore()

    def editorEvent(self, event, model, option, index):
        if event.type() == QEvent.MouseButtonRelease:
            cb_rect = QRect(
                option.rect.left() + self.PAD,
                option.rect.top() + (option.rect.height() - self.CB_SIZE) // 2,
                self.CB_SIZE, self.CB_SIZE
            )
            if cb_rect.contains(event.pos()):
                cur = index.data(Qt.CheckStateRole)
                new_val = Qt.Unchecked if cur == Qt.Checked else Qt.Checked
                model.setData(index, new_val, Qt.CheckStateRole)
                return True
        return False


class ScanUnusedWorker(QThread):
    """Scans covers/icons dirs for files not referenced in DB."""
    progress   = pyqtSignal(int, str)   # pct, message
    finished   = pyqtSignal(list)       # list of unused absolute paths
    cancelled  = pyqtSignal()
    error      = pyqtSignal(str)

    def __init__(self, db_path, covers_dir, icons_dir, bg_dir=None, translations=None):
        super().__init__()
        self.db_path       = db_path
        self.covers_dir    = covers_dir
        self.icons_dir     = icons_dir
        self.bg_dir        = bg_dir
        self.translations  = translations or {}
        self._cancel_event = threading.Event()

    def cancel(self):
        self._cancel_event.set()

    def run(self):
        self.setTerminationEnabled(False)  # не убивать поток принудительно
        try:
            self.progress.emit(5, self.translations.get('progress_collecting_files', 'Collecting files...'))
            all_files = []
            dirs_to_scan = [d for d in (self.covers_dir, self.icons_dir, self.bg_dir) if d]
            for d in dirs_to_scan:
                if not os.path.isdir(str(d)):
                    continue
                entries = os.listdir(str(d))
                for i, f in enumerate(entries):
                    if self._cancel_event.is_set():
                        self.cancelled.emit(); return
                    fpath = str(Path(d) / f)
                    if os.path.isfile(fpath):
                        all_files.append(fpath)
                    if i % 50 == 0:
                        collecting_msg = self.translations.get('progress_collecting_files', 'Collecting files...')
                        self.progress.emit(5, f"{collecting_msg} {i + 1}/{len(entries)}")

            total = len(all_files)
            self.progress.emit(15, self.translations.get('progress_querying_db', 'Querying database ({} files)...').format(total))

            if self._cancel_event.is_set():
                self.cancelled.emit(); return

            conn = sqlite3.connect(self.db_path)
            conn.row_factory = sqlite3.Row
            cursor = conn.cursor()
            used = set()
            cursor.execute('SELECT cover_path FROM items WHERE cover_path IS NOT NULL')
            for row in cursor.fetchall():
                if row[0]:
                    used.add(to_absolute_path(row[0]))
            cursor.execute('SELECT icon FROM categories WHERE icon LIKE "file:%"')
            for row in cursor.fetchall():
                if row[0]:
                    v = row[0]
                    if not v.startswith('file:base64:') and not v.startswith('file:folder:'):
                        used.add(to_absolute_path(v[5:]))
            cursor.execute('SELECT icon FROM custom_fields WHERE icon LIKE "file:%"')
            for row in cursor.fetchall():
                if row[0]:
                    v = row[0]
                    if not v.startswith('file:base64:') and not v.startswith('file:folder:'):
                        used.add(to_absolute_path(v[5:]))
            cursor.execute('SELECT bg_path FROM categories WHERE bg_path IS NOT NULL AND bg_path != ""')
            for row in cursor.fetchall():
                if row[0]:
                    used.add(to_absolute_path(row[0]))
            conn.close()

            if self._cancel_event.is_set():
                self.cancelled.emit(); return

            self.progress.emit(60, self.translations.get('progress_comparing', 'Comparing...'))
            unused = []
            for i, fpath in enumerate(all_files):
                if self._cancel_event.is_set():
                    self.cancelled.emit(); return
                if fpath not in used:
                    unused.append(fpath)
                if i % 50 == 0:
                    pct = 60 + int((i / max(total, 1)) * 39)
                    self.progress.emit(pct, f"{self.translations.get('progress_checking', 'Checking')} {i+1}/{total}...")

            self.progress.emit(100, self.translations.get('progress_done', 'Done'))
            self.finished.emit(sorted(unused))
        except Exception as e:
            self.error.emit(str(e))


class DeleteUnusedWorker(QThread):
    """Deletes a list of files in the background with progress reporting."""
    progress  = pyqtSignal(int, str)   # pct, message
    finished  = pyqtSignal(list)       # list of paths that failed to delete
    cancelled = pyqtSignal()
    error     = pyqtSignal(str)

    def __init__(self, paths, translations=None):
        super().__init__()
        self.paths         = list(paths)
        self.translations  = translations or {}
        self._cancel_event = threading.Event()

    def cancel(self):
        self._cancel_event.set()

    def run(self):
        self.setTerminationEnabled(False)  # не убивать поток принудительно
        try:
            total   = len(self.paths)
            failed  = []
            for i, fpath in enumerate(self.paths):
                if self._cancel_event.is_set():
                    self.cancelled.emit()
                    return
                pct = int((i / total) * 100) if total else 100
                msg = self.translations.get('progress_deleting', 'Deleting...') + f' {i + 1}/{total}'
                self.progress.emit(pct, msg)
                try:
                    os.remove(fpath)
                except Exception:
                    failed.append(fpath)
            self.progress.emit(100, self.translations.get('progress_done', 'Done'))
            self.finished.emit(failed)
        except Exception as e:
            self.error.emit(str(e))



class CoverLoaderThread(QThread):
    """Фоновый поток загрузки обложек для виджетов списка.

    Принимает задачи через put_task(path, callback_id).
    При завершении испускает cover_ready(callback_id, QPixmap).
    Задачи с устаревшим callback_id безопасно игнорируются виджетом.

    Алгоритм:
      • _queue — LIFO (последние задачи = видимые сейчас = приоритет).
      • _cancelled — множество callback_id для пропуска без обработки.
    """
    cover_ready = pyqtSignal(int, QPixmap)  # (callback_id, pixmap)

    _instance = None

    @classmethod
    def instance(cls):
        if cls._instance is None:
            cls._instance = cls()
            cls._instance.start()
        return cls._instance

    def __init__(self):
        super().__init__()
        self._queue = queue.LifoQueue()
        self._cancelled = set()
        self._lock = threading.Lock()
        self._running = True

    def put_task(self, path: str, callback_id: int, task_type: str = 'cover'):
        """Добавить задачу на загрузку изображения.
        task_type: 'cover' — обложка (50×75), 'icon' — file-иконка (14×14)."""
        with self._lock:
            self._cancelled.discard(callback_id)
        self._queue.put((path, callback_id, task_type))

    def cancel(self, callback_id: int):
        """Отменить задачу (если ещё не выполнена)."""
        with self._lock:
            self._cancelled.add(callback_id)

    def cancel_all(self):
        """Отменить все задачи в очереди (например при смене категории)."""
        while True:
            try:
                item = self._queue.get_nowait()
                cb_id = item[1]
                with self._lock:
                    self._cancelled.add(cb_id)
                self._queue.task_done()
            except queue.Empty:
                break

    def stop(self):
        self._running = False

    @staticmethod
    def _load_pixmap(abs_path: str, task_type: str):
        """Загрузить изображение через Pillow (обложки) или Qt (иконки)."""
        if task_type == 'icon':
            # Используем _APP_DPR напрямую — _get_dpr() вызывает QApplication из потока
            # и может вернуть 1.0 вместо реального DPR на HiDPI
            sc = _APP_DPR if _APP_DPR > 1.0 else _APP_SCALE
            pix = QPixmap(abs_path)
            if not pix.isNull():
                phys = round(14 * sc)
                pix = pix.scaled(phys, phys, Qt.KeepAspectRatio, Qt.SmoothTransformation)
                pix.setDevicePixelRatio(sc)
            return pix
        else:
            sc = _get_dpr()
            img = Image.open(abs_path)
            if img.mode not in ('RGB',):
                img = img.convert('RGB')
            if task_type == 'tier_cover':
                tw, th = round(TIER_COVER_W * sc), round(TIER_COVER_H * sc)
            else:
                tw, th = round(50 * sc), round(75 * sc)  # matches MediaItemDelegate.COVER_W/H
            iw, ih = img.size
            if iw / ih > tw / th:
                new_w = int(ih * tw / th)
                left = (iw - new_w) // 2
                img = img.crop((left, 0, left + new_w, ih))
            else:
                new_h = int(iw * th / tw)
                top = (ih - new_h) // 2
                img = img.crop((0, top, iw, top + new_h))
            img = img.resize((tw, th), Image.LANCZOS)
            data = img.tobytes('raw', 'RGB')
            qimg = QImage(data, tw, th, tw * 3, QImage.Format_RGB888)
            pix = QPixmap.fromImage(qimg)
            pix.setDevicePixelRatio(sc)
            return pix

    def run(self):
        while self._running:
            try:
                task = self._queue.get(timeout=0.1)
            except queue.Empty:
                continue

            path, callback_id, task_type = task

            with self._lock:
                is_cancelled = callback_id in self._cancelled

            if is_cancelled:
                with self._lock:
                    self._cancelled.discard(callback_id)
                self._queue.task_done()
                continue

            try:
                abs_path = to_absolute_path(path)
                if os.path.exists(abs_path):
                    if task_type == 'icon' and abs_path in _ICON_PIXMAP_CACHE:
                        pixmap = _ICON_PIXMAP_CACHE[abs_path]
                    else:
                        pixmap = self._load_pixmap(abs_path, task_type)
                        if task_type == 'icon':
                            _ICON_PIXMAP_CACHE[abs_path] = pixmap

                    with self._lock:
                        still_needed = callback_id not in self._cancelled
                    if still_needed:
                        self.cover_ready.emit(callback_id, pixmap)
            except Exception:
                pass
            finally:
                self._queue.task_done()


def _merge_tier_order(all_db_ids, visible_ids):
    """Смёржить полный порядок тира с новым порядком видимых элементов.

    all_db_ids  — текущий порядок всех элементов тира из БД (включая скрытые фильтром).
    visible_ids — новый порядок видимых элементов (после drag-and-drop).

    Каждый скрытый элемент привязывается к своему правому видимому соседу
    в старом порядке и вставляется перед ним в новом порядке.
    Скрытые без правого видимого соседа (были в самом конце) — остаются в конце.
    """
    visible_set = set(visible_ids)
    hidden_ids = [iid for iid in all_db_ids if iid not in visible_set]

    # Для каждого скрытого — его правый видимый сосед в старом порядке
    right_anchor = {}   # hidden_id → visible_id or None
    pending = []
    for iid in all_db_ids:
        if iid in visible_set:
            for hid in pending:
                right_anchor[hid] = iid
            pending = []
        else:
            pending.append(iid)
    for hid in pending:
        right_anchor[hid] = None  # нет правого → в конец

    # Группируем: перед каким видимым вставить
    hidden_before = {}  # visible_id → [hidden_ids...]
    tail = []           # скрытые без правого соседа → в самый конец
    for hid in hidden_ids:
        rv = right_anchor[hid]
        if rv is None:
            tail.append(hid)
        else:
            hidden_before.setdefault(rv, []).append(hid)

    merged = []
    for vid in visible_ids:
        merged.extend(hidden_before.get(vid, []))
        merged.append(vid)
    merged.extend(tail)
    return merged


class Database:
    """Класс для работы с базой данных с поддержкой позиции категорий"""
    
    def __init__(self):
        self.conn = sqlite3.connect(str(DB_PATH))
        self.conn.row_factory = sqlite3.Row
        # Оптимизации производительности
        self.conn.execute('PRAGMA journal_mode = DELETE')     # single file, no -wal/-shm side files
        self.conn.execute('PRAGMA cache_size = -64000')      # 64MB кеш страниц в RAM
        self.conn.execute('PRAGMA temp_store = MEMORY')      # временные таблицы в RAM
        self.conn.execute('PRAGMA mmap_size = 268435456')    # 256MB memory-mapped I/O
        # Регистрируем функцию для поиска без учёта регистра (в т.ч. кириллица)
        self.conn.create_function('ilike', 2, lambda a, b: (a or '').lower() in (b or '').lower())
        def natural_sort_key(s):
            s = (s or '').lower()
            parts = re.split(r'(\d+)', s)
            return ''.join(p.zfill(10) if p.isdigit() else p for p in parts)
        self.conn.create_function('natsort', 1, natural_sort_key)

        def natsort_title_key(raw):
            """natsort по sort:-ключу (или первой части title)."""
            return natural_sort_key(_extract_sort_key(raw or ''))
        self.conn.create_function('natsort_title', 1, natsort_title_key)

        def normalize_watch_date(wd):
            """Нормализует watch_date до yyyy-mm-dd для сортировки.
            '2024' → '2024-01-01', '2024-03' → '2024-03-01', '2024-03-15' → '2024-03-15'"""
            if not wd:
                return ''
            parts = wd.split('-')
            y = parts[0] if len(parts) > 0 else '0000'
            m = parts[1] if len(parts) > 1 else '01'
            d = parts[2] if len(parts) > 2 else '01'
            return f'{y}-{m}-{d}'
        self.conn.create_function('norm_watch_date', 1, normalize_watch_date)

        def title_search_text(raw):
            """Строка для поиска по title: все части кроме самого 'sort:', но включая его значение."""
            return ' '.join(_search_titles(raw or ''))
        self.conn.create_function('title_search', 1, title_search_text)
        self.create_tables()
        
    def commit(self):
        self.conn.commit()

    def close(self):
        try:
            self.conn.close()
        except Exception:
            pass

    def __del__(self):
        self.close()

    def backup(self):
        """Устарело — бэкап теперь управляется через настройки. Метод оставлен для совместимости."""
        pass
            
    def create_tables(self):
        cursor = self.conn.cursor()

        cursor.execute('''
            CREATE TABLE IF NOT EXISTS categories (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL,
